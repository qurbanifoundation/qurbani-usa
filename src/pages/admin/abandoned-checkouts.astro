---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

export const prerender = false;

// Get query params for filtering
const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get('status') || 'all';
const dateRange = url.searchParams.get('range') || '30d';
const page = parseInt(url.searchParams.get('page') || '1');
const perPage = 25;

// Date range filter
let dateThreshold: Date | null = null;
if (dateRange === '7d') dateThreshold = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);
else if (dateRange === '30d') dateThreshold = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);
else if (dateRange === '90d') dateThreshold = new Date(Date.now() - 90 * 24 * 60 * 60 * 1000);

// Build query
let query = supabaseAdmin
  .from('abandoned_checkouts')
  .select('*', { count: 'exact' })
  .order('checkout_started_at', { ascending: false });

if (statusFilter !== 'all') {
  query = query.eq('status', statusFilter);
}
if (dateThreshold) {
  query = query.gte('checkout_started_at', dateThreshold.toISOString());
}

// Pagination
const { data: checkouts, count, error } = await query
  .range((page - 1) * perPage, page * perPage - 1);

const totalPages = Math.ceil((count || 0) / perPage);

// Get stats (within the date range)
let statsQuery = supabaseAdmin
  .from('abandoned_checkouts')
  .select('status, amount, recovered_at');

if (dateThreshold) {
  statsQuery = statsQuery.gte('checkout_started_at', dateThreshold.toISOString());
}

const { data: statsData } = await statsQuery;

const stats = {
  total: statsData?.length || 0,
  started: statsData?.filter(d => d.status === 'started').length || 0,
  abandoned: statsData?.filter(d => d.status === 'abandoned').length || 0,
  recovered: statsData?.filter(d => d.status === 'recovered').length || 0,
  completed: statsData?.filter(d => d.status === 'completed').length || 0,
  expired: statsData?.filter(d => d.status === 'expired').length || 0,
  recoveryRate: 0,
  revenueRecovered: 0,
  revenueAbandoned: 0,
  revenueCompleted: 0,
};

// Recovery rate = truly recovered / (abandoned + recovered) — excludes normal completions
const abandonedPlusRecovered = stats.abandoned + stats.recovered;
stats.recoveryRate = abandonedPlusRecovered > 0
  ? Math.round((stats.recovered / abandonedPlusRecovered) * 100)
  : 0;

stats.revenueRecovered = statsData
  ?.filter(d => d.status === 'recovered' && d.amount)
  .reduce((sum, d) => sum + (parseFloat(d.amount) || 0), 0) || 0;

stats.revenueAbandoned = statsData
  ?.filter(d => d.status === 'abandoned' && d.amount)
  .reduce((sum, d) => sum + (parseFloat(d.amount) || 0), 0) || 0;

stats.revenueCompleted = statsData
  ?.filter(d => d.status === 'completed' && d.amount)
  .reduce((sum, d) => sum + (parseFloat(d.amount) || 0), 0) || 0;

// Campaign breakdown for recovered revenue
const campaignBreakdown: Record<string, { count: number; revenue: number }> = {};
statsData?.filter(d => d.status === 'recovered').forEach(d => {
  const key = (d as any).campaign_type || 'general';
  if (!campaignBreakdown[key]) campaignBreakdown[key] = { count: 0, revenue: 0 };
  campaignBreakdown[key].count++;
  campaignBreakdown[key].revenue += parseFloat(d.amount) || 0;
});

// Format date helper (Eastern Time)
function formatDate(dateStr: string | null) {
  if (!dateStr) return '-';
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
    timeZone: 'America/New_York',
  });
}

function formatAmount(amount: number | string | null) {
  if (!amount) return '-';
  const num = typeof amount === 'string' ? parseFloat(amount) : amount;
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(num || 0);
}

function getStatusBadge(status: string) {
  switch (status) {
    case 'started': return 'bg-blue-100 text-blue-800';
    case 'abandoned': return 'bg-amber-100 text-amber-800';
    case 'recovered': return 'bg-green-100 text-green-800';
    case 'completed': return 'bg-teal-100 text-teal-800';
    case 'expired': return 'bg-gray-100 text-gray-600';
    default: return 'bg-gray-100 text-gray-800';
  }
}

function getRecoveryStepLabel(step: number) {
  if (!step || step === 0) return '-';
  return `${step}/5`;
}

// Pre-compute pagination (Astro JSX can't handle < in expressions)
const paginationPages: number[] = [];
for (let i = 0; i < Math.min(totalPages, 5); i++) {
  const p = page <= 3 ? i + 1 : page + i - 2;
  if (p >= 1 && p <= totalPages) paginationPages.push(p);
}
const showPrevPage = page > 1;
const showNextPage = page < totalPages;
const showPagination = totalPages > 1;
---

<AdminLayout title="Cart Recovery" activeNav="cart-recovery">
  <!-- Stats Cards -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
    <div class="bg-white rounded-xl shadow-sm p-5 border border-teal-100">
      <p class="text-sm text-teal-600 font-medium">Completed</p>
      <p class="text-2xl font-bold text-teal-700 mt-1">{stats.completed}</p>
      <p class="text-xs text-gray-400 mt-1">{formatAmount(stats.revenueCompleted)} normal</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5 border border-amber-100">
      <p class="text-sm text-amber-600 font-medium">Abandoned</p>
      <p class="text-2xl font-bold text-amber-700 mt-1">{stats.abandoned}</p>
      <p class="text-xs text-gray-400 mt-1">{formatAmount(stats.revenueAbandoned)} at risk</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5 border border-green-100">
      <p class="text-sm text-green-600 font-medium">Recovered</p>
      <p class="text-2xl font-bold text-green-700 mt-1">{stats.recovered}</p>
      <p class="text-xs text-gray-400 mt-1">{formatAmount(stats.revenueRecovered)} won back</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5 border border-emerald-100">
      <p class="text-sm text-emerald-600 font-medium">Recovery Rate</p>
      <p class="text-2xl font-bold text-emerald-700 mt-1">{stats.recoveryRate}%</p>
      <p class="text-xs text-gray-400 mt-1">abandoned → recovered</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5 border border-blue-100">
      <p class="text-sm text-blue-600 font-medium">In Progress</p>
      <p class="text-2xl font-bold text-blue-700 mt-1">{stats.started}</p>
      <p class="text-xs text-gray-400 mt-1">currently in checkout</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5 border border-gray-100">
      <p class="text-sm text-gray-500 font-medium">Expired</p>
      <p class="text-2xl font-bold text-gray-600 mt-1">{stats.expired}</p>
      <p class="text-xs text-gray-400 mt-1">closed/unsubscribed</p>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6 flex flex-wrap items-center gap-4">
    <div class="flex items-center gap-2">
      <label class="text-sm font-medium text-gray-600">Status:</label>
      <div class="flex gap-1">
        {['all', 'started', 'abandoned', 'recovered', 'completed', 'expired'].map((s) => (
          <a
            href={`?status=${s}&range=${dateRange}&page=1`}
            class={`px-3 py-1.5 rounded-lg text-sm font-medium transition ${
              statusFilter === s
                ? 'bg-[#01534d] text-white'
                : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
            }`}
          >
            {s.charAt(0).toUpperCase() + s.slice(1)}
          </a>
        ))}
      </div>
    </div>

    <div class="flex items-center gap-2 ml-auto">
      <label class="text-sm font-medium text-gray-600">Range:</label>
      <div class="flex gap-1">
        {['7d', '30d', '90d', 'all'].map((r) => (
          <a
            href={`?status=${statusFilter}&range=${r}&page=1`}
            class={`px-3 py-1.5 rounded-lg text-sm font-medium transition ${
              dateRange === r
                ? 'bg-[#01534d] text-white'
                : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
            }`}
          >
            {r === 'all' ? 'All Time' : r}
          </a>
        ))}
      </div>
    </div>

    <a
      href={`/api/admin/abandoned-checkouts-csv?status=${statusFilter}&range=${dateRange}`}
      class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 flex items-center gap-1"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      Export CSV
    </a>

    <!-- Bulk Delete Button (hidden until items selected) -->
    <button
      id="bulk-delete-btn"
      class="hidden px-3 py-1.5 bg-red-500 text-white rounded-lg text-sm font-medium hover:bg-red-600 flex items-center gap-1 transition"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
      Delete <span id="delete-count">0</span> selected
    </button>
  </div>

  <!-- Campaign Breakdown (only if there are recovered checkouts) -->
  {Object.keys(campaignBreakdown).length > 0 && (
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">Recovery by Campaign Type</h3>
      <div class="flex flex-wrap gap-3">
        {Object.entries(campaignBreakdown).sort((a, b) => b[1].revenue - a[1].revenue).map(([type, data]) => (
          <div class="bg-green-50 rounded-lg px-4 py-2 border border-green-100">
            <span class="text-sm font-medium text-green-800 capitalize">{type}</span>
            <span class="text-sm text-green-600 ml-2">{data.count} recovered</span>
            <span class="text-sm font-semibold text-green-700 ml-1">({formatAmount(data.revenue)})</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Data Table -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    {error ? (
      <div class="p-8 text-center text-red-600">Error loading data: {error.message}</div>
    ) : !checkouts || checkouts.length === 0 ? (
      <div class="p-8 text-center text-gray-500">No abandoned checkouts found for this filter.</div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-4 py-3 w-10">
                <input type="checkbox" id="select-all-cb" class="w-4 h-4 rounded border-gray-300 text-[#01534d] focus:ring-[#01534d] cursor-pointer" title="Select all on this page" />
              </th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Date</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Donor</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Campaign</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Source</th>
              <th class="text-right px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Amount</th>
              <th class="text-center px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Status</th>
              <th class="text-center px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Emails</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Abandoned</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Recovered</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {checkouts.map((c: any) => (
              <tr class="hover:bg-gray-50 transition-colors" data-checkout-id={c.id}>
                <td class="px-4 py-3">
                  <input type="checkbox" class="row-cb w-4 h-4 rounded border-gray-300 text-[#01534d] focus:ring-[#01534d] cursor-pointer" value={c.id} />
                </td>
                <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap">{formatDate(c.checkout_started_at)}</td>
                <td class="px-4 py-3">
                  <div class="text-sm font-medium text-gray-800">{c.first_name} {c.last_name || ''}</div>
                  <div class="text-xs text-gray-500">{c.email}</div>
                  {c.phone && <div class="text-xs text-gray-400">{c.phone}</div>}
                </td>
                <td class="px-4 py-3">
                  <div class="text-sm text-gray-700">{c.campaign_slug || '-'}</div>
                  <div class="text-xs text-gray-400 capitalize">{c.campaign_type || ''}</div>
                </td>
                <td class="px-4 py-3">
                  {c.checkout_source ? (
                    <span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-semibold bg-indigo-100 text-indigo-700">{c.checkout_source}</span>
                  ) : (
                    <span class="text-gray-300 text-xs">-</span>
                  )}
                  {c.utm_source && (
                    <div class="mt-1 flex flex-wrap gap-0.5">
                      <span class="inline-block px-1.5 py-0.5 bg-blue-50 text-blue-600 text-[9px] font-medium rounded" title="utm_source">{c.utm_source}</span>
                      {c.utm_medium && <span class="inline-block px-1.5 py-0.5 bg-green-50 text-green-600 text-[9px] font-medium rounded" title="utm_medium">{c.utm_medium}</span>}
                      {c.utm_campaign && <span class="inline-block px-1.5 py-0.5 bg-amber-50 text-amber-600 text-[9px] font-medium rounded" title="utm_campaign">{c.utm_campaign}</span>}
                    </div>
                  )}
                  {(c.utm_content || c.utm_term) && (
                    <div class="mt-0.5 flex flex-wrap gap-0.5">
                      {c.utm_content && <span class="inline-block px-1.5 py-0.5 bg-purple-50 text-purple-600 text-[9px] font-medium rounded" title="utm_content">{c.utm_content}</span>}
                      {c.utm_term && <span class="inline-block px-1.5 py-0.5 bg-pink-50 text-pink-600 text-[9px] font-medium rounded" title="utm_term">{c.utm_term}</span>}
                    </div>
                  )}
                </td>
                <td class="px-4 py-3 text-sm font-medium text-gray-800 text-right whitespace-nowrap">{formatAmount(c.amount)}</td>
                <td class="px-4 py-3 text-center">
                  <span class={`inline-block px-2.5 py-1 rounded-full text-xs font-semibold ${getStatusBadge(c.status)}`}>
                    {c.status}
                  </span>
                </td>
                <td class="px-4 py-3 text-sm text-center text-gray-600">{getRecoveryStepLabel(c.recovery_step_last_sent)}</td>
                <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap">{formatDate(c.abandoned_at)}</td>
                <td class="px-4 py-3 text-sm whitespace-nowrap">
                  {c.recovered_at ? (
                    <span class="text-green-600 font-medium">{formatDate(c.recovered_at)}</span>
                  ) : (
                    <span class="text-gray-400">-</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    <!-- Pagination -->
    {showPagination && (
      <div class="px-4 py-3 bg-gray-50 border-t border-gray-200 flex items-center justify-between">
        <p class="text-sm text-gray-600">
          Showing {(page - 1) * perPage + 1}-{Math.min(page * perPage, count || 0)} of {count} results
        </p>
        <div class="flex gap-1">
          {page > 1 && (
            <a href={`?status=${statusFilter}&range=${dateRange}&page=${page - 1}`} class="px-3 py-1.5 bg-white border rounded text-sm hover:bg-gray-50">Prev</a>
          )}
          {paginationPages.map((p) => (
              <a
                href={`?status=${statusFilter}&range=${dateRange}&page=${p}`}
                class={`px-3 py-1.5 rounded text-sm ${p === page ? 'bg-[#01534d] text-white' : 'bg-white border hover:bg-gray-50'}`}
              >
                {p}
              </a>
          ))}
          {showNextPage && (
            <a href={`?status=${statusFilter}&range=${dateRange}&page=${page + 1}`} class="px-3 py-1.5 bg-white border rounded text-sm hover:bg-gray-50">Next</a>
          )}
        </div>
      </div>
    )}
  </div>
  <!-- Bulk Delete Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const selectAllCb = document.getElementById('select-all-cb') as HTMLInputElement;
      const bulkDeleteBtn = document.getElementById('bulk-delete-btn');
      const deleteCountSpan = document.getElementById('delete-count');
      const rowCheckboxes = document.querySelectorAll('.row-cb') as NodeListOf<HTMLInputElement>;

      if (!selectAllCb || !bulkDeleteBtn || !deleteCountSpan) return;

      function updateUI() {
        const checked = document.querySelectorAll('.row-cb:checked') as NodeListOf<HTMLInputElement>;
        const count = checked.length;
        deleteCountSpan!.textContent = count.toString();

        if (count > 0) {
          bulkDeleteBtn!.classList.remove('hidden');
          bulkDeleteBtn!.classList.add('flex');
        } else {
          bulkDeleteBtn!.classList.add('hidden');
          bulkDeleteBtn!.classList.remove('flex');
        }

        // Update select-all state
        if (rowCheckboxes.length > 0) {
          selectAllCb!.checked = count === rowCheckboxes.length;
          selectAllCb!.indeterminate = count > 0 && count < rowCheckboxes.length;
        }
      }

      // Select all toggle
      selectAllCb.addEventListener('change', () => {
        rowCheckboxes.forEach(cb => { cb.checked = selectAllCb.checked; });
        updateUI();
      });

      // Individual checkbox toggle
      rowCheckboxes.forEach(cb => {
        cb.addEventListener('change', updateUI);
      });

      // Bulk delete
      bulkDeleteBtn.addEventListener('click', async () => {
        const checked = document.querySelectorAll('.row-cb:checked') as NodeListOf<HTMLInputElement>;
        const ids = Array.from(checked).map(cb => cb.value);

        if (ids.length === 0) return;

        const confirmed = confirm(`Are you sure you want to delete ${ids.length} checkout record(s)? This cannot be undone.`);
        if (!confirmed) return;

        bulkDeleteBtn.textContent = 'Deleting...';
        (bulkDeleteBtn as HTMLButtonElement).disabled = true;

        try {
          const res = await fetch('/api/admin/abandoned-checkouts-delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids }),
          });

          const data = await res.json();

          if (res.ok && data.success) {
            // Remove deleted rows from DOM
            ids.forEach(id => {
              const row = document.querySelector(`tr[data-checkout-id="${id}"]`);
              if (row) row.remove();
            });

            // Reset UI
            selectAllCb.checked = false;
            selectAllCb.indeterminate = false;
            bulkDeleteBtn.classList.add('hidden');
            bulkDeleteBtn.classList.remove('flex');

            // Show quick toast
            const toast = document.createElement('div');
            toast.className = 'fixed bottom-6 right-6 bg-green-600 text-white px-5 py-3 rounded-xl shadow-lg text-sm font-medium z-50 animate-fade-in';
            toast.textContent = `${data.deleted} record(s) deleted successfully`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);

            // Reload after short delay to refresh stats
            setTimeout(() => window.location.reload(), 1500);
          } else {
            alert('Error deleting records: ' + (data.error || 'Unknown error'));
          }
        } catch (err) {
          alert('Network error. Please try again.');
          console.error('Delete error:', err);
        } finally {
          bulkDeleteBtn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg> Delete <span id="delete-count">0</span> selected`;
          (bulkDeleteBtn as HTMLButtonElement).disabled = false;
          updateUI();
        }
      });
    });
  </script>
</AdminLayout>
