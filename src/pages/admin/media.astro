---
import AdminLayout from '../../layouts/AdminLayout.astro';
export const prerender = false;
---

<AdminLayout title="Media Library" activeNav="media">
  <div class="p-6 max-w-[1600px] mx-auto">

    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Media Library</h1>
        <p class="text-sm text-gray-500 mt-1">
          <span id="statsLine">Loading images...</span>
        </p>
      </div>
      <div class="flex items-center gap-3">
        <button
          id="toggleUploadBtn"
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-[#01534d] text-white rounded-lg hover:bg-[#013d38] transition-colors text-sm font-medium"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Upload
        </button>
        <button
          id="refreshBtn"
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          Refresh
        </button>
        <button
          id="pngAuditBtn"
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-red-50 border border-red-200 text-red-700 rounded-lg hover:bg-red-100 transition-colors text-sm font-medium"
          title="Find PNG files used on pages that should be converted to WebP"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
          </svg>
          PNG Audit
        </button>
      </div>
    </div>

    <!-- Upload Panel (collapsible) -->
    <div id="uploadPanel" class="hidden mb-6">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900">Upload Image</h2>
          <button id="closeUploadBtn" class="text-gray-400 hover:text-gray-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Tabs -->
        <div class="flex gap-1 mb-4 bg-gray-100 rounded-lg p-1 w-fit">
          <button class="upload-tab active px-4 py-2 text-sm font-medium rounded-md transition-colors" data-tab="file">
            File Upload
          </button>
          <button class="upload-tab px-4 py-2 text-sm font-medium rounded-md transition-colors" data-tab="url">
            From URL
          </button>
        </div>

        <!-- File Upload Tab -->
        <div id="fileUploadTab">
          <div
            id="dropZone"
            class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:border-[#01534d] hover:bg-[#01534d]/5 transition-all cursor-pointer"
          >
            <svg class="w-12 h-12 mx-auto text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <p class="text-gray-600 font-medium">Drag and drop an image here</p>
            <p class="text-sm text-gray-400 mt-1">or click to select a file</p>
            <p class="text-xs text-gray-400 mt-2">PNG, JPG, WebP, GIF, SVG - Max 10MB</p>
            <input type="file" id="fileInput" accept="image/*" class="hidden" />
          </div>
          <div id="filePreview" class="hidden mt-4 flex items-center gap-4 p-4 bg-gray-50 rounded-lg">
            <img id="filePreviewImg" class="w-16 h-16 object-cover rounded-lg" src="" alt="" />
            <div class="flex-1 min-w-0">
              <p id="filePreviewName" class="text-sm font-medium text-gray-900 truncate"></p>
              <p id="filePreviewSize" class="text-xs text-gray-500"></p>
            </div>
            <button id="clearFileBtn" class="text-gray-400 hover:text-red-500">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>

        <!-- URL Upload Tab -->
        <div id="urlUploadTab" class="hidden">
          <div class="flex gap-3">
            <input
              type="text"
              id="urlInput"
              placeholder="https://example.com/image.png"
              class="flex-1 px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#01534d]/20 focus:border-[#01534d] outline-none"
            />
            <input
              type="text"
              id="urlFilename"
              placeholder="filename (optional)"
              class="w-48 px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#01534d]/20 focus:border-[#01534d] outline-none"
            />
          </div>
        </div>

        <!-- Options & Submit -->
        <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="autoConvertWebp" checked class="w-4 h-4 rounded border-gray-300 text-[#01534d] focus:ring-[#01534d]" />
            <span class="text-sm text-gray-700">Auto-convert to WebP</span>
          </label>
          <button
            id="uploadSubmitBtn"
            disabled
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#01534d] text-white rounded-lg hover:bg-[#013d38] transition-colors text-sm font-medium disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
            </svg>
            <span id="uploadBtnText">Upload</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-6">
      <div class="flex flex-col md:flex-row gap-3">
        <!-- Search Mode -->
        <select id="searchMode" class="px-3 py-2.5 border border-gray-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-[#01534d]/20 focus:border-[#01534d] outline-none min-w-[130px]">
          <option value="all">Search All</option>
          <option value="images">Images Only</option>
          <option value="pages">Pages Only</option>
        </select>

        <!-- Search -->
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input
            type="text"
            id="searchInput"
            placeholder="Search by filename or page name (e.g. zakat, orphan, aqiqah)..."
            class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#01534d]/20 focus:border-[#01534d] outline-none"
          />
        </div>

        <!-- Sort -->
        <select id="sortSelect" class="px-4 py-2.5 border border-gray-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-[#01534d]/20 focus:border-[#01534d] outline-none min-w-[160px]">
          <option value="newest">Newest First</option>
          <option value="oldest">Oldest First</option>
          <option value="name-asc">Name A-Z</option>
          <option value="name-desc">Name Z-A</option>
          <option value="size-desc">Size (Largest)</option>
          <option value="size-asc">Size (Smallest)</option>
        </select>

        <!-- Filter -->
        <select id="typeFilter" class="px-4 py-2.5 border border-gray-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-[#01534d]/20 focus:border-[#01534d] outline-none min-w-[120px]">
          <option value="all">All Types</option>
          <!-- Populated dynamically from available types -->
        </select>

        <!-- View Toggle -->
        <div class="flex bg-gray-100 rounded-lg p-1">
          <button id="gridViewBtn" class="view-toggle active p-2 rounded-md transition-colors" title="Grid View">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
            </svg>
          </button>
          <button id="listViewBtn" class="view-toggle p-2 rounded-md transition-colors" title="List View">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Bulk Action Bar -->
    <div id="bulkBar" class="hidden bg-white rounded-xl shadow-sm border border-gray-200 p-3 mb-4">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="selectAllCheckbox" class="w-4 h-4 rounded border-gray-300 text-[#01534d] focus:ring-[#01534d]" />
            <span class="text-sm font-medium text-gray-700">Select All (<span id="selectAllCount">0</span>)</span>
          </label>
          <span id="selectedCount" class="text-sm text-gray-500">0 selected</span>
        </div>
        <div class="flex items-center gap-2">
          <button
            id="bulkDeleteBtn"
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition-colors text-sm font-medium"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
            </svg>
            Delete Selected
          </button>
          <button
            id="bulkCancelBtn"
            class="px-4 py-2 bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 transition-colors text-sm font-medium"
          >
            Cancel
          </button>
        </div>
      </div>
    </div>

    <!-- Loading Skeleton -->
    <div id="loadingSkeleton" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-6 gap-4">
      {Array.from({ length: 12 }).map(() => (
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden animate-pulse">
          <div class="aspect-square bg-gray-200"></div>
          <div class="p-3">
            <div class="h-3 bg-gray-200 rounded w-3/4 mb-2"></div>
            <div class="h-3 bg-gray-200 rounded w-1/2"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Grid View -->
    <div id="gridView" class="hidden grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-6 gap-4">
    </div>

    <!-- List View -->
    <div id="listView" class="hidden">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-4 py-3 w-16"></th>
              <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-4 py-3">Name</th>
              <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-4 py-3">Size</th>
              <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-4 py-3">Type</th>
              <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-4 py-3">Modified</th>
              <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-4 py-3">URL</th>
              <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider px-4 py-3">Actions</th>
            </tr>
          </thead>
          <tbody id="listBody" class="divide-y divide-gray-100">
          </tbody>
        </table>
      </div>
    </div>

    <!-- Empty State -->
    <div id="emptyState" class="hidden text-center py-16">
      <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
      </svg>
      <p class="text-gray-500 text-lg font-medium">No images found</p>
      <p class="text-gray-400 text-sm mt-1">Try adjusting your search or filters</p>
    </div>

    <!-- Image Detail Modal -->
    <div id="detailModal" class="hidden fixed inset-0 z-50">
      <div class="absolute inset-0 bg-black/50" id="modalOverlay"></div>
      <div class="absolute right-0 top-0 bottom-0 w-full max-w-lg bg-white shadow-2xl overflow-y-auto">
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-semibold text-gray-900">Image Details</h2>
            <button id="closeModalBtn" class="text-gray-400 hover:text-gray-600 p-1">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
          <div class="bg-gray-100 rounded-xl p-4 mb-6 flex items-center justify-center min-h-[200px]">
            <img id="modalImage" class="max-w-full max-h-[400px] object-contain rounded-lg" src="" alt="" />
          </div>
          <div class="space-y-4">
            <div>
              <label class="text-xs font-medium text-gray-500 uppercase tracking-wider">Filename</label>
              <p id="modalFilename" class="text-sm font-medium text-gray-900 mt-1 break-all"></p>
            </div>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="text-xs font-medium text-gray-500 uppercase tracking-wider">Size</label>
                <p id="modalSize" class="text-sm font-medium text-gray-900 mt-1"></p>
              </div>
              <div>
                <label class="text-xs font-medium text-gray-500 uppercase tracking-wider">Format</label>
                <p id="modalFormat" class="text-sm font-medium text-gray-900 mt-1 uppercase"></p>
              </div>
              <div>
                <label class="text-xs font-medium text-gray-500 uppercase tracking-wider">WebP</label>
                <p id="modalWebpStatus" class="text-sm font-medium mt-1"></p>
              </div>
            </div>
            <div>
              <label class="text-xs font-medium text-gray-500 uppercase tracking-wider">URL</label>
              <div class="flex items-center gap-2 mt-1">
                <code id="modalUrl" class="flex-1 text-sm bg-gray-100 px-3 py-2 rounded-lg text-gray-700 break-all"></code>
                <button id="modalCopyBtn" class="flex-shrink-0 p-2 text-gray-400 hover:text-[#01534d] transition-colors" title="Copy URL">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
                  </svg>
                </button>
              </div>
            </div>

            <!-- Convert Section -->
            <div id="modalConvertSection" class="border-t border-gray-100 pt-4">
              <label class="text-xs font-medium text-gray-500 uppercase tracking-wider">Convert to WebP</label>
              <div class="flex items-center gap-4 mt-2">
                <div class="flex-1">
                  <label class="text-xs text-gray-500">Quality: <span id="qualityValue">80</span></label>
                  <input type="range" id="qualitySlider" min="60" max="100" value="80" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-[#01534d]" />
                </div>
                <button
                  id="modalConvertBtn"
                  class="inline-flex items-center gap-2 px-4 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600 transition-colors text-sm font-medium"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                  </svg>
                  Convert
                </button>
              </div>
            </div>

            <!-- Replace Image (swap references) -->
            <div id="modalReplaceSection" class="border-t border-gray-100 pt-4">
              <label class="text-xs font-medium text-gray-500 uppercase tracking-wider">Replace Image on Pages</label>
              <p class="text-xs text-gray-400 mt-1 mb-2">Pick a replacement — all page/campaign references will be updated.</p>
              <div class="relative">
                <input
                  type="text"
                  id="replaceSearchInput"
                  placeholder="Search replacement image..."
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#01534d]/20 focus:border-[#01534d] outline-none"
                />
                <div id="replaceResults" class="absolute left-0 right-0 top-full mt-1 bg-white border border-gray-200 rounded-lg shadow-xl max-h-48 overflow-y-auto z-10 hidden">
                  <!-- Populated by JS -->
                </div>
              </div>
              <div id="replacePreview" class="hidden mt-2 p-2 bg-gray-50 rounded-lg">
                <div class="flex items-center gap-3">
                  <img id="replacePreviewImg" class="w-12 h-12 object-cover rounded" src="" alt="" />
                  <div class="flex-1 min-w-0">
                    <p id="replacePreviewName" class="text-xs font-medium text-gray-800 truncate"></p>
                    <p id="replacePreviewSize" class="text-xs text-gray-500"></p>
                  </div>
                  <button
                    id="replaceConfirmBtn"
                    class="px-3 py-1.5 bg-[#01534d] text-white text-xs font-bold rounded-lg hover:bg-[#013d38] transition"
                  >
                    Replace
                  </button>
                </div>
              </div>
            </div>

            <!-- Delete -->
            <div class="border-t border-gray-100 pt-4">
              <button
                id="modalDeleteBtn"
                class="inline-flex items-center gap-2 px-4 py-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition-colors text-sm font-medium w-full justify-center"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
                Delete Image
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Toast Container -->
    <div id="toastContainer" class="fixed bottom-6 right-6 z-[60] flex flex-col gap-2"></div>

  </div>
</AdminLayout>

<style>
  .upload-tab.active {
    background: white;
    color: #1a1a1a;
    box-shadow: 0 1px 2px rgba(0,0,0,0.08);
  }
  .upload-tab:not(.active) {
    color: #6b7280;
  }
  .upload-tab:not(.active):hover {
    color: #374151;
  }
  .view-toggle.active {
    background: white;
    color: #1a1a1a;
    box-shadow: 0 1px 2px rgba(0,0,0,0.08);
  }
  .view-toggle:not(.active) {
    color: #6b7280;
  }
  .view-toggle:not(.active):hover {
    color: #374151;
  }
  @keyframes flashGreen {
    0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5); }
    50% { box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
    100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
  }
  .flash-green {
    animation: flashGreen 0.8s ease-out;
  }
  .drag-over {
    border-color: #01534d !important;
    background-color: rgba(1, 83, 77, 0.08) !important;
  }
</style>

<script>
  // ─── State ──────────────────────────────────────────────────────────────────
  let allImages: any[] = [];
  let currentView = 'grid';
  let selectedFile: File | null = null;
  let selectedImage: any = null;

  // ─── Elements ───────────────────────────────────────────────────────────────
  const $ = (s: string) => document.querySelector(s) as HTMLElement;
  const $$ = (s: string) => document.querySelectorAll(s);

  const statsLine = $('#statsLine');
  const toggleUploadBtn = $('#toggleUploadBtn');
  const uploadPanel = $('#uploadPanel');
  const closeUploadBtn = $('#closeUploadBtn');
  const refreshBtn = $('#refreshBtn');
  const searchInput = $('#searchInput') as HTMLInputElement;
  const sortSelect = $('#sortSelect') as HTMLSelectElement;
  const typeFilter = $('#typeFilter') as HTMLSelectElement;
  const gridViewBtn = $('#gridViewBtn');
  const listViewBtn = $('#listViewBtn');
  const gridView = $('#gridView');
  const listView = $('#listView');
  const listBody = $('#listBody');
  const loadingSkeleton = $('#loadingSkeleton');
  const emptyState = $('#emptyState');
