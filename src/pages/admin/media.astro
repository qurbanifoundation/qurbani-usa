  // ─── Detail Modal ───────────────────────────────────────────────────────────
  function openDetailModal(img: any) {
    selectedImage = img;
    ($('#modalImage') as HTMLImageElement).src = img.url;
    $('#modalFilename').textContent = img.name;
    $('#modalSize').textContent = img.sizeFormatted;
    $('#modalFormat').textContent = img.extension;
    $('#modalUrl').textContent = img.url;

    // WebP status
    const webpStatus = $('#modalWebpStatus');
    if (img.hasWebp === true) {
      webpStatus.textContent = 'Exists';
      webpStatus.className = 'text-sm font-medium mt-1 text-green-600';
    } else if (img.hasWebp === false) {
      webpStatus.textContent = 'None';
      webpStatus.className = 'text-sm font-medium mt-1 text-gray-400';
    } else {
      webpStatus.textContent = 'N/A';
      webpStatus.className = 'text-sm font-medium mt-1 text-gray-400';
    }

    // Usage info with front-end URLs
    let usageEl = document.getElementById('modalUsage');
    if (!usageEl) {
      usageEl = document.createElement('div');
      usageEl.id = 'modalUsage';
      webpStatus.parentElement?.after(usageEl);
    }

    function usageToUrl(usage: string): string {
      // Extract slug if present [slug:xxx]
      var slugMatch = usage.match(/\[slug:([^\]]+)\]/);
      var slug = slugMatch ? slugMatch[1] : '';

      // Source file paths
      if (usage.includes('src/pages/')) {
        var page = usage.replace('src/pages/', '/').replace('/index.astro', '').replace('.astro', '');
        if (page.includes('[')) return ''; // dynamic routes
        return page;
      }
      if (usage.includes('src/templates/')) {
        return ''; // templates don't have direct URLs
      }
      // Campaign references — use slug for URL
      if (slug) {
        return '/appeals/' + slug;
      }
      return '';
    }

    function usageDisplayName(usage: string): string {
      // Remove the [slug:xxx] part for display
      return usage.replace(/\s*\[slug:[^\]]+\]/, '');
    }

    if (img.usedOn && img.usedOn.length > 0) {
      usageEl.innerHTML = '<div class="mt-3"><div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Used on</div>' +
        img.usedOn.map((u: string) => {
          const url = usageToUrl(u);
          const displayName = usageDisplayName(u);
          if (url) {
            return '<a href="' + url + '" target="_blank" class="flex items-center gap-2 py-1.5 px-2 -mx-2 rounded-lg hover:bg-gray-50 transition group">'
              + '<svg class="w-4 h-4 text-[#01534d] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>'
              + '<span class="text-sm text-[#01534d] group-hover:underline">' + displayName + '</span></a>';
          }
          return '<div class="flex items-center gap-2 py-1.5 px-2 -mx-2">'
            + '<svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>'
            + '<span class="text-sm text-gray-500">' + displayName + '</span></div>';
        }).join('') + '</div>';
    } else {
      usageEl.innerHTML = '<div class="mt-3"><div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Used on</div><div class="text-sm text-gray-400 italic">Not used on any page or campaign</div></div>';
    }

    // Reset replace section
    const replaceSearch = document.getElementById('replaceSearchInput') as HTMLInputElement;
    const replaceResults = document.getElementById('replaceResults');
    const replacePreview = document.getElementById('replacePreview');
    if (replaceSearch) replaceSearch.value = '';
    if (replaceResults) replaceResults.classList.add('hidden');
    if (replacePreview) replacePreview.classList.add('hidden');
    // Show replace section only if image is used somewhere
    const replaceSection = document.getElementById('modalReplaceSection');
    if (replaceSection) {
      if (img.usedOn && img.usedOn.length > 0) {
        replaceSection.classList.remove('hidden');
      } else {
        replaceSection.classList.add('hidden');
      }
    }

    // Show/hide convert section
    if (img.extension !== 'webp' && img.extension !== 'svg') {
      modalConvertSection.classList.remove('hidden');
    } else {
      modalConvertSection.classList.add('hidden');
    }

    detailModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeDetailModal() {
    detailModal.classList.add('hidden');
    document.body.style.overflow = '';
    selectedImage = null;
  }

  // ─── Convert ────────────────────────────────────────────────────────────────
  async function convertImage(filename: string, quality = 80) {
    try {
      showToast('Converting ' + filename + ' to WebP...', 'info');
      const res = await fetch('/api/media', { credentials: 'include',
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'convert', filename, quality }),
      });
      const data = await res.json();
      if (data.success) {
        showToast(data.message, 'success');
        // Flash the card
        const card = gridView.querySelector(`[data-name="${filename}"]`);
        if (card) card.classList.add('flash-green');
        await loadImages();
      } else {
        showToast(data.error || 'Conversion failed', 'error');
      }
    } catch (e: any) {
      showToast('Conversion failed: ' + e.message, 'error');
    }
  }

  async function replaceWithWebp(filename: string, quality = 80) {
    try {
      showToast('Converting & updating all references for ' + filename + '...', 'info');
      const res = await fetch('/api/media', { credentials: 'include',
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'replace-with-webp', filename, quality }),
      });
      const data = await res.json();
      if (data.success) {
        let msg = 'Converted to WebP (' + data.savings + ' smaller)';
        if (data.updatedRefs && data.updatedRefs.length > 0) {
          msg += '. Updated: ' + data.updatedRefs.join(', ');
        }
        showToast(msg, 'success');
        await loadImages();
      } else {
        showToast(data.error || 'Replace failed', 'error');
      }
    } catch (e: any) {
      showToast('Replace failed: ' + e.message, 'error');
    }
  }

  // ─── Delete ─────────────────────────────────────────────────────────────────
  async function deleteImage(filename: string) {
    if (!confirm('Are you sure you want to delete "' + filename + '"? This cannot be undone.')) return;
    try {
      const res = await fetch('/api/media', { credentials: 'include',
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'delete', filename }),
      });
      const data = await res.json();
      if (data.success) {
        showToast(data.message, 'success');
        closeDetailModal();
        await loadImages();
      } else {
        showToast(data.error || 'Delete failed', 'error');
      }
    } catch (e: any) {
      showToast('Delete failed: ' + e.message, 'error');
    }
  }

  // ─── Copy URL ───────────────────────────────────────────────────────────────
  async function copyToClipboard(text: string) {
    try {
      await navigator.clipboard.writeText(text);
      showToast('URL copied to clipboard', 'success');
    } catch {
      // Fallback
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.left = '-9999px';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      showToast('URL copied to clipboard', 'success');
    }
  }

  // ─── Upload ─────────────────────────────────────────────────────────────────
  function updateUploadBtn() {
    const activeTab = document.querySelector('.upload-tab.active') as HTMLElement;
    const tab = activeTab?.getAttribute('data-tab');
    if (tab === 'file') {
      uploadSubmitBtn.disabled = !selectedFile;
    } else {
      uploadSubmitBtn.disabled = !(urlInput as HTMLInputElement).value.trim();
    }
  }

  async function handleFileUpload() {
    if (!selectedFile) return;
    uploadSubmitBtn.disabled = true;
    uploadBtnText.textContent = 'Uploading...';

    const formData = new FormData();
    formData.append('file', selectedFile);
    formData.append('convertToWebp', String(autoConvertWebp.checked));
    formData.append('quality', '80');

    try {
      const res = await fetch('/api/media', { credentials: 'include', method: 'POST', body: formData });
      const data = await res.json();
      if (data.success) {
        showToast(data.message, 'success');
        clearSelectedFile();
        await loadImages();
      } else {
        showToast(data.error || 'Upload failed', 'error');
      }
    } catch (e: any) {
      showToast('Upload failed: ' + e.message, 'error');
    } finally {
      uploadBtnText.textContent = 'Upload';
      updateUploadBtn();
    }
  }

  async function handleUrlUpload() {
    const url = (urlInput as HTMLInputElement).value.trim();
    if (!url) return;
    uploadSubmitBtn.disabled = true;
    uploadBtnText.textContent = 'Downloading...';

    try {
      const res = await fetch('/api/media', { credentials: 'include',
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'upload-url',
          url,
          filename: (urlFilename as HTMLInputElement).value.trim() || undefined,
          convertToWebp: autoConvertWebp.checked,
          quality: 80,
        }),
      });
      const data = await res.json();
      if (data.success) {
        showToast(data.message, 'success');
        (urlInput as HTMLInputElement).value = '';
        (urlFilename as HTMLInputElement).value = '';
        await loadImages();
      } else {
        showToast(data.error || 'Download failed', 'error');
      }
    } catch (e: any) {
      showToast('Download failed: ' + e.message, 'error');
    } finally {
      uploadBtnText.textContent = 'Upload';
      updateUploadBtn();
    }
  }

  function selectFile(file: File) {
    selectedFile = file;
    filePreviewName.textContent = file.name;
    filePreviewSize.textContent = formatSize(file.size);
    const reader = new FileReader();
    reader.onload = (e) => {
      (filePreviewImg as HTMLImageElement).src = e.target?.result as string;
    };
    reader.readAsDataURL(file);
    filePreview.classList.remove('hidden');
    dropZone.classList.add('hidden');
    updateUploadBtn();
  }

  function clearSelectedFile() {
    selectedFile = null;
    (fileInput as HTMLInputElement).value = '';
    filePreview.classList.add('hidden');
    dropZone.classList.remove('hidden');
    updateUploadBtn();
  }

  // ─── Event Listeners ───────────────────────────────────────────────────────

  // Upload panel toggle
  toggleUploadBtn.addEventListener('click', () => {
    uploadPanel.classList.toggle('hidden');
  });
  closeUploadBtn.addEventListener('click', () => {
    uploadPanel.classList.add('hidden');
  });

  // Refresh
  refreshBtn.addEventListener('click', loadImages);

  // PNG Audit — filter to show only PNG files that are used on pages
  document.getElementById('pngAuditBtn')?.addEventListener('click', () => {
    const tf = typeFilter as HTMLSelectElement;
    tf.value = 'png';
    (searchInput as HTMLInputElement).value = '';
    renderImages();
    // Count used PNGs
    const usedPngs = allImages.filter((img: any) => img.extension === 'png' && img.usedOn && img.usedOn.length > 0);
    const totalPngs = allImages.filter((img: any) => img.extension === 'png');
    showToast(`Found ${usedPngs.length} PNG files in use (${totalPngs.length} total). Convert to WebP for better SEO & performance.`, 'info');
  });

  // Search, sort, filter
  searchInput.addEventListener('input', renderImages);
  document.getElementById('searchMode')?.addEventListener('change', () => {
    const mode = (document.getElementById('searchMode') as HTMLSelectElement).value;
    if (mode === 'images') searchInput.placeholder = 'Search by image filename...';
    else if (mode === 'pages') searchInput.placeholder = 'Search by page or campaign name...';
    else searchInput.placeholder = 'Search by filename or page name (e.g. zakat, orphan, aqiqah)...';
    renderImages();
  });
  sortSelect.addEventListener('change', renderImages);
  typeFilter.addEventListener('change', renderImages);

  // View toggle
  gridViewBtn.addEventListener('click', () => {
    currentView = 'grid';
    gridViewBtn.classList.add('active');
    listViewBtn.classList.remove('active');
    renderImages();
  });
  listViewBtn.addEventListener('click', () => {
    currentView = 'list';
    listViewBtn.classList.add('active');
    gridViewBtn.classList.remove('active');
    renderImages();
  });

  // Upload tabs
  $$('.upload-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      $$('.upload-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const tabName = tab.getAttribute('data-tab');
      ($('#fileUploadTab') as HTMLElement).classList.toggle('hidden', tabName !== 'file');
      ($('#urlUploadTab') as HTMLElement).classList.toggle('hidden', tabName !== 'url');
      updateUploadBtn();
    });
  });

  // Drag & drop
  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const files = (e as DragEvent).dataTransfer?.files;
    if (files && files.length > 0) selectFile(files[0]);
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) selectFile(fileInput.files[0]);
  });
  clearFileBtn.addEventListener('click', clearSelectedFile);
  urlInput.addEventListener('input', updateUploadBtn);

  // Upload submit
  uploadSubmitBtn.addEventListener('click', () => {
    const activeTab = document.querySelector('.upload-tab.active') as HTMLElement;
    const tab = activeTab?.getAttribute('data-tab');
    if (tab === 'file') handleFileUpload();
    else handleUrlUpload();
  });

  // Modal
  modalOverlay.addEventListener('click', closeDetailModal);
  closeModalBtn.addEventListener('click', closeDetailModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDetailModal();
  });

  // Modal copy
  modalCopyBtn.addEventListener('click', () => {
    const url = $('#modalUrl').textContent || '';
    copyToClipboard(url);
  });

  // Modal convert
  qualitySlider.addEventListener('input', () => {
    qualityValue.textContent = qualitySlider.value;
  });
  modalConvertBtn.addEventListener('click', async () => {
    if (!selectedImage) return;
    modalConvertBtn.disabled = true;
    modalConvertBtn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Converting...';
    await convertImage(selectedImage.name, parseInt(qualitySlider.value));
    closeDetailModal();
    modalConvertBtn.disabled = false;
    modalConvertBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg> Convert';
  });

  // Modal delete
  modalDeleteBtn.addEventListener('click', () => {
    if (selectedImage) deleteImage(selectedImage.name);
  });

  // ─── Replace Image Picker ─────────────────────────────────────────────────
  let replaceTarget: any = null;
  const replaceSearchInput = document.getElementById('replaceSearchInput') as HTMLInputElement;
  const replaceResultsEl = document.getElementById('replaceResults');
  const replacePreviewEl = document.getElementById('replacePreview');

  if (replaceSearchInput) {
    replaceSearchInput.addEventListener('input', () => {
      const q = replaceSearchInput.value.toLowerCase().trim();
      if (q.length < 2) {
        replaceResultsEl?.classList.add('hidden');
        return;
      }
      // Filter images (exclude current)
      const matches = allImages
        .filter((img: any) => img.name !== selectedImage?.name && img.name.toLowerCase().includes(q))
        .slice(0, 8);

      if (matches.length === 0) {
        replaceResultsEl!.innerHTML = '<div class="p-3 text-sm text-gray-400">No images found</div>';
      } else {
        replaceResultsEl!.innerHTML = matches.map((img: any) =>
          `<div class="replace-option flex items-center gap-2 p-2 hover:bg-gray-50 cursor-pointer border-b border-gray-100 last:border-0" data-name="${img.name}" data-url="${img.url}" data-size="${img.sizeFormatted}">
            <img src="${img.url}" class="w-8 h-8 object-cover rounded flex-shrink-0" alt="" />
            <div class="flex-1 min-w-0">
              <div class="text-xs font-medium text-gray-800 truncate">${img.name}</div>
              <div class="text-[10px] text-gray-400">${img.sizeFormatted} | ${img.extension.toUpperCase()}</div>
            </div>
          </div>`
        ).join('');
      }
      replaceResultsEl?.classList.remove('hidden');

      // Bind clicks on results
      replaceResultsEl?.querySelectorAll('.replace-option').forEach(opt => {
        opt.addEventListener('click', () => {
          const name = (opt as HTMLElement).dataset.name || '';
          const url = (opt as HTMLElement).dataset.url || '';
          const size = (opt as HTMLElement).dataset.size || '';
          replaceTarget = { name, url };
          (document.getElementById('replacePreviewImg') as HTMLImageElement).src = url;
          document.getElementById('replacePreviewName')!.textContent = name;
          document.getElementById('replacePreviewSize')!.textContent = size;
          replacePreviewEl?.classList.remove('hidden');
          replaceResultsEl?.classList.add('hidden');
          replaceSearchInput.value = name;
        });
      });
    });
  }

  // Replace confirm button
  document.getElementById('replaceConfirmBtn')?.addEventListener('click', async () => {
    if (!selectedImage || !replaceTarget) return;
    try {
      showToast('Replacing ' + selectedImage.name + ' with ' + replaceTarget.name + '...', 'info');
      const res = await fetch('/api/media', { credentials: 'include',
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'replace-refs',
          oldFilename: selectedImage.name,
          newFilename: replaceTarget.name,
        }),
      });
      const data = await res.json();
      if (data.success) {
        showToast(data.message || 'Replaced successfully', 'success');
        closeDetailModal();
        await loadImages();
      } else {
        showToast(data.error || 'Replace failed', 'error');
      }
    } catch (e: any) {
      showToast('Replace failed: ' + e.message, 'error');
    }
  });

  // ─── Bulk Selection ────────────────────────────────────────────────────────
  const bulkBar = document.getElementById('bulkBar');
  const selectAllCheckbox = document.getElementById('selectAllCheckbox') as HTMLInputElement;
  const selectAllCountEl = document.getElementById('selectAllCount');
  const selectedCountEl = document.getElementById('selectedCount');
  const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');
  const bulkCancelBtn = document.getElementById('bulkCancelBtn');
  let selectedFiles = new Set<string>();

  function updateBulkBar() {
    const checkboxes = document.querySelectorAll('.bulk-select-cb') as NodeListOf<HTMLInputElement>;
    selectedFiles.clear();
    checkboxes.forEach(cb => {
      if (cb.checked) selectedFiles.add(cb.dataset.name || '');
    });

    if (selectedFiles.size > 0) {
      bulkBar?.classList.remove('hidden');
      if (selectedCountEl) selectedCountEl.textContent = selectedFiles.size + ' selected';
    } else {
      bulkBar?.classList.add('hidden');
    }

    // Update select all count
    const filtered = getFilteredImages();
    if (selectAllCountEl) selectAllCountEl.textContent = String(filtered.length);
    if (selectAllCheckbox) selectAllCheckbox.checked = selectedFiles.size === checkboxes.length && checkboxes.length > 0;
  }

  // Delegate checkbox change events
  document.addEventListener('change', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('bulk-select-cb')) {
      updateBulkBar();
    }
  });

  // Select All
  selectAllCheckbox?.addEventListener('change', () => {
    const checkboxes = document.querySelectorAll('.bulk-select-cb') as NodeListOf<HTMLInputElement>;
    checkboxes.forEach(cb => { cb.checked = selectAllCheckbox.checked; });
    updateBulkBar();
  });

  // Cancel selection
  bulkCancelBtn?.addEventListener('click', () => {
    const checkboxes = document.querySelectorAll('.bulk-select-cb') as NodeListOf<HTMLInputElement>;
    checkboxes.forEach(cb => { cb.checked = false; });
    selectedFiles.clear();
    bulkBar?.classList.add('hidden');
    if (selectAllCheckbox) selectAllCheckbox.checked = false;
  });

  // Bulk delete
  bulkDeleteBtn?.addEventListener('click', async () => {
    if (selectedFiles.size === 0) return;

    const usedFiles = Array.from(selectedFiles).filter(name => {
      const img = allImages.find((i: any) => i.name === name);
      return img?.usedOn && img.usedOn.length > 0;
    });

    let msg = 'Delete ' + selectedFiles.size + ' image(s)?';
    if (usedFiles.length > 0) {
      msg += '\n\nWARNING: ' + usedFiles.length + ' of these are IN USE on pages:\n' + usedFiles.join('\n') + '\n\nDeleting them will cause broken images on your site.';
    }
    msg += '\n\nThis cannot be undone.';

    if (!confirm(msg)) return;

    let deleted = 0;
    let failed = 0;
    for (const name of selectedFiles) {
      try {
        const res = await fetch('/api/media', { credentials: 'include',
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'delete', filename: name }),
        });
        const data = await res.json();
        if (data.success) deleted++;
        else failed++;
      } catch {
        failed++;
      }
    }

    selectedFiles.clear();
    bulkBar?.classList.add('hidden');
    if (selectAllCheckbox) selectAllCheckbox.checked = false;

    showToast(
      deleted + ' image(s) deleted' + (failed > 0 ? ', ' + failed + ' failed' : ''),
      failed > 0 ? 'error' : 'success'
    );
    await loadImages();
  });

  // ─── Init ───────────────────────────────────────────────────────────────────
  loadImages();
</script>
