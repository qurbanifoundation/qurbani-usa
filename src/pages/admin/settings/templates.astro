---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import SettingsTabs from '../../../components/admin/SettingsTabs.astro';
import TemplateColorEditor from '../../../components/admin/TemplateColorEditor.astro';
import { supabaseAdmin } from '../../../lib/supabase';
import { getPageTemplates, getDonationBoxTemplates, getAppealsPageTemplates, getOrphanSponsorshipTemplates, getHomepageTemplates, getRamadanPageTemplates, getRamadanTenNightsTemplates, getCheckoutTemplates } from '../../../lib/templates';

export const prerender = false;

// Fetch templates from database (centralized)
const pageTemplates = await getPageTemplates();
const donationBoxTemplates = await getDonationBoxTemplates();
const appealsPageTemplates = await getAppealsPageTemplates();
const orphanSponsorshipTemplates = await getOrphanSponsorshipTemplates();
const homepageTemplates = await getHomepageTemplates();
const ramadanPageTemplates = await getRamadanPageTemplates();
const ramadanTenNightsTemplates = await getRamadanTenNightsTemplates();
const checkoutTemplates = await getCheckoutTemplates();

// Fetch current settings
let settings: any = null;
try {
  const { data, error } = await supabaseAdmin
    .from('site_settings')
    .select('default_donation_box_template, default_campaign_page_template, default_appeals_page_template, orphan_sponsorship_template, homepage_template, ramadan_page_template, ramadan_tennights_template, checkout_template')
    .limit(1);

  if (data && data.length > 0) {
    settings = data[0];
  }
} catch (e) {
  console.error('Error fetching site settings:', e);
}

const currentDonationBoxTemplate = settings?.default_donation_box_template || 'teal-yellow';
const currentCampaignPageTemplate = settings?.default_campaign_page_template || 'green-with-yellow';
const currentAppealsPageTemplate = settings?.default_appeals_page_template || 'green';
const currentOrphanSponsorshipTemplate = settings?.orphan_sponsorship_template || 'orphan-sponsorship';
const currentHomepageTemplate = settings?.homepage_template || 'pennybill';
const currentRamadanPageTemplate = settings?.ramadan_page_template || 'pennyappeal';
const currentRamadanTenNightsTemplate = settings?.ramadan_tennights_template || 'amanah';
const currentCheckoutTemplate = settings?.checkout_template || 'three-step';

// Default colors for each donation box template
const defaultColors: Record<string, any> = {
  'teal-yellow': {
    bg_color: '#255764', text_color: '#ffffff', text_muted_color: 'rgba(255,255,255,0.7)',
    accent_color: '#fdc448', accent_text_color: '#61470e', border_color: 'rgba(255,255,255,0.3)',
    active_bg_color: 'rgba(253,196,72,0.2)', active_text_color: '#ffffff',
    inactive_btn_bg: 'transparent', toggle_active_color: 'rgba(255,255,255,0.2)',
  },
  'dark-teal': {
    bg_color: '#004139', text_color: '#ffffff', text_muted_color: '#d4c4a8',
    accent_color: '#c41e3a', accent_text_color: '#ffffff', border_color: '#108D70',
    active_bg_color: '#ECF0EE', active_text_color: '#004139',
    inactive_btn_bg: '#005A4C', toggle_active_color: '#108D70',
  },
  'white': {
    bg_color: '#ffffff', text_color: '#1f2937', text_muted_color: '#6b7280',
    accent_color: '#01534d', accent_text_color: '#ffffff', border_color: '#01534d',
    active_bg_color: '#01534d', active_text_color: '#ffffff',
    inactive_btn_bg: 'transparent', toggle_active_color: '#01534d',
  },
  'compact': {
    bg_color: '#1a4a55', text_color: '#ffffff', text_muted_color: 'rgba(255,255,255,0.7)',
    accent_color: '#fdc448', accent_text_color: '#61470e', border_color: 'rgba(255,255,255,0.3)',
    active_bg_color: 'rgba(253,196,72,0.2)', active_text_color: '#ffffff',
    inactive_btn_bg: 'transparent', toggle_active_color: 'rgba(255,255,255,0.2)',
  },
  'list-style': {
    bg_color: '#f5f5f5', text_color: '#374151', text_muted_color: '#6b7280',
    accent_color: '#D97706', accent_text_color: '#ffffff', border_color: '#e5e7eb',
    active_bg_color: '#D97706', active_text_color: '#ffffff',
    inactive_btn_bg: '#ffffff', toggle_active_color: '#D97706',
  },
  'urgent-appeal': {
    bg_color: '#ffffff', header_bg_color: '#c41e3a', text_color: '#1f2937',
    text_muted_color: '#6b7280', accent_color: '#c41e3a', accent_text_color: '#ffffff',
    border_color: '#e5e7eb', active_bg_color: '#c41e3a10', active_text_color: '#1f2937',
    inactive_btn_bg: '#ffffff', toggle_active_color: '#c41e3a',
  },
  'cw-donation': {
    bg_color: '#ffffff', text_color: '#1f2937', text_muted_color: '#6b7280',
    accent_color: '#d4a017', accent_text_color: '#5a3e00', border_color: '#e5e7eb',
    active_bg_color: 'rgba(212,160,23,0.1)', active_text_color: '#1f2937',
    inactive_btn_bg: '#ffffff', toggle_active_color: '#d4a017',
  },
  'home-donation': {
    bg_color: '#ffffff', text_color: '#1f2937', text_muted_color: '#6b7280',
    accent_color: '#d97706', accent_text_color: '#ffffff', border_color: '#e5e7eb',
    active_bg_color: '#d97706', active_text_color: '#ffffff',
    inactive_btn_bg: '#ffffff', toggle_active_color: '#d97706',
  },
};

// Fetch template colors from database
let templateColors: Record<string, any> = {};
let customTemplates: any[] = [];
const builtInTemplates = ['teal-yellow', 'dark-teal', 'white', 'compact', 'list-style', 'urgent-appeal', 'cw-donation', 'home-donation'];

try {
  const { data } = await supabaseAdmin
    .from('template_colors')
    .select('*');
  if (data) {
    data.forEach((t: any) => {
      templateColors[t.template_name] = t;
      if (!builtInTemplates.includes(t.template_name)) {
        customTemplates.push(t);
      }
    });
  }
} catch (e) {}

// Merge database colors with defaults
const getColors = (templateName: string) => {
  const defaults = defaultColors[templateName] || defaultColors['teal-yellow'];
  const dbColors = templateColors[templateName] || {};
  return {
    bg_color: dbColors.bg_color || defaults.bg_color,
    text_color: dbColors.text_color || defaults.text_color,
    text_muted_color: dbColors.text_muted_color || defaults.text_muted_color,
    accent_color: dbColors.accent_color || defaults.accent_color,
    accent_text_color: dbColors.accent_text_color || defaults.accent_text_color,
    border_color: dbColors.border_color || defaults.border_color,
    active_bg_color: dbColors.active_bg_color || defaults.active_bg_color,
    active_text_color: dbColors.active_text_color || defaults.active_text_color,
    inactive_btn_bg: dbColors.inactive_btn_bg || defaults.inactive_btn_bg,
    toggle_active_color: dbColors.toggle_active_color || defaults.toggle_active_color,
  };
};

// ============================================================
// TEMPLATE FILE PATH MAPPING — Used to show file paths in admin
// ============================================================
const filePathMap: Record<string, string> = {
  // Campaign Page Templates
  'green-with-yellow': 'src/templates/GreenWithYellowTemplate.astro',
  'emergency-appeal': 'src/templates/EmergencyAppealTemplate.astro',
  'orphan-sponsorship': 'src/templates/OrphanSponsorshipTemplate.astro',
  'tilestack-sponsorship': 'src/templates/TileStackSponsorshipTemplate.astro',
  'aqiqah': 'src/templates/AqiqahTemplate.astro',
  'zakat-calculator': 'src/templates/ZakatCalculatorTemplate.astro',
  'zakat-hub': 'src/templates/ZakatHubTemplate.astro',
  'food-aid': 'src/templates/FoodAidTemplate.astro',
  'qurbani': 'src/templates/QurbaniTemplate.astro',
  // Donation Box Templates
  'teal-yellow': 'src/components/donation/TealYellowDonationBox.astro',
  'dark-teal': 'src/components/donation/DonationBox.astro',
  'white': 'src/components/donation/WhiteDonationBox.astro',
  'compact': 'src/components/donation/DonationBox.astro',
  'list-style': 'src/components/donation/ListStyleDonationBox.astro',
  'urgent-appeal': 'src/components/donation/UrgentAppealDonationBox.astro',
  'cw-donation': 'src/components/donation/CWDonationBox.astro',
  'home-donation': 'src/components/donation/HomeDonationBox.astro',
  // Homepage Templates
  'pennybill': 'src/templates/PennybillHomepageTemplate.astro',
  'immersive': 'src/templates/ImmersiveHomepageTemplate.astro',
  'almustafa': 'src/templates/AlmustafaHomepageTemplate.astro',
  // Ramadan Templates
  'pennyappeal': 'src/templates/ramadan/PennyAppealTemplate.astro',
  'amanah': 'src/templates/ramadan/AmanahTemplate.astro',
  // Appeals Templates
  'green': 'src/templates/appeals/GreenAppealTemplate.astro',
  'orange': 'src/templates/appeals/OrangeAppealTemplate.astro',
  // Checkout Templates
  'three-step': 'src/pages/checkout.astro',
  'two-step': 'src/pages/checkout.astro',
  'gg-one-step': 'src/pages/checkout.astro',
};

// ============================================================
// BUILD ALL TEMPLATE SECTIONS
// ============================================================
interface TemplateEntry {
  key: string;
  label: string;
  description: string | null;
  filePath: string;
  isDefault: boolean;
  settingsKey: string; // Which site_settings field controls the default
  hasColorEditor: boolean;
  category: string;
}

// Page URL mapping — shows which URL each template section powers
const sectionPageUrls: Record<string, string> = {
  'homepage': '/',
  'ramadan': '/ramadan/my30days',
  'ramadan-tennights': '/ramadan/mytennights',
  'appeals': '/appeals',
  'checkout': '/checkout',
};

const allSections = [
  {
    id: 'campaign-pages',
    title: 'Campaign Page Templates',
    subtitle: 'Full-page layouts for campaigns and appeals. Each campaign can select a different template.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>`,
    settingsKey: 'default_campaign_page_template',
    currentDefault: currentCampaignPageTemplate,
    templates: pageTemplates.map(t => ({
      key: t.template_key,
      label: t.template_label,
      description: t.description,
      filePath: filePathMap[t.template_key] || 'Unknown',
      isDefault: currentCampaignPageTemplate === t.template_key,
      settingsKey: 'default_campaign_page_template',
      hasColorEditor: false,
      category: 'campaign-pages',
    })),
  },
  {
    id: 'donation-boxes',
    title: 'Donation Box Templates',
    subtitle: 'Styles for the donation amount selector box. Colors and text are fully customizable.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`,
    settingsKey: 'default_donation_box_template',
    currentDefault: currentDonationBoxTemplate,
    templates: donationBoxTemplates.map(t => ({
      key: t.template_key,
      label: t.template_label,
      description: t.description,
      filePath: filePathMap[t.template_key] || 'Unknown',
      isDefault: currentDonationBoxTemplate === t.template_key,
      settingsKey: 'default_donation_box_template',
      hasColorEditor: builtInTemplates.includes(t.template_key) || customTemplates.some(c => c.template_name === t.template_key),
      category: 'donation-boxes',
    })),
  },
  {
    id: 'homepage',
    title: 'Homepage Templates',
    subtitle: 'Main landing page layout. Changing this affects the site homepage.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>`,
    settingsKey: 'homepage_template',
    currentDefault: currentHomepageTemplate,
    templates: homepageTemplates.map(t => ({
      key: t.template_key,
      label: t.template_label,
      description: t.description,
      filePath: filePathMap[t.template_key] || 'Unknown',
      isDefault: currentHomepageTemplate === t.template_key,
      settingsKey: 'homepage_template',
      hasColorEditor: false,
      category: 'homepage',
    })),
  },
  {
    id: 'ramadan',
    title: 'Ramadan Page Templates',
    subtitle: 'Seasonal Ramadan campaign page layouts.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>`,
    settingsKey: 'ramadan_page_template',
    currentDefault: currentRamadanPageTemplate,
    templates: ramadanPageTemplates.map(t => ({
      key: t.template_key,
      label: t.template_label,
      description: t.description,
      filePath: filePathMap[t.template_key] || 'Unknown',
      isDefault: currentRamadanPageTemplate === t.template_key,
      settingsKey: 'ramadan_page_template',
      hasColorEditor: false,
      category: 'ramadan',
    })),
  },
  {
    id: 'ramadan-tennights',
    title: 'Ramadan Ten Nights Templates',
    subtitle: 'Template for the My Ten Nights page (/ramadan/mytennights). Independent from My 30 Days.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>`,
    settingsKey: 'ramadan_tennights_template',
    currentDefault: currentRamadanTenNightsTemplate,
    templates: ramadanTenNightsTemplates.map(t => ({
      key: t.template_key,
      label: t.template_label,
      description: t.description,
      filePath: filePathMap[t.template_key] || 'Unknown',
      isDefault: currentRamadanTenNightsTemplate === t.template_key,
      settingsKey: 'ramadan_tennights_template',
      hasColorEditor: false,
      category: 'ramadan',
    })),
  },
  {
    id: 'appeals',
    title: 'Appeals Page Templates',
    subtitle: 'Layout for the main /appeals listing page.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>`,
    settingsKey: 'default_appeals_page_template',
    currentDefault: currentAppealsPageTemplate,
    templates: appealsPageTemplates.map(t => ({
      key: t.template_key,
      label: t.template_label,
      description: t.description,
      filePath: filePathMap[t.template_key] || 'Unknown',
      isDefault: currentAppealsPageTemplate === t.template_key,
      settingsKey: 'default_appeals_page_template',
      hasColorEditor: false,
      category: 'appeals',
    })),
  },
  {
    id: 'checkout',
    title: 'Checkout Templates',
    subtitle: 'Payment flow layout. Controls the checkout experience.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>`,
    settingsKey: 'checkout_template',
    currentDefault: currentCheckoutTemplate,
    templates: checkoutTemplates.map(t => ({
      key: t.template_key,
      label: t.template_label,
      description: t.description,
      filePath: filePathMap[t.template_key] || 'Unknown',
      isDefault: currentCheckoutTemplate === t.template_key,
      settingsKey: 'checkout_template',
      hasColorEditor: false,
      category: 'checkout',
    })),
  },
  {
    id: 'orphan-sponsorship',
    title: 'Orphan Sponsorship Templates',
    subtitle: 'Dedicated orphan sponsorship page layouts (also available as campaign templates).',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>`,
    settingsKey: 'orphan_sponsorship_template',
    currentDefault: currentOrphanSponsorshipTemplate,
    templates: orphanSponsorshipTemplates.map(t => ({
      key: t.template_key,
      label: t.template_label,
      description: t.description,
      filePath: filePathMap[t.template_key] || 'Unknown',
      isDefault: currentOrphanSponsorshipTemplate === t.template_key,
      settingsKey: 'orphan_sponsorship_template',
      hasColorEditor: false,
      category: 'orphan-sponsorship',
    })),
  },
];

const totalTemplateCount = allSections.reduce((sum, s) => sum + s.templates.length, 0);
---

<AdminLayout title="Template Management" activeNav="settings">
  <div class="max-w-7xl">
    <SettingsTabs active="templates" />

    <!-- Toast -->
    <div id="toast" class="hidden fixed top-4 right-4 px-6 py-3 rounded-lg shadow-lg z-50"></div>

    <!-- Page Header -->
    <div class="mb-6 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Template Management</h1>
        <p class="text-sm text-gray-500 mt-1">{totalTemplateCount} templates across {allSections.length} categories. Click any name to rename it.</p>
      </div>
      <div class="flex items-center gap-3">
        <button id="resetAllCampaignsBtn" class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
          Apply Defaults to All Campaigns
        </button>
      </div>
    </div>

    <!-- Category Tabs -->
    <div class="mb-6 border-b border-gray-200">
      <nav class="flex gap-1 overflow-x-auto pb-px" id="categoryTabs">
        <button data-tab="all" class="tab-btn active px-4 py-2.5 text-sm font-medium border-b-2 border-[#01534d] text-[#01534d] whitespace-nowrap transition">
          All ({totalTemplateCount})
        </button>
        {allSections.map(section => (
          <button data-tab={section.id} class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap transition">
            {section.title.replace(' Templates', '')} ({section.templates.length})
          </button>
        ))}
      </nav>
    </div>

    <!-- Template Sections -->
    {allSections.map(section => (
      <div class="template-section mb-8" data-section={section.id}>
        <!-- Section Header -->
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-[#01534d]/10 text-[#01534d] flex items-center justify-center" set:html={section.icon} />
            <div>
              <h2 class="text-lg font-bold text-gray-900">{section.title}</h2>
              <p class="text-xs text-gray-500">{section.subtitle}</p>
              {sectionPageUrls[section.id] && (
                <div class="flex items-center gap-1.5 mt-1">
                  <svg class="w-3 h-3 text-[#01534d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                  <a href={sectionPageUrls[section.id]} target="_blank" class="text-xs text-[#01534d] font-mono hover:underline">{sectionPageUrls[section.id]}</a>
                </div>
              )}
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-400">Default:</span>
            <span class="px-2.5 py-1 bg-[#01534d] text-white text-xs font-medium rounded-full">
              {section.templates.find(t => t.isDefault)?.label || section.currentDefault}
            </span>
          </div>
        </div>

        <!-- Template Cards -->
        <div class="grid gap-3">
          {section.templates.map((tmpl) => {
            const colors = tmpl.hasColorEditor ? getColors(tmpl.key) : null;
            return (
              <div class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
                <div class="flex items-center p-4 gap-4">
                  {/* Color swatch for donation boxes */}
                  {colors ? (
                    <div class="w-12 h-12 rounded-lg border border-gray-200 flex-shrink-0 flex items-center justify-center overflow-hidden" style={`background: ${colors.bg_color};`}>
                      <div class="w-6 h-3 rounded-sm" style={`background: ${colors.accent_color};`}></div>
                    </div>
                  ) : (
                    <div class="w-12 h-12 rounded-lg bg-gray-50 border border-gray-200 flex-shrink-0 flex items-center justify-center">
                      <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
                      </svg>
                    </div>
                  )}

                  {/* Template Info */}
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      {/* Editable name */}
                      <span
                        class="template-name font-semibold text-gray-900 cursor-pointer hover:text-[#01534d] transition"
                        data-template-key={tmpl.key}
                        data-template-type={section.templates[0]?.category || section.id}
                        title="Click to rename"
                      >
                        {tmpl.label}
                      </span>
                      <button
                        class="rename-btn text-gray-400 hover:text-[#01534d] transition"
                        data-template-key={tmpl.key}
                        title="Rename template"
                      >
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                        </svg>
                      </button>
                      {tmpl.isDefault && (
                        <span class="px-2 py-0.5 bg-[#01534d] text-white text-[10px] font-bold rounded uppercase tracking-wide">Default</span>
                      )}
                    </div>

                    {/* Key + File path */}
                    <div class="flex items-center gap-3 text-xs">
                      <span class="inline-flex items-center gap-1 text-gray-500">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path></svg>
                        <code class="font-mono text-gray-600 select-all">{tmpl.key}</code>
                      </span>
                      <span class="inline-flex items-center gap-1 text-gray-400">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        <code class="font-mono text-gray-500 select-all text-[11px]">{tmpl.filePath}</code>
                      </span>
                    </div>

                    {/* Description */}
                    {tmpl.description && (
                      <p class="text-xs text-gray-400 mt-1 truncate">{tmpl.description}</p>
                    )}
                  </div>

                  {/* Actions */}
                  <div class="flex items-center gap-2 flex-shrink-0">
                    {tmpl.hasColorEditor && (
                      <button
                        onclick={`openColorEditor('${tmpl.key}')`}
                        class="px-3 py-1.5 text-xs font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition flex items-center gap-1.5"
                      >
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
                        </svg>
                        Edit Colors
                      </button>
                    )}
                    {!tmpl.isDefault ? (
                      <button
                        data-set-default
                        data-template-type={tmpl.settingsKey}
                        data-template-value={tmpl.key}
                        class="px-3 py-1.5 text-xs font-medium text-[#01534d] border border-[#01534d]/20 hover:bg-[#01534d]/5 rounded-lg transition"
                      >
                        Set Default
                      </button>
                    ) : (
                      <span class="px-3 py-1.5 text-xs font-medium text-gray-400 border border-gray-200 rounded-lg cursor-default">
                        Active
                      </span>
                    )}
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        {/* Custom donation box templates */}
        {section.id === 'donation-boxes' && customTemplates.length > 0 && (
          <div class="mt-4">
            <h3 class="text-sm font-semibold text-gray-600 mb-3 flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
              Custom Templates
            </h3>
            <div class="grid gap-3">
              {customTemplates.map((ct: any) => {
                const ctColors = getColors(ct.template_name);
                const ctLabel = ct.template_label || ct.template_name.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
                return (
                  <div class="bg-white rounded-xl border border-dashed border-gray-300 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
                    <div class="flex items-center p-4 gap-4">
                      <div class="w-12 h-12 rounded-lg border border-gray-200 flex-shrink-0 flex items-center justify-center overflow-hidden" style={`background: ${ctColors.bg_color};`}>
                        <div class="w-6 h-3 rounded-sm" style={`background: ${ctColors.accent_color};`}></div>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                          <span class="font-semibold text-gray-900">{ctLabel}</span>
                          <span class="px-1.5 py-0.5 bg-purple-100 text-purple-700 text-[10px] font-medium rounded">Custom</span>
                        </div>
                        <div class="flex items-center gap-3 text-xs">
                          <span class="inline-flex items-center gap-1 text-gray-500">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path></svg>
                            <code class="font-mono text-gray-600 select-all">{ct.template_name}</code>
                          </span>
                          <span class="text-gray-400">Custom color variant</span>
                        </div>
                      </div>
                      <div class="flex items-center gap-2 flex-shrink-0">
                        <button onclick={`openColorEditor('${ct.template_name}')`} class="px-3 py-1.5 text-xs font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition">
                          Edit Colors
                        </button>
                        <button onclick={`duplicateTemplate('${ct.template_name}', '${ctLabel}')`} class="px-3 py-1.5 text-xs font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition">
                          Duplicate
                        </button>
                        <button onclick={`deleteTemplate('${ct.template_name}', '${ctLabel}')`} class="px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 rounded-lg transition">
                          Delete
                        </button>
                        <button data-set-default data-template-type="default_donation_box_template" data-template-value={ct.template_name} class="px-3 py-1.5 text-xs font-medium text-[#01534d] border border-[#01534d]/20 hover:bg-[#01534d]/5 rounded-lg transition">
                          Set Default
                        </button>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* Add custom template button for donation boxes */}
        {section.id === 'donation-boxes' && (
          <div class="mt-4">
            <button onclick="openCreateTemplateModal()" class="w-full py-3 border-2 border-dashed border-gray-300 rounded-xl text-sm font-medium text-gray-500 hover:text-[#01534d] hover:border-[#01534d]/30 transition flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              Create Custom Donation Box Template
            </button>
          </div>
        )}
      </div>
    ))}
  </div>

  {/* Color Editor Modals — kept for donation box templates */}
  <TemplateColorEditor templateName="teal-yellow" templateLabel="Teal Yellow" />
  <TemplateColorEditor templateName="dark-teal" templateLabel="Dark Teal" />
  <TemplateColorEditor templateName="white" templateLabel="White / Light" />
  <TemplateColorEditor templateName="compact" templateLabel="Compact" />
  <TemplateColorEditor templateName="list-style" templateLabel="List Style" />
  <TemplateColorEditor templateName="urgent-appeal" templateLabel="Urgent Appeal" />
  <TemplateColorEditor templateName="cw-donation" templateLabel="CW Donation" />
  <TemplateColorEditor templateName="home-donation" templateLabel="Home Donation Box" />

  {/* Custom Template Editors */}
  {customTemplates.map((template: any) => {
    const displayName = template.template_label || template.template_name.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    return <TemplateColorEditor templateName={template.template_name} templateLabel={displayName} />;
  })}

  <!-- Create/Duplicate Template Modal -->
  <div id="create-template-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl max-w-md w-full">
      <div class="p-4 border-b border-gray-200 flex items-center justify-between">
        <h3 id="create-modal-title" class="font-bold text-lg">Create New Template</h3>
        <button onclick="closeCreateTemplateModal()" class="p-2 hover:bg-gray-100 rounded-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <div class="p-6">
        <form id="create-template-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Template Name</label>
            <input type="text" id="new-template-name" name="template_name" placeholder="e.g., my-custom-box" class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#01534d]" required />
            <p class="text-xs text-gray-400 mt-1">Lowercase letters, numbers, and hyphens only</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Display Name</label>
            <input type="text" id="new-template-label" name="template_label" placeholder="e.g., My Custom Box" class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#01534d]" required />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Copy Settings From</label>
            <div class="space-y-2 max-h-48 overflow-y-auto">
              <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                <input type="radio" name="copy_from" value="teal-yellow" checked class="text-[#01534d] focus:ring-[#01534d]" />
                <span class="font-medium text-gray-800">Teal Yellow</span>
              </label>
              <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                <input type="radio" name="copy_from" value="dark-teal" class="text-[#01534d] focus:ring-[#01534d]" />
                <span class="font-medium text-gray-800">Dark Teal</span>
              </label>
              <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                <input type="radio" name="copy_from" value="white" class="text-[#01534d] focus:ring-[#01534d]" />
                <span class="font-medium text-gray-800">White / Light</span>
              </label>
              <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                <input type="radio" name="copy_from" value="list-style" class="text-[#01534d] focus:ring-[#01534d]" />
                <span class="font-medium text-gray-800">List Style</span>
              </label>
            </div>
          </div>
        </form>
      </div>
      <div class="p-4 border-t border-gray-200 flex justify-end gap-3">
        <button onclick="closeCreateTemplateModal()" class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">Cancel</button>
        <button onclick="createNewTemplate()" class="px-4 py-2 bg-[#01534d] text-white rounded-lg text-sm font-medium hover:bg-[#013d39]">Create Template</button>
      </div>
    </div>
  </div>

  <!-- Rename Template Modal -->
  <div id="rename-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl max-w-sm w-full">
      <div class="p-4 border-b border-gray-200">
        <h3 class="font-bold text-lg">Rename Template</h3>
      </div>
      <div class="p-6">
        <label class="block text-sm font-medium text-gray-700 mb-2">Display Name</label>
        <input type="text" id="rename-input" class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#01534d]" />
        <input type="hidden" id="rename-key" />
        <p class="text-xs text-gray-400 mt-2">This changes the name shown in dropdowns and admin panels. The template key remains the same.</p>
      </div>
      <div class="p-4 border-t border-gray-200 flex justify-end gap-3">
        <button onclick="closeRenameModal()" class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">Cancel</button>
        <button onclick="saveTemplateName()" class="px-4 py-2 bg-[#01534d] text-white rounded-lg text-sm font-medium hover:bg-[#013d39]">Save</button>
      </div>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  // ============================================================
  // TAB NAVIGATION
  // ============================================================
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const tab = this.dataset.tab;

      // Update active tab
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('active', 'border-[#01534d]', 'text-[#01534d]');
        b.classList.add('border-transparent', 'text-gray-500');
      });
      this.classList.add('active', 'border-[#01534d]', 'text-[#01534d]');
      this.classList.remove('border-transparent', 'text-gray-500');

      // Show/hide sections
      document.querySelectorAll('.template-section').forEach(section => {
        if (tab === 'all' || section.dataset.section === tab) {
          section.style.display = '';
        } else {
          section.style.display = 'none';
        }
      });
    });
  });

  // ============================================================
  // RENAME TEMPLATE
  // ============================================================
  function openRenameModal(key, currentLabel) {
    document.getElementById('rename-input').value = currentLabel;
    document.getElementById('rename-key').value = key;
    document.getElementById('rename-modal').classList.remove('hidden');
    document.getElementById('rename-input').focus();
    document.getElementById('rename-input').select();
  }

  function closeRenameModal() {
    document.getElementById('rename-modal').classList.add('hidden');
  }

  async function saveTemplateName() {
    const key = document.getElementById('rename-key').value;
    const newLabel = document.getElementById('rename-input').value.trim();
    if (!newLabel) {
      showToast('Name cannot be empty', 'error');
      return;
    }

    try {
      const res = await fetch('/api/settings/template-options', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ template_key: key, template_label: newLabel })
      });

      if (!res.ok) {
        const result = await res.json();
        throw new Error(result.error || 'Failed to rename');
      }

      showToast(`Renamed to "${newLabel}"`);
      closeRenameModal();
      setTimeout(() => window.location.reload(), 800);
    } catch (e) {
      showToast(e.message, 'error');
    }
  }

  // Click on template name or pencil icon to rename
  document.querySelectorAll('.template-name, .rename-btn').forEach(el => {
    el.addEventListener('click', function(e) {
      e.preventDefault();
      const key = this.dataset.templateKey;
      const nameEl = this.classList.contains('template-name') ? this : this.closest('.flex').querySelector('.template-name');
      const currentLabel = nameEl ? nameEl.textContent.trim() : '';
      openRenameModal(key, currentLabel);
    });
  });

  // Enter key to save rename
  document.getElementById('rename-input')?.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      e.preventDefault();
      saveTemplateName();
    }
  });

  window.openRenameModal = openRenameModal;
  window.closeRenameModal = closeRenameModal;
  window.saveTemplateName = saveTemplateName;

  // ============================================================
  // TOAST NOTIFICATION
  // ============================================================
  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.className = `fixed top-4 right-4 px-6 py-3 rounded-lg shadow-lg z-50 ${type === 'success' ? 'bg-green-500 text-white' : 'bg-red-500 text-white'}`;
    setTimeout(() => { toast.className = 'hidden'; }, 3000);
  }

  // ============================================================
  // SET DEFAULT BUTTONS
  // ============================================================
  document.querySelectorAll('[data-set-default]').forEach(btn => {
    btn.addEventListener('click', async function() {
      const templateType = this.dataset.templateType;
      const templateValue = this.dataset.templateValue;

      try {
        const data = {};
        data[templateType] = templateValue;

        const res = await fetch('/api/settings/templates', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (!res.ok) {
          const result = await res.json();
          throw new Error(result.error || 'Failed to save');
        }

        showToast(`Default updated!`);
        window.location.reload();
      } catch (e) {
        showToast(e.message, 'error');
      }
    });
  });

  // ============================================================
  // APPLY TO ALL CAMPAIGNS
  // ============================================================
  document.getElementById('resetAllCampaignsBtn')?.addEventListener('click', async function() {
    if (!confirm('This will clear all individual campaign template settings, making them use the site defaults. Continue?')) return;

    this.disabled = true;
    this.textContent = 'Applying...';

    try {
      const res = await fetch('/api/campaigns/clear-templates', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });

      if (!res.ok) {
        const result = await res.json();
        throw new Error(result.error || 'Failed to reset');
      }

      showToast('All campaigns now use site default templates!');
      setTimeout(() => window.location.reload(), 1000);
    } catch (e) {
      showToast(e.message, 'error');
      this.disabled = false;
      this.textContent = 'Apply Defaults to All Campaigns';
    }
  });

  // ============================================================
  // COLOR EDITOR FUNCTIONS (for donation box templates)
  // ============================================================
  const templateDefaultColors = {
    'teal-yellow': {
      bg_color: '#255764', text_color: '#ffffff', text_muted_color: 'rgba(255,255,255,0.7)',
      accent_color: '#fdc448', accent_text_color: '#61470e', border_color: 'rgba(255,255,255,0.3)',
      active_bg_color: 'rgba(253,196,72,0.2)', active_text_color: '#ffffff',
      inactive_btn_bg: 'transparent', toggle_active_color: 'rgba(255,255,255,0.2)',
    },
    'dark-teal': {
      bg_color: '#004139', text_color: '#ffffff', text_muted_color: '#d4c4a8',
      accent_color: '#c41e3a', accent_text_color: '#ffffff', border_color: '#108D70',
      active_bg_color: '#ECF0EE', active_text_color: '#004139',
      inactive_btn_bg: '#005A4C', toggle_active_color: '#108D70',
    },
    'white': {
      bg_color: '#ffffff', text_color: '#1f2937', text_muted_color: '#6b7280',
      accent_color: '#01534d', accent_text_color: '#ffffff', border_color: '#01534d',
      active_bg_color: '#01534d', active_text_color: '#ffffff',
      inactive_btn_bg: 'transparent', toggle_active_color: '#01534d',
    },
    'compact': {
      bg_color: '#1a4a55', text_color: '#ffffff', text_muted_color: 'rgba(255,255,255,0.7)',
      accent_color: '#fdc448', accent_text_color: '#61470e', border_color: 'rgba(255,255,255,0.3)',
      active_bg_color: 'rgba(253,196,72,0.2)', active_text_color: '#ffffff',
      inactive_btn_bg: 'transparent', toggle_active_color: 'rgba(255,255,255,0.2)',
    },
    'list-style': {
      bg_color: '#f5f5f5', text_color: '#374151', text_muted_color: '#6b7280',
      accent_color: '#D97706', accent_text_color: '#ffffff', border_color: '#e5e7eb',
      active_bg_color: '#D97706', active_text_color: '#ffffff',
      inactive_btn_bg: '#ffffff', toggle_active_color: '#D97706',
    },
    'urgent-appeal': {
      bg_color: '#ffffff', header_bg_color: '#c41e3a', text_color: '#1f2937',
      text_muted_color: '#6b7280', accent_color: '#c41e3a', accent_text_color: '#ffffff',
      border_color: '#e5e7eb', active_bg_color: '#c41e3a10', active_text_color: '#1f2937',
      inactive_btn_bg: '#ffffff', toggle_active_color: '#c41e3a',
    },
  };

  async function openColorEditor(templateName) {
    const modal = document.getElementById(`color-editor-${templateName}`);
    if (!modal) return;

    try {
      const res = await fetch(`/api/settings/template-colors?template=${templateName}`);
      const settings = await res.json();

      const form = document.getElementById(`color-form-${templateName}`);
      if (form && settings) {
        const colorFields = ['bg_color', 'header_bg_color', 'text_color', 'text_muted_color', 'accent_color', 'accent_text_color',
                       'border_color', 'active_bg_color', 'active_text_color', 'inactive_btn_bg', 'toggle_active_color'];

        colorFields.forEach(field => {
          const colorInput = form.querySelector(`[name="${field}"]`);
          const textInput = form.querySelector(`[name="${field}_text"]`);
          if (colorInput && settings[field]) {
            let colorValue = settings[field];
            if (colorValue.startsWith('rgba') || colorValue === 'transparent') {
              colorInput.value = '#000000';
            } else {
              colorInput.value = colorValue;
            }
            if (textInput) textInput.value = settings[field];
          }
        });

        const textFields = ['title_text', 'subtitle_text', 'button_text', 'single_text', 'monthly_text', 'custom_amount_placeholder'];
        textFields.forEach(field => {
          const input = form.querySelector(`[name="${field}"]`);
          if (input && settings[field]) input.value = settings[field];
        });

        const sizeFields = ['subtitle_size', 'title_size', 'button_size', 'amount_size'];
        sizeFields.forEach(field => {
          const select = form.querySelector(`[name="${field}"]`);
          if (select && settings[field]) select.value = settings[field];
        });

        updateColorPreview(templateName, settings);
        updateTextPreview(templateName, settings);
      }
    } catch (e) {
      console.error('Error fetching settings:', e);
    }

    modal.classList.remove('hidden');
    setupColorSync(templateName);
    setupTextSync(templateName);
    setupClickToEdit(templateName);
  }

  function closeColorEditor(templateName) {
    const modal = document.getElementById(`color-editor-${templateName}`);
    if (modal) modal.classList.add('hidden');
    closeColorPicker(templateName);
  }

  function closeColorPicker(templateName) {
    const popup = document.getElementById(`color-picker-popup-${templateName}`);
    if (popup) popup.classList.add('hidden');
  }

  function setupClickToEdit(templateName) {
    const modal = document.getElementById(`color-editor-${templateName}`);
    if (!modal) return;
    const clickableElements = modal.querySelectorAll('.clickable-color-element, .clickable-color-area');
    clickableElements.forEach(el => {
      el.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        const field = this.dataset.colorField;
        const label = this.dataset.colorLabel;
        const secondaryField = this.dataset.secondaryField;
        const secondaryLabel = this.dataset.secondaryLabel;
        if (field) showColorPicker(templateName, field, label, secondaryField, secondaryLabel, e);
      });
    });
  }

  function showColorPicker(templateName, field, label, secondaryField, secondaryLabel, event) {
    const popup = document.getElementById(`color-picker-popup-${templateName}`);
    const labelEl = document.getElementById(`color-picker-label-${templateName}`);
    const fieldsContainer = document.getElementById(`color-picker-fields-${templateName}`);
    const form = document.getElementById(`color-form-${templateName}`);
    if (!popup || !labelEl || !fieldsContainer || !form) return;

    labelEl.textContent = label;
    let fieldsHTML = '';

    const primaryTextInput = form.querySelector(`[name="${field}_text"]`);
    const primaryValue = primaryTextInput && primaryTextInput.value ? primaryTextInput.value : '#000000';

    fieldsHTML += `<div><label class="block text-sm font-medium text-gray-600 mb-1">${label}</label><div class="flex gap-2"><input type="color" id="popup-${field}-${templateName}" value="${primaryValue.startsWith('#') ? primaryValue : '#000000'}" class="w-12 h-10 rounded border cursor-pointer" /><input type="text" id="popup-${field}-text-${templateName}" value="${primaryValue}" class="flex-1 px-3 py-2 border border-gray-200 rounded-lg text-sm" /></div></div>`;

    if (secondaryField && secondaryLabel) {
      const secondaryTextInput = form.querySelector(`[name="${secondaryField}_text"]`);
      let secondaryValue = secondaryTextInput && secondaryTextInput.value ? secondaryTextInput.value : '#000000';
      fieldsHTML += `<div><label class="block text-sm font-medium text-gray-600 mb-1">${secondaryLabel}</label><div class="flex gap-2"><input type="color" id="popup-${secondaryField}-${templateName}" value="${secondaryValue.startsWith('#') ? secondaryValue : '#000000'}" class="w-12 h-10 rounded border cursor-pointer" /><input type="text" id="popup-${secondaryField}-text-${templateName}" value="${secondaryValue}" class="flex-1 px-3 py-2 border border-gray-200 rounded-lg text-sm" /></div></div>`;
    }

    const defaults = templateDefaultColors[templateName] || {};
    const primaryDefault = defaults[field] || '';
    const secondaryDefault = secondaryField ? (defaults[secondaryField] || '') : '';

    fieldsHTML += `<div class="flex gap-2 mt-2"><button type="button" onclick="applyColorFromPicker('${templateName}', '${field}', '${secondaryField || ''}')" class="flex-1 px-4 py-2 bg-[#01534d] text-white rounded-lg text-sm font-medium hover:bg-[#013d39]">Apply</button><button type="button" onclick="resetColorToDefault('${templateName}', '${field}', '${primaryDefault}', '${secondaryField || ''}', '${secondaryDefault}')" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 border border-gray-200" title="Reset"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg></button></div>`;

    fieldsContainer.innerHTML = fieldsHTML;

    const popupColorInput = document.getElementById(`popup-${field}-${templateName}`);
    const popupTextInput = document.getElementById(`popup-${field}-text-${templateName}`);
    if (popupColorInput && popupTextInput) {
      popupColorInput.addEventListener('input', function() { popupTextInput.value = this.value; });
      popupTextInput.addEventListener('input', function() { if (/^#[0-9A-Fa-f]{6}$/.test(this.value)) popupColorInput.value = this.value; });
    }

    if (secondaryField) {
      const secColorInput = document.getElementById(`popup-${secondaryField}-${templateName}`);
      const secTextInput = document.getElementById(`popup-${secondaryField}-text-${templateName}`);
      if (secColorInput && secTextInput) {
        secColorInput.addEventListener('input', function() { secTextInput.value = this.value; });
        secTextInput.addEventListener('input', function() { if (/^#[0-9A-Fa-f]{6}$/.test(this.value)) secColorInput.value = this.value; });
      }
    }

    const rect = event.target.getBoundingClientRect();
    const modalRect = document.getElementById(`color-editor-${templateName}`).getBoundingClientRect();
    popup.style.top = (rect.bottom - modalRect.top + 10) + 'px';
    popup.style.left = Math.max(10, Math.min(rect.left - modalRect.left, modalRect.width - 300)) + 'px';
    popup.classList.remove('hidden');
    highlightField(templateName, field);
  }

  function applyColorFromPicker(templateName, field, secondaryField) {
    const form = document.getElementById(`color-form-${templateName}`);
    const popupTextInput = document.getElementById(`popup-${field}-text-${templateName}`);
    if (popupTextInput && form) {
      const formColorInput = form.querySelector(`[name="${field}"]`);
      const formTextInput = form.querySelector(`[name="${field}_text"]`);
      if (formColorInput && formTextInput) {
        formTextInput.value = popupTextInput.value;
        if (/^#[0-9A-Fa-f]{6}$/.test(popupTextInput.value)) formColorInput.value = popupTextInput.value;
      }
    }
    if (secondaryField) {
      const secPopupTextInput = document.getElementById(`popup-${secondaryField}-text-${templateName}`);
      if (secPopupTextInput && form) {
        const secFormColorInput = form.querySelector(`[name="${secondaryField}"]`);
        const secFormTextInput = form.querySelector(`[name="${secondaryField}_text"]`);
        if (secFormColorInput && secFormTextInput) {
          secFormTextInput.value = secPopupTextInput.value;
          if (/^#[0-9A-Fa-f]{6}$/.test(secPopupTextInput.value)) secFormColorInput.value = secPopupTextInput.value;
        }
      }
    }
    updateLivePreview(templateName, form);
    checkColorContrast(templateName, form);
    closeColorPicker(templateName);
  }

  function resetColorToDefault(templateName, field, defaultValue, secondaryField, secondaryDefault) {
    const popupColorInput = document.getElementById(`popup-${field}-${templateName}`);
    const popupTextInput = document.getElementById(`popup-${field}-text-${templateName}`);
    if (popupColorInput && popupTextInput && defaultValue) {
      popupTextInput.value = defaultValue;
      if (/^#[0-9A-Fa-f]{6}$/.test(defaultValue)) popupColorInput.value = defaultValue;
    }
    if (secondaryField && secondaryDefault) {
      const secPopupColorInput = document.getElementById(`popup-${secondaryField}-${templateName}`);
      const secPopupTextInput = document.getElementById(`popup-${secondaryField}-text-${templateName}`);
      if (secPopupColorInput && secPopupTextInput) {
        secPopupTextInput.value = secondaryDefault;
        if (/^#[0-9A-Fa-f]{6}$/.test(secondaryDefault)) secPopupColorInput.value = secondaryDefault;
      }
    }
    applyColorFromPicker(templateName, field, secondaryField);
  }

  function checkColorContrast(templateName, form) {
    const bgColor = form.querySelector('[name="bg_color_text"]')?.value || '#255764';
    const textColor = form.querySelector('[name="text_color_text"]')?.value || '#ffffff';
    const getBrightness = (color) => {
      if (color.startsWith('#')) {
        const hex = color.slice(1);
        return (parseInt(hex.substr(0,2),16)*299 + parseInt(hex.substr(2,2),16)*587 + parseInt(hex.substr(4,2),16)*114) / 1000;
      }
      if (color.includes('rgb')) {
        const m = color.match(/\d+/g);
        if (m && m.length >= 3) return (parseInt(m[0])*299 + parseInt(m[1])*587 + parseInt(m[2])*114) / 1000;
      }
      return 128;
    };
    const contrast = Math.abs(getBrightness(bgColor) - getBrightness(textColor));
    const warningEl = document.getElementById(`contrast-warning-${templateName}`);
    if (contrast < 80) {
      if (!warningEl) {
        const preview = document.getElementById(`preview-${templateName}`);
        if (preview) {
          const warning = document.createElement('div');
          warning.id = `contrast-warning-${templateName}`;
          warning.className = 'absolute top-2 left-2 right-2 bg-yellow-100 border border-yellow-400 text-yellow-800 text-xs px-3 py-2 rounded-lg z-20';
          warning.innerHTML = '<strong>Low contrast!</strong> Text may be hard to see.';
          preview.style.position = 'relative';
          preview.insertBefore(warning, preview.firstChild);
        }
      }
    } else if (warningEl) {
      warningEl.remove();
    }
  }

  function highlightField(templateName, field) {
    const allFields = document.querySelectorAll(`#color-form-${templateName} .color-field-group`);
    allFields.forEach(f => f.classList.remove('highlight'));
    const targetField = document.getElementById(`field-${field}-${templateName}`);
    if (targetField) {
      targetField.classList.add('highlight');
      const details = targetField.closest('details');
      if (details) details.open = true;
      setTimeout(() => targetField.classList.remove('highlight'), 2000);
    }
  }

  function setupColorSync(templateName) {
    const form = document.getElementById(`color-form-${templateName}`);
    if (!form) return;
    const fields = ['bg_color', 'text_color', 'text_muted_color', 'accent_color', 'accent_text_color',
                   'border_color', 'active_bg_color', 'active_text_color', 'inactive_btn_bg', 'toggle_active_color'];
    fields.forEach(field => {
      const colorInput = form.querySelector(`[name="${field}"]`);
      const textInput = form.querySelector(`[name="${field}_text"]`);
      if (colorInput && textInput) {
        colorInput.addEventListener('input', function() {
          textInput.value = this.value;
          updateLivePreview(templateName, form);
          if (field === 'bg_color' || field === 'text_color') checkColorContrast(templateName, form);
        });
        textInput.addEventListener('input', function() {
          if (/^#[0-9A-Fa-f]{6}$/.test(this.value.trim())) colorInput.value = this.value.trim();
          updateLivePreview(templateName, form);
          if (field === 'bg_color' || field === 'text_color') checkColorContrast(templateName, form);
        });
      }
    });
  }

  function updateLivePreview(templateName, form) {
    const preview = document.getElementById(`preview-${templateName}`);
    if (!preview) return;
    const getVal = (name) => { const t = form.querySelector(`[name="${name}_text"]`); return t ? t.value : ''; };
    preview.style.backgroundColor = getVal('bg_color') || '#255764';
    const title = preview.querySelector('.preview-title');
    if (title) title.style.color = getVal('text_color') || '#ffffff';
    const subtitle = preview.querySelector('.preview-subtitle');
    if (subtitle) subtitle.style.color = getVal('text_muted_color') || 'rgba(255,255,255,0.7)';
    const toggle = preview.querySelector('.preview-toggle');
    if (toggle) {
      const activeToggle = toggle.querySelector('.preview-toggle-active');
      if (activeToggle) { activeToggle.style.backgroundColor = getVal('toggle_active_color') || 'rgba(255,255,255,0.2)'; activeToggle.style.color = getVal('text_color') || '#ffffff'; }
      const inactiveToggle = toggle.querySelector('.preview-toggle-inactive');
      if (inactiveToggle) inactiveToggle.style.color = getVal('text_muted_color') || 'rgba(255,255,255,0.7)';
    }
    const activeBtn = preview.querySelector('.preview-btn-active');
    if (activeBtn) { activeBtn.style.backgroundColor = getVal('active_bg_color'); activeBtn.style.borderColor = getVal('accent_color'); activeBtn.style.color = getVal('active_text_color'); }
    const inactiveBtns = preview.querySelectorAll('.preview-btn');
    inactiveBtns.forEach(btn => { btn.style.backgroundColor = getVal('inactive_btn_bg'); btn.style.borderColor = getVal('border_color'); btn.style.color = getVal('text_color'); });
    const customInput = preview.querySelector('.preview-custom-input');
    if (customInput) customInput.style.borderColor = getVal('border_color');
    const donateBtn = preview.querySelector('.preview-donate-btn');
    if (donateBtn) { donateBtn.style.backgroundColor = getVal('accent_color'); donateBtn.style.color = getVal('accent_text_color'); }
  }

  function updateColorPreview(templateName, colors) {
    const preview = document.getElementById(`preview-${templateName}`);
    if (!preview || !colors) return;
    preview.style.backgroundColor = colors.bg_color || '#255764';
    const header = preview.querySelector('.preview-header');
    if (header && colors.header_bg_color) header.style.background = `linear-gradient(135deg, ${colors.header_bg_color} 0%, ${colors.header_bg_color}dd 100%)`;
    const title = preview.querySelector('.preview-title');
    if (title) title.style.color = colors.text_color || '#ffffff';
    const subtitle = preview.querySelector('.preview-subtitle');
    if (subtitle) subtitle.style.color = colors.text_muted_color || 'rgba(255,255,255,0.7)';
    const isUA = templateName === 'urgent-appeal';
    const toggle = preview.querySelector('.preview-toggle');
    if (toggle) {
      const at = toggle.querySelector('.preview-toggle-active');
      if (at) { at.style.backgroundColor = isUA ? (colors.accent_color || '#c41e3a') : (colors.toggle_active_color || 'rgba(255,255,255,0.2)'); at.style.color = isUA ? (colors.accent_text_color || '#fff') : (colors.text_color || '#fff'); }
      const it = toggle.querySelector('.preview-toggle-inactive');
      if (it) it.style.color = colors.text_muted_color || 'rgba(255,255,255,0.7)';
    }
    const activeBtn = preview.querySelector('.preview-btn-active');
    if (activeBtn) { activeBtn.style.backgroundColor = colors.active_bg_color; activeBtn.style.borderColor = colors.accent_color; activeBtn.style.color = colors.active_text_color; }
    const inactiveBtns = preview.querySelectorAll('.preview-btn');
    inactiveBtns.forEach(btn => { btn.style.backgroundColor = colors.inactive_btn_bg; btn.style.borderColor = colors.border_color; btn.style.color = colors.text_color; });
    const donateBtn = preview.querySelector('.preview-donate-btn');
    if (donateBtn) { donateBtn.style.backgroundColor = colors.accent_color; donateBtn.style.color = colors.accent_text_color; }
    const customInput = preview.querySelector('.preview-custom-input');
    if (customInput) customInput.style.borderColor = colors.border_color;
  }

  function updateTextPreview(templateName, settings) {
    const preview = document.getElementById(`preview-${templateName}`);
    if (!preview || !settings) return;
    const fsm = { 'text-xs': '0.75rem', 'text-sm': '0.875rem', 'text-base': '1rem', 'text-lg': '1.125rem', 'text-xl': '1.25rem', 'text-2xl': '1.5rem' };
    const title = preview.querySelector('.preview-title');
    if (title) { if (settings.title_text) title.textContent = settings.title_text; if (settings.title_size) title.style.fontSize = fsm[settings.title_size] || '1.25rem'; }
    const subtitle = preview.querySelector('.preview-subtitle');
    if (subtitle) { if (settings.subtitle_text) subtitle.textContent = settings.subtitle_text; if (settings.subtitle_size) subtitle.style.fontSize = fsm[settings.subtitle_size] || '0.875rem'; }
    const donateBtn = preview.querySelector('.donate-btn-text');
    if (donateBtn && settings.button_text) donateBtn.textContent = settings.button_text;
    const donateBtnEl = preview.querySelector('.preview-donate-btn');
    if (donateBtnEl && settings.button_size) donateBtnEl.style.fontSize = fsm[settings.button_size] || '1.125rem';
    const toggleActive = preview.querySelector('.preview-toggle-active');
    if (toggleActive && settings.single_text) toggleActive.textContent = settings.single_text;
    const toggleInactive = preview.querySelector('.preview-toggle-inactive');
    if (toggleInactive && settings.monthly_text) toggleInactive.textContent = settings.monthly_text;
    const customInput = preview.querySelector('.preview-custom-input');
    if (customInput && settings.custom_amount_placeholder) customInput.placeholder = settings.custom_amount_placeholder;
  }

  function setupTextSync(templateName) {
    const form = document.getElementById(`color-form-${templateName}`);
    const preview = document.getElementById(`preview-${templateName}`);
    if (!form || !preview) return;
    const fsm = { 'text-xs': '0.75rem', 'text-sm': '0.875rem', 'text-base': '1rem', 'text-lg': '1.125rem', 'text-xl': '1.25rem', 'text-2xl': '1.5rem' };
    const bind = (sel, cb) => { const el = form.querySelector(sel); if (el) el.addEventListener('input', cb); };
    const bindChange = (sel, cb) => { const el = form.querySelector(sel); if (el) el.addEventListener('change', cb); };
    bind('[name="title_text"]', function() { const t = preview.querySelector('.preview-title'); if (t) t.textContent = this.value; });
    bindChange('[name="title_size"]', function() { const t = preview.querySelector('.preview-title'); if (t) t.style.fontSize = fsm[this.value] || '1.25rem'; });
    bind('[name="subtitle_text"]', function() { const s = preview.querySelector('.preview-subtitle'); if (s) s.textContent = this.value; });
    bindChange('[name="subtitle_size"]', function() { const s = preview.querySelector('.preview-subtitle'); if (s) s.style.fontSize = fsm[this.value] || '0.875rem'; });
    bind('[name="button_text"]', function() { const b = preview.querySelector('.donate-btn-text'); if (b) b.textContent = this.value; });
    bindChange('[name="button_size"]', function() { const b = preview.querySelector('.preview-donate-btn'); if (b) b.style.fontSize = fsm[this.value] || '1.125rem'; });
    bind('[name="single_text"]', function() { const t = preview.querySelector('.preview-toggle-active'); if (t) t.textContent = this.value; });
    bind('[name="monthly_text"]', function() { const t = preview.querySelector('.preview-toggle-inactive'); if (t) t.textContent = this.value; });
    bind('[name="custom_amount_placeholder"]', function() { const c = preview.querySelector('.preview-custom-input'); if (c) c.placeholder = this.value; });
  }

  async function saveTemplateColors(templateName) {
    const form = document.getElementById(`color-form-${templateName}`);
    if (!form) return;
    const gcv = (n) => { const t = form.querySelector(`[name="${n}_text"]`); return t ? t.value.trim() : ''; };
    const gtv = (n) => { const i = form.querySelector(`[name="${n}"]`); return i ? i.value.trim() : ''; };
    const data = {
      template_name: templateName,
      bg_color: gcv('bg_color'), text_color: gcv('text_color'), text_muted_color: gcv('text_muted_color'),
      accent_color: gcv('accent_color'), accent_text_color: gcv('accent_text_color'), border_color: gcv('border_color'),
      active_bg_color: gcv('active_bg_color'), active_text_color: gcv('active_text_color'),
      inactive_btn_bg: gcv('inactive_btn_bg'), toggle_active_color: gcv('toggle_active_color'),
      title_text: gtv('title_text'), subtitle_text: gtv('subtitle_text'), button_text: gtv('button_text'),
      single_text: gtv('single_text'), monthly_text: gtv('monthly_text'), custom_amount_placeholder: gtv('custom_amount_placeholder'),
      subtitle_size: gtv('subtitle_size'), title_size: gtv('title_size'), button_size: gtv('button_size'), amount_size: gtv('amount_size'),
      trust_message_text: gtv('trust_message_text'), trust_link_text: gtv('trust_link_text'), trust_link_url: gtv('trust_link_url'),
    };
    const defaultAmounts = [];
    for (let i = 1; i <= 6; i++) {
      const ai = form.querySelector(`[name="amount_${i}"]`);
      const li = form.querySelector(`[name="label_${i}"]`);
      if (ai && ai.value) defaultAmounts.push({ amount: parseFloat(ai.value), label: li ? li.value : '' });
    }
    if (defaultAmounts.length > 0) data.default_amounts = defaultAmounts;
    try {
      const res = await fetch('/api/settings/template-colors', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (!res.ok) { const r = await res.json(); throw new Error(r.error || 'Failed to save'); }
      showToast('Settings saved successfully!');
      closeColorEditor(templateName);
      setTimeout(() => window.location.reload(), 1000);
    } catch (e) { showToast(e.message, 'error'); }
  }

  function resetAllColors(templateName) {
    if (!confirm('Reset all colors to defaults? You still need to save to apply.')) return;
    const defaults = templateDefaultColors[templateName];
    if (!defaults) { showToast('No defaults found', 'error'); return; }
    const form = document.getElementById(`color-form-${templateName}`);
    if (!form) return;
    Object.keys(defaults).forEach(field => {
      const ci = form.querySelector(`[name="${field}"]`);
      const ti = form.querySelector(`[name="${field}_text"]`);
      if (ti) ti.value = defaults[field];
      if (ci && /^#[0-9A-Fa-f]{6}$/.test(defaults[field])) ci.value = defaults[field];
    });
    updateLivePreview(templateName, form);
    showToast('Colors reset. Click Save to apply.', 'success');
  }

  function updateFontSize(templateName, element, value) {
    const preview = document.getElementById(`preview-${templateName}`);
    if (!preview) return;
    const fsm = { 'text-xs': '0.75rem', 'text-sm': '0.875rem', 'text-base': '1rem', 'text-lg': '1.125rem', 'text-xl': '1.25rem', 'text-2xl': '1.5rem' };
    const fs = fsm[value] || '1rem';
    if (element === 'title') { const t = preview.querySelector('.preview-title'); if (t) t.style.fontSize = fs; }
    else if (element === 'subtitle') { const s = preview.querySelector('.preview-subtitle'); if (s) s.style.fontSize = fs; }
    else if (element === 'button') { const b = preview.querySelector('.preview-donate-btn'); if (b) b.style.fontSize = fs; }
    else if (element === 'amount') { preview.querySelectorAll('.preview-btn span, .preview-btn-active span').forEach(s => s.style.fontSize = fs); }
  }

  // Create/Duplicate Template Functions
  function openCreateTemplateModal(copyFrom = '', copyLabel = '') {
    const modal = document.getElementById('create-template-modal');
    if (!modal) return;
    document.getElementById('create-template-form').reset();
    const titleEl = document.getElementById('create-modal-title');
    const nameInput = document.getElementById('new-template-name');
    const labelInput = document.getElementById('new-template-label');
    if (copyFrom && copyLabel) {
      titleEl.textContent = `Duplicate "${copyLabel}" Template`;
      nameInput.value = copyFrom + '-copy';
      labelInput.value = copyLabel + ' Copy';
      const radio = document.querySelector(`input[name="copy_from"][value="${copyFrom}"]`);
      if (radio) radio.checked = true;
    } else {
      titleEl.textContent = 'Create New Template';
    }
    modal.classList.remove('hidden');
  }

  function closeCreateTemplateModal() {
    document.getElementById('create-template-modal')?.classList.add('hidden');
  }

  function duplicateTemplate(templateName, templateLabel) {
    openCreateTemplateModal(templateName, templateLabel);
  }

  async function createNewTemplate() {
    const nameInput = document.getElementById('new-template-name');
    const labelInput = document.getElementById('new-template-label');
    const copyFromInput = document.querySelector('input[name="copy_from"]:checked');
    const templateName = nameInput.value.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    const templateLabel = labelInput.value.trim();
    const copyFrom = copyFromInput ? copyFromInput.value : '';
    if (!templateName || !templateLabel) { showToast('Please fill in all fields', 'error'); return; }
    if (!/^[a-z0-9-]+$/.test(templateName)) { showToast('Only lowercase letters, numbers, and hyphens allowed', 'error'); return; }
    try {
      let templateData = { template_name: templateName, template_label: templateLabel };
      if (copyFrom) {
        const res = await fetch(`/api/settings/template-colors?template=${copyFrom}`);
        if (res.ok) {
          const src = await res.json();
          delete src.id; delete src.template_name; delete src.created_at; delete src.updated_at;
          templateData = { ...templateData, ...src };
        }
      }
      const res = await fetch('/api/settings/template-colors', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ template_name: templateName, ...templateData }) });
      if (!res.ok) { const r = await res.json(); throw new Error(r.error || 'Failed to create'); }
      showToast(`Template "${templateLabel}" created!`);
      closeCreateTemplateModal();
      setTimeout(() => window.location.reload(), 1000);
    } catch (e) { showToast(e.message, 'error'); }
  }

  async function deleteTemplate(templateName, templateLabel) {
    if (!confirm(`Delete "${templateLabel}"? This cannot be undone.`)) return;
    try {
      const res = await fetch(`/api/settings/template-colors?template=${templateName}`, { method: 'DELETE' });
      if (!res.ok) { const r = await res.json(); throw new Error(r.error || 'Failed to delete'); }
      showToast(`Deleted "${templateLabel}"`);
      setTimeout(() => window.location.reload(), 1000);
    } catch (e) { showToast(e.message, 'error'); }
  }

  // Expose all functions globally
  window.openColorEditor = openColorEditor;
  window.closeColorEditor = closeColorEditor;
  window.saveTemplateColors = saveTemplateColors;
  window.closeColorPicker = closeColorPicker;
  window.applyColorFromPicker = applyColorFromPicker;
  window.resetColorToDefault = resetColorToDefault;
  window.resetAllColors = resetAllColors;
  window.updateFontSize = updateFontSize;
  window.openCreateTemplateModal = openCreateTemplateModal;
  window.closeCreateTemplateModal = closeCreateTemplateModal;
  window.duplicateTemplate = duplicateTemplate;
  window.createNewTemplate = createNewTemplate;
  window.deleteTemplate = deleteTemplate;
</script>
