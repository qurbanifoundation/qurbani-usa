---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import SettingsTabs from '../../../components/admin/SettingsTabs.astro';
import { supabaseAdmin } from '../../../lib/supabase';

export const prerender = false;

// Fetch current upsells — handle both old array and new object format
let upsells: any[] = [];
let headingDesktop = 'Please support us further:';
let headingMobile = 'Please support us further:';

try {
  const { data, error } = await supabaseAdmin
    .from('site_settings')
    .select('checkout_upsells')
    .eq('id', 'main')
    .single();

  const raw = data?.checkout_upsells;
  if (Array.isArray(raw)) {
    // Old format: plain array
    upsells = raw;
  } else if (raw && Array.isArray(raw.items)) {
    // New format: object with items + headings
    upsells = raw.items;
    headingDesktop = raw.heading_desktop || headingDesktop;
    headingMobile = raw.heading_mobile || headingMobile;
  }
} catch (e) {
  console.error('Error fetching upsells:', e);
}

// Fallback defaults if empty
if (upsells.length === 0) {
  upsells = [
    { id: 'prophetic-qurbani', title: 'Prophetic Qurbani', description: 'Follow the Sunnah of the Prophet ﷺ', amount: 50, enabled: true, sort_order: 1, visibility: 'both' },
    { id: 'feed-family', title: 'Feed a Family', description: 'Provide meals for a family in need', amount: 25, enabled: true, sort_order: 2, visibility: 'both' },
  ];
}
---

<AdminLayout title="Checkout Upsells" currentPage="settings">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Settings</h1>
        <p class="text-sm text-gray-500 mt-1">Manage checkout upsell items</p>
      </div>
    </div>

    <SettingsTabs active="upsells" />

    <!-- Section Headings -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
      <h2 class="text-lg font-bold text-gray-900 mb-1">Upsell Section Headings</h2>
      <p class="text-sm text-gray-500 mb-4">Customize the heading text shown above upsell items on desktop vs mobile</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Desktop Heading</label>
          <input type="text" id="heading-desktop" value={headingDesktop}
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#01534d] focus:border-transparent" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Mobile Heading</label>
          <input type="text" id="heading-mobile" value={headingMobile}
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#01534d] focus:border-transparent" />
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-lg font-bold text-gray-900">Checkout Upsells</h2>
          <p class="text-sm text-gray-500 mt-0.5">Items shown in the upsell section during checkout</p>
        </div>
        <button type="button" id="add-upsell-btn" class="px-4 py-2 bg-[#01534d] text-white text-sm font-semibold rounded-lg hover:bg-[#013d39] transition flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          Add Upsell
        </button>
      </div>

      <div id="upsells-list" class="space-y-4">
        <!-- Rendered by JS -->
      </div>

      <div id="empty-state" class="hidden text-center py-8 text-gray-400">
        <p class="text-sm">No upsells configured. Click "Add Upsell" to create one.</p>
      </div>

      <div class="mt-6 pt-6 border-t border-gray-200 flex items-center justify-between">
        <p id="save-status" class="text-sm text-gray-400"></p>
        <button type="button" id="save-btn" class="px-6 py-2.5 bg-[#01534d] text-white font-semibold rounded-lg hover:bg-[#013d39] transition disabled:opacity-50 disabled:cursor-not-allowed">
          Save Changes
        </button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-6 right-6 bg-gray-900 text-white px-5 py-3 rounded-lg shadow-lg text-sm font-medium transform translate-y-20 opacity-0 transition-all duration-300 z-50"></div>

  <script define:vars={{ initialUpsells: upsells, initialHeadingDesktop: headingDesktop, initialHeadingMobile: headingMobile }}>
    let upsells = JSON.parse(JSON.stringify(initialUpsells));

    function generateId(title) {
      return title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || ('upsell-' + Date.now());
    }

    function renderUpsells() {
      const container = document.getElementById('upsells-list');
      const emptyState = document.getElementById('empty-state');

      if (upsells.length === 0) {
        container.innerHTML = '';
        emptyState.classList.remove('hidden');
        return;
      }

      emptyState.classList.add('hidden');

      container.innerHTML = upsells.map(function(u, i) {
        return `
          <div class="border border-gray-200 rounded-lg p-4 ${u.enabled ? 'bg-white' : 'bg-gray-50 opacity-75'}" data-index="${i}">
            <!-- Row 1: Title + Description -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
              <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Title</label>
                <input type="text" value="${u.title.replace(/"/g, '&quot;')}" data-field="title" data-index="${i}"
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#01534d] focus:border-transparent" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Description</label>
                <input type="text" value="${(u.description || '').replace(/"/g, '&quot;')}" data-field="description" data-index="${i}"
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#01534d] focus:border-transparent" />
              </div>
            </div>
            <!-- Row 2: Amount, Type, Show On, Order + Toggle/Delete -->
            <div class="grid grid-cols-2 md:grid-cols-5 gap-3 items-end">
              <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Amount ($)</label>
                <input type="number" value="${u.amount}" min="1" step="1" data-field="amount" data-index="${i}"
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#01534d] focus:border-transparent" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Type</label>
                <select data-field="type" data-index="${i}"
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#01534d] focus:border-transparent bg-white">
                  <option value="single" ${(u.type || 'single') === 'single' ? 'selected' : ''}>One-time</option>
                  <option value="monthly" ${u.type === 'monthly' ? 'selected' : ''}>Monthly</option>
                  <option value="weekly" ${u.type === 'weekly' ? 'selected' : ''}>Every Friday</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Show On</label>
                <select data-field="visibility" data-index="${i}"
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#01534d] focus:border-transparent bg-white">
                  <option value="both" ${(u.visibility || 'both') === 'both' ? 'selected' : ''}>Both</option>
                  <option value="mobile" ${u.visibility === 'mobile' ? 'selected' : ''}>Mobile Only</option>
                  <option value="desktop" ${u.visibility === 'desktop' ? 'selected' : ''}>Desktop Only</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Order</label>
                <input type="number" value="${u.sort_order || i + 1}" min="1" step="1" data-field="sort_order" data-index="${i}"
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#01534d] focus:border-transparent" />
              </div>
              <div class="flex items-center gap-3 justify-end md:justify-center pb-1">
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" ${u.enabled ? 'checked' : ''} data-field="enabled" data-index="${i}" class="sr-only peer" />
                  <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-[#01534d]/30 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#01534d]"></div>
                </label>
                <button type="button" data-remove="${i}" class="text-xs text-red-400 hover:text-red-600 font-medium transition">Delete</button>
              </div>
            </div>
            <!-- Stamp text row -->
            <div class="mt-3 pt-3 border-t border-gray-100 flex items-center gap-3">
              <label class="flex items-center gap-2 cursor-pointer flex-shrink-0">
                <input type="checkbox" ${u.show_stamp ? 'checked' : ''} data-field="show_stamp" data-index="${i}"
                  class="w-4 h-4 text-[#01534d] rounded focus:ring-[#01534d]" />
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Stamp Text</span>
              </label>
              <input type="text" value="${(u.stamp_text || 'Cancel anytime.').replace(/"/g, '&quot;')}" data-field="stamp_text" data-index="${i}"
                placeholder="e.g. Cancel anytime."
                class="flex-1 px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#01534d] focus:border-transparent ${u.show_stamp ? '' : 'opacity-40'}" />
            </div>
            <!-- Cart display name row -->
            <div class="mt-3 pt-3 border-t border-gray-100">
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Cart Display Name <span class="text-gray-400 normal-case font-normal">(optional — overrides title in cart)</span></label>
              <input type="text" value="${(u.cart_label || u.title || '').replace(/"/g, '&quot;')}" data-field="cart_label" data-index="${i}"
                placeholder="${(u.title || 'e.g. Friday Giving').replace(/"/g, '&quot;')}"
                class="w-full px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#01534d] focus:border-transparent" />
            </div>
          </div>
        `;
      }).join('');

      // Attach input listeners
      container.querySelectorAll('input[data-field]').forEach(function(input) {
        input.addEventListener('input', function() {
          const idx = parseInt(this.dataset.index);
          const field = this.dataset.field;
          if (field === 'enabled') {
            upsells[idx].enabled = this.checked;
            renderUpsells();
          } else if (field === 'amount' || field === 'sort_order') {
            upsells[idx][field] = parseFloat(this.value) || 0;
          } else {
            upsells[idx][field] = this.value;
            // Auto-update ID if title changes and it's a new item
            if (field === 'title') {
              upsells[idx].id = generateId(this.value);
            }
          }
        });

        // For checkboxes, use change event
        if (input.type === 'checkbox') {
          input.addEventListener('change', function() {
            const idx = parseInt(this.dataset.index);
            const field = this.dataset.field;
            if (field === 'show_stamp') {
              upsells[idx].show_stamp = this.checked;
            } else {
              upsells[idx].enabled = this.checked;
            }
            renderUpsells();
          });
        }
      });

      // Attach select listeners (type dropdown)
      container.querySelectorAll('select[data-field]').forEach(function(select) {
        select.addEventListener('change', function() {
          const idx = parseInt(this.dataset.index);
          upsells[idx][this.dataset.field] = this.value;
        });
      });

      // Attach delete listeners
      container.querySelectorAll('button[data-remove]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          const idx = parseInt(this.dataset.remove);
          if (confirm('Remove "' + upsells[idx].title + '"?')) {
            upsells.splice(idx, 1);
            renderUpsells();
          }
        });
      });
    }

    // Add new upsell
    document.getElementById('add-upsell-btn').addEventListener('click', function() {
      upsells.push({
        id: 'new-upsell-' + Date.now(),
        title: '',
        description: '',
        amount: 10,
        enabled: true,
        sort_order: upsells.length + 1,
        type: 'single',
        show_stamp: false,
        stamp_text: 'Cancel anytime.',
        visibility: 'both',
        cart_label: '',
      });
      renderUpsells();
      // Focus the new title input
      setTimeout(function() {
        const inputs = document.querySelectorAll('input[data-field="title"]');
        if (inputs.length) inputs[inputs.length - 1].focus();
      }, 50);
    });

    // Save
    document.getElementById('save-btn').addEventListener('click', async function() {
      const btn = this;
      const status = document.getElementById('save-status');
      btn.disabled = true;
      btn.textContent = 'Saving...';

      try {
        // Filter out upsells with no title
        const toSave = upsells.filter(function(u) { return u.title.trim().length > 0; });
        // Ensure IDs
        toSave.forEach(function(u) {
          if (!u.id || u.id.startsWith('new-upsell-')) {
            u.id = generateId(u.title);
          }
        });

        const config = {
          items: toSave,
          heading_desktop: document.getElementById('heading-desktop').value.trim() || 'Please support us further:',
          heading_mobile: document.getElementById('heading-mobile').value.trim() || 'Please support us further:',
        };

        const res = await fetch('/api/settings/upsells', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(config),
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Failed to save');
        }

        upsells = toSave;
        renderUpsells();
        showToast('Upsells saved successfully!');
      } catch (err) {
        showToast('Error: ' + err.message, true);
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Changes';
      }
    });

    function showToast(message, isError) {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.className = toast.className.replace('bg-gray-900', isError ? 'bg-red-600' : 'bg-gray-900').replace('bg-red-600', isError ? 'bg-red-600' : 'bg-gray-900');
      toast.style.transform = 'translateY(0)';
      toast.style.opacity = '1';
      setTimeout(function() {
        toast.style.transform = 'translateY(80px)';
        toast.style.opacity = '0';
      }, 3000);
    }

    // Initial render
    renderUpsells();
  </script>
</AdminLayout>
