---
import AdminLayout from '../../layouts/AdminLayout.astro';

export const prerender = false;

// Define landing pages — each maps to a file in src/pages/
const landingPages = [
  {
    slug: 'islamic-qurbani-relief',
    title: 'Islamic Qurbani Relief',
    url: '/islamic-qurbani-relief',
    keywords: ['islamic qurbani relief', 'donate qurbani online'],
    basePage: '/qurbani',
    status: 'active',
    description: 'Google Ads landing page optimized for "islamic qurbani relief" and "donate qurbani online" keywords.',
  },
  {
    slug: 'islamic-zakat-relief',
    title: 'Islamic Zakat Relief',
    url: '/islamic-zakat-relief',
    keywords: ['islamic zakat relief', 'pay zakat online', 'zakat donation online'],
    basePage: '/zakat',
    status: 'active',
    description: 'Google Ads landing page optimized for "islamic zakat relief" and "pay zakat online" keywords.',
  },
  {
    slug: 'zakat',
    title: 'Give Your Zakat',
    url: '/zakat',
    keywords: ['pay zakat online', 'zakat donation'],
    basePage: null,
    status: 'active',
    description: 'Main Zakat donation page with conversion-optimized hero and single-tab donation box.',
  },
  {
    slug: 'zakat-ul-fitr',
    title: 'Zakat al-Fitr (Fitrana)',
    url: '/zakat-ul-fitr',
    keywords: ['zakat al fitr', 'pay fitrana online'],
    basePage: null,
    status: 'active',
    description: 'Fitrana donation page with per-person calculator and countdown to Eid.',
  },
];
---

<AdminLayout title="Landing Pages" activeNav="landing-pages">
  <div class="mb-6">
    <p class="text-gray-500 text-sm">Google Ads landing pages optimized for specific keywords. Each page uses the same design as the base campaign page but with SEO-optimized hero text, meta tags, and conversion copy.</p>
  </div>

  <!-- Landing Pages Grid -->
  <div class="grid gap-5">
    {landingPages.map((page) => (
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="text-lg font-bold text-gray-800">{page.title}</h3>
              <span class={`px-2.5 py-0.5 rounded-full text-xs font-semibold ${
                page.status === 'active' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'
              }`}>
                {page.status}
              </span>
              {page.basePage && (
                <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-600">
                  Variant of {page.basePage}
                </span>
              )}
            </div>
            <p class="text-sm text-gray-500 mb-3">{page.description}</p>

            <!-- Keywords -->
            <div class="flex flex-wrap gap-2 mb-3">
              {page.keywords.map((kw) => (
                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-amber-50 border border-amber-200 rounded-full text-xs font-medium text-amber-800">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                  </svg>
                  {kw}
                </span>
              ))}
            </div>

            <!-- URL -->
            <div class="flex items-center gap-2 text-sm">
              <span class="text-gray-400">URL:</span>
              <a href={`https://www.qurbani.com${page.url}`} target="_blank" class="text-[#01534d] hover:underline font-mono text-xs">
                www.qurbani.com{page.url}
              </a>
              <button
                class="copy-url-btn text-gray-400 hover:text-gray-600 transition"
                data-url={`https://www.qurbani.com${page.url}`}
                title="Copy URL"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex items-center gap-2 flex-shrink-0">
            <a
              href={page.url}
              target="_blank"
              class="px-4 py-2 bg-[#01534d] text-white rounded-lg text-sm font-medium hover:bg-[#013d38] transition flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              Preview
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Tips Section -->
  <div class="mt-8 bg-amber-50 border border-amber-200 rounded-xl p-6">
    <h3 class="text-sm font-bold text-amber-800 mb-2 flex items-center gap-2">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
      </svg>
      Google Ads Quality Score Tips
    </h3>
    <ul class="text-sm text-amber-700 space-y-1.5">
      <li>&#8226; <strong>Landing Page Experience:</strong> Each page uses the target keyword naturally in the H1, meta title, meta description, and subheadline</li>
      <li>&#8226; <strong>Ad Relevance:</strong> Match your Google Ads headline to the landing page H1 for maximum relevance score</li>
      <li>&#8226; <strong>Expected CTR:</strong> Keep the conversion flow identical to the main page — only the hero text changes</li>
      <li>&#8226; <strong>URL Structure:</strong> Use the landing page URL as the final URL in your Google Ads (not the base campaign URL)</li>
      <li>&#8226; <strong>Ad Copy Tip:</strong> Include keywords in Ad Headline 1 and Description 1 that match the landing page H1</li>
    </ul>
  </div>

  <script>
    document.querySelectorAll('.copy-url-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const url = (btn as HTMLElement).dataset.url || '';
        navigator.clipboard.writeText(url).then(() => {
          const svg = btn.querySelector('svg');
          if (svg) {
            svg.style.color = '#16a34a';
            setTimeout(() => { svg.style.color = ''; }, 1500);
          }
        });
      });
    });
  </script>
</AdminLayout>
