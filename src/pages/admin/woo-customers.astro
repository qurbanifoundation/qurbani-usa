---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

export const prerender = false;

// Get query params
const url = new URL(Astro.request.url);
const search = url.searchParams.get('search') || '';
const categoryFilter = url.searchParams.get('category') || 'all';
const tierFilter = url.searchParams.get('tier') || 'all';
const tab = url.searchParams.get('tab') || 'customers';
const customerId = url.searchParams.get('customer') || '';
const page = parseInt(url.searchParams.get('page') || '1');
const perPage = 25;

// ─── Stats ───
const { data: allCustomers } = await supabaseAdmin
  .from('woo_customers')
  .select('total_donated, order_count, donor_tier, ghl_synced');

const stats = {
  total: allCustomers?.length || 0,
  totalRevenue: allCustomers?.reduce((sum, c) => sum + (parseFloat(c.total_donated) || 0), 0) || 0,
  repeatDonors: allCustomers?.filter(c => c.order_count > 1).length || 0,
  ghlSynced: allCustomers?.filter(c => c.ghl_synced).length || 0,
  platinum: allCustomers?.filter(c => c.donor_tier === 'platinum').length || 0,
  gold: allCustomers?.filter(c => c.donor_tier === 'gold').length || 0,
  silver: allCustomers?.filter(c => c.donor_tier === 'silver').length || 0,
  bronze: allCustomers?.filter(c => c.donor_tier === 'bronze').length || 0,
};

// ─── Customer Detail View ───
let customerDetail: any = null;
let customerOrders: any[] = [];
if (customerId) {
  const { data: cust } = await supabaseAdmin
    .from('woo_customers')
    .select('*')
    .eq('id', customerId)
    .single();
  customerDetail = cust;

  if (customerDetail) {
    const { data: orders } = await supabaseAdmin
      .from('woo_orders')
      .select('*')
      .eq('email', customerDetail.email)
      .order('order_date', { ascending: false });
    customerOrders = orders || [];
  }
}

// ─── Customers List ───
let customers: any[] = [];
let customerCount = 0;

if (!customerId && tab === 'customers') {
  let query = supabaseAdmin
    .from('woo_customers')
    .select('*', { count: 'exact' })
    .order('total_donated', { ascending: false });

  if (search) {
    query = query.or(`email.ilike.%${search}%,first_name.ilike.%${search}%,last_name.ilike.%${search}%,phone.ilike.%${search}%`);
  }
  if (categoryFilter !== 'all') {
    query = query.contains('categories', [categoryFilter]);
  }
  if (tierFilter !== 'all') {
    query = query.eq('donor_tier', tierFilter);
  }

  const { data, count } = await query.range((page - 1) * perPage, page * perPage - 1);
  customers = data || [];
  customerCount = count || 0;
}

// ─── Orders List ───
let orders: any[] = [];
let orderCount = 0;

if (!customerId && tab === 'orders') {
  let query = supabaseAdmin
    .from('woo_orders')
    .select('*', { count: 'exact' })
    .order('order_date', { ascending: false });

  if (search) {
    query = query.or(`email.ilike.%${search}%,order_number.ilike.%${search}%`);
  }
  if (categoryFilter !== 'all') {
    query = query.contains('categories', [categoryFilter]);
  }

  const { data, count } = await query.range((page - 1) * perPage, page * perPage - 1);
  orders = data || [];
  orderCount = count || 0;
}

const totalPages = Math.ceil((tab === 'customers' ? customerCount : orderCount) / perPage);

// Helpers
function formatDate(dateStr: string) {
  if (!dateStr) return 'N/A';
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric',
    timeZone: 'America/New_York',
  });
}

function formatAmount(amount: number | string) {
  const num = typeof amount === 'string' ? parseFloat(amount) : amount;
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(num || 0);
}

function getStatusBadge(status: string) {
  const s = (status || '').toLowerCase();
  if (s.includes('completed') || s.includes('charged') || s === 'processing') return 'bg-green-100 text-green-800';
  if (s.includes('pending')) return 'bg-yellow-100 text-yellow-800';
  if (s.includes('failed') || s.includes('cancelled') || s.includes('declined') || s.includes('chargeback')) return 'bg-red-100 text-red-800';
  return 'bg-gray-100 text-gray-800';
}

function getTierBadge(tier: string) {
  switch (tier) {
    case 'platinum': return 'bg-purple-100 text-purple-800';
    case 'gold': return 'bg-yellow-100 text-yellow-800';
    case 'silver': return 'bg-gray-200 text-gray-700';
    default: return 'bg-orange-100 text-orange-700';
  }
}

function getCategoryBadge(cat: string) {
  const colors: Record<string, string> = {
    'qurbani': 'bg-green-100 text-green-700',
    'aqiqah': 'bg-blue-100 text-blue-700',
    'zakat': 'bg-teal-100 text-teal-700',
    'ramadan': 'bg-amber-100 text-amber-700',
    'orphan-sponsorship': 'bg-pink-100 text-pink-700',
    'education': 'bg-indigo-100 text-indigo-700',
    'emergency': 'bg-red-100 text-red-700',
    'palestine': 'bg-emerald-100 text-emerald-700',
    'water': 'bg-cyan-100 text-cyan-700',
    'healthcare': 'bg-violet-100 text-violet-700',
    'sadaqah': 'bg-lime-100 text-lime-700',
  };
  return colors[cat] || 'bg-gray-100 text-gray-600';
}

// Get unique customer name for orders tab by email lookup
const orderEmails = orders.map(o => o.email);
const uniqueEmails = [...new Set(orderEmails)];
let emailToCustomer: Record<string, { name: string; id: string }> = {};
if (uniqueEmails.length > 0) {
  const { data: custLookup } = await supabaseAdmin
    .from('woo_customers')
    .select('id, email, first_name, last_name')
    .in('email', uniqueEmails);
  if (custLookup) {
    for (const c of custLookup) {
      emailToCustomer[c.email] = {
        name: `${c.first_name || ''} ${c.last_name || ''}`.trim() || c.email,
        id: c.id,
      };
    }
  }
}
---

<AdminLayout title="WooCommerce Customers" activeNav="woo-customers">

  {/* ─── Customer Detail View ─── */}
  {customerDetail ? (
    <div>
      <a href="/admin/woo-customers" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        Back to all customers
      </a>

      <div class="bg-white rounded-lg shadow-sm border p-6 mb-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <h2 class="text-2xl font-bold text-gray-900">{customerDetail.first_name} {customerDetail.last_name}</h2>
            <p class="text-gray-500">{customerDetail.email}</p>
            {customerDetail.phone && <p class="text-gray-500">{customerDetail.phone}</p>}
            {customerDetail.address && (
              <p class="text-gray-400 text-sm mt-1">
                {customerDetail.address}, {customerDetail.city}, {customerDetail.state} {customerDetail.zip}
              </p>
            )}
          </div>
          <div class="flex flex-wrap gap-3">
            <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-2 text-center">
              <div class="text-2xl font-bold text-green-700">{formatAmount(customerDetail.total_donated)}</div>
              <div class="text-xs text-green-600">Lifetime Giving</div>
            </div>
            <div class="bg-blue-50 border border-blue-200 rounded-lg px-4 py-2 text-center">
              <div class="text-2xl font-bold text-blue-700">{customerDetail.order_count}</div>
              <div class="text-xs text-blue-600">Orders</div>
            </div>
            <div class="px-4 py-2 text-center">
              <span class={`inline-block px-3 py-1 rounded-full text-sm font-medium capitalize ${getTierBadge(customerDetail.donor_tier)}`}>
                {customerDetail.donor_tier}
              </span>
              <div class="text-xs text-gray-400 mt-1">Tier</div>
            </div>
          </div>
        </div>

        {/* Categories */}
        {customerDetail.categories && customerDetail.categories.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {customerDetail.categories.map((cat: string) => (
              <span class={`px-2 py-1 rounded-full text-xs font-medium ${getCategoryBadge(cat)}`}>{cat}</span>
            ))}
          </div>
        )}

        {/* Date info */}
        <div class="mt-4 flex gap-6 text-sm text-gray-500">
          <span>First order: <strong>{formatDate(customerDetail.first_order_date)}</strong></span>
          <span>Last order: <strong>{formatDate(customerDetail.last_order_date)}</strong></span>
          {customerDetail.ghl_synced && (
            <span class="text-green-600 flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              Synced to GHL
            </span>
          )}
        </div>
      </div>

      {/* Customer Orders */}
      <h3 class="text-lg font-semibold text-gray-800 mb-3">Orders ({customerOrders.length})</h3>
      <div class="bg-white rounded-lg shadow-sm border overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Order #</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Items</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {customerOrders.map(order => (
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-3 text-sm font-medium text-gray-900">#{order.order_number}</td>
                <td class="px-4 py-3 text-sm text-gray-600">{formatDate(order.order_date)}</td>
                <td class="px-4 py-3">
                  <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${getStatusBadge(order.status)}`}>
                    {order.status}
                  </span>
                </td>
                <td class="px-4 py-3 text-sm text-gray-600">
                  {(order.items as any[])?.map((item: any) => (
                    <div class="text-xs">{item.name} × {item.quantity}</div>
                  ))}
                </td>
                <td class="px-4 py-3 text-sm font-medium text-gray-900 text-right">{formatAmount(order.order_total)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

  ) : (
    /* ─── Main List View ─── */
    <div>
      {/* Stats Cards */}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <div class="text-2xl font-bold text-gray-900">{stats.total.toLocaleString()}</div>
          <div class="text-sm text-gray-500">Total Customers</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <div class="text-2xl font-bold text-green-600">{formatAmount(stats.totalRevenue)}</div>
          <div class="text-sm text-gray-500">Total Revenue</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <div class="text-2xl font-bold text-blue-600">{stats.repeatDonors}</div>
          <div class="text-sm text-gray-500">Repeat Donors</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <div class="text-2xl font-bold text-purple-600">{stats.ghlSynced}</div>
          <div class="text-sm text-gray-500">Synced to GHL</div>
        </div>
      </div>

      {/* Tier Breakdown */}
      <div class="flex gap-3 mb-6">
        <span class="px-3 py-1 bg-purple-100 text-purple-800 rounded-full text-xs font-medium">Platinum: {stats.platinum}</span>
        <span class="px-3 py-1 bg-yellow-100 text-yellow-800 rounded-full text-xs font-medium">Gold: {stats.gold}</span>
        <span class="px-3 py-1 bg-gray-200 text-gray-700 rounded-full text-xs font-medium">Silver: {stats.silver}</span>
        <span class="px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-xs font-medium">Bronze: {stats.bronze}</span>
      </div>

      {/* Tabs */}
      <div class="flex gap-1 mb-4 border-b">
        <a href={`/admin/woo-customers?tab=customers${search ? '&search=' + search : ''}${categoryFilter !== 'all' ? '&category=' + categoryFilter : ''}`}
           class={`px-4 py-2 text-sm font-medium border-b-2 -mb-px ${tab === 'customers' ? 'border-[#d97706] text-[#d97706]' : 'border-transparent text-gray-500 hover:text-gray-700'}`}>
          Customers ({customerCount || stats.total})
        </a>
        <a href={`/admin/woo-customers?tab=orders${search ? '&search=' + search : ''}${categoryFilter !== 'all' ? '&category=' + categoryFilter : ''}`}
           class={`px-4 py-2 text-sm font-medium border-b-2 -mb-px ${tab === 'orders' ? 'border-[#d97706] text-[#d97706]' : 'border-transparent text-gray-500 hover:text-gray-700'}`}>
          Orders ({orderCount || '...'})
        </a>
      </div>

      {/* Search & Filters */}
      <form method="GET" class="flex flex-col sm:flex-row gap-3 mb-4">
        <input type="hidden" name="tab" value={tab} />
        <input type="text" name="search" value={search} placeholder="Search by name, email, phone..."
               class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-[#d97706] focus:border-[#d97706]" />
        <select name="category" class="px-3 py-2 border border-gray-300 rounded-lg text-sm">
          <option value="all">All Categories</option>
          <option value="qurbani" selected={categoryFilter === 'qurbani'}>Qurbani</option>
          <option value="aqiqah" selected={categoryFilter === 'aqiqah'}>Aqiqah</option>
          <option value="zakat" selected={categoryFilter === 'zakat'}>Zakat</option>
          <option value="ramadan" selected={categoryFilter === 'ramadan'}>Ramadan</option>
          <option value="orphan-sponsorship" selected={categoryFilter === 'orphan-sponsorship'}>Orphan Sponsorship</option>
          <option value="emergency" selected={categoryFilter === 'emergency'}>Emergency</option>
          <option value="palestine" selected={categoryFilter === 'palestine'}>Palestine</option>
          <option value="education" selected={categoryFilter === 'education'}>Education</option>
          <option value="water" selected={categoryFilter === 'water'}>Water</option>
          <option value="general" selected={categoryFilter === 'general'}>General</option>
        </select>
        {tab === 'customers' && (
          <select name="tier" class="px-3 py-2 border border-gray-300 rounded-lg text-sm">
            <option value="all">All Tiers</option>
            <option value="platinum" selected={tierFilter === 'platinum'}>Platinum ($5K+)</option>
            <option value="gold" selected={tierFilter === 'gold'}>Gold ($1K+)</option>
            <option value="silver" selected={tierFilter === 'silver'}>Silver ($250+)</option>
            <option value="bronze" selected={tierFilter === 'bronze'}>Bronze</option>
          </select>
        )}
        <button type="submit" class="px-6 py-2 bg-[#d97706] text-white rounded-lg text-sm font-medium hover:bg-[#b45309]">
          Search
        </button>
        {(search || categoryFilter !== 'all' || tierFilter !== 'all') && (
          <a href={`/admin/woo-customers?tab=${tab}`} class="px-4 py-2 text-sm text-gray-500 hover:text-gray-700 self-center">
            Clear
          </a>
        )}
      </form>

      {/* ─── Customers Table ─── */}
      {tab === 'customers' && (
        <div class="bg-white rounded-lg shadow-sm border overflow-hidden">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Phone</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Categories</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Orders</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tier</th>
                  <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total Donated</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Order</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {customers.map(c => (
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3">
                      <a href={`/admin/woo-customers?customer=${c.id}`}
                         class="text-sm font-medium text-[#d97706] hover:text-[#b45309] hover:underline">
                        {c.first_name} {c.last_name}
                      </a>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-600">{c.email}</td>
                    <td class="px-4 py-3 text-sm text-gray-600">{c.phone || '—'}</td>
                    <td class="px-4 py-3">
                      <div class="flex flex-wrap gap-1">
                        {(c.categories || []).slice(0, 3).map((cat: string) => (
                          <span class={`px-1.5 py-0.5 rounded text-[10px] font-medium ${getCategoryBadge(cat)}`}>{cat}</span>
                        ))}
                        {(c.categories || []).length > 3 && (
                          <span class="text-[10px] text-gray-400">+{c.categories.length - 3}</span>
                        )}
                      </div>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-900 text-center font-medium">{c.order_count}</td>
                    <td class="px-4 py-3">
                      <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium capitalize ${getTierBadge(c.donor_tier)}`}>
                        {c.donor_tier}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-sm font-semibold text-gray-900 text-right">{formatAmount(c.total_donated)}</td>
                    <td class="px-4 py-3 text-sm text-gray-500">{formatDate(c.last_order_date)}</td>
                  </tr>
                ))}
                {customers.length === 0 && (
                  <tr><td colspan="8" class="px-4 py-8 text-center text-gray-400">No customers found</td></tr>
                )}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* ─── Orders Table ─── */}
      {tab === 'orders' && (
        <div class="bg-white rounded-lg shadow-sm border overflow-hidden">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Order #</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Items</th>
                  <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {orders.map(order => {
                  const cust = emailToCustomer[order.email];
                  return (
                    <tr class="hover:bg-gray-50">
                      <td class="px-4 py-3 text-sm font-medium text-gray-900">#{order.order_number}</td>
                      <td class="px-4 py-3">
                        {cust ? (
                          <a href={`/admin/woo-customers?customer=${cust.id}`}
                             class="text-sm font-medium text-[#d97706] hover:text-[#b45309] hover:underline">
                            {cust.name}
                          </a>
                        ) : (
                          <span class="text-sm text-gray-600">{order.email}</span>
                        )}
                      </td>
                      <td class="px-4 py-3 text-sm text-gray-600">{formatDate(order.order_date)}</td>
                      <td class="px-4 py-3">
                        <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${getStatusBadge(order.status)}`}>
                          {order.status}
                        </span>
                      </td>
                      <td class="px-4 py-3 text-sm text-gray-600 max-w-xs truncate">
                        {(order.items as any[])?.map((item: any) => item.name).join(', ')}
                      </td>
                      <td class="px-4 py-3 text-sm font-semibold text-gray-900 text-right">{formatAmount(order.order_total)}</td>
                    </tr>
                  );
                })}
                {orders.length === 0 && (
                  <tr><td colspan="6" class="px-4 py-8 text-center text-gray-400">No orders found</td></tr>
                )}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* Pagination */}
      {totalPages > 1 && (
        <div class="mt-4 flex items-center justify-between">
          <span class="text-sm text-gray-500">
            Page {page} of {totalPages} ({tab === 'customers' ? customerCount : orderCount} total)
          </span>
          <div class="flex gap-2">
            {page > 1 && (
              <a href={`/admin/woo-customers?tab=${tab}&page=${page - 1}${search ? '&search=' + search : ''}${categoryFilter !== 'all' ? '&category=' + categoryFilter : ''}${tierFilter !== 'all' ? '&tier=' + tierFilter : ''}`}
                 class="px-3 py-1 border rounded text-sm hover:bg-gray-50">
                ← Previous
              </a>
            )}
            {page < totalPages && (
              <a href={`/admin/woo-customers?tab=${tab}&page=${page + 1}${search ? '&search=' + search : ''}${categoryFilter !== 'all' ? '&category=' + categoryFilter : ''}${tierFilter !== 'all' ? '&tier=' + tierFilter : ''}`}
                 class="px-3 py-1 border rounded text-sm hover:bg-gray-50">
                Next →
              </a>
            )}
          </div>
        </div>
      )}
    </div>
  )}

</AdminLayout>
