---
/**
 * Feed Iftar Page
 * Hero with donation box on right, content on left
 * Conversion-optimized for older donors, $5/meal
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Feed Iftar - Qurbani Foundation USA" description="Provide iftar meals to fasting people in need. Just $5 provides a nutritious iftar meal. Earn immense rewards by feeding those who are fasting.">
  <Navbar />

  <!-- Scroll boundary for sticky donation box — box stops at the end of this wrapper -->
  <div id="donate-scroll-boundary" class="relative">

  <!-- Hero Section — Split Layout with Image Background -->
  <section class="relative pt-32 lg:pt-40 pb-12 lg:pb-20 min-h-[600px] lg:min-h-[750px]">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="/images/ramadan/ramadan-bg1.webp"
        alt="Iftar gathering"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#1a1a2e]/90 via-[#1a1a2e]/75 to-[#1a1a2e]/50"></div>
    </div>

    <div class="relative z-10 max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:max-w-[55%]">
        <div class="text-white pt-4 lg:pt-8">
          <!-- Breadcrumb -->
          <div class="flex items-center gap-2 text-white/50 text-sm mb-6">
            <a href="/" class="hover:text-white/80 transition">Home</a>
            <span>/</span>
            <a href="/ramadan" class="hover:text-white/80 transition">Ramadan 2026</a>
            <span>/</span>
            <span class="text-white/80">Feed Iftar</span>
          </div>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4 leading-tight" style="font-family: 'Signika', sans-serif;">
            Feed <span class="text-[#fdc448]">Iftar</span>
          </h1>

          <p class="text-lg md:text-xl text-white/85 mb-6 leading-relaxed max-w-lg" style="font-family: 'Lato', sans-serif;">
            Share the blessing of breaking fast with those in need. Just <strong class="text-[#fdc448]">$5</strong> provides a nutritious iftar meal.
          </p>

          <!-- Hadith Quote -->
          <div class="bg-white/10 backdrop-blur-sm border-l-4 border-[#fdc448] p-4 rounded-r-lg mb-8 max-w-lg">
            <p class="text-sm text-white/90 italic leading-relaxed">
              "Whoever feeds a fasting person will have a reward like that of the fasting person, without any reduction in his reward."
            </p>
            <p class="text-xs text-[#fdc448] mt-2 font-semibold">— Prophet Muhammad ﷺ, Tirmidhi</p>
          </div>

          <!-- Trust Badges -->
          <div class="flex flex-wrap gap-4 mb-6">
            <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full">
              <svg class="w-5 h-5 text-[#fdc448]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              <span class="text-sm text-white/90 font-medium">50,000+ Meals Served</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full">
              <svg class="w-5 h-5 text-[#fdc448]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              <span class="text-sm text-white/90 font-medium">15+ Countries</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full">
              <svg class="w-5 h-5 text-[#fdc448]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              <span class="text-sm text-white/90 font-medium">100% Donation Policy</span>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Fixed Donation Box — floats on right side on desktop, always visible -->
    <div id="fixed-donate-box" class="hidden lg:block fixed z-40 w-[470px]" style="top: 112px; right: max(2rem, calc((100vw - 1400px) / 2 + 16px));" data-mobile-donate>
      <div class="bg-white rounded-2xl shadow-2xl overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-[#ea580c] to-[#f97316] px-6 py-4 text-center">
          <h3 class="text-xl font-bold text-white mb-0.5" style="font-family: 'Signika', sans-serif;">
            🌙 Feed Iftar
          </h3>
          <p class="text-white/90 text-xs">$5 per meal · 100% goes to iftar</p>
        </div>

        <div class="p-5">
          <!-- Amount Selection -->
          <label class="block text-sm font-semibold text-gray-700 mb-2">Choose Your Impact</label>
          <div class="grid grid-cols-2 gap-2 mb-3">
            <button class="iftar-amount-btn group relative flex flex-col items-center p-2.5 border-2 border-gray-200 rounded-xl bg-white hover:border-[#ea580c] hover:bg-[#ea580c]/5 transition-all" data-amount="25" data-meals="5">
              <span class="text-lg font-bold text-gray-800 group-hover:text-[#ea580c]">$25</span>
              <span class="text-xs text-gray-500">5 meals</span>
            </button>
            <button class="iftar-amount-btn group relative flex flex-col items-center p-2.5 border-2 border-[#ea580c] rounded-xl bg-[#ea580c]/5 transition-all" data-amount="50" data-meals="10">
              <span class="text-lg font-bold text-[#ea580c]">$50</span>
              <span class="text-xs text-[#ea580c]/70">10 meals</span>
              <span class="absolute -top-2 -right-2 bg-[#ea580c] text-white text-[10px] font-bold px-2 py-0.5 rounded-full">Popular</span>
            </button>
            <button class="iftar-amount-btn group relative flex flex-col items-center p-2.5 border-2 border-gray-200 rounded-xl bg-white hover:border-[#ea580c] hover:bg-[#ea580c]/5 transition-all" data-amount="150" data-meals="30">
              <span class="text-lg font-bold text-gray-800 group-hover:text-[#ea580c]">$150</span>
              <span class="text-xs text-gray-500">1 person's Ramadan</span>
            </button>
            <button class="iftar-amount-btn group relative flex flex-col items-center p-2.5 border-2 border-gray-200 rounded-xl bg-white hover:border-[#ea580c] hover:bg-[#ea580c]/5 transition-all" data-amount="300" data-meals="60">
              <span class="text-lg font-bold text-gray-800 group-hover:text-[#ea580c]">$300</span>
              <span class="text-xs text-gray-500">2 people's Ramadan</span>
            </button>
          </div>

          <!-- Family Package -->
          <button class="iftar-amount-btn w-full flex items-center justify-between p-2.5 border-2 border-gray-200 rounded-xl bg-white hover:border-[#ea580c] hover:bg-[#ea580c]/5 transition-all mb-3" data-amount="750" data-meals="150">
            <div class="flex items-center gap-2">
              <span class="text-xl">👨‍👩‍👧‍👦</span>
              <div class="text-left">
                <span class="text-base font-bold text-gray-800">$750</span>
                <span class="text-xs text-gray-500 block">Feed a family of 5 for all of Ramadan</span>
              </div>
            </div>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </button>

          <!-- Meal Counter (+ / -) -->
          <div class="flex items-center justify-between bg-gray-50 rounded-xl p-3 mb-3 border border-gray-200">
            <span class="text-sm font-medium text-gray-700">Number of meals</span>
            <div class="flex items-center gap-0">
              <button id="iftar-minus" class="w-9 h-9 flex items-center justify-center rounded-l-lg bg-white border border-gray-300 hover:bg-gray-100 transition text-gray-600 font-bold text-xl leading-none">−</button>
              <span id="iftar-meal-count" class="w-12 h-9 flex items-center justify-center bg-white border-t border-b border-gray-300 text-base font-bold text-gray-800">10</span>
              <button id="iftar-plus" class="w-9 h-9 flex items-center justify-center rounded-r-lg bg-white border border-gray-300 hover:bg-gray-100 transition text-[#ea580c] font-bold text-xl leading-none">+</button>
            </div>
          </div>

          <!-- Description line -->
          <p class="text-sm text-gray-600 text-center mb-4" id="iftar-description">
            <span class="font-semibold text-[#ea580c]" id="iftar-meals-display">10</span> iftar meals for those in need — <span class="font-bold text-gray-800" id="iftar-total">$50</span>
          </p>

          <!-- Donate Button -->
          <button
            id="iftar-add-to-cart"
            class="w-full bg-gradient-to-r from-[#ea580c] to-[#c2410c] hover:from-[#c2410c] hover:to-[#9a3412] text-white font-bold py-3.5 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98] flex items-center justify-center gap-2 text-lg"
            style="font-family: 'Signika', sans-serif; box-shadow: 0 4px 20px rgba(234, 88, 12, 0.4);"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
            </svg>
            Donate Now
          </button>

          <!-- Trust Text -->
          <div class="flex items-center justify-center gap-2 mt-3">
            <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path></svg>
            <span class="text-xs text-gray-500">Secure · Tax-deductible · Instant receipt</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Wave divider -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-12 lg:h-16">
        <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- Mobile Donation Box (inline, visible only on mobile) -->
  <section class="lg:hidden py-8 bg-white" data-mobile-donate-inline>
    <div class="max-w-md mx-auto px-4">
      <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
        <!-- Header -->
        <div class="bg-gradient-to-r from-[#ea580c] to-[#f97316] px-6 py-4 text-center">
          <h3 class="text-xl font-bold text-white mb-0.5" style="font-family: 'Signika', sans-serif;">
            🌙 Feed Iftar
          </h3>
          <p class="text-white/90 text-xs">$5 per meal · 100% goes to iftar</p>
        </div>

        <div class="p-5">
          <!-- Amount Selection -->
          <label class="block text-sm font-semibold text-gray-700 mb-2">Choose Your Impact</label>
          <div class="grid grid-cols-2 gap-2 mb-3">
            <button class="iftar-amount-btn group relative flex flex-col items-center p-2.5 border-2 border-gray-200 rounded-xl bg-white hover:border-[#ea580c] hover:bg-[#ea580c]/5 transition-all" data-amount="25" data-meals="5">
              <span class="text-lg font-bold text-gray-800 group-hover:text-[#ea580c]">$25</span>
              <span class="text-xs text-gray-500">5 meals</span>
            </button>
            <button class="iftar-amount-btn group relative flex flex-col items-center p-2.5 border-2 border-[#ea580c] rounded-xl bg-[#ea580c]/5 transition-all" data-amount="50" data-meals="10">
              <span class="text-lg font-bold text-[#ea580c]">$50</span>
              <span class="text-xs text-[#ea580c]/70">10 meals</span>
              <span class="absolute -top-2 -right-2 bg-[#ea580c] text-white text-[10px] font-bold px-2 py-0.5 rounded-full">Popular</span>
            </button>
            <button class="iftar-amount-btn group relative flex flex-col items-center p-2.5 border-2 border-gray-200 rounded-xl bg-white hover:border-[#ea580c] hover:bg-[#ea580c]/5 transition-all" data-amount="150" data-meals="30">
              <span class="text-lg font-bold text-gray-800 group-hover:text-[#ea580c]">$150</span>
              <span class="text-xs text-gray-500">1 person's Ramadan</span>
            </button>
            <button class="iftar-amount-btn group relative flex flex-col items-center p-2.5 border-2 border-gray-200 rounded-xl bg-white hover:border-[#ea580c] hover:bg-[#ea580c]/5 transition-all" data-amount="300" data-meals="60">
              <span class="text-lg font-bold text-gray-800 group-hover:text-[#ea580c]">$300</span>
              <span class="text-xs text-gray-500">2 people's Ramadan</span>
            </button>
          </div>

          <!-- Family Package -->
          <button class="iftar-amount-btn w-full flex items-center justify-between p-2.5 border-2 border-gray-200 rounded-xl bg-white hover:border-[#ea580c] hover:bg-[#ea580c]/5 transition-all mb-3" data-amount="750" data-meals="150">
            <div class="flex items-center gap-2">
              <span class="text-xl">👨‍👩‍👧‍👦</span>
              <div class="text-left">
                <span class="text-base font-bold text-gray-800">$750</span>
                <span class="text-xs text-gray-500 block">Feed a family of 5 for all of Ramadan</span>
              </div>
            </div>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </button>

          <!-- Meal Counter (+ / -) -->
          <div class="flex items-center justify-between bg-gray-50 rounded-xl p-3 mb-3 border border-gray-200">
            <span class="text-sm font-medium text-gray-700">Number of meals</span>
            <div class="flex items-center gap-0">
              <button class="iftar-minus-btn w-9 h-9 flex items-center justify-center rounded-l-lg bg-white border border-gray-300 hover:bg-gray-100 transition text-gray-600 font-bold text-xl leading-none">−</button>
              <span class="iftar-meal-count-display w-12 h-9 flex items-center justify-center bg-white border-t border-b border-gray-300 text-base font-bold text-gray-800">10</span>
              <button class="iftar-plus-btn w-9 h-9 flex items-center justify-center rounded-r-lg bg-white border border-gray-300 hover:bg-gray-100 transition text-[#ea580c] font-bold text-xl leading-none">+</button>
            </div>
          </div>

          <!-- Description line -->
          <p class="text-sm text-gray-600 text-center mb-4">
            <span class="font-semibold text-[#ea580c] iftar-meals-text">10</span> iftar meals for those in need — <span class="font-bold text-gray-800 iftar-total-text">$50</span>
          </p>

          <!-- Donate Button -->
          <button
            class="iftar-donate-btn w-full bg-gradient-to-r from-[#ea580c] to-[#c2410c] hover:from-[#c2410c] hover:to-[#9a3412] text-white font-bold py-3.5 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98] flex items-center justify-center gap-2 text-lg"
            style="font-family: 'Signika', sans-serif; box-shadow: 0 4px 20px rgba(234, 88, 12, 0.4);"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
            </svg>
            Donate Now
          </button>

          <!-- Trust Text -->
          <div class="flex items-center justify-center gap-2 mt-3">
            <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path></svg>
            <span class="text-xs text-gray-500">Secure · Tax-deductible · Instant receipt</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 bg-white">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:max-w-[calc(100%-510px)]">
          <!-- The Reward of Feeding Iftar -->
          <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-6" style="font-family: 'Signika', sans-serif;">
            The Reward of Feeding <span class="text-[#ea580c]">Iftar</span>
          </h2>

          <p class="text-lg text-gray-700 leading-relaxed mb-6" style="font-family: 'Lato', sans-serif;">
            Iftar is the evening meal with which Muslims break their daily fast during Ramadan. Providing iftar to those who are fasting carries immense spiritual rewards and is one of the most beloved acts of charity during the blessed month.
          </p>

          <!-- Hadith Quote -->
          <div class="bg-[#fef3e2] border-l-4 border-[#ea580c] p-5 rounded-r-lg mb-6">
            <p class="text-gray-700 italic leading-relaxed" style="font-family: 'Lato', sans-serif;">
              "Whoever feeds a fasting person will have a reward like that of the fasting person, without any reduction in his reward."
            </p>
            <p class="text-[#ea580c] font-semibold mt-2 text-sm">— Prophet Muhammad (PBUH), Tirmidhi</p>
          </div>

          <p class="text-gray-700 leading-relaxed mb-10" style="font-family: 'Lato', sans-serif;">
            This hadith tells us that by providing iftar to someone who is fasting, you receive the same reward as their entire fast — without their reward being diminished at all. This is the beautiful multiplication of rewards that Allah provides during Ramadan.
          </p>

          <!-- What Does Your Donation Provide? -->
          <h2 class="text-2xl font-bold text-gray-800 mb-6" style="font-family: 'Signika', sans-serif;">
            What Does Your <span class="text-[#ea580c]">Donation</span> Provide?
          </h2>

          <ul class="space-y-4 mb-10" style="font-family: 'Lato', sans-serif;">
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-[#ea580c]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-[#ea580c]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <strong class="text-gray-800">Nutritious iftar meal</strong>
                <span class="text-gray-600"> including dates, water, and a balanced meal</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-[#ea580c]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-[#ea580c]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <strong class="text-gray-800">Community gatherings</strong>
                <span class="text-gray-600"> where people can break their fast together</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-[#ea580c]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-[#ea580c]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <strong class="text-gray-800">Support for orphans, widows, and refugees</strong>
                <span class="text-gray-600"> who struggle to provide for themselves</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-[#ea580c]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-[#ea580c]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <strong class="text-gray-800">Distribution in multiple countries</strong>
                <span class="text-gray-600"> where food insecurity is prevalent</span>
              </div>
            </li>
          </ul>

          <!-- Where Do We Distribute Iftar? -->
          <h2 class="text-2xl font-bold text-gray-800 mb-6" style="font-family: 'Signika', sans-serif;">
            Where Do We Distribute <span class="text-[#ea580c]">Iftar?</span>
          </h2>

          <p class="text-gray-700 leading-relaxed mb-6" style="font-family: 'Lato', sans-serif;">
            We distribute iftar meals across multiple countries including Pakistan, Bangladesh, Syria, Yemen, Somalia, and other regions where poverty and hunger are widespread. Our local partners ensure that meals reach the most vulnerable — orphans, widows, elderly, and displaced families.
          </p>

          <!-- Impact at a Glance -->
          <h2 class="text-2xl font-bold text-gray-800 mb-6" style="font-family: 'Signika', sans-serif;">
            Your <span class="text-[#ea580c]">Impact</span> at a Glance
          </h2>

          <div class="space-y-3 mb-10">
            <div class="flex items-center justify-between p-4 bg-[#ea580c]/5 rounded-xl border border-[#ea580c]/10">
              <span class="text-gray-700 font-medium">1 iftar meal</span>
              <span class="text-[#ea580c] font-bold text-lg">$5</span>
            </div>
            <div class="flex items-center justify-between p-4 bg-[#ea580c]/5 rounded-xl border border-[#ea580c]/10">
              <span class="text-gray-700 font-medium">5 iftar meals</span>
              <span class="text-[#ea580c] font-bold text-lg">$25</span>
            </div>
            <div class="flex items-center justify-between p-4 bg-[#ea580c]/5 rounded-xl border border-[#ea580c]/10">
