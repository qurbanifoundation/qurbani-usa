<script>
  document.addEventListener('DOMContentLoaded', () => {
    // All donation box elements (both desktop fixed + mobile inline share same classes)
    const amountButtons = document.querySelectorAll('.iftar-amount-btn');
    const totalDisplays = document.querySelectorAll('.iftar-total-text');
    const mealsDisplays = document.querySelectorAll('.iftar-meals-text');
    const mealCountDisplays = document.querySelectorAll('.iftar-meal-count-display');
    const donateButtons = document.querySelectorAll('.iftar-donate-btn');
    const minusButtons = document.querySelectorAll('.iftar-minus-btn');
    const plusButtons = document.querySelectorAll('.iftar-plus-btn');

    // Also grab by ID for the desktop fixed box
    const totalById = document.getElementById('iftar-total');
    const mealsById = document.getElementById('iftar-meals-display');
    const mealCountById = document.getElementById('iftar-meal-count');
    const addToCartById = document.getElementById('iftar-add-to-cart');
    const minusById = document.getElementById('iftar-minus');
    const plusById = document.getElementById('iftar-plus');

    const ctaDonateButtons = document.querySelectorAll('.iftar-cta-donate');
    const donationBox = document.querySelector('[data-mobile-donate]') || document.querySelector('[data-mobile-donate-inline]');

    const IFTAR_RATE = 5;
    let mealCount = 10;

    function updateDisplay() {
      const amount = mealCount * IFTAR_RATE;
      // Update all displays (desktop + mobile)
      if (totalById) totalById.textContent = `$${amount}`;
      if (mealsById) mealsById.textContent = mealCount.toString();
      if (mealCountById) mealCountById.textContent = mealCount.toString();
      totalDisplays.forEach(el => el.textContent = `$${amount}`);
      mealsDisplays.forEach(el => el.textContent = mealCount.toString());
      mealCountDisplays.forEach(el => el.textContent = mealCount.toString());
      // Disable minus at 1
      const allMinus = [minusById, ...Array.from(minusButtons)].filter(Boolean);
      allMinus.forEach(btn => {
        if (mealCount <= 1) {
          btn!.classList.add('opacity-40', 'cursor-not-allowed');
        } else {
          btn!.classList.remove('opacity-40', 'cursor-not-allowed');
        }
      });
    }

    function highlightButtons(targetAmount: number) {
      amountButtons.forEach(btn => {
        const btnAmount = parseInt(btn.getAttribute('data-amount') || '0');
        const spans = btn.querySelectorAll('span');

        btn.classList.remove('border-[#ea580c]', 'bg-[#ea580c]/5');
        btn.classList.add('border-gray-200');
        if (spans[0]) { spans[0].classList.remove('text-[#ea580c]'); spans[0].classList.add('text-gray-800'); }
        if (spans[1]) { spans[1].classList.remove('text-[#ea580c]/70'); spans[1].classList.add('text-gray-500'); }

        if (btnAmount === targetAmount) {
          btn.classList.add('border-[#ea580c]', 'bg-[#ea580c]/5');
          btn.classList.remove('border-gray-200');
          if (spans[0]) { spans[0].classList.add('text-[#ea580c]'); spans[0].classList.remove('text-gray-800'); }
          if (spans[1]) { spans[1].classList.add('text-[#ea580c]/70'); spans[1].classList.remove('text-gray-500'); }
        }
      });
    }

    function selectAmount(amount: number) {
      mealCount = Math.floor(amount / IFTAR_RATE);
      highlightButtons(amount);
      updateDisplay();
    }

    // Amount button clicks
    amountButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const amount = parseInt(btn.getAttribute('data-amount') || '50');
        selectAmount(amount);
      });
    });

    // Plus / Minus buttons (both desktop ID-based and mobile class-based)
    function handlePlus() {
      mealCount++;
      highlightButtons(mealCount * IFTAR_RATE);
      updateDisplay();
    }
    function handleMinus() {
      if (mealCount <= 1) return;
      mealCount--;
      highlightButtons(mealCount * IFTAR_RATE);
      updateDisplay();
    }

    plusById?.addEventListener('click', handlePlus);
    minusById?.addEventListener('click', handleMinus);
    plusButtons.forEach(btn => btn.addEventListener('click', handlePlus));
    minusButtons.forEach(btn => btn.addEventListener('click', handleMinus));

    // Add to cart
    function addIftarToCart() {
      if (mealCount < 1) return;
      const amount = mealCount * IFTAR_RATE;

      if (typeof (window as any).addToCart === 'function') {
        (window as any).addToCart({
          id: `iftar-${mealCount}-${Date.now()}`,
          type: 'donation',
          name: 'Feed Iftar',
          amount: amount,
          quantity: 1,
          description: `${mealCount} iftar meals x $${IFTAR_RATE}`,
          frequency: 'single'
        });
      }
    }

    addToCartById?.addEventListener('click', addIftarToCart);
    donateButtons.forEach(btn => btn.addEventListener('click', addIftarToCart));

    // CTA donate buttons (bottom section + sticky bar) — scroll to donation box
    ctaDonateButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        if (donationBox) {
          donationBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          addIftarToCart();
        }
      });
    });

    // Stop fixed donation box at end of content (before Impact Stats)
    // Stays fixed but slides up so its bottom never goes past the boundary
    const fixedDonateBox = document.getElementById('fixed-donate-box');
    const scrollBoundary = document.getElementById('donate-scroll-boundary');
    if (fixedDonateBox && scrollBoundary) {
      const FIXED_TOP = 112; // top-28 = 7rem = 112px

      function positionDonateBox() {
        const boundaryBottom = scrollBoundary!.getBoundingClientRect().bottom;
        const boxHeight = fixedDonateBox!.offsetHeight;
        const desiredBottom = FIXED_TOP + boxHeight;

        if (boundaryBottom < desiredBottom) {
          // Slide box up so its bottom stays at the boundary bottom
          fixedDonateBox!.style.top = `${boundaryBottom - boxHeight}px`;
        } else {
          fixedDonateBox!.style.top = `${FIXED_TOP}px`;
        }
      }

      window.addEventListener('scroll', positionDonateBox, { passive: true });
      window.addEventListener('resize', positionDonateBox, { passive: true });
      positionDonateBox();
    }

    // Initialize
    updateDisplay();
  });
</script>
