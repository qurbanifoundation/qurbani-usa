---
/**
 * Ramadan 2026 Main Page
 * Hub for all Ramadan giving options
 */
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Ramadan 2026 - Qurbani Foundation USA" description="Maximize your blessings this Ramadan. Give Fidya, Kaffarah, Zakat ul-Fitr, feed Iftar, and provide food packs to those in need.">
  <Navbar />

  <!-- Hero Section -->
  <section class="relative pt-24 pb-20 overflow-hidden">
    <!-- Background gradient with purple Ramadan theme -->
    <div class="absolute inset-0 bg-gradient-to-br from-[#012820] via-[#024139] to-[#013028]"></div>
    <!-- Decorative pattern - crescent moons and stars -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23ffffff\" fill-opacity=\"0.4\"%3E%3Cpath d=\"M30 30c0-8.284 6.716-15 15-15 1.657 0 3.258.268 4.758.764C45.722 8.396 38.463 3 30 3 16.193 3 5 14.193 5 28s11.193 25 25 25c8.463 0 15.722-5.396 19.758-12.764A15.014 15.014 0 0145 41c-8.284 0-15-6.716-15-15z\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <!-- Decorative elements -->
    <div class="absolute top-20 right-10 w-32 h-32 bg-[#fdc448]/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-48 h-48 bg-white/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <!-- Breadcrumb -->
        <div class="flex items-center justify-center gap-2 text-white/60 text-sm mb-6">
          <a href="/" class="hover:text-white transition">Home</a>
          <span>/</span>
          <span class="text-white">Ramadan 2026</span>
        </div>

        <!-- Crescent Moon Icon -->
        <div class="w-20 h-20 mx-auto mb-6 bg-white/10 rounded-full flex items-center justify-center backdrop-blur-sm border border-white/20">
          <svg class="w-10 h-10 text-[#fdc448]" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
          </svg>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6" style="font-family: 'Signika', sans-serif;">
          Ramadan <span class="text-[#fdc448]">2026</span>
        </h1>

        <p class="text-lg md:text-xl text-white/90 mb-4 leading-relaxed" style="font-family: 'Lato', sans-serif;">
          The blessed month of fasting, prayer, and charity
        </p>

        <p class="text-base text-white/70 max-w-2xl mx-auto mb-10" style="font-family: 'Lato', sans-serif;">
          "Whoever feeds a fasting person will have a reward like that of the fasting person, without any reduction in his reward."
          <span class="block mt-2 text-sm italic">- Prophet Muhammad (PBUH)</span>
        </p>

        <!-- Schedule My Giving CTA -->
        <div class="mt-8 mb-6">
          <a href="/ramadan/my30days" class="inline-flex items-center gap-3 bg-[#fdc448] hover:bg-[#efb000] text-[#61470e] font-bold px-8 py-4 rounded-xl transition-all hover:scale-105 text-lg" style="font-family: 'Signika', sans-serif; box-shadow: 0 4px 20px rgba(253, 196, 72, 0.4);">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Schedule My Giving
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>

        <!-- Quick Stats - Clickable -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4">
          <a href="/fidya" class="bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20 hover:bg-white/20 hover:scale-105 transition-all cursor-pointer block">
            <p class="text-2xl md:text-3xl font-bold text-[#fdc448]" style="font-family: 'Signika', sans-serif;">$10</p>
            <p class="text-sm text-white/70">Fidya per day</p>
          </a>
          <a href="/kaffarah" class="bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20 hover:bg-white/20 hover:scale-105 transition-all cursor-pointer block">
            <p class="text-2xl md:text-3xl font-bold text-[#fdc448]" style="font-family: 'Signika', sans-serif;">$180</p>
            <p class="text-sm text-white/70">Kaffarah</p>
          </a>
          <a href="/zakat-ul-fitr" class="bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20 hover:bg-white/20 hover:scale-105 transition-all cursor-pointer block">
            <p class="text-2xl md:text-3xl font-bold text-[#fdc448]" style="font-family: 'Signika', sans-serif;">$10</p>
            <p class="text-sm text-white/70">Zakat ul-Fitr</p>
          </a>
          <a href="/iftar" class="bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20 hover:bg-white/20 hover:scale-105 transition-all cursor-pointer block">
            <p class="text-2xl md:text-3xl font-bold text-[#fdc448]" style="font-family: 'Signika', sans-serif;">$5</p>
            <p class="text-sm text-white/70">Feed Iftar</p>
          </a>
        </div>
      </div>
    </div>

    <!-- Wave divider -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-16">
        <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="#f8f9fa"/>
      </svg>
    </div>
  </section>

  <!-- Ramadan Special Giving Options -->
  <section class="bg-[#f0f4f8] py-16">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4" style="font-family: 'Signika', sans-serif;">
          Ramadan Special <span class="text-[#024139]">Giving Options</span>
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Fulfill your obligations this blessed month
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Give Your Zakat -->
        <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 flex flex-col">
          <div class="p-6 flex-1 flex flex-col">
            <div class="mb-4">
              <span class="inline-flex items-center gap-1.5 bg-[#16a34a] text-white text-xs font-bold px-3 py-1.5 rounded-full">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
                ZAKAT
              </span>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2" style="font-family: 'Signika', sans-serif;">Give Your Zakat</h3>
            <p class="text-gray-500 text-sm mb-6 flex-1">Fulfill this pillar of Islam and purify your wealth by helping those in need.</p>
            <p class="mb-6">
              <span class="text-3xl font-bold text-gray-800" style="font-family: 'Signika', sans-serif;">2.5%</span>
              <span class="text-gray-400 text-sm ml-1">of wealth</span>
            </p>
            <a href="/zakat" class="inline-flex items-center justify-center gap-2 bg-[#1e3a5f] hover:bg-[#152d4a] text-white font-bold py-3 px-6 rounded-lg transition-all hover:scale-[1.02] text-sm" style="font-family: 'Signika', sans-serif;">
              Give Zakat
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>
        </div>

        <!-- Zakat Al-Fitr -->
        <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 flex flex-col">
          <div class="p-6 flex-1 flex flex-col">
            <div class="mb-4">
              <span class="inline-flex items-center gap-1.5 bg-[#D97718] text-white text-xs font-bold px-3 py-1.5 rounded-full">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
                OBLIGATORY
              </span>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2" style="font-family: 'Signika', sans-serif;">Zakat Al-Fitr</h3>
            <p class="text-gray-500 text-sm mb-6 flex-1">Purify your fast and bring joy to the needy before Eid. $10 per person.</p>
            <p class="mb-6">
              <span class="text-3xl font-bold text-gray-800" style="font-family: 'Signika', sans-serif;">$10</span>
              <span class="text-gray-400 text-sm ml-1">/ person</span>
            </p>
            <a href="/zakat-ul-fitr" class="inline-flex items-center justify-center gap-2 bg-[#1e3a5f] hover:bg-[#152d4a] text-white font-bold py-3 px-6 rounded-lg transition-all hover:scale-[1.02] text-sm" style="font-family: 'Signika', sans-serif;">
              Pay Zakat Al-Fitr
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>
        </div>

        <!-- Fidya & Kaffarah -->
        <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 flex flex-col">
          <div class="p-6 flex-1 flex flex-col">
            <div class="mb-4">
              <span class="inline-flex items-center gap-1.5 bg-[#7c3aed] text-white text-xs font-bold px-3 py-1.5 rounded-full">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                EXPIATION
              </span>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2" style="font-family: 'Signika', sans-serif;">Fidya & Kaffarah</h3>
            <p class="text-gray-500 text-sm mb-6 flex-1">For those who cannot fast due to chronic illness or have broken their fast.</p>
            <p class="mb-6">
              <span class="text-3xl font-bold text-gray-800" style="font-family: 'Signika', sans-serif;">$10</span>
              <span class="text-gray-400 text-sm ml-1">/ day (Fidya)</span>
            </p>
            <a href="/fidya" class="inline-flex items-center justify-center gap-2 bg-[#1e3a5f] hover:bg-[#152d4a] text-white font-bold py-3 px-6 rounded-lg transition-all hover:scale-[1.02] text-sm" style="font-family: 'Signika', sans-serif;">
              Pay Fidya/Kaffarah
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>
        </div>

        <!-- Automated Giving -->
        <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 flex flex-col">
          <div class="p-6 flex-1 flex flex-col">
            <div class="mb-4">
              <span class="inline-flex items-center gap-1.5 bg-[#0096D6] text-white text-xs font-bold px-3 py-1.5 rounded-full">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path></svg>
                MONTHLY
              </span>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2" style="font-family: 'Signika', sans-serif;">Automated Giving</h3>
            <p class="text-gray-500 text-sm mb-6 flex-1">Maximize your rewards with recurring donations throughout Ramadan and beyond.</p>
            <p class="mb-6">
              <span class="text-3xl font-bold text-[#0096D6]" style="font-family: 'Signika', sans-serif;">Choose</span>
              <span class="text-gray-400 text-sm ml-1">your amount</span>
            </p>
            <a href="/30-days-of-ramadan" class="inline-flex items-center justify-center gap-2 bg-[#1e3a5f] hover:bg-[#152d4a] text-white font-bold py-3 px-6 rounded-lg transition-all hover:scale-[1.02] text-sm" style="font-family: 'Signika', sans-serif;">
              Set Up Monthly Giving
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- More Ways to Give -->
  <section class="bg-white py-16">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4" style="font-family: 'Signika', sans-serif;">
          More Ways to <span class="text-[#024139]">Give</span>
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Maximize your blessings during the holiest month. Every act of charity is multiplied in reward.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Food Packs Card -->
        <a href="/ramadan/food-packs" class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100">
          <div class="h-48 bg-gradient-to-br from-[#eab308] to-[#ca8a04] relative overflow-hidden flex items-center justify-center">
            <div class="absolute inset-0 bg-black/10"></div>
            <div class="relative z-10 text-center">
              <div class="flex items-center justify-center gap-2 mb-2">
                <svg class="w-8 h-8 text-white/80" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a4 4 0 00-4 4v1H5a1 1 0 00-.994.89l-1 9A1 1 0 004 18h12a1 1 0 00.994-1.11l-1-9A1 1 0 0015 7h-1V6a4 4 0 00-4-4zm2 5V6a2 2 0 10-4 0v1h4zm-6 3a1 1 0 112 0 1 1 0 01-2 0zm7-1a1 1 0 100 2 1 1 0 000-2z"></path></svg>
                <span class="text-4xl font-bold text-white">1</span>
              </div>
              <p class="text-white/90 text-sm font-medium">Month of Food Supplies</p>
            </div>
            <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-sm text-white text-sm font-bold px-3 py-1 rounded-full">
              From $50
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-[#eab308] transition" style="font-family: 'Signika', sans-serif;">
              Food Packs
            </h3>
            <p class="text-gray-600 text-sm mb-4">
              Provide a family with essential food supplies for the entire month of Ramadan.
            </p>
            <span class="inline-flex items-center gap-2 text-[#ca8a04] font-semibold text-sm group-hover:gap-3 transition-all">
              Provide Food Packs
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </div>
        </a>

        <!-- Feed Iftar Card -->
        <a href="/iftar" class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100">
          <div class="h-48 bg-gradient-to-br from-[#ea580c] to-[#c2410c] relative overflow-hidden flex items-center justify-center">
            <div class="absolute inset-0 bg-black/10"></div>
            <div class="relative z-10 text-center">
              <div class="flex items-center justify-center gap-2 mb-2">
                <span class="text-4xl font-bold text-white">$5</span>
              </div>
              <p class="text-white/90 text-sm font-medium">Per Iftar Meal</p>
            </div>
            <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-sm text-white text-sm font-bold px-3 py-1 rounded-full">
              FEED IFTAR
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-[#ea580c] transition" style="font-family: 'Signika', sans-serif;">
              Feed Iftar
            </h3>
            <p class="text-gray-600 text-sm mb-4">
              Provide a nutritious iftar meal to a fasting person. Share the blessings of breaking fast together.
            </p>
            <span class="inline-flex items-center gap-2 text-[#ea580c] font-semibold text-sm group-hover:gap-3 transition-all">
              Feed Someone Today
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </div>
        </a>

        <!-- Zakat Calculator Card -->
        <a href="/zakat/calculator" class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100">
          <div class="h-48 bg-gradient-to-br from-[#024139] to-[#012820] relative overflow-hidden flex items-center justify-center">
            <div class="absolute inset-0 bg-black/10"></div>
            <div class="relative z-10 text-center">
              <div class="flex items-center justify-center gap-2 mb-2">
                <svg class="w-8 h-8 text-[#fdc448]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
              </div>
              <p class="text-white/90 text-sm font-medium">Know What You Owe</p>
            </div>
            <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-sm text-white text-sm font-bold px-3 py-1 rounded-full">
              CALCULATOR
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-[#024139] transition" style="font-family: 'Signika', sans-serif;">
              Zakat Calculator
            </h3>
            <p class="text-gray-600 text-sm mb-4">
              Calculate your Zakat accurately with our easy-to-use calculator. Based on current gold and silver prices.
            </p>
            <span class="inline-flex items-center gap-2 text-[#024139] font-semibold text-sm group-hover:gap-3 transition-all">
              Calculate Now
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- The Virtues of Ramadan -->
  <section class="py-16 bg-white">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4" style="font-family: 'Signika', sans-serif;">
          The Virtues of <span class="text-[#024139]">Ramadan</span>
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Ramadan is a time of spiritual reflection, self-improvement, and heightened devotion to Allah.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Virtue 1 -->
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-[#024139]/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-[#024139]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-2" style="font-family: 'Signika', sans-serif;">Gates of Paradise Open</h3>
          <p class="text-gray-600 text-sm">
            "When the month of Ramadan begins, the gates of Paradise are opened and the gates of Hellfire are closed." - Hadith
          </p>
        </div>

        <!-- Virtue 2 -->
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-[#fdc448]/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-[#ca8a04]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
