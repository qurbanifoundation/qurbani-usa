---
/**
 * My Ten Nights - Last 10 Nights of Ramadan Giving
 * Has its own independent template setting (ramadan_tennights_template)
 * separate from my30days (ramadan_page_template)
 *
 * Change template in Admin > Settings > Templates > Ramadan Ten Nights Templates
 *
 * URL: /ramadan/mytennights
 */
export const prerender = false;

import { supabaseAdmin } from '../../lib/supabase';

// Import available templates
import AmanahTemplate from '../../templates/ramadan/AmanahTemplate.astro';
import PennyAppealTemplate from '../../templates/ramadan/PennyAppealTemplate.astro';

// Fetch current template setting from database (uses its own setting, not shared with my30days)
let currentTemplate = 'amanah'; // Default to amanah

try {
  const { data: settings } = await supabaseAdmin
    .from('site_settings')
    .select('ramadan_tennights_template')
    .eq('id', 'main')
    .single();

  if (settings?.ramadan_tennights_template) {
    currentTemplate = settings.ramadan_tennights_template;
  }
} catch (error) {
  console.error('Error fetching template setting:', error);
  // Default to amanah if there's an error
}
---

{currentTemplate === 'amanah' && <AmanahTemplate
  nights={10}
  heroTitle="Never Miss<br>Laylatul Qadr"
  heroSubtitle="Automate your giving over the last 10 nights of Ramadan<br>and secure the reward of Laylatul Qadr."
  pageTitle="My Ten Nights - Never Miss Laylatul Qadr | Qurbani Foundation"
  pageDescription="Automate your Sadaqah over the last 10 nights of Ramadan. Never miss the reward of Laylatul Qadr."
  ctaText="Start My 10 Nights Giving"
/>}
{currentTemplate === 'pennyappeal' && <PennyAppealTemplate />}
