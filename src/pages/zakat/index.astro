---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CWDonationBox from '../../components/donation/CWDonationBox.astro';
---

<Layout title="Pay Your Zakat | Qurbani USA - 100% Zakat Policy">
  <Navbar />
  <main>
    <!-- Hero Section -->
    <section class="relative min-h-[500px] flex items-center" style="background: linear-gradient(135deg, #255764 0%, #1a3d47 100%);">
      <div class="absolute inset-0">
        <div class="absolute inset-0" style="background-image: url('/images/qurbani-foundation-food-distribution.png'); background-size: cover; background-position: center;"></div>
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#255764]/80 to-[#255764]/50"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="text-white">
            <div class="inline-flex items-center gap-2 bg-[#0096D6] text-white text-sm font-bold px-4 py-2 rounded-full mb-6">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z"></path>
              </svg>
              THIRD PILLAR OF ISLAM
            </div>

            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6" style="font-family: 'Signika', sans-serif;">
              Fulfill Your <span class="text-[#e1861d]">Zakat</span> Today
            </h1>

            <p class="text-lg md:text-xl text-gray-200 mb-8 leading-relaxed" style="font-family: 'Lato', sans-serif;">
              Fulfill your obligation and purify your wealth. 100% of your Zakat reaches those in need through our verified distribution channels across 50+ countries.
            </p>

            <div class="flex flex-wrap gap-4 mb-8">
              <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full backdrop-blur-sm">
                <svg class="w-5 h-5 text-[#e1861d]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-sm">100% Zakat Policy</span>
              </div>
              <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full backdrop-blur-sm">
                <svg class="w-5 h-5 text-[#e1861d]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-sm">Shariah Compliant</span>
              </div>
              <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full backdrop-blur-sm">
                <svg class="w-5 h-5 text-[#e1861d]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-sm">Tax Deductible</span>
              </div>
            </div>

            <a href="/zakat-calculator" class="inline-flex items-center gap-2 bg-[#e1861d] text-white font-bold px-6 py-3 rounded-lg hover:bg-[#c97418] transition shadow-lg" style="font-family: 'Signika', sans-serif;">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V4a2 2 0 00-2-2H6zm0 2h8v2H6V4zm0 4h2v2H6V8zm0 3h2v2H6v-2zm0 3h2v2H6v-2zm3-6h2v2H9V8zm0 3h2v2H9v-2zm0 3h2v2H9v-2zm3-6h2v2h-2V8zm0 3h2v5h-2v-5z"></path>
              </svg>
              Calculate My Zakat
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>

          <!-- Donation Box -->
          <div>
            <CWDonationBox
              campaignSlug="zakat"
              campaignTitle="Zakat 2026"
              donationBoxHeading="Pay Your Zakat"
              tabEmoji="🤲"
              skipUpsell={true}
              frequencies={[
                {
                  key: 'single',
                  label: 'GIVE ONCE',
                  type: 'single',
                  stripeInterval: null,
                  suffix: 'USD',
                  buttonText: 'GIVE',
                  amounts: [50, 100, 150, 200],
                  impactTexts: {
                    50: '100% Zakat Policy • Shariah Compliant • Tax Deductible',
                    100: '100% Zakat Policy • Shariah Compliant • Tax Deductible',
                    150: '100% Zakat Policy • Shariah Compliant • Tax Deductible',
                    200: '100% Zakat Policy • Shariah Compliant • Tax Deductible'
                  },
                  defaultAmountIndex: 1,
                  fallbackImpactText: ''
                },
                {
                  key: 'yearly',
                  label: 'YEARLY',
                  type: 'recurring',
                  stripeInterval: 'year',
                  suffix: 'USD/yr',
                  buttonText: 'GIVE YEARLY',
                  amounts: [100, 250, 500, 1000],
                  impactTexts: {
                    100: '100% Zakat Policy • Shariah Compliant • Tax Deductible',
                    250: '100% Zakat Policy • Shariah Compliant • Tax Deductible',
                    500: '100% Zakat Policy • Shariah Compliant • Tax Deductible',
                    1000: '100% Zakat Policy • Shariah Compliant • Tax Deductible'
                  },
                  defaultAmountIndex: 1,
                  fallbackImpactText: 'Your yearly gift makes a lasting impact'
                }
              ]}
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Zakat Categories Section -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4" style="font-family: 'Signika', sans-serif;">
            Where Your Zakat Goes
          </h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto" style="font-family: 'Lato', sans-serif;">
            Your Zakat is distributed according to the eight categories mentioned in the Quran, ensuring it reaches those most deserving.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-gradient-to-br from-[#255764] to-[#1a3d47] rounded-xl p-6 text-white">
            <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2" style="font-family: 'Signika', sans-serif;">The Poor (Al-Fuqara)</h3>
            <p class="text-sm text-gray-200" style="font-family: 'Lato', sans-serif;">Those who do not have enough to meet their basic needs.</p>
          </div>

          <div class="bg-gradient-to-br from-[#D97706] to-[#b45309] rounded-xl p-6 text-white">
            <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2" style="font-family: 'Signika', sans-serif;">The Needy (Al-Masakin)</h3>
            <p class="text-sm text-gray-200" style="font-family: 'Lato', sans-serif;">Those who have some income but not enough to meet their needs.</p>
          </div>

          <div class="bg-gradient-to-br from-[#0096D6] to-[#0077b3] rounded-xl p-6 text-white">
            <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2" style="font-family: 'Signika', sans-serif;">Orphan Support</h3>
            <p class="text-sm text-gray-200" style="font-family: 'Lato', sans-serif;">Providing care, education, and support for orphaned children.</p>
          </div>

          <div class="bg-gradient-to-br from-[#7c3aed] to-[#6d28d9] rounded-xl p-6 text-white">
            <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2" style="font-family: 'Signika', sans-serif;">Education</h3>
            <p class="text-sm text-gray-200" style="font-family: 'Lato', sans-serif;">Building schools and providing education to underprivileged communities.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Give Zakat Section -->
    <section class="py-16 bg-stone-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-6" style="font-family: 'Signika', sans-serif;">
              Why Give Your Zakat Through Us?
            </h2>

            <div class="space-y-6">
              <div class="flex gap-4">
                <div class="w-12 h-12 bg-[#0096D6] rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-bold text-gray-800 mb-2" style="font-family: 'Signika', sans-serif;">100% Zakat Policy</h3>
                  <p class="text-gray-600" style="font-family: 'Lato', sans-serif;">Every single cent of your Zakat reaches those in need. Our operational costs are covered by separate funds.</p>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="w-12 h-12 bg-[#D97706] rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-bold text-gray-800 mb-2" style="font-family: 'Signika', sans-serif;">Shariah Compliant</h3>
                  <p class="text-gray-600" style="font-family: 'Lato', sans-serif;">Our Zakat distribution is overseen by qualified Islamic scholars to ensure compliance with Islamic principles.</p>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="w-12 h-12 bg-[#255764] rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-bold text-gray-800 mb-2" style="font-family: 'Signika', sans-serif;">Global Reach</h3>
                  <p class="text-gray-600" style="font-family: 'Lato', sans-serif;">We distribute Zakat in over 50 countries, reaching the most vulnerable communities worldwide.</p>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="w-12 h-12 bg-[#16a34a] rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm2 10a1 1 0 10-2 0v3a1 1 0 102 0v-3zm2-3a1 1 0 011 1v5a1 1 0 11-2 0v-5a1 1 0 011-1zm4-1a1 1 0 10-2 0v7a1 1 0 102 0V8z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-bold text-gray-800 mb-2" style="font-family: 'Signika', sans-serif;">Full Transparency</h3>
                  <p class="text-gray-600" style="font-family: 'Lato', sans-serif;">We provide detailed reports on how your Zakat is distributed and the impact it creates.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="relative">
            <div class="relative rounded-xl overflow-hidden shadow-lg">
              <img
                src="/images/qurbani-foundation-zakat.png"
                alt="Qurbani Foundation volunteer distributing food to a child"
                class="w-full"
              />
              <div class="absolute inset-0 bg-black/40 rounded-xl"></div>
            </div>
            <div class="absolute -bottom-6 -left-6 bg-[#0096D6] text-white p-6 rounded-xl shadow-lg">
              <p class="text-4xl font-bold" style="font-family: 'Signika', sans-serif;">50+</p>
              <p class="text-sm" style="font-family: 'Lato', sans-serif;">Countries Served</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Zakat Info Banner -->
    <section class="py-12 bg-[#0096D6]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="text-white text-center md:text-left">
            <h3 class="text-2xl md:text-3xl font-bold mb-2" style="font-family: 'Signika', sans-serif;">Not Sure How Much Zakat You Owe?</h3>
            <p class="text-blue-100" style="font-family: 'Lato', sans-serif;">Use our easy Zakat Calculator to determine your obligation in minutes.</p>
          </div>
          <a href="/zakat/calculator" class="bg-white text-[#0096D6] font-bold px-8 py-4 rounded-lg hover:bg-gray-100 transition flex items-center gap-2" style="font-family: 'Signika', sans-serif;">
            Calculate Your Zakat
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Quick Links Section -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4" style="font-family: 'Signika', sans-serif;">
            Learn More About Zakat
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <a href="/what-is-zakat" class="group bg-stone-50 rounded-xl p-6 hover:shadow-lg transition border border-gray-100">
            <div class="w-12 h-12 bg-[#D97706] rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-[#D97706] transition" style="font-family: 'Signika', sans-serif;">What is Zakat?</h3>
            <p class="text-gray-600 text-sm" style="font-family: 'Lato', sans-serif;">Learn about the importance and significance of Zakat in Islam.</p>
          </a>

          <a href="/zakat-faq" class="group bg-stone-50 rounded-xl p-6 hover:shadow-lg transition border border-gray-100">
            <div class="w-12 h-12 bg-[#7c3aed] rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-[#7c3aed] transition" style="font-family: 'Signika', sans-serif;">Zakat FAQ</h3>
            <p class="text-gray-600 text-sm" style="font-family: 'Lato', sans-serif;">Get answers to commonly asked questions about Zakat.</p>
          </a>

          <a href="/zakat-on-gold" class="group bg-stone-50 rounded-xl p-6 hover:shadow-lg transition border border-gray-100">
            <div class="w-12 h-12 bg-[#eab308] rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5 2a2 2 0 00-2 2v14l3.5-2 3.5 2 3.5-2 3.5 2V4a2 2 0 00-2-2H5zm2.5 3a1.5 1.5 0 100 3 1.5 1.5 0 000-3zm6.207.293a1 1 0 00-1.414 0l-6 6a1 1 0 101.414 1.414l6-6a1 1 0 000-1.414zM12.5 10a1.5 1.5 0 100 3 1.5 1.5 0 000-3z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-[#eab308] transition" style="font-family: 'Signika', sans-serif;">Zakat on Gold & Silver</h3>
            <p class="text-gray-600 text-sm" style="font-family: 'Lato', sans-serif;">Understand how to calculate Zakat on precious metals.</p>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

