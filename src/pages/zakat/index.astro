---
/**
 * Zakat Page — Conversion-optimized landing page
 * Pulls ALL content from the campaigns DB (editable via /admin/campaigns)
 * Uses the conversion layout with mobile-first design, sticky CTA, and trust signals
 *
 * Data Mapping (from campaign admin):
 * - Hero badge text       → campaign.subtitle2 (default: "100% Zakat Policy")
 * - Hero title            → campaign.hero_title (supports *italic* for orange text)
 * - Hero description      → campaign.subtitle
 * - Hero background image → campaign.featured_image
 * - Hero trust badges     → template_config.heroBadges[]
 * - Donation box config   → template_config.cwDonation (heading, amounts, impact, etc.)
 * - Category cards        → template_config.pageContent.howDonationHelps.items[]
 * - Why Give benefits     → content_sections[] (title + content)
 * - Why Give image        → gallery_images[0]
 * - Why Give heading      → template_config.pageContent.whyMonthly.heading
 * - Impact stat badge     → impact_stats[0] { value, label }
 * - Hadith/banner         → template_config.pageContent.midCta { heading, subtext }
 * - Quick links           → template_config.quickLinks[]
 * - Final CTA             → template_config.pageContent.finalCta { heading, subtext, primaryButtonText }
 * - SEO                   → meta_title, meta_description
 * - Sticky bar text       → template_config.stickyBar { title, subtitle, buttonText }
 */
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CWDonationBox from '../../components/donation/CWDonationBox.astro';
import { supabaseAdmin } from '../../lib/supabase';
import { DEFAULT_PAGE_CONTENT } from '../../lib/page-content-defaults';

export const prerender = false;

// Fetch campaign data
let campaign: any = null;
try {
  const { data } = await supabaseAdmin
    .from('campaigns')
    .select('*')
    .eq('url_path', '/zakat')
    .eq('is_active', true)
    .single();
  campaign = data;
} catch (e) {
  // Fallback — try by slug
}
if (!campaign) {
  try {
    const { data } = await supabaseAdmin
      .from('campaigns')
      .select('*')
      .eq('slug', 'zakat')
      .eq('is_active', true)
      .single();
    campaign = data;
  } catch (e) {}
}

// If no campaign found, use sensible defaults
const tc = campaign?.template_config || {};
const cwConfig = tc.cwDonation || {};
const savedPC = tc.pageContent || {};

// ── Hero ────────────────────────────────────────────────────────────
const heroTitle = campaign?.hero_title || 'Your Zakat';
const heroTitleAccent = campaign?.hero_title_accent || 'Their Relief';
const heroDescription = campaign?.subtitle || '100% Zakat distributed according to Islamic guidelines to verified eligible recipients across 50+ countries.';
const heroBadgeText = campaign?.subtitle2 || '100% Zakat Policy';
const heroImage = campaign?.featured_image || '/images/qurbani-foundation-zakat.webp';
const heroBadges: string[] = tc.heroBadges || ['Shariah Compliant', 'Tax-Deductible', 'Secure Payment'];

// ── Donation Box ────────────────────────────────────────────────────
// Build frequencies from cwDonation config
const cwFrequencies = cwConfig.frequencies || null;
const cwOneTimeAmounts = cwConfig.oneTimeAmounts || [100, 250, 500, 1000];
const cwMonthlyAmounts = cwConfig.monthlyAmounts || [25, 50, 100, 250];
const cwImpactTexts = cwConfig.impactTexts || {};
const cwButtonTextOneTime = cwConfig.buttonTextOneTime || 'Pay Zakat Now';
const cwButtonTextMonthly = cwConfig.buttonTextMonthly || 'Give Monthly';
const cwHeading = cwConfig.donationBoxHeading || 'Pay Your Zakat';
const cwSkipUpsell = cwConfig.skipUpsell !== false;
const cwTabEmoji = cwConfig.tabEmoji || '🕌';

// ── Category cards ──────────────────────────────────────────────────
const pageContent = {
  howDonationHelps: {
    heading: savedPC.howDonationHelps?.heading || 'Where Your Zakat Goes',
    subheading: savedPC.howDonationHelps?.subheading || 'Your Zakat reaches the most vulnerable through verified, Shariah-compliant programs',
    items: savedPC.howDonationHelps?.items || [],
  },
  midCta: { ...DEFAULT_PAGE_CONTENT.midCta, ...savedPC.midCta },
  whyMonthly: { ...DEFAULT_PAGE_CONTENT.whyMonthly, ...savedPC.whyMonthly },
  finalCta: { ...DEFAULT_PAGE_CONTENT.finalCta, ...savedPC.finalCta },
};

const categoryCards = pageContent.howDonationHelps.items || [];
const cardGradients = [
  'from-[#255764] to-[#1a3d47]',
  'from-[#D97706] to-[#b45309]',
  'from-[#0096D6] to-[#0077b3]',
  'from-[#7c3aed] to-[#6d28d9]',
];
const cardIcons = [
  '<path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>',
  '<path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"></path>',
  '<path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>',
  '<path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0z"></path>',
];

// ── Why Give section ────────────────────────────────────────────────
const whyGiveHeading = pageContent.whyMonthly.heading || 'Why Pay Your Zakat Through Us?';
const contentSections = campaign?.content_sections || [];
const whyGiveImage = campaign?.gallery_images?.[0] || '/images/qurbani-foundation-zakat.webp';
const imageOverlay = tc.imageOverlay ?? 30;

// ── Impact stats badge ──────────────────────────────────────────────
const rawImpactStats = campaign?.impact_stats;
let statBadge = { value: '20+', label: 'Countries Served' };
if (Array.isArray(rawImpactStats) && rawImpactStats.length > 0) {
  statBadge = rawImpactStats[0];
} else if (rawImpactStats && typeof rawImpactStats === 'object' && !Array.isArray(rawImpactStats)) {
  const entries = Object.entries(rawImpactStats);
  if (entries.length > 0) statBadge = { value: String(entries[0][1]), label: entries[0][0] };
}

// ── Quick links ─────────────────────────────────────────────────────
const quickLinks = (tc.quickLinks || [
  { title: 'What is Zakat?', description: 'Learn about the third pillar of Islam', url: '/what-is-zakat', color: '#D97706' },
  { title: 'Zakat Calculator', description: 'Calculate exactly how much you owe', url: '/zakat-calculator', color: '#0096D6' },
  { title: 'Zakat FAQ', description: 'Answers to common Zakat questions', url: '/zakat-faq', color: '#7c3aed' },
]).filter((l: any) => !l.url?.includes('calculator'));

// ── Sticky bar ──────────────────────────────────────────────────────
const stickyBar = tc.stickyBar || { title: 'Pay Your Zakat', subtitle: '100% Zakat Policy · Tax-Deductible', buttonText: 'Pay Zakat Now' };

// ── SEO ─────────────────────────────────────────────────────────────
const metaTitle = campaign?.meta_title || 'Pay Your Zakat Online 2026 — 100% Zakat Policy | Qurbani Foundation USA';
const metaDescription = campaign?.meta_description || 'Pay your Zakat online with confidence. 100% Zakat policy ensures every dollar reaches those in need. Shariah-compliant, tax-deductible.';

// No renderHeroTitle needed — hero uses two separate fields
---

<Layout title={metaTitle} description={metaDescription}>
  <Navbar />

  <main>
    <!-- Hero Section -->
    <section class="relative pt-20 pb-6 lg:pt-32 lg:pb-20 overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0">
        <div class="absolute inset-0" style={`background-image: url('${heroImage}'); background-size: cover; background-position: center;`}></div>
        <div class="absolute inset-0 bg-gradient-to-b lg:bg-gradient-to-r from-[#1a3040]/90 via-[#1a3040]/80 to-[#1a3040]/60"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-4 lg:gap-10 items-center">
          <!-- Left Column: Hero Copy -->
          <div class="text-white text-center lg:text-left">
            <!-- Badge -->
            <div class="flex items-center justify-start gap-2 text-[#e1861d] text-xs font-bold mb-3 lg:mb-5 uppercase tracking-[0.15em]">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              {heroBadgeText}
            </div>

            <h1 class="text-4xl leading-[1.1] md:text-5xl lg:text-6xl font-bold mb-2 lg:mb-4" style="font-family: 'Signika', sans-serif;">
              {heroTitle}
              {heroTitleAccent && (
                <>
                  <br />
                  <span class="text-[#e1861d] italic" style="font-family: 'Playfair Display', serif;">{heroTitleAccent}</span>
                  <span class="text-[#e1861d]"> 2026</span>
                </>
              )}
            </h1>

            {heroDescription && (
              <p class="text-xs md:text-base lg:text-lg text-gray-300 mb-2 lg:mb-6 leading-relaxed max-w-md mx-auto lg:mx-0" style="font-family: 'Lato', sans-serif;">
                {heroDescription}
              </p>
            )}

            <!-- Trust badges — hidden on mobile, shown on desktop -->
            {heroBadges.length > 0 && (
              <div class="hidden lg:flex flex-wrap gap-3 mb-6">
                {heroBadges.map((badge: string) => (
                  <div class="flex items-center gap-1.5 bg-white/10 px-3 py-1.5 rounded-full backdrop-blur-sm text-sm">
                    <svg class="w-4 h-4 text-[#e1861d]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                    {badge}
                  </div>
                ))}
              </div>
            )}

            <!-- Social proof — desktop only -->
            <div class="hidden lg:flex items-center gap-3 text-gray-400 text-sm">
              <div class="flex -space-x-2">
                <div class="w-8 h-8 rounded-full bg-[#e1861d]/30 border-2 border-white/20 flex items-center justify-center text-xs font-bold text-white">A</div>
                <div class="w-8 h-8 rounded-full bg-[#0096D6]/30 border-2 border-white/20 flex items-center justify-center text-xs font-bold text-white">S</div>
                <div class="w-8 h-8 rounded-full bg-[#255764]/30 border-2 border-white/20 flex items-center justify-center text-xs font-bold text-white">M</div>
              </div>
              <span>Trusted by <strong class="text-white">thousands</strong> of donors across the US</span>
            </div>
          </div>

          <!-- Right Column: Donation Box — shows on first fold on mobile -->
          <div data-zakat-donate>
            <CWDonationBox
              campaignSlug={campaign?.slug || 'zakat'}
              campaignTitle={campaign?.title || 'Zakat'}
              campaignImage={campaign?.featured_image}
              donationBoxHeading={cwHeading}
              tabEmoji={cwTabEmoji}
              skipUpsell={cwSkipUpsell}
              hideHeadingOnMobile={true}
              frequencies={cwFrequencies}
              monthlyAmounts={cwMonthlyAmounts}
              oneTimeAmounts={cwOneTimeAmounts}
              impactTexts={cwImpactTexts}
              buttonTextOneTime={cwButtonTextOneTime}
              buttonTextMonthly={cwButtonTextMonthly}
            />
            <!-- Calculator link — right under donation box -->
            <p class="text-center mt-3 text-sm text-white/60">
              Not sure of your amount?
              <a href="/zakat-calculator" class="text-[#e1861d] hover:text-[#fdc448] font-semibold underline underline-offset-2 transition">Calculate your Zakat</a>
            </p>
          </div>
        </div>

        <!-- Mobile trust row — compact, below donation box -->
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 mt-5 lg:hidden">
          <div class="flex items-center gap-1.5 text-white/50 text-xs">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            Secure
          </div>
          <div class="flex items-center gap-1.5 text-white/50 text-xs">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Tax-Deductible
          </div>
          <div class="flex items-center gap-1.5 text-white/50 text-xs">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            100% Zakat Policy
          </div>
          <div class="flex items-center gap-1.5 text-white/50 text-xs">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Shariah Compliant
          </div>
        </div>
      </div>

      <!-- Straight divider -->
      <div class="absolute bottom-0 left-0 right-0 h-1 bg-white"></div>
    </section>

    <!-- What is Zakat? — Educational Section -->
    <section class="py-14 md:py-20 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Last Updated Badge -->
        <div class="flex items-center gap-2 text-xs text-gray-400 uppercase tracking-widest mb-6">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          Last Updated: {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
        </div>

        <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
          <!-- Left Column: Content -->
          <div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#1a3040] mb-6 leading-tight" style="font-family: 'Signika', sans-serif;">
              What is <span class="text-[#e1861d]">Zakat</span>?
            </h2>

            <div class="space-y-4 text-gray-600 leading-relaxed" style="font-family: 'Lato', sans-serif;">
              <p class="text-base md:text-lg">
                Zakat is one of the <strong class="text-gray-800">Five Pillars of Islam</strong> — a mandatory act of worship that requires every eligible Muslim to give <strong class="text-gray-800">2.5% of their qualifying wealth</strong> annually to those in need.
              </p>
              <p class="text-base md:text-lg">
                More than just charity, Zakat is a divine obligation that purifies your wealth, strengthens the community, and uplifts the most vulnerable members of society. It is a means of spiritual growth and social justice prescribed by Allah (SWT).
              </p>
              <p class="text-base md:text-lg">
                Your Zakat reaches <strong class="text-gray-800">eight categories of recipients</strong> defined in the Quran — from the poor and needy to those in debt and travelers in need — ensuring your obligation is fulfilled with precision and care.
              </p>
            </div>

            <!-- Quranic Quote -->
            <blockquote class="mt-8 border-l-4 border-[#e1861d] pl-5 py-3 bg-orange-50/50 rounded-r-lg">
              <p class="text-gray-700 italic text-base md:text-lg leading-relaxed" style="font-family: 'Playfair Display', serif;">
                "And those in whose wealth there is a recognized right, for the one who asks and the one who is deprived."
              </p>
              <cite class="block mt-2 text-sm text-[#e1861d] font-bold not-italic" style="font-family: 'Signika', sans-serif;">— Quran 70:24-25</cite>
            </blockquote>

            <!-- CTA Buttons -->
            <div class="flex flex-wrap gap-3 mt-8">
              <button id="what-is-zakat-donate-btn" class="inline-flex items-center gap-2 bg-[#e1861d] hover:bg-[#c97418] text-white font-bold px-6 py-3 rounded-xl transition-all hover:scale-105 cursor-pointer shadow-lg" style="font-family: 'Signika', sans-serif;">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path></svg>
                Donate Zakat
              </button>
              <a href="/zakat-calculator" class="inline-flex items-center gap-2 bg-white border-2 border-[#255764] text-[#255764] hover:bg-[#255764] hover:text-white font-bold px-6 py-3 rounded-xl transition-all cursor-pointer" style="font-family: 'Signika', sans-serif;">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V4a2 2 0 00-2-2H6zm0 2h8v2H6V4zm0 4h2v2H6V8zm0 3h2v2H6v-2zm0 3h2v2H6v-2zm3-6h2v2H9V8zm0 3h2v2H9v-2zm0 3h2v2H9v-2zm3-6h2v2h-2V8zm0 3h2v5h-2v-5z"></path></svg>
                Calculate Your Zakat
              </a>
            </div>
          </div>

          <!-- Right Column: Impact Image -->
          <div class="relative">
            <div class="relative rounded-2xl overflow-hidden shadow-xl">
              <img src={whyGiveImage} alt="Zakat impact — families receiving aid" class="w-full h-[350px] md:h-[450px] object-cover" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
              <!-- Impact badge overlay -->
              <div class="absolute bottom-5 left-5 right-5">
                <div class="bg-white/95 backdrop-blur-sm rounded-xl p-4 shadow-lg">
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-[#e1861d] rounded-full flex items-center justify-center flex-shrink-0">
                      <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                    </div>
                    <div>
                      <p class="text-xl font-bold text-gray-800" style="font-family: 'Signika', sans-serif;">{statBadge.value}</p>
                      <p class="text-sm text-gray-500">{statBadge.label}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Your Zakat in Trusted Hands -->
    <section class="py-14 md:py-20 bg-[#e8e6e1]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-[#1a3040] mb-6 uppercase tracking-tight" style="font-family: 'Signika', sans-serif;">
          Your Zakat in Trusted Hands
        </h2>

        <div class="max-w-4xl mx-auto space-y-4 text-gray-700 text-base md:text-lg mb-12" style="font-family: 'Lato', sans-serif;">
          <p>
            Your Zakat is an Amanah — a sacred trust from Allah (SWT). At Qurbani Foundation, we uphold a strict <strong class="text-gray-800">100% Zakat Policy</strong>, meaning every single dollar of your Zakat goes directly to eligible recipients. We cover all operational costs separately so your obligation is fulfilled completely.
          </p>
          <p>
            Our Zakat distribution is overseen by qualified scholars to ensure full Shariah compliance. From identifying the eight eligible categories to verifying recipients on the ground, we follow Islamic guidelines at every step — across 50+ countries worldwide.
          </p>
        </div>

        <!-- Stats Row -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 mb-12">
          <div>
            <p class="text-3xl md:text-4xl font-black text-[#1a3040]" style="font-family: 'Signika', sans-serif;">2M+</p>
            <p class="text-sm text-gray-500 mt-1" style="font-family: 'Lato', sans-serif;">Lives Changed</p>
          </div>
          <div>
            <p class="text-3xl md:text-4xl font-black text-[#1a3040]" style="font-family: 'Signika', sans-serif;">53+</p>
            <p class="text-sm text-gray-500 mt-1" style="font-family: 'Lato', sans-serif;">Countries Reached</p>
          </div>
          <div>
            <p class="text-3xl md:text-4xl font-black text-[#1a3040]" style="font-family: 'Signika', sans-serif;">100%</p>
            <p class="text-sm text-gray-500 mt-1" style="font-family: 'Lato', sans-serif;">Zakat Policy — Every Dollar Delivered</p>
          </div>
          <div>
            <p class="text-3xl md:text-4xl font-black text-[#1a3040]" style="font-family: 'Signika', sans-serif;">8</p>
            <p class="text-sm text-gray-500 mt-1" style="font-family: 'Lato', sans-serif;">Eligible Zakat Categories Served</p>
          </div>
        </div>

        <!-- CTA Button -->
        <a href="/zakat/zakat-policy" class="inline-flex items-center gap-2 border-2 border-[#1a3040] text-[#1a3040] hover:bg-[#1a3040] hover:text-white font-bold px-8 py-3.5 rounded-lg transition-all" style="font-family: 'Signika', sans-serif;">
          Learn More About Our 100% Zakat Policy
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>
    </section>

    <!-- Where Your Zakat Goes — Category Cards (only if items exist) -->
    {categoryCards.length > 0 && (
      <section class="py-14 md:py-16 bg-white">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-3" style="font-family: 'Signika', sans-serif;" set:html={pageContent.howDonationHelps.heading.replace(/\*(.*?)\*/g, '<span class="text-[#e1861d]">$1</span>')} />
            {pageContent.howDonationHelps.subheading && (
              <p class="text-gray-500 max-w-2xl mx-auto" style="font-family: 'Lato', sans-serif;">
                {pageContent.howDonationHelps.subheading}
              </p>
            )}
          </div>

          <div class={`grid grid-cols-2 lg:grid-cols-${Math.min(categoryCards.length, 4)} gap-4 md:gap-6`}>
            {categoryCards.map((card: { amount: string; label: string }, index: number) => (
              <div class={`bg-gradient-to-br ${cardGradients[index % cardGradients.length]} rounded-xl p-5 text-white text-center`}>
                <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-3">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                    <Fragment set:html={cardIcons[index % cardIcons.length]} />
                  </svg>
                </div>
                <h3 class="font-bold text-sm md:text-base mb-1" style="font-family: 'Signika', sans-serif;">{card.amount}</h3>
                <p class="text-xs text-gray-300 hidden md:block">{card.label}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Hadith / Mid CTA Banner (only if heading exists) -->
    {pageContent.midCta.heading && savedPC.midCta?.heading && (
      <section class="py-10 md:py-12 bg-[#255764]">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <p class="text-white/80 text-lg md:text-xl italic mb-3" style="font-family: 'Lato', sans-serif;">
            {pageContent.midCta.heading}
          </p>
          {pageContent.midCta.subtext && (
            <p class="text-[#e1861d] font-bold text-sm">{pageContent.midCta.subtext}</p>
          )}
        </div>
      </section>
    )}

    <!-- Calculator Callout Strip -->
    <section class="py-10 md:py-12 bg-[#0096D6]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-5">
          <div class="text-white text-center md:text-left">
            <h3 class="text-xl md:text-2xl font-bold mb-1" style="font-family: 'Signika', sans-serif;">
              Not Sure How Much Zakat You Owe?
            </h3>
            <p class="text-blue-100 text-sm md:text-base">
              Use our free Zakat calculator to find your exact obligation in minutes.
            </p>
          </div>
          <a href="/zakat-calculator" class="inline-flex items-center gap-2 bg-white text-[#0096D6] font-bold px-6 py-3 rounded-xl hover:bg-gray-100 transition shadow-lg whitespace-nowrap" style="font-family: 'Signika', sans-serif;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V4a2 2 0 00-2-2H6zm0 2h8v2H6V4zm0 4h2v2H6V8zm0 3h2v2H6v-2zm0 3h2v2H6v-2zm3-6h2v2H9V8zm0 3h2v2H9v-2zm0 3h2v2H9v-2zm3-6h2v2h-2V8zm0 3h2v5h-2v-5z"></path></svg>
            Calculate My Zakat
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Quick Links -->
    {quickLinks.length > 0 && (
      <section class="py-14 md:py-16 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-8 text-center" style="font-family: 'Signika', sans-serif;">
            Learn More About Zakat
          </h2>

          <div class={`grid md:grid-cols-${Math.min(quickLinks.length, 3)} gap-5`}>
            {quickLinks.map((link: { title: string; description: string; url: string; color: string }) => (
              <a href={link.url} class="group bg-stone-50 rounded-xl p-5 hover:shadow-lg transition border border-gray-100">
                <div class="w-11 h-11 rounded-lg flex items-center justify-center mb-3 group-hover:scale-110 transition" style={`background-color: ${link.color}`}>
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.586 4.586a2 2 0 112.828 2.828l-3 3a2 2 0 01-2.828 0 1 1 0 00-1.414 1.414 4 4 0 005.656 0l3-3a4 4 0 00-5.656-5.656l-1.5 1.5a1 1 0 101.414 1.414l1.5-1.5zm-5 5a2 2 0 012.828 0 1 1 0 101.414-1.414 4 4 0 00-5.656 0l-3 3a4 4 0 105.656 5.656l1.5-1.5a1 1 0 10-1.414-1.414l-1.5 1.5a2 2 0 11-2.828-2.828l3-3z" clip-rule="evenodd"></path></svg>
                </div>
                <h3 class="font-bold text-gray-800 mb-1" style="font-family: 'Signika', sans-serif;">{link.title}</h3>
                <p class="text-sm text-gray-500">{link.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Final CTA -->
    {savedPC.finalCta?.heading && (
      <section class="py-14 md:py-16 bg-gradient-to-r from-[#255764] to-[#1a3d47] text-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <h2 class="text-3xl md:text-4xl font-bold mb-4" style="font-family: 'Signika', sans-serif;">
            {pageContent.finalCta.heading}
          </h2>
          {pageContent.finalCta.subtext && (
            <p class="text-lg text-gray-300 mb-8 max-w-2xl mx-auto" style="font-family: 'Lato', sans-serif;">
              {pageContent.finalCta.subtext}
            </p>
          )}
          <button id="final-cta-btn" class="inline-flex items-center gap-2 bg-[#e1861d] hover:bg-[#c97418] text-white font-bold px-8 py-4 rounded-xl transition-all hover:scale-105 cursor-pointer shadow-lg text-lg" style="font-family: 'Signika', sans-serif;">
            {pageContent.finalCta.primaryButtonText || 'Pay Your Zakat Now'}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </button>
        </div>
      </section>
    )}
  </main>

  <!-- Mobile Sticky CTA Bar -->
  <div id="zakat-sticky-bar" class="fixed bottom-0 left-0 right-0 z-50 lg:hidden translate-y-full transition-transform duration-300">
    <div class="bg-white border-t border-gray-200 shadow-[0_-4px_20px_rgba(0,0,0,0.1)] px-4 py-3">
      <div class="flex items-center justify-between gap-3 max-w-lg mx-auto">
        <div>
          <p class="text-sm font-bold text-gray-800">{stickyBar.title}</p>
          <p class="text-xs text-gray-500">{stickyBar.subtitle}</p>
        </div>
        <button id="zakat-sticky-btn" class="bg-[#DC1A34] hover:bg-[#b8162c] text-white font-bold px-6 py-3 rounded-xl text-sm flex items-center gap-2 transition-all cursor-pointer whitespace-nowrap" style="font-family: 'Signika', sans-serif;">
          <span id="sticky-btn-text">{stickyBar.buttonText}</span>
          <span id="sticky-btn-amount" class="hidden bg-white/20 rounded-lg px-2 py-0.5 text-xs font-bold"></span>
        </button>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const donationBox = document.querySelector('[data-zakat-donate]');

    // Scroll to donation box
    function scrollToDonationBox() {
      if (donationBox) {
        const rect = donationBox.getBoundingClientRect();
        const scrollTarget = window.pageYOffset + rect.top - 20;
        window.scrollTo({ top: Math.max(0, scrollTarget), behavior: 'smooth' });
      }
    }

    // Hero button
    document.getElementById('hero-give-btn')?.addEventListener('click', scrollToDonationBox);
    // What is Zakat donate button
    document.getElementById('what-is-zakat-donate-btn')?.addEventListener('click', scrollToDonationBox);
    // Final CTA button
    document.getElementById('final-cta-btn')?.addEventListener('click', scrollToDonationBox);

    // Mobile sticky bar — show when donation box is NOT visible, hide when it IS
    const stickyBar = document.getElementById('zakat-sticky-bar');
    const stickyBtn = document.getElementById('zakat-sticky-btn');

    stickyBtn?.addEventListener('click', scrollToDonationBox);

    // Update sticky button with selected amount
    const stickyBtnAmount = document.getElementById('sticky-btn-amount');
    document.addEventListener('cw:amount-change', (e) => {
      const amt = (e as CustomEvent).detail?.amount;
      if (stickyBtnAmount && amt > 0) {
        stickyBtnAmount.textContent = '$' + amt.toLocaleString();
        stickyBtnAmount.classList.remove('hidden');
      } else if (stickyBtnAmount) {
        stickyBtnAmount.classList.add('hidden');
      }
    });

    if (stickyBar && donationBox) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            stickyBar.classList.add('translate-y-full');
          } else {
            stickyBar.classList.remove('translate-y-full');
          }
        },
        { threshold: 0.1 }
      );
      observer.observe(donationBox);
    }
  });
</script>
