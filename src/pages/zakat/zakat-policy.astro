<script>
  document.addEventListener('DOMContentLoaded', () => {
    // FAQ accordion
    document.querySelectorAll('.zp-faq-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const body = btn.nextElementSibling as HTMLElement;
        const arrow = btn.querySelector('.zp-faq-arrow') as HTMLElement;
        const isOpen = !body.classList.contains('hidden');

        // Close all others
        document.querySelectorAll('.zp-faq-body').forEach((b) => b.classList.add('hidden'));
        document.querySelectorAll('.zp-faq-arrow').forEach((a) => (a as HTMLElement).style.transform = '');

        if (!isOpen) {
          body.classList.remove('hidden');
          if (arrow) arrow.style.transform = 'rotate(180deg)';
        }
      });
    });
  });
</script>
