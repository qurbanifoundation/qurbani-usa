---
import '../styles/global.css'
import SEO from '../components/SEO.astro';
import DonationCart from '../components/DonationCart.astro';
import RamadanPopup from '../components/RamadanPopup.astro';
import SocialProofPopup from '../components/SocialProofPopup.astro';
import { getSettings } from '../lib/settings';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  campaign?: {
    meta_title?: string;
    meta_description?: string;
    og_image_url?: string;
    canonical_url?: string;
  };
}

const { title, description, ogImage, canonicalUrl, noindex, campaign } = Astro.props;
const settings = await getSettings();

// Determine favicon - use admin setting if available, otherwise fallback to local file
const adminFavicon = settings.site_favicon;
const faviconHref = adminFavicon || '/favicon.png';
const faviconType = adminFavicon
  ? (adminFavicon.endsWith('.svg') ? 'image/svg+xml' : adminFavicon.endsWith('.ico') ? 'image/x-icon' : 'image/png')
  : 'image/png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Analytics 4 + Google Ads Conversion Tracking -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-0WC0W1PBKC"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      // GA4 Config — transport_url uses sendBeacon for reliable event delivery
      gtag('config', 'G-0WC0W1PBKC', {
        send_page_view: true,
        cookie_flags: 'SameSite=None;Secure',
        transport_type: 'beacon'
      });

      // Google Ads Config
      gtag('config', 'AW-793369119');

      // E-commerce tracking helper functions
      window.trackAddToCart = function(item) {
        var campaignName = item.campaign || 'donation';
        var pagePath = window.location.pathname;
        var pageTitle = document.title;

        // Standard GA4 add_to_cart event
        gtag('event', 'add_to_cart', {
          currency: 'USD',
          value: item.amount * (item.quantity || 1),
          items: [{
            item_id: item.id || item.slug,
            item_name: item.name,
            item_category: campaignName,
            price: item.amount,
            quantity: item.quantity || 1
          }]
        });

        // Custom per-campaign donate button click event
        // Shows exactly: which campaign page → how many clicked donate
        gtag('event', 'donate_button_click', {
          campaign_name: campaignName,
          item_name: item.name,
          donation_amount: item.amount,
          donation_type: item.type || 'single',
          page_path: pagePath,
          page_title: pageTitle,
          source_location: item.sourceLocation || pagePath,
          value: item.amount * (item.quantity || 1),
          currency: 'USD'
        });
      };

      window.trackBeginCheckout = function(items, total) {
        gtag('event', 'begin_checkout', {
          currency: 'USD',
          value: total,
          items: items.map(function(item) {
            return {
              item_id: item.id || item.slug,
              item_name: item.name,
              item_category: item.campaign || 'donation',
              price: item.amount,
              quantity: item.quantity || 1
            };
          })
        });
      };

      window.trackPurchase = function(transactionId, items, total) {
        // GA4 Purchase Event
        gtag('event', 'purchase', {
          transaction_id: transactionId,
          currency: 'USD',
          value: total,
          items: items.map(function(item) {
            return {
              item_id: item.id || item.slug,
              item_name: item.name,
              item_category: item.campaign || 'donation',
              price: item.amount,
              quantity: item.quantity || 1
            };
          }),
          send_to: 'G-0WC0W1PBKC'
        });

        // Google Ads Conversion
        gtag('event', 'conversion', {
          'send_to': 'AW-793369119/2lawCM74xKcBEJ-0p_oC',
          'value': total,
          'currency': 'USD',
          'transaction_id': transactionId
        });
      };

      // View item (campaign/appeal page)
      window.trackViewItem = function(item) {
        gtag('event', 'view_item', {
          currency: 'USD',
          value: item.amount || 0,
          items: [{
            item_id: item.id || item.slug,
            item_name: item.name,
            item_category: item.campaign || item.category || 'donation',
            price: item.amount || 0
          }]
        });
      };

      // View cart
      window.trackViewCart = function(items, total) {
        gtag('event', 'view_cart', {
          currency: 'USD',
          value: total,
          items: items.map(function(item) {
            return {
              item_id: item.id || item.slug,
              item_name: item.name,
              item_category: item.campaign || 'donation',
              price: item.amount,
              quantity: item.quantity || 1
            };
          })
        });
      };

      // Remove from cart
      window.trackRemoveFromCart = function(item) {
        gtag('event', 'remove_from_cart', {
          currency: 'USD',
          value: item.amount * (item.quantity || 1),
          items: [{
            item_id: item.id || item.slug,
            item_name: item.name,
            item_category: item.campaign || 'donation',
            price: item.amount,
            quantity: item.quantity || 1
          }]
        });
      };

      // Add payment info (step 2 of checkout)
      window.trackAddPaymentInfo = function(items, total, paymentType) {
        gtag('event', 'add_payment_info', {
          currency: 'USD',
          value: total,
          payment_type: paymentType || 'credit_card',
          items: items.map(function(item) {
            return {
              item_id: item.id || item.slug,
              item_name: item.name,
              item_category: item.campaign || 'donation',
              price: item.amount,
              quantity: item.quantity || 1
            };
          })
        });
      };

      // Custom donation events
      window.trackDonationEvent = function(eventName, params) {
        gtag('event', eventName, params);
      };

      // ============================================
      // DONOR ATTRIBUTION & JOURNEY TRACKING
      // Captures first-touch + last-touch UTMs, page journey, device, session timing
      // ============================================
      (function() {
        try {
          var KEY = 'qurbani_tracking';
          var raw = localStorage.getItem(KEY);
          var tracking = raw ? JSON.parse(raw) : null;
          var now = Date.now();
          var params = new URLSearchParams(window.location.search);
          var path = window.location.pathname;

          // Detect device + browser (only on first visit)
          function detectDevice() {
            var ua = navigator.userAgent;
            var isMobile = /Mobi|Android|iPhone|iPad|iPod/i.test(ua);
            var isTablet = /iPad|Tablet|PlayBook/i.test(ua) || (isMobile && Math.min(screen.width, screen.height) > 600);
            var browser = 'Other';
            if (ua.indexOf('Chrome') > -1 && ua.indexOf('Edg') === -1) browser = 'Chrome';
            else if (ua.indexOf('Safari') > -1 && ua.indexOf('Chrome') === -1) browser = 'Safari';
            else if (ua.indexOf('Firefox') > -1) browser = 'Firefox';
            else if (ua.indexOf('Edg') > -1) browser = 'Edge';
            var os = 'Other';
            if (/iPhone/i.test(ua)) os = 'iPhone';
            else if (/iPad/i.test(ua)) os = 'iPad';
            else if (/Android/i.test(ua)) os = 'Android';
            else if (/Windows/i.test(ua)) os = 'Windows';
            else if (/Macintosh|Mac OS/i.test(ua)) os = 'Mac';
            else if (/CrOS/i.test(ua)) os = 'ChromeOS';
            else if (/Linux/i.test(ua)) os = 'Linux';
            return { device: isTablet ? 'tablet' : isMobile ? 'mobile' : 'desktop', browser: browser, os: os };
          }

          // Extract current UTM params from URL
          function getCurrentUTMs() {
            var utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];
            var utms = {};
            var hasAny = false;
            utmKeys.forEach(function(k) {
              var v = params.get(k);
              if (v) { utms[k] = v; hasAny = true; }
            });
            return hasAny ? utms : null;
          }

          // Expire after 30 days — preserve first-touch attribution for returning donors
          if (!tracking || (now - tracking.session_started > 2592000000)) {
            var dev = detectDevice();
            var currentUtms = getCurrentUTMs();
            // Google Ads parameters from tracking template
            var gads = {
              gclid: params.get('gclid') || '',
              fbclid: params.get('fbclid') || '',
              matchtype: params.get('matchtype') || '',
              network: params.get('network') || '',
              campaignid: params.get('campaignid') || params.get('campaign_id') || '',
              adgroupid: params.get('adgroupid') || params.get('ad_group_id') || '',
              keyword: params.get('keyword') || params.get('utm_term') || '',
              creative: params.get('creative') || '',
              loc_interest: params.get('loc_interest_ms') || '',
              loc_physical: params.get('loc_physical_ms') || '',
              device: params.get('device') || '',
            };

            tracking = {
              session_started: now,
              // First-touch attribution (set once, never overwritten)
              first_touch: {
                utm: currentUtms || {},
                landing_page: path,
                referrer: document.referrer || 'direct',
                gclid: gads.gclid,
                fbclid: gads.fbclid,
                matchtype: gads.matchtype,
                network: gads.network,
                campaignid: gads.campaignid,
                adgroupid: gads.adgroupid,
                keyword: gads.keyword,
                creative: gads.creative,
                loc_interest: gads.loc_interest,
                loc_physical: gads.loc_physical,
                device: gads.device,
              },
              // Last-touch attribution (updated on each new UTM arrival)
              last_touch: {
                utm: currentUtms || {},
                landing_page: path,
                referrer: document.referrer || 'direct',
                gclid: gads.gclid,
                fbclid: gads.fbclid,
                matchtype: gads.matchtype,
                network: gads.network,
                campaignid: gads.campaignid,
                adgroupid: gads.adgroupid,
                keyword: gads.keyword,
                creative: gads.creative,
                loc_interest: gads.loc_interest,
                loc_physical: gads.loc_physical,
                device: gads.device,
              },
              device: dev.device,
              browser: dev.browser,
              os: dev.os,
              pages: []
            };
          } else {
            // Existing session — update last-touch if new UTMs arrive
            var newUtms = getCurrentUTMs();
            if (newUtms || params.get('gclid')) {
              tracking.last_touch = {
                utm: newUtms || tracking.last_touch.utm || {},
                landing_page: path,
                referrer: document.referrer || 'direct',
                gclid: params.get('gclid') || tracking.last_touch.gclid || '',
                fbclid: params.get('fbclid') || tracking.last_touch.fbclid || '',
                matchtype: params.get('matchtype') || tracking.last_touch.matchtype || '',
                network: params.get('network') || tracking.last_touch.network || '',
                campaignid: params.get('campaignid') || params.get('campaign_id') || tracking.last_touch.campaignid || '',
                adgroupid: params.get('adgroupid') || params.get('ad_group_id') || tracking.last_touch.adgroupid || '',
                keyword: params.get('keyword') || params.get('utm_term') || tracking.last_touch.keyword || '',
                creative: params.get('creative') || tracking.last_touch.creative || '',
                loc_interest: params.get('loc_interest_ms') || tracking.last_touch.loc_interest || '',
                loc_physical: params.get('loc_physical_ms') || tracking.last_touch.loc_physical || '',
                device: params.get('device') || tracking.last_touch.device || '',
              };
            }
          }

          // Track page visit (avoid consecutive duplicates, keep last 10)
          var lastPage = tracking.pages.length > 0 ? tracking.pages[tracking.pages.length - 1] : null;
          if (!lastPage || lastPage.p !== path) {
            tracking.pages.push({ p: path, t: now });
            if (tracking.pages.length > 10) tracking.pages = tracking.pages.slice(-10);
          }

          localStorage.setItem(KEY, JSON.stringify(tracking));
        } catch(e) {}
      })();

      // Helper: get stored UTM params (last-touch, for payment flow compatibility)
      window.getStoredUTM = function() {
        try {
          var raw = localStorage.getItem('qurbani_tracking');
          if (!raw) return null;
          var data = JSON.parse(raw);
          if (Date.now() - data.session_started > 86400000) return null;
          var utm = data.last_touch && data.last_touch.utm ? data.last_touch.utm : {};
          utm.ts = data.session_started;
          return utm;
        } catch(e) { return null; }
      };

      // Helper: get full tracking data for donation attribution
      window.getStoredJourney = function() {
        try {
          var raw = localStorage.getItem('qurbani_tracking');
          if (!raw) return null;
          var data = JSON.parse(raw);
          if (Date.now() - data.session_started > 86400000) {
            localStorage.removeItem('qurbani_tracking');
            return null;
          }
          return data;
        } catch(e) { return null; }
      };
    </script>
    <link rel="icon" type={faviconType} href={faviconHref} />
    <link rel="alternate icon" href="/favicon.ico" />

    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalUrl={canonicalUrl}
      noindex={noindex}
      campaign={campaign}
    />

    <!-- Preconnect to external domains -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- DNS prefetch for third-party domains loaded later -->
    <link rel="dns-prefetch" href="https://js.stripe.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- Google Fonts: Non-render-blocking load with Caveat included -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500&family=Lato:wght@400;700;900&family=Oswald:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Signika:wght@400;500;600;700&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500&family=Lato:wght@400;700;900&family=Oswald:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Signika:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500&family=Lato:wght@400;700;900&family=Oswald:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Signika:wght@400;500;600;700&display=swap" rel="stylesheet" /></noscript>

    <!-- Donation box hover effects -->
    <style is:inline>
      [data-donation-box] button { cursor: pointer; transition: filter 0.15s ease; }
      [data-donation-box] button:hover { filter: brightness(1.08); }
      [data-donation-box] .cw-donate-btn:hover,
      [data-donation-box] .cw-upsell-btn:hover,
      [data-donation-box] #donate-btn:hover { filter: brightness(1.12); }
    </style>
  </head>
  <body class="bg-stone-50 text-stone-900 antialiased">
    <slot />
    <DonationCart checkoutTemplate={settings.checkout_template || 'three-step'} showCartReminder={settings.show_cart_reminder !== false} sidecartEnabled={settings.sidecart_enabled !== false} showSidecartMonthly={settings.show_sidecart_monthly !== false} showSidecartJummah={settings.show_sidecart_jummah !== false} />
    {settings.show_ramadan_popup !== false && <RamadanPopup />}
    {settings.show_social_proof !== false && <SocialProofPopup />}

    <!-- Mobile auto-scroll removed — sticky CTA buttons handle scroll-to-donate per page -->
  </body>
</html>
