  <!-- ===== STICKY MOBILE CTA BAR ===== -->
  <div id="fat-sticky-bar" class="fixed bottom-0 left-0 right-0 z-40 lg:hidden hidden" style={`background: ${heroBg};`}>
    <div class="fat-sticky-bar flex items-center justify-between px-4 py-3 max-w-lg mx-auto">
      <div>
        <div class="text-white font-bold text-sm" style="font-family: 'Signika', sans-serif;">{campaign.title}</div>
        <div class="text-white/60 text-xs" style="font-family: 'Lato', sans-serif;">100% goes to those in need</div>
      </div>
      <button
        type="button"
        id="fat-sticky-donate-btn"
        class="px-6 py-2.5 rounded-full text-white font-bold text-sm transition-all hover:scale-105 flex-shrink-0"
