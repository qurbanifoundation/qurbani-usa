  <!-- ===== FINAL CTA SECTION ===== -->
  <section class="py-14 sm:py-20 text-center" style={`background: linear-gradient(135deg, ${heroBg} 0%, ${heroBgEnd} 100%);`}>
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-white mb-4" style="font-family: 'Signika', sans-serif;">
