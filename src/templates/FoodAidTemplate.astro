        Donate
      </button>
    </div>
  </div>

  <Footer />

  <!-- ===== CLIENT-SIDE JAVASCRIPT ===== -->
  <script is:inline define:vars={{ clientConfig }}>
    (function() {
      var cfg = JSON.parse(clientConfig);

      // ===== ANIMATED COUNTERS =====
      var counterObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          var elms = el.querySelectorAll('[data-counter]');
          elms.forEach(function(counter) {
            if (counter.dataset.animated) return;
            counter.dataset.animated = 'true';
            var target = counter.dataset.counter;
            // If it contains non-numeric characters (like "100,000+"), animate the numeric part
            var numMatch = target.replace(/,/g, '').match(/(\d+)/);
            if (numMatch) {
              var num = parseInt(numMatch[1]);
              var prefix = target.substring(0, target.indexOf(numMatch[0]));
              var suffix = target.substring(target.indexOf(numMatch[0]) + numMatch[0].length);
              var hasCommas = target.includes(',');
              var duration = 1500;
              var start = performance.now();

              function animate(now) {
                var elapsed = now - start;
                var progress = Math.min(elapsed / duration, 1);
                // Ease out cubic
                var eased = 1 - Math.pow(1 - progress, 3);
                var current = Math.floor(eased * num);
                var formatted = hasCommas ? current.toLocaleString() : String(current);
                counter.textContent = prefix + formatted + suffix;
                if (progress < 1) requestAnimationFrame(animate);
              }
              requestAnimationFrame(animate);
            }
            counter.classList.add('fat-counter-animate');
          });
          counterObserver.unobserve(el);
        });
      }, { threshold: 0.3 });

      var counterStrip = document.getElementById('fat-counter-strip');
      if (counterStrip) counterObserver.observe(counterStrip);

      // ===== TIER CARD CLICKS =====
      var tierMode = 'single'; // 'single' or 'monthly'

      document.querySelectorAll('.fat-tier-card').forEach(function(card) {
        card.addEventListener('click', function() {
          var amount = parseInt(card.dataset.tierAmount);
          if (!amount) return;
          if (typeof window.addToCart === 'function') {
            window.addToCart({
              id: cfg.slug + '-' + amount + '-' + tierMode,
              name: cfg.title,
              amount: amount,
              type: tierMode === 'monthly' ? 'monthly' : 'single',
              campaign: cfg.slug,
            });
          }
        });
      });

      // ===== SINGLE / MONTHLY TOGGLE =====
      document.querySelectorAll('.fat-toggle-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          tierMode = btn.dataset.mode;
          document.querySelectorAll('.fat-toggle-btn').forEach(function(b) {
            b.classList.toggle('active', b.dataset.mode === tierMode);
          });
          // Show/hide monthly suffix on tier cards
          document.querySelectorAll('.fat-tier-suffix').forEach(function(suf) {
            if (tierMode === 'monthly') {
              suf.classList.remove('hidden');
            } else {
              suf.classList.add('hidden');
            }
          });
        });
      });

      // ===== FAQ ACCORDION =====
      document.querySelectorAll('.fat-faq-toggle').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var answer = btn.nextElementSibling;
          var chevron = btn.querySelector('.fat-faq-chevron');
          var isOpen = answer.classList.contains('open');

          // Close all others
          document.querySelectorAll('.fat-faq-answer.open').forEach(function(a) {
            a.classList.remove('open');
            a.style.maxHeight = '0';
          });
          document.querySelectorAll('.fat-faq-chevron.open').forEach(function(c) {
            c.classList.remove('open');
          });

          // Toggle current
          if (!isOpen) {
            answer.classList.add('open');
            answer.style.maxHeight = answer.scrollHeight + 'px';
            chevron.classList.add('open');
          }
        });
      });

      // ===== STICKY MOBILE CTA BAR =====
      var stickyBar = document.getElementById('fat-sticky-bar');
      var heroEnd = document.getElementById('fat-counter-strip');

      if (stickyBar && heroEnd) {
        var stickyObserver = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              stickyBar.classList.add('hidden');
            } else {
              // Only show when scrolled past the counter strip (i.e., below it)
              if (entry.boundingClientRect.top < 0) {
                stickyBar.classList.remove('hidden');
              }
            }
          });
        }, { threshold: 0 });
        stickyObserver.observe(heroEnd);
      }

      // Sticky bar donate click → scroll to mobile donation box
      var stickyDonateBtn = document.getElementById('fat-sticky-donate-btn');
      if (stickyDonateBtn) {
        stickyDonateBtn.addEventListener('click', function() {
          var mobileBox = document.getElementById('fat-donation-box-mobile');
          if (mobileBox) {
            mobileBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        });
      }

      // Final CTA → scroll to appropriate donation box
      var finalCta = document.getElementById('fat-final-cta');
      if (finalCta) {
        finalCta.addEventListener('click', function() {
          var isDesktop = window.innerWidth >= 1024;
          if (isDesktop) {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          } else {
            var mobileBox = document.getElementById('fat-donation-box-mobile');
            if (mobileBox) mobileBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        });
      }

    })();
  </script>
</Layout>
