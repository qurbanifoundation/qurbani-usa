      </h2>
      <p class="text-white/70 mb-8 text-sm sm:text-base" style="font-family: 'Lato', sans-serif;">
        {config.ctaSubtext || 'Join thousands of donors making a difference. Your generosity brings hope to families in need around the world.'}
      </p>
      <button
        type="button"
        id="fat-final-cta"
        class="inline-flex items-center gap-2 px-10 py-4 rounded-full text-white font-bold text-lg transition-all hover:scale-105"
