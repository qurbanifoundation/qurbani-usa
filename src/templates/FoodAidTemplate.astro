          {config.faqHeading || 'Frequently Asked Questions'}
        </h2>

        <div class="space-y-3" id="fat-faq-container">
          {faqItems.map((faq, i) => (
            <div class="border border-gray-200 rounded-xl overflow-hidden">
              <button
                type="button"
                class="fat-faq-toggle w-full flex items-center justify-between px-5 py-4 text-left hover:bg-gray-50 transition"
