---
/**
 * SADAQAH JARIYAH TEMPLATE
 * High-converting layout: Donation box RIGHT IN the hero (above the fold)
 * Deep teal/emerald color scheme
 * Multiple campaign options below for maximum impact
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  campaign: {
    id: string;
    name: string;
    slug: string;
    title: string;
    hero_title?: string;
    hero_title_accent?: string;
    subtitle?: string;
    subtitle2?: string;
    featured_image?: string;
    description?: string;
    meta_title?: string;
    meta_description?: string;
    content_sections?: any[];
    donation_options?: any[];
    template_config?: any;
    [key: string]: any;
  };
  donationBoxTemplate: string;
}

const { campaign, donationBoxTemplate } = Astro.props;
const pageTitle = campaign.meta_title || campaign.title || 'Sadaqah Jariyah - Ongoing Charity | Qurbani Foundation USA';
const pageDescription = campaign.meta_description || campaign.description || 'Give Sadaqah Jariyah — charity that keeps giving. Build wells, fund education, and create lasting change. Rewards continue even after you pass away.';
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <style>
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes pulseGlow {
      0%, 100% { box-shadow: 0 0 0 0 rgba(13, 148, 136, 0.4); }
      50% { box-shadow: 0 0 20px 8px rgba(13, 148, 136, 0.15); }
    }
    .sj-fade-in { animation: fadeInUp 0.6s ease-out both; }
    .sj-fade-in-d1 { animation: fadeInUp 0.6s ease-out 0.1s both; }
    .sj-fade-in-d2 { animation: fadeInUp 0.6s ease-out 0.2s both; }
    .sj-fade-in-d3 { animation: fadeInUp 0.6s ease-out 0.3s both; }
    .sj-pulse { animation: pulseGlow 2s ease-in-out infinite; }
    .sj-project-card { transition: all 0.25s ease; cursor: pointer; }
    .sj-project-card:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
    .sj-project-card.active { border-color: #0d9488 !important; background: rgba(13, 148, 136, 0.05); }
    details summary::-webkit-details-marker { display: none; }
    details summary { list-style: none; }
  </style>

  <!-- ===== HERO SECTION — Donation box visible immediately ===== -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #0d2b2e 0%, #134e4a 60%, #1a5c4e 100%);">
    <!-- Background image -->
    <div class="absolute inset-0 z-0">
      <img src="/images/ramadan/ramadan-bg1.webp" alt="" class="w-full h-full object-cover opacity-15" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0d2b2e]/95 via-[#0d2b2e]/80 to-[#134e4a]/60"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 pt-28 sm:pt-36 pb-12 sm:pb-16">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-start">

        <!-- Left: Hero Content (3 cols) -->
        <div class="lg:col-span-3 text-center lg:text-left">
          <!-- Badges -->
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-2 mb-4 sj-fade-in">
            <span class="bg-[#4dd4ac]/20 text-[#4dd4ac] text-xs font-bold px-3 py-1.5 rounded-full border border-[#4dd4ac]/30">
              🌿 Rewards Never Stop
            </span>
            <span class="bg-white/10 text-white/90 text-xs font-medium px-3 py-1.5 rounded-full border border-white/20">
              100% Donation Policy
            </span>
          </div>

          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.25rem] font-bold text-white leading-tight mb-4 sj-fade-in" style="font-family: 'Signika', sans-serif;">
            Sadaqah <span class="text-[#4dd4ac]">Jariyah</span>
          </h1>

          <p class="text-base sm:text-lg text-white/80 mb-6 max-w-xl mx-auto lg:mx-0 sj-fade-in-d1" style="font-family: 'Lato', sans-serif; line-height: 1.7;">
            Give once. Earn rewards forever. Sadaqah Jariyah is the charity that <strong class="text-[#4dd4ac]">never stops giving</strong> — for you, for your loved ones, and for generations to come.
          </p>

          <!-- Hadith -->
          <div class="bg-white/8 backdrop-blur-sm border-l-4 border-[#4dd4ac] p-4 rounded-r-lg mb-6 max-w-lg mx-auto lg:mx-0 sj-fade-in-d2">
            <p class="text-sm text-white/85 italic leading-relaxed">
              "When a person dies, their deeds come to an end except for three: ongoing charity, knowledge that benefits others, or a righteous child who prays for them."
            </p>
            <p class="text-xs text-[#4dd4ac] mt-2 font-semibold">— Prophet Muhammad ﷺ, Sahih Muslim</p>
          </div>

          <!-- Trust badges -->
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-x-5 gap-y-2 mt-6 sj-fade-in-d2">
            <div class="flex items-center gap-1.5 text-white/60 text-xs">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
              <span style="font-family: 'Lato', sans-serif;">Secure Payment</span>
            </div>
            <div class="flex items-center gap-1.5 text-white/60 text-xs">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span style="font-family: 'Lato', sans-serif;">501(c)(3) Nonprofit</span>
            </div>
            <div class="flex items-center gap-1.5 text-white/60 text-xs">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span style="font-family: 'Lato', sans-serif;">Tax-Deductible</span>
            </div>
            <div class="flex items-center gap-1.5 text-white/60 text-xs">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span style="font-family: 'Lato', sans-serif;">15+ Countries</span>
            </div>
          </div>

          <!-- Mobile: scroll to donation box -->
          <div class="mt-8 lg:hidden sj-fade-in-d3">
            <button onclick="document.getElementById('sj-mobile-donate')?.scrollIntoView({behavior:'smooth', block:'center'})" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full text-white font-bold text-lg transition-all hover:scale-105 bg-[#0d9488]" style="font-family: 'Signika', sans-serif; box-shadow: 0 4px 15px rgba(13,148,136,0.4);">
              Give Sadaqah Jariyah
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
          </div>
        </div>

        <!-- Right: Donation Box (2 cols) — VISIBLE IMMEDIATELY on desktop -->
        <div class="lg:col-span-2 sj-fade-in-d2 hidden lg:block" id="sj-desktop-donate">
          <div class="bg-white rounded-2xl shadow-2xl overflow-hidden">
            <!-- Header -->
            <div class="bg-gradient-to-r from-[#0d9488] to-[#14b8a6] px-6 py-4 text-center">
              <h3 class="text-xl font-bold text-white mb-0.5" style="font-family: 'Signika', sans-serif;">
                🌿 Sadaqah Jariyah
              </h3>
              <p class="text-white/90 text-xs">Ongoing charity · Rewards that never end</p>
            </div>

            <div class="p-5">
              <!-- Frequency Toggle -->
              <div class="flex bg-gray-100 rounded-xl p-1 mb-4">
                <button class="sj-freq-btn flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all bg-white text-[#0d9488] shadow-sm" data-freq="single">
                  One-Time
                </button>
                <button class="sj-freq-btn flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all text-gray-500 hover:text-gray-700" data-freq="monthly">
                  Monthly 💚
                </button>
              </div>

              <!-- Impact Selection -->
              <label class="block text-sm font-semibold text-gray-700 mb-2">Choose Your Impact</label>
              <div class="flex flex-col gap-2 mb-3">
                <button class="sj-amount-btn group flex items-center gap-3 p-3 border-2 border-gray-200 rounded-xl bg-white hover:border-[#0d9488] hover:bg-[#0d9488]/5 transition-all text-left" data-amount="600" data-project="Orphan Full Year">
                  <span class="w-9 h-9 rounded-lg bg-[#0d9488]/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-[#0d9488]" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"></path></svg>
                  </span>
                  <div class="flex-1 min-w-0">
                    <span class="text-sm font-bold text-gray-800 group-hover:text-[#0d9488]">One Year Orphan Sponsorship</span>
                    <span class="block text-xs text-gray-500">Food, school, healthcare — full year</span>
                  </div>
                  <span class="text-base font-bold text-[#0d9488] flex-shrink-0">$600</span>
                </button>
                <button class="sj-amount-btn group flex items-center gap-3 p-3 border-2 border-[#0d9488] rounded-xl bg-[#0d9488]/5 transition-all text-left relative" data-amount="300" data-project="Water Hand Pump">
                  <span class="absolute -top-2 -right-2 bg-[#0d9488] text-white text-[10px] font-bold px-2 py-0.5 rounded-full">Popular</span>
                  <span class="w-9 h-9 rounded-lg bg-[#0d9488]/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-[#0d9488]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 3.636a1 1 0 010 1.414 7 7 0 000 9.9 1 1 0 11-1.414 1.414 9 9 0 010-12.728 1 1 0 011.414 0zm9.9 0a9 9 0 010 12.728 1 1 0 11-1.414-1.414 7 7 0 000-9.9 1 1 0 011.414-1.414zM7.879 6.464a1 1 0 010 1.414 3 3 0 000 4.243 1 1 0 11-1.415 1.414 5 5 0 010-7.07 1 1 0 011.415 0zm4.242 0a5 5 0 010 7.072 1 1 0 01-1.415-1.415 3 3 0 000-4.242 1 1 0 011.415-1.415zM10 9a1 1 0 011 1v.01a1 1 0 11-2 0V10a1 1 0 011-1z" clip-rule="evenodd"></path></svg>
                  </span>
                  <div class="flex-1 min-w-0">
                    <span class="text-sm font-bold text-[#0d9488]">Water Hand Pump</span>
                    <span class="block text-xs text-[#0d9488]/70">Clean water for 50 families</span>
                  </div>
                  <span class="text-base font-bold text-[#0d9488] flex-shrink-0">$300</span>
                </button>
                <button class="sj-amount-btn group flex items-center gap-3 p-3 border-2 border-gray-200 rounded-xl bg-white hover:border-[#0d9488] hover:bg-[#0d9488]/5 transition-all text-left" data-amount="50" data-project="Cataract Surgery">
                  <span class="w-9 h-9 rounded-lg bg-[#0d9488]/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-[#0d9488]" fill="currentColor" viewBox="0 0 20 20"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path></svg>
                  </span>
                  <div class="flex-1 min-w-0">
                    <span class="text-sm font-bold text-gray-800 group-hover:text-[#0d9488]">Cataract Surgery</span>
                    <span class="block text-xs text-gray-500">Restore someone's sight</span>
                  </div>
                  <span class="text-base font-bold text-[#0d9488] flex-shrink-0">$50</span>
                </button>
              </div>

              <!-- Custom Amount -->
              <div class="relative mb-4">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-bold text-sm">$</span>
                <input
                  type="number"
                  placeholder="Other amount"
                  min="1"
                  class="sj-custom-input w-full pl-7 pr-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm font-semibold text-gray-800 focus:border-[#0d9488] focus:ring-2 focus:ring-[#0d9488]/20 outline-none transition"
                />
              </div>

              <!-- Dedicate toggle -->
              <label class="flex items-center gap-2 mb-3 cursor-pointer group">
                <input type="checkbox" class="sj-dedicate w-4 h-4 text-[#0d9488] border-gray-300 rounded focus:ring-[#0d9488]" />
                <span class="text-sm text-gray-600 group-hover:text-gray-800 transition">Give on behalf of a loved one</span>
              </label>
              <div class="sj-dedicate-name-wrap hidden mb-3">
                <input type="text" placeholder="Name of your loved one" class="sj-dedicate-name w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl text-sm text-gray-800 focus:border-[#0d9488] focus:ring-2 focus:ring-[#0d9488]/20 outline-none transition" />
              </div>

              <!-- Donate Button -->
              <button
                class="sj-donate-btn w-full bg-gradient-to-r from-[#0d9488] to-[#0f766e] hover:from-[#0f766e] hover:to-[#115e59] text-white font-bold py-3.5 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98] flex items-center justify-center gap-2 text-lg sj-pulse"
                style="font-family: 'Signika', sans-serif;"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
                </svg>
                Give Sadaqah Jariyah
              </button>

              <!-- Trust -->
              <div class="flex items-center justify-center gap-2 mt-3">
                <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path></svg>
                <span class="text-xs text-gray-500">Secure · Tax-deductible · Instant receipt</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== IMPACT COUNTER STRIP ===== -->
  <section class="py-5 sm:py-6" style="background: #0a1f21;">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold text-white mb-1" style="font-family: 'Signika', sans-serif;">10,000+</div>
          <div class="text-xs sm:text-sm text-white/50 uppercase tracking-wider" style="font-family: 'Lato', sans-serif;">Lives Impacted</div>
        </div>
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold text-white mb-1" style="font-family: 'Signika', sans-serif;">15+</div>
          <div class="text-xs sm:text-sm text-white/50 uppercase tracking-wider" style="font-family: 'Lato', sans-serif;">Countries</div>
        </div>
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold text-white mb-1" style="font-family: 'Signika', sans-serif;">100%</div>
          <div class="text-xs sm:text-sm text-white/50 uppercase tracking-wider" style="font-family: 'Lato', sans-serif;">Donation Policy</div>
        </div>
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold text-white mb-1" style="font-family: 'Signika', sans-serif;">∞</div>
          <div class="text-xs sm:text-sm text-white/50 uppercase tracking-wider" style="font-family: 'Lato', sans-serif;">Ongoing Reward</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MOBILE DONATION BOX ===== -->
  <section class="lg:hidden py-8 bg-gray-50" id="sj-mobile-donate">
    <div class="max-w-md mx-auto px-4">
      <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
        <div class="bg-gradient-to-r from-[#0d9488] to-[#14b8a6] px-6 py-4 text-center">
          <h3 class="text-xl font-bold text-white mb-0.5" style="font-family: 'Signika', sans-serif;">🌿 Sadaqah Jariyah</h3>
          <p class="text-white/90 text-xs">Ongoing charity · Rewards that never end</p>
        </div>
        <div class="p-5">
          <!-- Frequency -->
          <div class="flex bg-gray-100 rounded-xl p-1 mb-4">
            <button class="sj-freq-btn flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all bg-white text-[#0d9488] shadow-sm" data-freq="single">One-Time</button>
            <button class="sj-freq-btn flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all text-gray-500 hover:text-gray-700" data-freq="monthly">Monthly 💚</button>
          </div>
          <!-- Impact Selection -->
          <label class="block text-sm font-semibold text-gray-700 mb-2">Choose Your Impact</label>
          <div class="flex flex-col gap-2 mb-3">
            <button class="sj-amount-btn group flex items-center gap-3 p-3 border-2 border-gray-200 rounded-xl bg-white hover:border-[#0d9488] hover:bg-[#0d9488]/5 transition-all text-left" data-amount="600" data-project="Orphan Full Year">
              <span class="w-9 h-9 rounded-lg bg-[#0d9488]/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#0d9488]" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"></path></svg>
              </span>
              <div class="flex-1 min-w-0">
                <span class="text-sm font-bold text-gray-800 group-hover:text-[#0d9488]">One Year Orphan Sponsorship</span>
                <span class="block text-xs text-gray-500">Food, school, healthcare — full year</span>
              </div>
              <span class="text-base font-bold text-[#0d9488] flex-shrink-0">$600</span>
            </button>
            <button class="sj-amount-btn group flex items-center gap-3 p-3 border-2 border-[#0d9488] rounded-xl bg-[#0d9488]/5 transition-all text-left relative" data-amount="300" data-project="Water Hand Pump">
              <span class="absolute -top-2 -right-2 bg-[#0d9488] text-white text-[10px] font-bold px-2 py-0.5 rounded-full">Popular</span>
              <span class="w-9 h-9 rounded-lg bg-[#0d9488]/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#0d9488]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 3.636a1 1 0 010 1.414 7 7 0 000 9.9 1 1 0 11-1.414 1.414 9 9 0 010-12.728 1 1 0 011.414 0zm9.9 0a9 9 0 010 12.728 1 1 0 11-1.414-1.414 7 7 0 000-9.9 1 1 0 011.414-1.414zM7.879 6.464a1 1 0 010 1.414 3 3 0 000 4.243 1 1 0 11-1.415 1.414 5 5 0 010-7.07 1 1 0 011.415 0zm4.242 0a5 5 0 010 7.072 1 1 0 01-1.415-1.415 3 3 0 000-4.242 1 1 0 011.415-1.415zM10 9a1 1 0 011 1v.01a1 1 0 11-2 0V10a1 1 0 011-1z" clip-rule="evenodd"></path></svg>
              </span>
              <div class="flex-1 min-w-0">
                <span class="text-sm font-bold text-[#0d9488]">Water Hand Pump</span>
                <span class="block text-xs text-[#0d9488]/70">Clean water for 50 families</span>
              </div>
              <span class="text-base font-bold text-[#0d9488] flex-shrink-0">$300</span>
            </button>
            <button class="sj-amount-btn group flex items-center gap-3 p-3 border-2 border-gray-200 rounded-xl bg-white hover:border-[#0d9488] hover:bg-[#0d9488]/5 transition-all text-left" data-amount="50" data-project="Cataract Surgery">
              <span class="w-9 h-9 rounded-lg bg-[#0d9488]/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#0d9488]" fill="currentColor" viewBox="0 0 20 20"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path></svg>
              </span>
              <div class="flex-1 min-w-0">
                <span class="text-sm font-bold text-gray-800 group-hover:text-[#0d9488]">Cataract Surgery</span>
                <span class="block text-xs text-gray-500">Restore someone's sight</span>
              </div>
              <span class="text-base font-bold text-[#0d9488] flex-shrink-0">$50</span>
            </button>
          </div>
          <!-- Custom -->
