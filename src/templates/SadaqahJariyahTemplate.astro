<script>
  document.addEventListener('DOMContentLoaded', () => {
    // State
    let selectedAmount = 300;
    let selectedProject = 'Water Hand Pump';
    let frequency: 'single' | 'monthly' = 'single';

    // Elements
    const amountButtons = document.querySelectorAll('.sj-amount-btn');
    const customInputs = document.querySelectorAll('.sj-custom-input');
    const freqButtons = document.querySelectorAll('.sj-freq-btn');
    const donateButtons = document.querySelectorAll('.sj-donate-btn');
    const projectDonateButtons = document.querySelectorAll('.sj-project-donate');
    const ctaButtons = document.querySelectorAll('.sj-cta-donate');
    const dedicateChecks = document.querySelectorAll('.sj-dedicate') as NodeListOf<HTMLInputElement>;
    const dedicateWraps = document.querySelectorAll('.sj-dedicate-name-wrap');
    const dedicateNames = document.querySelectorAll('.sj-dedicate-name') as NodeListOf<HTMLInputElement>;
    const stickyBar = document.getElementById('sj-sticky-bar');
    const mobileBox = document.getElementById('sj-mobile-donate');

    function highlightAmountButtons() {
      amountButtons.forEach(btn => {
        const amt = parseInt(btn.getAttribute('data-amount') || '0');
        const isActive = amt === selectedAmount;

        // Reset
        btn.classList.remove('border-[#0d9488]', 'bg-[#0d9488]/5');
        btn.classList.add('border-gray-200');

        // Find the title and subtitle spans inside the flex-1 div
        const titleSpan = btn.querySelector('.flex-1 .text-sm');
        const subtitleSpan = btn.querySelector('.flex-1 .text-xs');

        if (isActive) {
          btn.classList.add('border-[#0d9488]', 'bg-[#0d9488]/5');
          btn.classList.remove('border-gray-200');
          if (titleSpan) { titleSpan.classList.add('text-[#0d9488]'); titleSpan.classList.remove('text-gray-800'); }
          if (subtitleSpan) { subtitleSpan.classList.add('text-[#0d9488]/70'); subtitleSpan.classList.remove('text-gray-500'); }
        } else {
          if (titleSpan) { titleSpan.classList.remove('text-[#0d9488]'); titleSpan.classList.add('text-gray-800'); }
          if (subtitleSpan) { subtitleSpan.classList.remove('text-[#0d9488]/70'); subtitleSpan.classList.add('text-gray-500'); }
        }
      });
    }

    function highlightFreqButtons() {
      freqButtons.forEach(btn => {
        const freq = btn.getAttribute('data-freq');
        btn.classList.remove('bg-white', 'text-[#0d9488]', 'shadow-sm');
        btn.classList.add('text-gray-500');
        if (freq === frequency) {
          btn.classList.add('bg-white', 'text-[#0d9488]', 'shadow-sm');
          btn.classList.remove('text-gray-500');
        }
      });
    }

    // Amount clicks
    amountButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        selectedAmount = parseInt(btn.getAttribute('data-amount') || '300');
        selectedProject = btn.getAttribute('data-project') || 'General';
        customInputs.forEach(input => (input as HTMLInputElement).value = '');
        highlightAmountButtons();
      });
    });

    // Custom amount
    customInputs.forEach(input => {
      input.addEventListener('input', () => {
        const val = parseInt((input as HTMLInputElement).value);
        if (val && val > 0) {
          selectedAmount = val;
          selectedProject = 'General';
          customInputs.forEach(other => {
            if (other !== input) (other as HTMLInputElement).value = val.toString();
          });
          highlightAmountButtons();
        }
      });
    });

    // Frequency toggle
    freqButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        frequency = (btn.getAttribute('data-freq') as 'single' | 'monthly') || 'single';
        highlightFreqButtons();
      });
    });

    // Dedicate toggles (sync)
    dedicateChecks.forEach(cb => {
      cb.addEventListener('change', () => {
        dedicateChecks.forEach(other => other.checked = cb.checked);
        dedicateWraps.forEach(wrap => wrap.classList.toggle('hidden', !cb.checked));
      });
    });

    // Add to cart function
    function addToCart(name: string, amount: number, freq?: string) {
      if (amount < 1) return;
      const dedicateName = Array.from(dedicateNames).find(el => el.value)?.value || '';
      let description = `Sadaqah Jariyah — ${name}`;
      if (dedicateName) description += ` (In memory of ${dedicateName})`;

      if (typeof (window as any).addToCart === 'function') {
        (window as any).addToCart({
          id: `sadaqah-jariyah-${Date.now()}`,
          type: 'donation',
          name: `Sadaqah Jariyah - ${name}`,
          amount: amount,
          quantity: 1,
          description: description,
          frequency: (freq || frequency) === 'monthly' ? 'monthly' : 'single'
        });
      }
    }

    // Main donate buttons
    donateButtons.forEach(btn => {
      btn.addEventListener('click', () => addToCart(selectedProject, selectedAmount));
    });

    // Project donate buttons
    projectDonateButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const project = btn.getAttribute('data-project') || 'General';
        const amount = parseInt(btn.getAttribute('data-amount') || '50');
        const freq = btn.getAttribute('data-freq') || 'single';
        addToCart(project, amount, freq);
      });
    });

    // CTA buttons — scroll to donation box
    ctaButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = document.getElementById('sj-mobile-donate') || document.getElementById('sj-desktop-donate');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          addToCart('General', selectedAmount);
        }
      });
    });

    // Mobile sticky bar — show when mobile donation box scrolls out of view
    if (stickyBar && mobileBox) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            stickyBar.classList.add('translate-y-full');
          } else {
            stickyBar.classList.remove('translate-y-full');
          }
        },
        { threshold: 0.1 }
      );
      observer.observe(mobileBox);
    }

    // Init
    highlightAmountButtons();
    highlightFreqButtons();
  });
</script>
