        </p>

        <!-- Toggle card -->
        <div id="sadaqah-toggle-card" class="rounded-lg p-4 mb-5 border border-gray-200 cursor-pointer transition-all" style="background-color: #f9f9f7;" onclick="toggleSadaqah()">
          <div class="flex items-center gap-3">
            <!-- Toggle switch -->
            <button type="button" id="sadaqah-toggle" class="relative w-14 h-7 rounded-full bg-gray-300 transition-colors flex-shrink-0" role="switch" aria-checked="false">
              <span id="sadaqah-toggle-dot" class="absolute top-0.5 left-0.5 w-6 h-6 bg-white rounded-full shadow-md transition-transform flex items-center justify-center">
                <svg id="sadaqah-toggle-x" class="w-3 h-3 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
                <svg id="sadaqah-toggle-check" class="w-3.5 h-3.5 text-white hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
            </button>
            <span id="sadaqah-toggle-label" class="text-sm font-semibold text-gray-700">
              Add $50 Sadaqah
            </span>
          </div>
          <p id="sadaqah-toggle-desc" class="text-xs text-gray-400 mt-2.5 leading-relaxed">
            A beautiful Sunnah practice. Your Sadaqah will provide food, clean water, or education for those in need.
          </p>
        </div>

        <!-- CTA Button -->
        <button
          id="sadaqah-cta-btn"
          onclick="confirmSadaqahAndCheckout()"
          class="w-full py-4 rounded-xl font-extrabold text-[15px] uppercase tracking-[0.1em] transition-all active:scale-[0.99] text-white"
          style="background-color: #e1861d; font-family: 'Signika', sans-serif;"
        >
          CONTINUE
        </button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ campaignSlug: campaign.slug, campaignTitle: campaign.title }}>
    // Track campaign page view in GA4
    if (window.trackViewItem) {
      window.trackViewItem({
        id: campaignSlug,
        name: campaignTitle,
        slug: campaignSlug,
        campaign: campaignSlug,
        amount: 0
      });
    }
  </script>

  <script is:inline>
    // Store pending Aqiqah details for the upsell flow
    let pendingAqiqah = null;

    // FAQ Accordion
    document.querySelectorAll('.faq-toggle').forEach(button => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling;
        const icon = button.querySelector('.faq-icon');

        // Close all others
        document.querySelectorAll('.faq-content').forEach(c => {
          if (c !== content) {
            c.classList.add('hidden');
            c.previousElementSibling.querySelector('.faq-icon').classList.remove('rotate-180');
          }
        });

        // Toggle current
        content.classList.toggle('hidden');
        icon.classList.toggle('rotate-180');
      });
    });

    // Package Selection
    function selectAqiqahPackage(type, name, price) {
      // If selecting Sadaqah directly, add to cart immediately
      if (type === 'sadaqah') {
        if (typeof window.addToCart === 'function') {
          window.addToCart({
            id: `sadaqah-${Date.now()}`,
            name: 'Sadaqah',
            amount: price,
            type: 'single',
            campaign: 'aqiqah',
            label: 'Sadaqah',
            metadata: {
              type: 'sadaqah',
              description: 'Charity on behalf of child'
            }
          });
        }
        // Open cart
        if (typeof window.openCart === 'function') {
          window.openCart();
        }
        return;
      }

      document.getElementById('modal-package-name').textContent = name + ' Aqiqah';
      document.getElementById('modal-package-price-display').textContent = '$' + price;
      document.getElementById('package-type').value = type;
      document.getElementById('package-amount').value = price;

      const modal = document.getElementById('aqiqah-modal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeAqiqahModal() {
      const modal = document.getElementById('aqiqah-modal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    function closeSadaqahModal() {
      const modal = document.getElementById('sadaqah-modal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      pendingAqiqah = null;
    }

    function editAqiqahDetails() {
      // Close the sadaqah upsell modal
      const sadaqahModal = document.getElementById('sadaqah-modal');
      sadaqahModal.classList.add('hidden');
      sadaqahModal.classList.remove('flex');

      // Re-populate the first modal with pending data
      if (pendingAqiqah) {
        const pkgName = pendingAqiqah.packageType === 'boy' ? 'Baby Boy' : 'Baby Girl';
        document.getElementById('modal-package-name').textContent = pkgName + ' Aqiqah';
        document.getElementById('modal-package-price-display').textContent = '$' + pendingAqiqah.amount;
        document.getElementById('package-type').value = pendingAqiqah.packageType;
        document.getElementById('package-amount').value = pendingAqiqah.amount;
        document.getElementById('child-name').value = pendingAqiqah.childName || '';
        document.getElementById('aqiqah-for').value = pendingAqiqah.aqiqahFor || 'child';
        document.getElementById('special-notes').value = pendingAqiqah.notes || '';
      }

      // Show the first modal
      const aqiqahModal = document.getElementById('aqiqah-modal');
      aqiqahModal.classList.remove('hidden');
      aqiqahModal.classList.add('flex');
    }

    // Sadaqah toggle state
    let sadaqahToggleOn = false;
    const SADAQAH_AMOUNT = 50;

    function toggleSadaqah() {
      sadaqahToggleOn = !sadaqahToggleOn;
      const toggle = document.getElementById('sadaqah-toggle');
      const dot = document.getElementById('sadaqah-toggle-dot');
      const xIcon = document.getElementById('sadaqah-toggle-x');
      const checkIcon = document.getElementById('sadaqah-toggle-check');
      const card = document.getElementById('sadaqah-toggle-card');
      const ctaBtn = document.getElementById('sadaqah-cta-btn');

      const amountEl = document.getElementById('sadaqah-aqiqah-amount');
      const baseAmount = pendingAqiqah ? pendingAqiqah.amount : 0;

      if (sadaqahToggleOn) {
        toggle.style.backgroundColor = '#e1861d';
        dot.style.transform = 'translateX(28px)';
        xIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');
        card.style.borderColor = '#e1861d';
        card.style.backgroundColor = '#fef3e2';
        const totalAmount = baseAmount + SADAQAH_AMOUNT;
        ctaBtn.textContent = 'GIVE $' + totalAmount;
        if (amountEl) amountEl.textContent = '$' + totalAmount;
      } else {
        toggle.style.backgroundColor = '';
        dot.style.transform = '';
        xIcon.classList.remove('hidden');
        checkIcon.classList.add('hidden');
        card.style.borderColor = '';
        card.style.backgroundColor = '#f9f9f7';
        ctaBtn.textContent = 'GIVE $' + baseAmount;
        if (amountEl) amountEl.textContent = '$' + baseAmount;
      }
    }

    function showSadaqahUpsell() {
      // Reset toggle state
      sadaqahToggleOn = false;
      const toggle = document.getElementById('sadaqah-toggle');
      const dot = document.getElementById('sadaqah-toggle-dot');
      const xIcon = document.getElementById('sadaqah-toggle-x');
      const checkIcon = document.getElementById('sadaqah-toggle-check');
      const card = document.getElementById('sadaqah-toggle-card');
      if (toggle) { toggle.style.backgroundColor = ''; }
      if (dot) { dot.style.transform = ''; }
      if (xIcon) { xIcon.classList.remove('hidden'); }
      if (checkIcon) { checkIcon.classList.add('hidden'); }
      if (card) { card.style.borderColor = ''; card.style.backgroundColor = '#f9f9f7'; }

      // Set the Aqiqah amount in the top bar
      const amountEl = document.getElementById('sadaqah-aqiqah-amount');
      if (amountEl && pendingAqiqah) {
        amountEl.textContent = '$' + pendingAqiqah.amount;
      }

      // Set CTA button text
      const ctaBtn = document.getElementById('sadaqah-cta-btn');
      if (ctaBtn && pendingAqiqah) {
        ctaBtn.textContent = 'GIVE $' + pendingAqiqah.amount;
      }

      // Set dynamic toggle label based on who aqiqah is for
      const toggleLabel = document.getElementById('sadaqah-toggle-label');
      if (toggleLabel && pendingAqiqah) {
        const forText = pendingAqiqah.aqiqahFor === 'self' ? 'for myself'
          : pendingAqiqah.aqiqahFor === 'other' ? 'for ' + (pendingAqiqah.childName || 'them')
          : 'for ' + (pendingAqiqah.childName || 'my child');
        toggleLabel.textContent = 'Add $' + SADAQAH_AMOUNT + ' Sadaqah ' + forText;
      }

      const modal = document.getElementById('sadaqah-modal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function confirmSadaqahAndCheckout() {
      if (sadaqahToggleOn) {
        addSadaqahAndCheckout();
      } else {
        skipSadaqahAndCheckout();
      }
    }

    function addAqiqahToCart() {
      if (!pendingAqiqah) return;

      const { childName, packageType, amount, aqiqahFor, notes } = pendingAqiqah;
      const packageLabel = packageType === 'boy' ? 'Baby Boy' : 'Baby Girl';

      if (typeof window.addToCart === 'function') {
        window.addToCart({
          id: `aqiqah-${packageType}-${Date.now()}`,
          name: `Aqiqah for ${childName}`,
          amount: amount,
          type: 'single',
          campaign: 'aqiqah',
          label: `Aqiqah (${packageLabel})`,
          metadata: {
            childName: childName,
            packageType: packageType,
            aqiqahFor: aqiqahFor,
            notes: notes,
            service: 'aqiqah'
          }
        });
      }
    }

    function addSadaqahAndCheckout() {
      // First add the Aqiqah
      addAqiqahToCart();

      // Then add Sadaqah
      if (typeof window.addToCart === 'function') {
        window.addToCart({
          id: `sadaqah-${Date.now()}`,
          name: pendingAqiqah.aqiqahFor === 'self' ? 'Sadaqah for myself' : `Sadaqah for ${pendingAqiqah.childName}`,
          amount: SADAQAH_AMOUNT,
          type: 'single',
          campaign: 'aqiqah',
          label: 'Sadaqah',
          metadata: {
            childName: pendingAqiqah.childName,
            type: 'sadaqah',
            description: 'Charity on behalf of child'
          }
        });
      }

      closeSadaqahModal();
      pendingAqiqah = null;

      // Open cart
      if (typeof window.openCart === 'function') {
        window.openCart();
      }
    }

    function skipSadaqahAndCheckout() {
      // Just add the Aqiqah
      addAqiqahToCart();

      closeSadaqahModal();
      pendingAqiqah = null;

      // Open cart
      if (typeof window.openCart === 'function') {
        window.openCart();
      }
    }

    // Close modal on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeAqiqahModal();
        closeSadaqahModal();
      }
    });

    // Close modal on backdrop click
    document.getElementById('aqiqah-modal').addEventListener('click', (e) => {
      if (e.target.id === 'aqiqah-modal') closeAqiqahModal();
    });

    document.getElementById('sadaqah-modal').addEventListener('click', (e) => {
      if (e.target.id === 'sadaqah-modal') closeSadaqahModal();
    });

    // Hide sticky mobile CTA when packages section is visible
    (function() {
      const packagesSection = document.getElementById('packages');
      const stickyBar = document.getElementById('mobile-sticky-cta');
      if (!packagesSection || !stickyBar) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            stickyBar.style.transform = 'translateY(100%)';
          } else {
            stickyBar.style.transform = 'translateY(0)';
          }
        });
      }, { threshold: 0.1 });

      observer.observe(packagesSection);
    })();

    // Form submission - Step 1: Collect details, then show Sadaqah upsell
    document.getElementById('aqiqah-form').addEventListener('submit', (e) => {
      e.preventDefault();

      const childName = document.getElementById('child-name').value;
      const packageType = document.getElementById('package-type').value;
      const amount = parseInt(document.getElementById('package-amount').value);
      const aqiqahFor = document.getElementById('aqiqah-for').value;
      const notes = document.getElementById('special-notes').value;

      // Store details for the upsell flow
      pendingAqiqah = {
        childName,
        packageType,
        amount,
        aqiqahFor,
        notes
      };

      // Close first modal
      closeAqiqahModal();

      // Clear form
      document.getElementById('aqiqah-form').reset();

      // Show Sadaqah upsell modal
      showSadaqahUpsell();
    });
  </script>

  <!-- FAQ Structured Data for Google Rich Results -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
