    25% { box-shadow: 0 0 20px 8px rgba(217, 119, 6, 0.4); transform: scale(1.03); }
    50% { box-shadow: 0 0 0 0 rgba(217, 119, 6, 0.2); transform: scale(1); }
    75% { box-shadow: 0 0 20px 8px rgba(217, 119, 6, 0.4); transform: scale(1.03); }
