---
/**
 * TILE STACK SPONSORSHIP TEMPLATE
 * Inspired by Penny Appeal OrphanKind & Ramadan 30-day program
 *
 * Features:
 * - Tile-based quantity selection (1, 2, 3, 5, 10 children)
 * - Visual stacking effect
 * - Social proof ("Most sponsors choose 2 children")
 * - Country selection
 * - Impact multiplier visualization
 * - Animated selection feedback
 */

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  campaign: {
    id: string;
    title: string;
    subtitle?: string;
    slug: string;
    featured_image?: string;
    description?: string;
    goal_amount?: number;
    raised_amount?: number;
    is_zakat_eligible?: boolean;
    template_config?: Record<string, unknown>;
  };
  donationBoxTemplate?: string;
}

const { campaign, donationBoxTemplate } = Astro.props;

// Base price per child per month (default $45)
const defaultBasePrice = 45;

// Merge saved pricing overrides from template_config (admin-editable)
// orphanPricing stores per-country monthly/yearly; we derive basePrice from pakistan's monthly
const savedOrphanPricing = (campaign.template_config?.orphanPricing || {}) as Record<string, { monthly?: number; yearly?: number }>;
const effectiveBasePrice = savedOrphanPricing?.pakistan?.monthly || defaultBasePrice;

// Sponsorship quantity tiles with social proof — dynamically computed from base price
const quantityTiles = [
  { qty: 1, label: '1 Child', monthly: effectiveBasePrice * 1, badge: null, popularity: 15 },
  { qty: 2, label: '2 Children', monthly: effectiveBasePrice * 2, badge: 'Most Popular', popularity: 45 },
  { qty: 3, label: '3 Children', monthly: effectiveBasePrice * 3, badge: null, popularity: 25 },
  { qty: 5, label: '5 Children', monthly: effectiveBasePrice * 5, badge: 'Best Impact', popularity: 10 },
  { qty: 10, label: '10 Children', monthly: effectiveBasePrice * 10, badge: null, popularity: 5 },
];

// Countries available — derive multipliers from saved pricing
const countries = [
  { id: 'general', name: 'Greatest Need', flag: '🌍', priceMultiplier: (savedOrphanPricing?.general?.monthly || defaultBasePrice) / effectiveBasePrice, popular: true },
  { id: 'pakistan', name: 'Pakistan', flag: '🇵🇰', priceMultiplier: (savedOrphanPricing?.pakistan?.monthly || defaultBasePrice) / effectiveBasePrice },
  { id: 'palestine', name: 'Palestine', flag: '🇵🇸', priceMultiplier: (savedOrphanPricing?.palestine?.monthly || defaultBasePrice) / effectiveBasePrice, urgent: true },
  { id: 'yemen', name: 'Yemen', flag: '🇾🇪', priceMultiplier: (savedOrphanPricing?.yemen?.monthly || Math.round(defaultBasePrice * 0.89)) / effectiveBasePrice },
  { id: 'syria', name: 'Syria', flag: '🇸🇾', priceMultiplier: (savedOrphanPricing?.syria?.monthly || defaultBasePrice) / effectiveBasePrice },
  { id: 'afghanistan', name: 'Afghanistan', flag: '🇦🇫', priceMultiplier: (savedOrphanPricing?.afghanistan?.monthly || Math.round(defaultBasePrice * 0.89)) / effectiveBasePrice },
  { id: 'iraq', name: 'Iraq', flag: '🇮🇶', priceMultiplier: (savedOrphanPricing?.iraq?.monthly || Math.round(defaultBasePrice * 0.89)) / effectiveBasePrice },
  { id: 'lebanon', name: 'Lebanon', flag: '🇱🇧', priceMultiplier: (savedOrphanPricing?.lebanon?.monthly || Math.round(defaultBasePrice * 0.89)) / effectiveBasePrice },
  { id: 'macedonia', name: 'Macedonia', flag: '🇲🇰', priceMultiplier: (savedOrphanPricing?.macedonia?.monthly || Math.round(defaultBasePrice * 0.89)) / effectiveBasePrice },
  { id: 'morocco', name: 'Morocco', flag: '🇲🇦', priceMultiplier: (savedOrphanPricing?.morocco?.monthly || Math.round(defaultBasePrice * 0.89)) / effectiveBasePrice },
  { id: 'somalia', name: 'Somalia', flag: '🇸🇴', priceMultiplier: (savedOrphanPricing?.somalia?.monthly || Math.round(defaultBasePrice * 0.89)) / effectiveBasePrice },
  { id: 'sri-lanka', name: 'Sri Lanka', flag: '🇱🇰', priceMultiplier: (savedOrphanPricing?.['sri-lanka']?.monthly || Math.round(defaultBasePrice * 0.89)) / effectiveBasePrice },
  { id: 'sudan', name: 'Sudan', flag: '🇸🇩', priceMultiplier: (savedOrphanPricing?.sudan?.monthly || Math.round(defaultBasePrice * 0.89)) / effectiveBasePrice },
  { id: 'tunisia', name: 'Tunisia', flag: '🇹🇳', priceMultiplier: (savedOrphanPricing?.tunisia?.monthly || Math.round(defaultBasePrice * 0.89)) / effectiveBasePrice },
  { id: 'turkey', name: 'Türkiye (Turkey)', flag: '🇹🇷', priceMultiplier: (savedOrphanPricing?.turkey?.monthly || Math.round(defaultBasePrice * 0.89)) / effectiveBasePrice },
];

// What each sponsorship provides
const benefits = [
  { icon: 'book', label: 'Education' },
  { icon: 'utensils', label: 'Food' },
  { icon: 'heart', label: 'Healthcare' },
  { icon: 'home', label: 'Shelter' },
  { icon: 'shirt', label: 'Clothing' },
  { icon: 'smile', label: 'Love & Care' },
];

// Recent sponsors will be handled dynamically via JavaScript
---

<Layout
  title="Sponsor Orphans | Choose How Many Lives to Change | Qurbani Foundation"
  description="Sponsor 1, 2, 3 or more orphans. Most sponsors choose 2 children. 100% Zakat eligible. See the impact multiply."
>
  <Navbar />

  <main class="bg-gray-50 min-h-screen">
    <!-- Hero Section -->
    <section class="relative pt-36 pb-16 md:pt-40 md:pb-20 overflow-hidden min-h-[450px] md:min-h-[520px]">
      <!-- Background Image -->
      <div class="absolute inset-0">
        <img
          src="/images/palestine-orphan-sponsorship-qurbani-foundation.png"
          alt="Palestine orphan sponsorship - Qurbani Foundation"
          class="w-full h-full object-cover object-[center_25%]"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-transparent"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-6">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4" style="font-family: 'Signika', sans-serif;">
            How Many Lives Will<br /><span class="text-[#ef7c01]">You Change?</span>
          </h1>

          <p class="text-xl text-white/90 max-w-2xl mx-auto mb-2">
            Join <strong class="text-white">15,847 sponsors</strong> who are transforming orphans' futures
          </p>

          <p class="text-white/70 text-sm">
            Most sponsors choose to support <strong class="text-[#ef7c01]">2-3 children</strong>
          </p>
        </div>

        <!-- Sponsor Button with Down Arrow -->
        <div class="flex justify-center">
          <button type="button" id="hero-cta-btn" class="group inline-flex items-center gap-3 bg-[#d97706] hover:bg-[#b45309] text-white font-bold py-3 px-6 rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl">
            <span class="text-base" style="font-family: 'Signika', sans-serif;">Give an Orphan Hope This Ramadan</span>
            <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </button>
        </div>
      </div>
    </section>

    <!-- Main Selection Area -->
    <section id="donate" class="py-12 -mt-8">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-3 gap-8">

            <!-- Step 1: Choose Country -->
            <div id="region-section" class="lg:col-span-2 bg-white rounded-2xl shadow-sm transition-all duration-300 overflow-hidden">
              <!-- Mobile: Clean card with radio-style list -->
              <div class="md:hidden">
                <div class="px-5 pt-5 pb-3">
                  <div class="flex items-center justify-between">
                    <h2 class="text-base font-bold text-gray-900" style="font-family: 'Signika', sans-serif;">Where would you like to Sponsor?</h2>
                    <span class="text-[10px] text-gray-400 uppercase tracking-wider">Step 1</span>
                  </div>
                </div>
                <div class="divide-y divide-gray-100">
                  {countries.slice(0, 3).map((country) => (
                    <button
                      type="button"
                      class="country-btn w-full flex items-center gap-3.5 px-5 py-3.5 transition-all text-left active:bg-gray-50 border-l-4 border-l-transparent"
                      data-country={country.id}
                      data-multiplier={country.priceMultiplier}
                      data-name={country.name}
                      data-flag={country.flag}
                    >
                      <span class="text-[26px] leading-none">{country.flag}</span>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                          <span class="text-[15px] font-semibold text-gray-900">{country.name}</span>
                          {country.popular && <span class="bg-[#ef7c01] text-white text-[8px] px-1.5 py-0.5 rounded font-bold uppercase">Popular</span>}
                          {country.urgent && <span class="bg-red-500 text-white text-[8px] px-1.5 py-0.5 rounded font-bold uppercase">Urgent</span>}
                        </div>
                        <span class="text-[11px] text-gray-400">from ${Math.round(effectiveBasePrice * country.priceMultiplier)}/mo per child</span>
                      </div>
                      <div class="w-5 h-5 rounded-full border-2 border-gray-300 shrink-0 flex items-center justify-center country-radio transition-all">
                      </div>
                    </button>
                  ))}
                </div>
                <!-- More countries -->
                <div id="more-countries-mobile" class="hidden divide-y divide-gray-100 border-t border-gray-100">
                  {countries.slice(3).map((country) => (
                    <button
                      type="button"
                      class="country-btn w-full flex items-center gap-3.5 px-5 py-3.5 transition-all text-left active:bg-gray-50 border-l-4 border-l-transparent"
                      data-country={country.id}
                      data-multiplier={country.priceMultiplier}
                      data-name={country.name}
                      data-flag={country.flag}
                    >
                      <span class="text-[26px] leading-none">{country.flag}</span>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                          <span class="text-[15px] font-semibold text-gray-900">{country.name}</span>
                          {country.popular && <span class="bg-[#ef7c01] text-white text-[8px] px-1.5 py-0.5 rounded font-bold uppercase">Popular</span>}
                          {country.urgent && <span class="bg-red-500 text-white text-[8px] px-1.5 py-0.5 rounded font-bold uppercase">Urgent</span>}
                        </div>
                        <span class="text-[11px] text-gray-400">from ${Math.round(effectiveBasePrice * country.priceMultiplier)}/mo per child</span>
                      </div>
                      <div class="w-5 h-5 rounded-full border-2 border-gray-300 shrink-0 flex items-center justify-center country-radio transition-all">
                      </div>
                    </button>
                  ))}
                </div>
                <button
                  type="button"
                  class="show-more-countries-btn w-full flex items-center justify-center gap-1.5 text-[13px] font-semibold text-[#d97706] py-3 border-t border-gray-100 transition-colors active:bg-gray-50"
                >
                  <span class="more-text">+{countries.length - 3} more countries</span>
                  <svg class="more-icon w-3.5 h-3.5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
              </div>

              <!-- Desktop -->
              <div class="hidden md:block p-6">
                <div class="flex items-center gap-3 mb-4">
                  <div id="step-1-badge" class="w-8 h-8 bg-[#d97706] rounded-full flex items-center justify-center text-white font-bold text-sm transition-all duration-300">1</div>
                  <h2 class="text-lg font-bold text-gray-800" style="font-family: 'Signika', sans-serif;">Choose a Region</h2>
                </div>
                <div class="grid grid-cols-5 gap-3" id="country-selector-desktop">
                  {countries.slice(0, 5).map((country) => (
                    <button
                      type="button"
                      class="country-btn relative p-4 rounded-xl border-2 transition-all cursor-pointer hover:shadow-md border-gray-200 hover:border-[#d97706] hover:bg-[#d97706]/5 text-center"
                      data-country={country.id}
                      data-multiplier={country.priceMultiplier}
                      data-name={country.name}
                      data-flag={country.flag}
                    >
                      {country.urgent && <span class="absolute -top-2 -right-1 bg-red-500 text-white text-[10px] px-1.5 py-0.5 rounded-full font-bold">URGENT</span>}
                      {country.popular && <span class="absolute -top-2 -right-1 bg-[#ef7c01] text-white text-[10px] px-1.5 py-0.5 rounded-full font-bold">POPULAR</span>}
                      <div class="text-2xl mb-1">{country.flag}</div>
                      <div class="text-xs font-medium text-gray-700">{country.name}</div>
                    </button>
                  ))}
                </div>
                <div id="more-countries" class="hidden md:grid-cols-5 md:gap-3 mt-3">
                  {countries.slice(5).map((country) => (
                    <button
                      type="button"
                      class="country-btn relative p-4 rounded-xl border-2 transition-all cursor-pointer hover:shadow-md border-gray-200 hover:border-[#d97706] hover:bg-[#d97706]/5 text-center"
                      data-country={country.id}
                      data-multiplier={country.priceMultiplier}
                      data-name={country.name}
                      data-flag={country.flag}
                    >
                      {country.urgent && <span class="absolute -top-2 -right-1 bg-red-500 text-white text-[10px] px-1.5 py-0.5 rounded-full font-bold">URGENT</span>}
                      {country.popular && <span class="absolute -top-2 -right-1 bg-[#ef7c01] text-white text-[10px] px-1.5 py-0.5 rounded-full font-bold">POPULAR</span>}
                      <div class="text-2xl mb-1">{country.flag}</div>
                      <div class="text-xs font-medium text-gray-700">{country.name}</div>
                    </button>
                  ))}
                </div>
                <button
                  type="button"
                  id="show-more-countries"
                  class="mt-3 w-full flex items-center justify-center gap-2 text-sm font-medium text-[#d97706] hover:text-[#b45309] py-2 transition-colors"
                >
                  <span class="more-text">More countries</span>
                  <svg class="more-icon w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
              </div>
            </div>

            <!-- Step 2: How Many Children -->
            <div id="quantity-section" class="lg:col-span-2 bg-white rounded-2xl shadow-sm transition-all duration-300 overflow-hidden">
              <!-- Mobile: Number selector circles + dynamic summary -->
              <div class="md:hidden">
                <div class="px-5 pt-5 pb-3">
                  <div class="flex items-center justify-between">
                    <h2 class="text-base font-bold text-gray-900" style="font-family: 'Signika', sans-serif;">How many children?</h2>
                    <span class="text-[10px] text-gray-400 uppercase tracking-wider">Step 2</span>
                  </div>
                  <p class="text-[11px] text-gray-400 mt-0.5">Most sponsors choose <strong class="text-[#d97706]">2 children</strong></p>
                </div>
                <!-- Number circles -->
                <div class="flex justify-center gap-3 px-5 pb-4">
                  {quantityTiles.map((tile) => (
                    <button
                      type="button"
                      class="qty-tile w-14 h-14 rounded-full border-2 border-gray-200 bg-white flex flex-col items-center justify-center transition-all active:scale-95 relative"
                      data-qty={tile.qty}
                      data-monthly={tile.monthly}
                    >
                      {tile.badge === 'Most Popular' && (
                        <span class="absolute -top-1.5 left-1/2 -translate-x-1/2 bg-[#fdc448] text-[#61470e] text-[7px] px-1 py-0 rounded font-bold whitespace-nowrap leading-tight">POPULAR</span>
                      )}
                      <span class="text-lg font-bold text-gray-700 leading-none qty-number">{tile.qty}</span>
                      <span class="text-[8px] text-gray-400 leading-none mt-0.5 qty-label">{tile.qty === 1 ? 'child' : 'children'}</span>
                    </button>
                  ))}
                </div>
                <!-- Dynamic price summary -->
                <div id="mobile-price-summary" class="mx-5 mb-4 bg-gradient-to-r from-[#d97706]/5 to-[#fdc448]/5 rounded-xl p-4 text-center border border-[#d97706]/10 hidden">
                  <div class="text-2xl font-bold text-[#d97706]" id="mobile-total-price" style="font-family: 'Signika', sans-serif;">$90/mo</div>
                  <div class="text-xs text-gray-500 mt-0.5" id="mobile-price-detail">2 children × $45/mo</div>
                  <div class="text-[11px] text-gray-400 mt-1" id="mobile-daily-price">That's just $1.50/day per child</div>
                </div>
              </div>

              <!-- Desktop -->
              <div class="hidden md:block p-6">
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div id="step-2-badge" class="w-8 h-8 bg-[#d97706] rounded-full flex items-center justify-center text-white font-bold text-sm transition-all duration-300">2</div>
                    <h2 class="text-lg font-bold text-gray-800" style="font-family: 'Signika', sans-serif;">How Many Children?</h2>
                  </div>
                  <div class="text-sm text-gray-500">
                    <span class="text-[#d97706] font-semibold">45%</span> choose 2 children
                  </div>
                </div>
                <div class="grid grid-cols-5 gap-3" id="quantity-tiles">
                  {quantityTiles.map((tile, i) => (
                    <button
                      type="button"
                      class="qty-tile relative p-4 rounded-xl border-2 transition-all cursor-pointer hover:shadow-lg hover:-translate-y-1 border-gray-200 hover:border-[#d97706] hover:bg-[#d97706]/5"
                      data-qty={tile.qty}
                      data-monthly={tile.monthly}
                    >
                      {tile.badge && (
                        <span class={`absolute -top-2 left-1/2 -translate-x-1/2 text-[10px] px-2 py-0.5 rounded-full font-bold whitespace-nowrap ${tile.badge === 'Most Popular' ? 'bg-[#fdc448] text-[#61470e]' : tile.badge === 'Best Impact' ? 'bg-[#d97706] text-white' : 'bg-purple-500 text-white'}`}>
                          {tile.badge}
                        </span>
                      )}
                      <div class="flex justify-center items-end mb-2 h-12 gap-0.5">
                        {Array.from({ length: Math.min(tile.qty, 5) }).map((_, idx) => (
                          <svg class="w-6 h-10 text-gray-700" fill="currentColor" viewBox="0 0 24 24" style={`opacity: ${1 - idx * 0.12};`}>
                            <circle cx="12" cy="4" r="3"/><path d="M12 8c-3.5 0-6 2.5-6 6v6h3v-4h6v4h3v-6c0-3.5-2.5-6-6-6z"/>
                          </svg>
                        ))}
                        {tile.qty > 5 && <span class="ml-1 text-sm font-semibold text-gray-700">+{tile.qty - 5}</span>}
                      </div>
                      <div class="text-center">
                        <div class="font-bold text-gray-800" style="font-family: 'Signika', sans-serif;">{tile.label}</div>
                        <div class="text-lg font-bold text-[#d97706]">${tile.monthly}<span class="text-xs text-gray-400">/mo</span></div>
                      </div>
                      <div class="mt-2 h-1 bg-gray-100 rounded-full overflow-hidden">
                        <div class="h-full bg-[#fdc448] rounded-full" style={`width: ${tile.popularity}%`}></div>
                      </div>
                      <div class="text-[10px] text-gray-400 mt-1">{tile.popularity}% choose this</div>
                    </button>
                  ))}
                </div>
              </div>

              <!-- Custom Amount -->
              <div class="mx-5 md:mx-6 mt-4 md:mt-6 pt-4 md:pt-6 pb-5 md:pb-6 border-t border-gray-100">
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" id="custom-toggle" class="w-5 h-5 shrink-0 rounded border-gray-300 text-[#d97706] focus:ring-[#d97706]" />
                  <span class="text-sm text-gray-600">I want to sponsor a different number of children</span>
                </label>
                <div id="custom-qty-input" class="mt-4 hidden">
                  <!-- Mobile: stacked layout -->
                  <div class="md:hidden space-y-3">
                    <div class="flex items-center justify-center">
                      <div class="flex items-center border-2 border-gray-200 rounded-xl overflow-hidden">
                        <button type="button" class="custom-decrease-btn px-5 py-3.5 bg-gray-50 active:bg-gray-200 transition">
                          <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 12H4"/>
                          </svg>
                        </button>
                        <input type="number" class="custom-qty-field w-20 py-3.5 text-center text-2xl font-bold text-gray-800 border-0 focus:ring-0" value="4" min="1" max="100" inputmode="numeric" />
                        <button type="button" class="custom-increase-btn px-5 py-3.5 bg-gray-50 active:bg-gray-200 transition">
                          <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
                          </svg>
                        </button>
                      </div>
                    </div>
                    <div class="text-center bg-[#d97706]/5 rounded-xl py-3 px-4 border border-[#d97706]/10">
                      <span class="text-gray-500 text-sm">children × $45 = </span>
                      <span class="custom-total-display text-2xl font-bold text-[#d97706]">$180</span>
                      <span class="text-gray-400 text-sm">/mo</span>
                    </div>
                  </div>
                  <!-- Desktop: inline layout -->
                  <div class="hidden md:flex items-center gap-4">
                    <div class="flex items-center border-2 border-gray-200 rounded-xl overflow-hidden">
                      <button type="button" id="custom-decrease" class="px-4 py-3 bg-gray-50 hover:bg-gray-100 transition">
                        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
                        </svg>
                      </button>
                      <input type="number" id="custom-qty" value="4" min="1" max="100" class="w-20 py-3 text-center text-xl font-bold text-gray-800 border-0 focus:ring-0" />
                      <button type="button" id="custom-increase" class="px-4 py-3 bg-gray-50 hover:bg-gray-100 transition">
                        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                      </button>
                    </div>
                    <div>
                      <span class="text-gray-500">children × $45 = </span>
                      <span id="custom-total" class="text-xl font-bold text-[#d97706]">$180</span>
                      <span class="text-gray-400">/mo</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Mobile trust badges (below the card) -->
            <div class="md:hidden lg:col-span-2 flex items-center justify-center gap-3 text-[11px] text-gray-500 -mt-2 mb-1">
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
                Secure
              </span>
              <span class="text-gray-300">|</span>
              <span>Tax Deductible</span>
              <span class="text-gray-300">|</span>
              <span class="font-semibold text-[#61470e]">100% Zakat Eligible</span>
            </div>

