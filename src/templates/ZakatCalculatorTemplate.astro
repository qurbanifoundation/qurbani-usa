          <p class="text-2xl md:text-3xl font-bold text-[#fdc448]" style="font-family: 'Signika', sans-serif;">50+</p>
          <p class="text-white/60 text-xs mt-1">Countries Served</p>
        </div>
        <div class="bg-white/10 rounded-xl p-4 text-center backdrop-blur-sm">
          <p class="text-2xl md:text-3xl font-bold text-[#fdc448]" style="font-family: 'Signika', sans-serif;">100%</p>
          <p class="text-white/60 text-xs mt-1">Zakat Policy</p>
        </div>
        <div class="bg-white/10 rounded-xl p-4 text-center backdrop-blur-sm">
          <p class="text-2xl md:text-3xl font-bold text-[#fdc448]" style="font-family: 'Signika', sans-serif;">25+</p>
          <p class="text-white/60 text-xs mt-1">Years of Service</p>
        </div>
        <div class="bg-white/10 rounded-xl p-4 text-center backdrop-blur-sm">
          <p class="text-2xl md:text-3xl font-bold text-[#fdc448]" style="font-family: 'Signika', sans-serif;">1M+</p>
          <p class="text-white/60 text-xs mt-1">Lives Impacted</p>
        </div>
      </div>

      <!-- Trust Signal -->
      <div class="flex items-center justify-center mb-8">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
          <span class="text-white/70 text-sm">Shariah-Compliant Distribution</span>
        </div>
      </div>

      <!-- Zakat Eligibility Link -->
      <div class="text-center">
        <a href="/zakat-eligibility" class="inline-flex items-center gap-2 text-white/50 hover:text-white/80 text-sm transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          Learn about Zakat eligibility
        </a>
