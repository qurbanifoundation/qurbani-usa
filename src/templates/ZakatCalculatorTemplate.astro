  <Footer />
</Layout>

<!-- ===== CALCULATOR JAVASCRIPT ===== -->
<script is:inline define:vars={{ serializedConfig }}>
  const cfg = JSON.parse(serializedConfig);

  // Metal prices (fallbacks updated Feb 28, 2026)
  let goldPerGram = 166.00;
  let silverPerGram = 3.04;
  let nisabGold = goldPerGram * cfg.nisabGoldGrams;
  let nisabSilver = silverPerGram * cfg.nisabSilverGrams;
  let activeNisab = 'silver'; // default

  const fmt = (n) => '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const fmtShort = (n) => '$' + Math.round(n).toLocaleString('en-US');

  // Field definitions per category — using inline color values (Tailwind purges dynamic classes from JS)
  const fieldDefs = {
    cash: {
      title: 'My Cash',
      accentColor: '#16a34a', accentBg: '#f0fdf4', accentBorder: '#bbf7d0',
      fields: [
        { label: 'Cash in hand', tip: 'Physical cash, money at home, in your wallet, or safe', cat: 'cash' },
        { label: 'Cash in bank', tip: 'Checking accounts, savings accounts, CDs, money market accounts', cat: 'cash' },
        { label: 'Cash tied up in a business or businesses', tip: 'Cash reserves held within your business accounts', cat: 'cash' },
        { label: 'Rental income', tip: 'Accumulated rental income you have saved or received', cat: 'cash' },
        { label: 'Dividends / cash from investments', tip: 'Dividend payouts, interest income, or cash returns from investments', cat: 'cash' },
        { label: 'Money owed to me', tip: 'Loans you have given to others that you expect to be repaid', cat: 'cash' },
      ]
    },
    metals: {
      title: 'My Gold & Silver',
      accentColor: '#ca8a04', accentBg: '#fefce8', accentBorder: '#fde68a',
      isMetals: true,
      fields: [
        { label: 'Gold', tip: 'Total value or weight of gold jewelry, coins, or bars', cat: 'gold-grams', metalType: 'gold' },
        { label: 'Silver', tip: 'Total value or weight of silver jewelry, coins, or bars', cat: 'silver-grams', metalType: 'silver' },
      ]
    },
    crypto: {
      title: 'My Crypto',
      accentColor: '#2563eb', accentBg: '#eff6ff', accentBorder: '#bfdbfe',
      description: 'Cryptocurrency value',
      fields: [
        { label: 'Cryptocurrency value', tip: 'Total value of all your crypto holdings (Bitcoin, Ethereum, etc.)', cat: 'crypto' },
      ]
    },
    shares: {
      title: 'My Shares',
      accentColor: '#4f46e5', accentBg: '#eef2ff', accentBorder: '#c7d2fe',
      fields: [
        { label: 'Shares bought to resell for capital gains', tip: 'Stocks, ETFs, or mutual funds purchased for trading/profit', cat: 'shares' },
        { label: 'Shares bought for any other reason', tip: '401k, IRA, long-term holdings, dividend stocks', cat: 'shares' },
      ]
    },
    business: {
      title: 'My Business Assets',
      accentColor: '#9333ea', accentBg: '#faf5ff', accentBorder: '#e9d5ff',
      fields: [
        { label: 'Items of trade', tip: 'Goods or products you buy and sell for profit', cat: 'business' },
        { label: 'Stock', tip: 'Business inventory or stock held for sale', cat: 'business' },
      ]
    },
    property: {
      title: 'Property I Own',
      accentColor: '#0d9488', accentBg: '#f0fdfa', accentBorder: '#99f6e4',
      isProperty: true,
      fields: [
        { label: 'Total market value of all your properties', tip: 'Include only property you intend to sell — not your primary home', cat: 'property' },
      ]
    },
  };

  const liabilityFields = [
    { label: 'Dues', tip: 'Total of all money you currently owe', cat: 'liability' },
  ];

  // ===== CATEGORY TOGGLE =====
  window.toggleCategory = function(el) {
    el.classList.toggle('selected');
  };

  // ===== STEP NAVIGATION =====
  let currentStep = 1;
  let highestStepVisited = 1;

  // clickStep kept for backwards compatibility (no longer used by UI)
  window.clickStep = function(step) {
    if (step <= highestStepVisited) {
      goToStep(step);
    }
  };

  window.goToStep = function(step) {
    if (step === 2) buildStep2Fields();
    if (step === 3) buildStep3Fields();
    if (step === 4) calculateAndShowResults();

    // Hide all steps, show target
    document.querySelectorAll('.zw-step').forEach(s => s.classList.remove('active'));
    document.getElementById('zw-step-' + step).classList.add('active');

    currentStep = step;
    if (step > highestStepVisited) highestStepVisited = step;

    // Scroll to the top of the wizard so the form fields are visible
    const scrollAnchor = document.getElementById('zw-scroll-anchor');
    if (scrollAnchor) {
      setTimeout(() => {
        scrollAnchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 50);
    } else {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  };

  // ===== BUILD STEP 2 FIELDS =====
  // Tooltip SVG icon (orange circle-question)
  const tipIcon = '<svg style="width:16px;height:16px;color:#E1861D;flex-shrink:0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>';

  // Format number with commas (e.g. 10000 → 10,000)
  function formatWithCommas(val) {
    if (!val && val !== 0) return '';
    const num = parseFloat(String(val).replace(/,/g, ''));
    if (isNaN(num) || num === 0) return '';
    // If it has decimals, show them; otherwise just commas
    const parts = String(val).replace(/,/g, '').split('.');
    const intPart = parseInt(parts[0] || '0').toLocaleString('en-US');
    if (parts.length > 1 && parts[1]) {
      return intPart + '.' + parts[1];
    }
    return intPart;
  }

  // Get raw number from a potentially comma-formatted value
  function getRawValue(str) {
    return parseFloat(String(str).replace(/,/g, '')) || 0;
  }

  function makeField(field, fieldId, existVal, isGrams, inputClass) {
    const prefix = isGrams
      ? '<svg style="width:16px;height:16px;color:#9ca3af" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>'
      : '$';
    const displayVal = existVal ? formatWithCommas(existVal) : '';
    return `<div>
      <div style="font-size:0.875rem;font-weight:500;color:#333;margin-bottom:0.5rem;display:flex;align-items:center;gap:0.35rem">
        ${field.label}
        <span class="zw-tip-trigger" style="position:relative;display:inline-flex;cursor:help" data-tip="${field.tip.replace(/"/g, '&quot;')}">${tipIcon}<span class="zw-tip-popup" style="visibility:hidden;opacity:0;position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:8px 12px;border-radius:8px;font-size:11px;font-weight:400;width:200px;text-align:center;z-index:100;transition:all 0.15s;line-height:1.4;pointer-events:none">${field.tip}<span style="position:absolute;top:100%;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:#1e293b"></span></span></span>
      </div>
      <div style="position:relative">
        <span style="position:absolute;left:0.625rem;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:0.875rem;pointer-events:none">${prefix}</span>
        <input type="text" inputmode="decimal"
          class="zw-input ${inputClass}"
          data-cat="${field.cat}" data-field-id="${fieldId}"
          placeholder="${isGrams ? '0' : '0.00'}"
          value="${displayVal}"
          style="width:100%;padding:0.75rem 0.75rem 0.75rem 1.75rem;font-size:1rem;background:#f5f5f5;border:1px solid #e5e5e5;border-radius:0.5rem;outline:none;color:#333" />
      </div>
    </div>`;
  }

  // Make a metal field with USD / Grams toggle
  // Gold karat purity percentages (24k = 99.9% pure)
  const goldPurities = [
    { label: '24k', purity: 0.999 },
    { label: '22k', purity: 0.9167 },
    { label: '21k', purity: 0.875 },
    { label: '18k', purity: 0.750 },
    { label: '14k', purity: 0.5833 },
    { label: '10k', purity: 0.4167 },
  ];
  // Silver fineness purity percentages
  const silverPurities = [
    { label: '999', purity: 0.999 },
    { label: '958', purity: 0.958 },
    { label: '925', purity: 0.925 },
    { label: '900', purity: 0.900 },
    { label: '800', purity: 0.800 },
  ];

  // Store purity selections and modes across step navigation
  if (!window._metalModes) window._metalModes = {};
  if (!window._metalPurity) window._metalPurity = {};

  function getMetalPurityMultiplier(metalType, fieldId) {
    const storedIdx = window._metalPurity[fieldId];
    const purities = metalType === 'gold' ? goldPurities : silverPurities;
    const idx = (storedIdx !== undefined && storedIdx < purities.length) ? storedIdx : 0;
    return purities[idx].purity;
  }

  function makeMetalField(field, fieldId, existVal, inputClass) {
    const displayVal = existVal ? formatWithCommas(existVal) : '';
    const storedMode = window._metalModes[fieldId];
    const isUsd = storedMode === 'usd';
    const prefix = isUsd ? '$' : 'g';
    const catVal = isUsd ? field.cat.replace('-grams', '-usd') : field.cat;
    const purities = field.metalType === 'gold' ? goldPurities : silverPurities;
    const storedPurityIdx = window._metalPurity[fieldId] || 0;
    const pricePerGram = field.metalType === 'gold' ? goldPerGram : silverPerGram;
    const purityLabel = field.metalType === 'gold' ? 'Karat' : 'Fineness';

    // Build purity dropdown options
    let purityOpts = '';
    purities.forEach((p, i) => {
      purityOpts += `<option value="${i}" ${i === storedPurityIdx ? 'selected' : ''}>${p.label}</option>`;
    });

    // Calculate initial total if grams mode with existing value
    let totalHtml = '';
    if (!isUsd && existVal) {
      const rawVal = parseFloat(String(existVal).replace(/,/g, '')) || 0;
      const purity = purities[storedPurityIdx].purity;
      const totalUsd = rawVal * pricePerGram * purity;
      if (totalUsd > 0) {
        totalHtml = `<span style="font-weight:700;color:#024139">Total ${field.label.toLowerCase()} value: ${fmt(totalUsd)}</span>`;
      }
    }

    return `<div style="grid-column:1/-1;margin-bottom:0.75rem">
      <div style="font-size:1rem;font-weight:600;color:#333;margin-bottom:0.75rem;display:flex;align-items:center;gap:0.35rem">
        ${field.label}
        <span class="zw-tip-trigger" style="position:relative;display:inline-flex;cursor:help" data-tip="${field.tip.replace(/"/g, '&quot;')}">${tipIcon}<span class="zw-tip-popup" style="visibility:hidden;opacity:0;position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:8px 12px;border-radius:8px;font-size:11px;font-weight:400;width:200px;text-align:center;z-index:100;transition:all 0.15s;line-height:1.4;pointer-events:none">${field.tip}<span style="position:absolute;top:100%;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:#1e293b"></span></span></span>
      </div>
      <div style="display:flex;gap:0.625rem;align-items:stretch">
        <!-- Purity dropdown -->
        <div class="zw-purity-wrap" data-for="${fieldId}" style="display:${isUsd ? 'none' : 'flex'};flex-direction:column;justify-content:center">
          <select class="zw-purity-select" data-field="${fieldId}" data-metal="${field.metalType}"
            style="padding:1.125rem 2.5rem 1.125rem 1.25rem;font-size:1.125rem;font-weight:700;background:#f5f5f5;border:1px solid #e5e5e5;border-radius:0.625rem;outline:none;color:#333;cursor:pointer;min-width:110px;appearance:auto;height:100%">
            ${purityOpts}
          </select>
        </div>
        <!-- Value input -->
        <div style="position:relative;flex:1">
          <span class="zw-metal-prefix" data-for="${fieldId}" style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:1.125rem;pointer-events:none;font-weight:500">${prefix}</span>
          <input type="text" inputmode="${isUsd ? 'decimal' : 'numeric'}"
            class="zw-input ${inputClass}"
            data-cat="${catVal}" data-field-id="${fieldId}" data-metal-type="${field.metalType}"
            placeholder="${isUsd ? '0.00' : '0'}"
            value="${displayVal}"
            style="width:100%;padding:1.125rem 1rem 1.125rem 2.25rem;font-size:1.25rem;font-weight:600;background:#f5f5f5;border:1px solid #e5e5e5;border-radius:0.625rem;outline:none;color:#333" />
        </div>
      </div>
      <!-- Toggle + live total row -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-top:0.75rem">
        <!-- Live total value (only visible in grams mode) -->
        <div class="zw-metal-total" data-for="${fieldId}" style="font-size:0.875rem;color:#6b7280;flex:1;${isUsd ? 'display:none' : ''}">${totalHtml}</div>
        <!-- USD / Grams toggle -->
        <div style="display:flex;gap:0;flex-shrink:0">
          <button type="button" class="zw-metal-toggle ${isUsd ? 'active' : ''}" data-field="${fieldId}" data-mode="usd"
            style="font-size:0.75rem;font-weight:700;padding:0.3125rem 0.875rem;border:1px solid #d1d5db;border-radius:0.375rem 0 0 0.375rem;cursor:pointer;transition:all 0.15s;${isUsd ? 'background:#024139;color:#fff;border-color:#024139' : 'background:#fff;color:#6b7280'}">USD</button>
          <button type="button" class="zw-metal-toggle ${!isUsd ? 'active' : ''}" data-field="${fieldId}" data-mode="grams"
            style="font-size:0.75rem;font-weight:700;padding:0.3125rem 0.875rem;border:1px solid #d1d5db;border-left:none;border-radius:0 0.375rem 0.375rem 0;cursor:pointer;transition:all 0.15s;${!isUsd ? 'background:#024139;color:#fff;border-color:#024139' : 'background:#fff;color:#6b7280'}">Grams</button>
        </div>
      </div>
    </div>`;
  }

  function buildStep2Fields() {
    const container = document.getElementById('zw-fields-container');
    const selectedCats = Array.from(document.querySelectorAll('.zw-cat-card.selected')).map(c => c.dataset.cat);

    // Preserve existing values
    const existingValues = {};
    container.querySelectorAll('.zw-input').forEach(inp => {
      if (inp.value) existingValues[inp.dataset.fieldId] = inp.value;
    });

    let html = '';

    selectedCats.forEach((catKey, catIndex) => {
      const def = fieldDefs[catKey];
      if (!def) return;
      const mb = catIndex < selectedCats.length - 1 ? '1.25rem' : '0';

      // ===== Section card wrapper =====
      html += `<div style="background:#fff;border-radius:1rem;border:1px solid ${def.accentBorder};overflow:hidden;margin-bottom:${mb}">`;

      // Prominent colored section header
      html += `<div style="background:${def.accentBg};padding:1rem 1.25rem;border-bottom:1px solid ${def.accentBorder}">
        <h3 style="font-size:1.125rem;font-weight:800;color:${def.accentColor};margin:0;letter-spacing:0.01em;text-transform:uppercase;font-family:'Signika',sans-serif">
          ${def.title}
        </h3>
      </div>`;

      html += `<div style="padding:1.5rem 1.25rem">`;

      if (def.isMetals) {
        // Gold & Silver — special metal fields with purity dropdowns
        html += `<div style="display:grid;grid-template-columns:1fr;gap:1.5rem">`;
        def.fields.forEach((field, i) => {
          const fieldId = catKey + '-' + i;
          const existVal = existingValues[fieldId] || '';
          html += makeMetalField(field, fieldId, existVal, 'zw-asset-input');
        });
        html += `</div>`;
      } else if (def.isProperty) {
        // Property — notice + Yes/No toggle + input
        const fieldId = catKey + '-0';
        const existVal = existingValues[fieldId] || '';
        const displayVal = existVal ? formatWithCommas(existVal) : '';
        const storedBuySell = window._propertyBuySell || 'no';
        // Notice box
        html += `<div style="background:#fffbeb;border:1px solid #fde68a;border-radius:0.625rem;padding:0.875rem 1rem;margin-bottom:1.25rem;text-align:center">
          <p style="font-size:0.8125rem;color:#92400e;margin:0;line-height:1.5">No zakat is due on the home you live in. Include only property you intend to sell; zakat is 2.5% of its market value after one lunar year.</p>
        </div>`;
        // Buy & Sell toggle
        html += `<p style="font-size:0.9375rem;color:#333;font-weight:600;margin:0 0 0.75rem 0">I Buy & Sell properties (2.5% owed on property value)</p>`;
        html += `<div style="display:flex;gap:0;margin-bottom:1.25rem">
          <button type="button" class="zw-prop-toggle" data-val="yes"
            style="flex:1;padding:0.75rem;font-size:0.9375rem;font-weight:700;border:1px solid #d1d5db;border-radius:0.5rem 0 0 0.5rem;cursor:pointer;transition:all 0.15s;${storedBuySell === 'yes' ? 'background:#024139;color:#fff;border-color:#024139' : 'background:#fff;color:#6b7280'}">Yes</button>
          <button type="button" class="zw-prop-toggle" data-val="no"
            style="flex:1;padding:0.75rem;font-size:0.9375rem;font-weight:700;border:1px solid #d1d5db;border-left:none;border-radius:0 0.5rem 0.5rem 0;cursor:pointer;transition:all 0.15s;${storedBuySell === 'no' ? 'background:#024139;color:#fff;border-color:#024139' : 'background:#fff;color:#6b7280'}">No</button>
        </div>`;
        // Input
        html += `<div style="position:relative">
          <span style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:1.125rem;pointer-events:none;font-weight:500">$</span>
          <input type="text" inputmode="decimal"
            class="zw-input zw-asset-input"
            data-cat="property" data-field-id="${fieldId}"
            placeholder="0.00"
            value="${displayVal}"
            style="width:100%;padding:1.125rem 1rem 1.125rem 2.25rem;font-size:1.25rem;font-weight:600;background:#f5f5f5;border:1px solid #e5e5e5;border-radius:0.625rem;outline:none;color:#333" />
        </div>`;
        html += `<p style="font-size:0.8125rem;color:#9ca3af;margin:0.5rem 0 0 0">Enter the total market value of all your properties</p>`;
      } else {
        // Non-metal categories — description + input(s)
        if (def.description) {
          html += `<p style="font-size:0.9375rem;color:#555;margin:0 0 1.25rem 0">${def.description}</p>`;
        }
        const useGrid = def.fields.length > 3;
        if (useGrid) {
          html += `<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem" class="zw-field-grid">`;
        }
        def.fields.forEach((field, i) => {
          const fieldId = catKey + '-' + i;
          const existVal = existingValues[fieldId] || '';
          const displayVal = existVal ? formatWithCommas(existVal) : '';
          if (useGrid) {
            // Grid cell: label with tooltip + input stacked inside
            html += `<div>`;
            html += `<div style="font-size:0.8125rem;color:#555;margin:0 0 0.5rem 0;display:flex;align-items:center;justify-content:space-between;min-height:1.75rem">
              <span style="line-height:1.3">${field.label}</span>
              <span class="zw-tip-trigger" style="position:relative;display:inline-flex;cursor:help;flex-shrink:0;margin-left:0.375rem" data-tip="${field.tip.replace(/"/g, '&quot;')}">${tipIcon}<span class="zw-tip-popup" style="visibility:hidden;opacity:0;position:absolute;bottom:calc(100% + 8px);right:0;transform:none;background:#1e293b;color:#fff;padding:8px 12px;border-radius:8px;font-size:11px;font-weight:400;width:200px;text-align:center;z-index:100;transition:all 0.15s;line-height:1.4;pointer-events:none">${field.tip}<span style="position:absolute;top:100%;right:12px;border:5px solid transparent;border-top-color:#1e293b"></span></span></span>
            </div>`;
            html += `<div style="position:relative">
              <span style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:1rem;pointer-events:none;font-weight:500">$</span>
              <input type="text" inputmode="decimal"
                class="zw-input zw-asset-input"
                data-cat="${field.cat}" data-field-id="${fieldId}"
                placeholder="0.00"
                value="${displayVal}"
                style="width:100%;padding:0.875rem 0.75rem 0.875rem 2rem;font-size:1.125rem;font-weight:600;background:#f5f5f5;border:1px solid #e5e5e5;border-radius:0.625rem;outline:none;color:#333" />
            </div>`;
            html += `</div>`;
          } else {
            // Stacked layout for 1-3 fields
            if (def.fields.length > 1) {
              html += `<div style="font-size:0.9375rem;color:#555;margin:${i > 0 ? '1.25rem' : '0'} 0 0.75rem 0;display:flex;align-items:center;justify-content:space-between">
                <span>${field.label}</span>
                <span class="zw-tip-trigger" style="position:relative;display:inline-flex;cursor:help" data-tip="${field.tip.replace(/"/g, '&quot;')}">${tipIcon}<span class="zw-tip-popup" style="visibility:hidden;opacity:0;position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:8px 12px;border-radius:8px;font-size:11px;font-weight:400;width:200px;text-align:center;z-index:100;transition:all 0.15s;line-height:1.4;pointer-events:none">${field.tip}<span style="position:absolute;top:100%;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:#1e293b"></span></span></span>
              </div>`;
            }
            html += `<div style="position:relative">
              <span style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:1.125rem;pointer-events:none;font-weight:500">$</span>
              <input type="text" inputmode="decimal"
                class="zw-input zw-asset-input"
                data-cat="${field.cat}" data-field-id="${fieldId}"
                placeholder="0.00"
                value="${displayVal}"
                style="width:100%;padding:1.125rem 1rem 1.125rem 2.25rem;font-size:1.25rem;font-weight:600;background:#f5f5f5;border:1px solid #e5e5e5;border-radius:0.625rem;outline:none;color:#333" />
            </div>`;
          }
        });
        if (useGrid) {
          html += `</div>`;
        }
      }

      html += `</div></div>`;  // close padding + card
    });

    // Fields rendered directly without card wrapper

    container.innerHTML = html;

    // Tooltip hover listeners (since Astro scoped styles don't apply to dynamic HTML)
    container.querySelectorAll('.zw-tip-trigger').forEach(trigger => {
      const popup = trigger.querySelector('.zw-tip-popup');
      if (!popup) return;
      trigger.addEventListener('mouseenter', () => {
        popup.style.visibility = 'visible';
        popup.style.opacity = '1';
      });
      trigger.addEventListener('mouseleave', () => {
        popup.style.visibility = 'hidden';
        popup.style.opacity = '0';
      });
    });

    // Focus styles + comma formatting on inputs
    container.querySelectorAll('.zw-input').forEach(inp => {
      inp.addEventListener('focus', function() {
        this.style.backgroundColor = '#fff';
        this.style.borderColor = '#024139';
        this.style.boxShadow = '0 0 0 2px rgba(2,65,57,0.2)';
        // Strip commas on focus so user can edit raw number
        const raw = this.value.replace(/,/g, '');
        if (raw && raw !== '0') this.value = raw;
      });
      inp.addEventListener('blur', function() {
        this.style.backgroundColor = '#f5f5f5';
        this.style.borderColor = '#e5e5e5';
        this.style.boxShadow = 'none';
        // Format with commas on blur
        const formatted = formatWithCommas(this.value);
        this.value = formatted;
      });
      // Filter to only allow digits, dots, and commas
      inp.addEventListener('keypress', function(e) {
        const char = String.fromCharCode(e.which || e.keyCode);
        if (!/[\d.,]/.test(char) && e.key !== 'Backspace' && e.key !== 'Tab' && e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') {
          e.preventDefault();
        }
      });
      inp.addEventListener('input', updateSubtotals);
    });

    // Property Buy & Sell toggle
    if (!window._propertyBuySell) window._propertyBuySell = 'no';
    container.querySelectorAll('.zw-prop-toggle').forEach(btn => {
      btn.addEventListener('click', function() {
        const val = this.dataset.val; // 'yes' or 'no'
        window._propertyBuySell = val;
        this.parentElement.querySelectorAll('.zw-prop-toggle').forEach(b => {
          const isActive = b.dataset.val === val;
          b.style.background = isActive ? '#024139' : '#fff';
          b.style.color = isActive ? '#fff' : '#6b7280';
          b.style.borderColor = isActive ? '#024139' : '#d1d5db';
        });
        updateSubtotals();
      });
    });

    // Live metal total update function
    function updateMetalTotal(fieldId) {
      const inp = container.querySelector(`[data-field-id="${fieldId}"]`);
      const totalEl = container.querySelector(`.zw-metal-total[data-for="${fieldId}"]`);
      if (!inp || !totalEl) return;
      const mode = window._metalModes[fieldId] || 'grams';
      if (mode === 'usd') {
        totalEl.style.display = 'none';
        return;
      }
      totalEl.style.display = '';
      const val = getRawValue(inp.value);
      const metalType = inp.dataset.metalType;
      const pricePerGram = metalType === 'gold' ? goldPerGram : silverPerGram;
      const purity = getMetalPurityMultiplier(metalType, fieldId);
      const totalUsd = val * pricePerGram * purity;
      if (val > 0) {
        const metalLabel = metalType === 'gold' ? 'gold' : 'silver';
        totalEl.innerHTML = `<span style="font-weight:700;color:#024139;font-size:0.9375rem">Total ${metalLabel} value: ${fmt(totalUsd)}</span>`;
      } else {
        const priceNote = metalType === 'gold'
          ? `Live 24k price: $${goldPerGram.toFixed(2)}/gram`
          : `Live 999 price: $${silverPerGram.toFixed(2)}/gram`;
        totalEl.innerHTML = `<span style="color:#9ca3af">${priceNote}</span>`;
      }
    }

    // Metal USD/Grams toggle listeners
    container.querySelectorAll('.zw-metal-toggle').forEach(btn => {
      btn.addEventListener('click', function() {
        const fieldId = this.dataset.field;
        const mode = this.dataset.mode; // 'usd' or 'grams'
        const inp = container.querySelector(`[data-field-id="${fieldId}"]`);
        if (!inp) return;

        // Store mode
        window._metalModes[fieldId] = mode;

        // Update data-cat on the input
        const metalType = inp.dataset.metalType; // 'gold' or 'silver'
        inp.dataset.cat = mode === 'usd' ? metalType + '-usd' : metalType + '-grams';

        // Update prefix
        const prefixEl = container.querySelector(`.zw-metal-prefix[data-for="${fieldId}"]`);
        if (prefixEl) {
          prefixEl.textContent = mode === 'usd' ? '$' : 'g';
        }

        // Show/hide purity dropdown
        const purityWrap = container.querySelector(`.zw-purity-wrap[data-for="${fieldId}"]`);
        if (purityWrap) {
          purityWrap.style.display = mode === 'usd' ? 'none' : 'flex';
        }

        // Update placeholder and keyboard type
        inp.placeholder = mode === 'usd' ? '0.00' : '0';
        inp.inputMode = mode === 'usd' ? 'decimal' : 'numeric';

        // Clear value when switching modes
        inp.value = '';

        // Toggle active button styles
        const parent = this.parentElement;
        parent.querySelectorAll('.zw-metal-toggle').forEach(b => {
          const isActive = b.dataset.mode === mode;
          b.style.background = isActive ? '#024139' : '#fff';
          b.style.color = isActive ? '#fff' : '#6b7280';
          b.style.borderColor = isActive ? '#024139' : '#d1d5db';
          b.classList.toggle('active', isActive);
        });

        updateMetalTotal(fieldId);
        updateSubtotals();
      });
    });

    // Purity dropdown change listeners
    container.querySelectorAll('.zw-purity-select').forEach(sel => {
      sel.addEventListener('change', function() {
        const fieldId = this.dataset.field;
        window._metalPurity[fieldId] = parseInt(this.value);
        updateMetalTotal(fieldId);
        updateSubtotals();
      });
    });

    // Wire up metal inputs for live total updates
    container.querySelectorAll('.zw-input[data-metal-type]').forEach(inp => {
      inp.addEventListener('input', function() {
        updateMetalTotal(this.dataset.fieldId);
      });
    });

    // Initialize metal totals
    container.querySelectorAll('.zw-input[data-metal-type]').forEach(inp => {
      updateMetalTotal(inp.dataset.fieldId);
    });

    updateSubtotals();
  }

  // ===== BUILD STEP 3 FIELDS (Liabilities) =====
  function buildStep3Fields() {
    const container = document.getElementById('zw-liabilities-container');
    if (!container) return;

    // Preserve existing value
    const existingValues = {};
    container.querySelectorAll('.zw-input').forEach(inp => {
      if (inp.value) existingValues[inp.dataset.fieldId] = inp.value;
    });
    const existVal = existingValues['liability-0'] || '';
    const displayVal = existVal ? formatWithCommas(existVal) : '';

    // Calculate total assets to show
    let totalAssets = 0;
    document.querySelectorAll('.zw-asset-input').forEach(inp => {
      totalAssets += getUsdValue(inp);
    });

    let html = '';

    // Card with accent header
    const accentColor = '#dc2626';
    const accentBg = '#fef2f2';
    const accentBorder = '#fecaca';

    html += `<div style="background:#fff;border-radius:1rem;border:1px solid ${accentBorder};overflow:hidden">`;
    html += `<div style="background:${accentBg};padding:1rem 1.25rem;border-bottom:1px solid ${accentBorder}">
      <h3 style="font-size:1.125rem;font-weight:800;color:${accentColor};margin:0;letter-spacing:0.01em;text-transform:uppercase;font-family:'Signika',sans-serif">
        Dues
      </h3>
    </div>`;
    html += `<div style="padding:1.5rem 1.25rem">`;
    // Description
    html += `<p style="font-size:0.9375rem;color:#555;margin:0 0 1.25rem 0">Include money you owe, other outgoings due</p>`;
    // Single input
    html += `<div style="position:relative">
      <span style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:1.125rem;pointer-events:none;font-weight:500">$</span>
      <input type="text" inputmode="decimal"
        class="zw-input zw-liability-input"
        data-cat="liability" data-field-id="liability-0"
        placeholder="0.00"
        value="${displayVal}"
        style="width:100%;padding:1.125rem 1rem 1.125rem 2.25rem;font-size:1.25rem;font-weight:600;background:#f5f5f5;border:1px solid #e5e5e5;border-radius:0.625rem;outline:none;color:#333" />
    </div>`;
    // Total assets line
    html += `<p id="zw-dues-total-assets" style="margin-top:1rem;font-size:0.875rem;color:#6b7280">Total assets: <span style="font-weight:700;color:#024139">${fmt(totalAssets)}</span></p>`;
    html += `</div></div>`;

    container.innerHTML = html;

    // Focus styles + comma formatting
    const inp = container.querySelector('.zw-input');
    if (inp) {
      inp.addEventListener('focus', function() {
        this.style.backgroundColor = '#fff';
        this.style.borderColor = '#024139';
        this.style.boxShadow = '0 0 0 2px rgba(2,65,57,0.2)';
        const raw = this.value.replace(/,/g, '');
        if (raw && raw !== '0') this.value = raw;
      });
      inp.addEventListener('blur', function() {
        this.style.backgroundColor = '#f5f5f5';
        this.style.borderColor = '#e5e5e5';
        this.style.boxShadow = 'none';
        this.value = formatWithCommas(this.value);
      });
      inp.addEventListener('keypress', function(e) {
        const char = String.fromCharCode(e.which || e.keyCode);
        if (!/[\d.,]/.test(char) && e.key !== 'Backspace' && e.key !== 'Tab' && e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') {
          e.preventDefault();
        }
      });
      inp.addEventListener('input', updateSubtotals);
    }

    updateSubtotals();
  }

  function getUsdValue(inp) {
    const cat = inp.dataset.cat;
    const val = getRawValue(inp.value);
    const fieldId = inp.dataset.fieldId;
    if (cat === 'gold-grams') return val * goldPerGram * getMetalPurityMultiplier('gold', fieldId);
    if (cat === 'silver-grams') return val * silverPerGram * getMetalPurityMultiplier('silver', fieldId);
    // gold-usd and silver-usd are already in USD
    return val;
  }

  function updateSubtotals() {
    // Totals are only used by calculateAndShowResults() now
    // No header bars to update — keeping function for input event listeners
  }

  // ===== CALCULATE & SHOW RESULTS =====
  function calculateAndShowResults() {
    let totalAssets = 0;
    document.querySelectorAll('.zw-asset-input').forEach(inp => {
      totalAssets += getUsdValue(inp);
    });

    let totalLiabilities = 0;
    document.querySelectorAll('.zw-liability-input').forEach(inp => {
      totalLiabilities += getRawValue(inp.value);
    });

    const netWealth = totalAssets - totalLiabilities;
    const selectedNisab = activeNisab === 'gold' ? nisabGold : nisabSilver;

    let zakatAmount = 0;
    let status = '';

    if (netWealth <= 0) {
      status = 'Your net wealth is zero or negative — no Zakat is due';
    } else if (netWealth < selectedNisab) {
      status = 'Below Nisab threshold — Zakat is not yet obligatory';
    } else {
      zakatAmount = netWealth * 0.025;
      status = 'Zakat is obligatory on your wealth';
    }

    // Update UI
    document.getElementById('zw-big-amount').textContent = fmt(zakatAmount);
    document.getElementById('zw-status').textContent = status;

    // Populate detailed assets breakdown in results card
    const assetsDetailEl = document.getElementById('zw-r-assets-detail');
    if (assetsDetailEl) {
      let aHtml = '';
      const selectedCats = Array.from(document.querySelectorAll('.zw-cat-card.selected')).map(c => c.dataset.cat);
      selectedCats.forEach(catKey => {
        const def = fieldDefs[catKey];
        if (!def) return;
        def.fields.forEach((field, i) => {
          const fieldId = catKey + '-' + i;
          const inp = document.querySelector(`[data-field-id="${fieldId}"]`);
          if (!inp) return;
          const usd = getUsdValue(inp);
          if (usd > 0) {
            aHtml += `<div class="flex justify-between text-xs sm:text-sm"><span class="text-white/60">${field.label}</span><span class="text-white/90 font-medium">${fmtShort(usd)}</span></div>`;
          }
        });
      });
      if (!aHtml) aHtml = '<p class="text-xs text-white/30 italic">No assets entered</p>';
      assetsDetailEl.innerHTML = aHtml;
    }
    document.getElementById('zw-r-assets').textContent = fmtShort(totalAssets);

    // Populate detailed liabilities breakdown in results card
    const liabDetailEl = document.getElementById('zw-r-liabilities-detail');
    if (liabDetailEl) {
      let lHtml = '';
      liabilityFields.forEach((field, i) => {
        const fieldId = 'liability-' + i;
        const inp = document.querySelector(`[data-field-id="${fieldId}"]`);
        if (!inp) return;
        const val = getRawValue(inp.value);
        if (val > 0) {
          lHtml += `<div class="flex justify-between text-xs sm:text-sm"><span class="text-white/60">${field.label}</span><span class="text-white/90 font-medium">${fmtShort(val)}</span></div>`;
        }
      });
      if (!lHtml) lHtml = '<div class="flex justify-between text-xs sm:text-sm"><span class="text-white/40 italic">No liabilities</span><span class="text-white/40">$0</span></div>';
      liabDetailEl.innerHTML = lHtml;
    }
    document.getElementById('zw-r-liabilities').textContent = '-' + fmtShort(totalLiabilities);

    document.getElementById('zw-r-net').textContent = fmtShort(netWealth);

    // Nisab values in toggle
    document.getElementById('zw-nisab-gold-val').textContent = fmtShort(nisabGold);
    document.getElementById('zw-nisab-silver-val').textContent = fmtShort(nisabSilver);

    // Show/hide pay area and impact
    const payArea = document.getElementById('zw-pay-area');
    const impactArea = document.getElementById('zw-impact-area');
    if (zakatAmount > 0) {
      payArea.classList.remove('hidden');
      impactArea.classList.remove('hidden');

      // Round up
      const roundedUp = Math.ceil(zakatAmount / 10) * 10;
      const roundupWrap = document.getElementById('zw-roundup-wrap');
      if (roundedUp > zakatAmount && roundedUp - zakatAmount >= 1) {
        roundupWrap.classList.remove('hidden');
        document.getElementById('zw-roundup-val').textContent = fmtShort(roundedUp);
      } else {
        roundupWrap.classList.add('hidden');
      }
    } else {
      payArea.classList.remove('hidden'); // Always show buttons
      impactArea.classList.add('hidden');
    }

    // ===== POPULATE DETAILED SUMMARY CARD =====
    populateSummaryCard(totalAssets, totalLiabilities, netWealth, zakatAmount, selectedNisab);
  }

  // Store breakdown data globally (used by email/modal)
  function populateSummaryCard(totalAssets, totalLiabilities, netWealth, zakatAmount, selectedNisab) {
    const selectedCats = Array.from(document.querySelectorAll('.zw-cat-card.selected')).map(c => c.dataset.cat);
    window._zakatBreakdown = { assets: [], liabilities: [], totalAssets, totalLiabilities, netWealth, zakatAmount, nisabType: activeNisab, nisabValue: selectedNisab };

    selectedCats.forEach(catKey => {
      const def = fieldDefs[catKey];
      if (!def) return;
      def.fields.forEach((field, i) => {
        const fieldId = catKey + '-' + i;
        const inp = document.querySelector(`[data-field-id="${fieldId}"]`);
        if (!inp) return;
        const usd = getUsdValue(inp);
        if (usd > 0) {
          window._zakatBreakdown.assets.push({ label: field.label, amount: usd });
        }
      });
    });

    liabilityFields.forEach((field, i) => {
      const fieldId = 'liability-' + i;
      const inp = document.querySelector(`[data-field-id="${fieldId}"]`);
      if (!inp) return;
      const val = getRawValue(inp.value);
      if (val > 0) {
        window._zakatBreakdown.liabilities.push({ label: field.label, amount: val });
      }
    });
  }

  // ===== NISAB TOGGLE =====
  window.switchNisab = function(type) {
    activeNisab = type;
    document.querySelectorAll('.zw-nisab-btn').forEach(b => {
      b.classList.toggle('active', b.dataset.nisab === type);
    });
    calculateAndShowResults();
  };

  // ===== RESET =====
  window.resetAll = function() {
    // Unselect all categories
    document.querySelectorAll('.zw-cat-card').forEach(c => {
      c.classList.remove('selected');
    });
    // Clear all fields
    document.querySelectorAll('.zw-input').forEach(inp => inp.value = '');
    // Clear liabilities container
    const liabContainer = document.getElementById('zw-liabilities-container');
    if (liabContainer) liabContainer.innerHTML = '';
    // Reset highest step
    highestStepVisited = 1;
    // Go to step 1
    goToStep(1);
  };

  // ===== PAY BUTTON =====
  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('zw-pay-btn')?.addEventListener('click', () => {
      const amtText = document.getElementById('zw-big-amount')?.textContent || '$0.00';
      let amount = parseFloat(amtText.replace(/[$,]/g, ''));

      const roundupCheck = document.getElementById('zw-roundup-check');
      if (roundupCheck && roundupCheck.checked) {
        amount = Math.ceil(amount / 10) * 10;
      }

      if (amount <= 0) { alert('Please calculate your Zakat first'); return; }

      if (typeof window.addToCart === 'function') {
        window.addToCart({
          id: 'zakat-' + Date.now(),
          name: 'Zakat Al Mal',
          description: 'Zakat Al Mal',
          amount: amount,
          quantity: 1,
          type: 'single',
          campaignSlug: cfg.campaignSlug || 'zakat',
          image: null,
        });
      } else {
        window.location.href = '/donate?cause=zakat&amount=' + amount;
      }
    });

    // Print
    document.getElementById('zw-print-btn')?.addEventListener('click', () => {
      const date = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
      const g = (id) => document.getElementById(id)?.textContent || '';
      const html = `<html><head><title>Zakat Calculation</title><style>body{font-family:Arial,sans-serif;max-width:550px;margin:40px auto;padding:0 20px}h1{color:#024139;margin-bottom:5px}.date{color:#666;margin-bottom:30px}.row{display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid #eee}.label{color:#666}.value{font-weight:bold}.total{font-size:40px;color:#024139;text-align:center;margin:30px 0}.status{text-align:center;color:#666;font-style:italic;margin:10px 0}.footer{margin-top:40px;text-align:center;color:#999;font-size:12px}</style></head><body><h1>Zakat Calculation</h1><p class="date">${date}</p><div class="row"><span class="label">Total Assets</span><span class="value">${g('zw-r-assets')}</span></div><div class="row"><span class="label">Liabilities</span><span class="value">${g('zw-r-liabilities')}</span></div><div class="row"><span class="label">Net Wealth</span><span class="value">${g('zw-r-net')}</span></div><div class="row"><span class="label">Nisab (${activeNisab})</span><span class="value">${fmtShort(activeNisab === 'gold' ? nisabGold : nisabSilver)}</span></div><p class="status">${g('zw-status')}</p><p class="total">${g('zw-big-amount')}</p><p class="footer">Calculated using Qurbani Foundation USA Zakat Calculator<br>www.qurbani.com</p></body></html>`;
      const w = window.open('', '_blank');
      if (w) { w.document.write(html); w.document.close(); w.print(); }
    });

    // Save Calculation button → always opens modal
    document.getElementById('zw-save-btn')?.addEventListener('click', () => {
      openSaveModal();
    });

    // ===== STICKY BAR + BOTTOM SHEET MODAL =====
    const stickyBar = document.getElementById('zw-sticky-bar');
    const modalOverlay = document.getElementById('zw-save-modal-overlay');
    const modalSheet = document.getElementById('zw-save-modal');

    // Show/hide sticky bars based on current step (4-step flow)
    const stickyContBar = document.getElementById('zw-sticky-continue');
    const stickyContBtn = stickyContBar ? stickyContBar.querySelector('button') : null;
    const arrowSvg = '<svg style="width:18px;height:18px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>';
    function updateStickyBar() {
      if (window.innerWidth <= 768) {
        // Only show sticky pay/email bar on Step 4 — inline buttons handle Steps 1-3
        if (stickyBar) stickyBar.style.display = currentStep === 4 ? 'flex' : 'none';
        if (stickyContBar) stickyContBar.style.display = 'none'; // no longer needed
      } else {
        if (stickyBar) stickyBar.style.display = 'none';
        if (stickyContBar) stickyContBar.style.display = 'none';
      }
    }

    // Override goToStep to also update sticky bar
    const origGoToStep = window.goToStep;
    window.goToStep = function(step) {
      origGoToStep(step);
      updateStickyBar();
    };
    updateStickyBar();

    // Sticky Pay button
    document.getElementById('zw-sticky-pay-btn')?.addEventListener('click', () => {
      document.getElementById('zw-pay-btn')?.click();
    });

    const isMobile = () => window.innerWidth < 768;

    // Position modal: bottom sheet on mobile, centered popup on desktop
    function positionModal() {
      if (!modalSheet) return;
      if (isMobile()) {
        // Bottom sheet style
        modalSheet.style.cssText = 'display:block;position:fixed;bottom:0;left:0;right:0;z-index:10000;background:#fff;border-radius:1.5rem 1.5rem 0 0;box-shadow:0 -4px 30px rgba(0,0,0,0.15);max-height:90vh;overflow-y:auto;transform:translateY(100%);transition:transform 0.3s ease-out;';
      } else {
        // Centered popup style
        modalSheet.style.cssText = 'display:block;position:fixed;top:50%;left:50%;z-index:10000;background:#fff;border-radius:1rem;box-shadow:0 20px 60px rgba(0,0,0,0.2);width:440px;max-width:calc(100vw - 2rem);overflow-y:auto;transform:translate(-50%,-50%) scale(0.9);opacity:0;transition:transform 0.25s ease-out, opacity 0.25s ease-out;';
      }
    }

    // Open modal
    function openSaveModal() {
      if (modalOverlay && modalSheet) {
        // Populate zakat amount in the modal
        const amountEl = document.getElementById('zw-modal-amount');
        if (amountEl && window._zakatBreakdown) {
          amountEl.textContent = '$' + Math.round(window._zakatBreakdown.zakatAmount).toLocaleString();
        }
        modalOverlay.classList.remove('hidden');
        positionModal();
        document.body.style.overflow = 'hidden';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            if (isMobile()) {
              modalSheet.style.transform = 'translateY(0)';
            } else {
              modalSheet.style.transform = 'translate(-50%,-50%) scale(1)';
              modalSheet.style.opacity = '1';
            }
          });
        });
        // Don't auto-focus on mobile — let user tap the field
        // (auto-focus triggers keyboard which distorts the bottom sheet)
        if (!isMobile()) {
          setTimeout(() => {
            document.getElementById('zw-modal-fullname')?.focus();
          }, 350);
        }
      }
    }

    // Close modal
    function closeSaveModal() {
      if (modalSheet) {
        if (isMobile()) {
          modalSheet.style.transform = 'translateY(100%)';
        } else {
          modalSheet.style.transform = 'translate(-50%,-50%) scale(0.9)';
          modalSheet.style.opacity = '0';
        }
      }
      document.body.style.overflow = '';
      // Reset keyboard adjustments
      if (modalSheet) {
        modalSheet.style.bottom = '0';
        modalSheet.style.maxHeight = '90vh';
      }
      setTimeout(() => {
        if (modalOverlay) modalOverlay.classList.add('hidden');
        if (modalSheet) modalSheet.style.display = 'none';
      }, 300);
    }

    // ── Mobile keyboard handling for bottom sheet ──
    // When the keyboard opens on mobile, the visual viewport shrinks.
    // We need to reposition the bottom sheet so it stays above the keyboard.
    function adjustModalForKeyboard() {
      if (!modalSheet || !isMobile()) return;
      if (modalOverlay?.classList.contains('hidden')) return;
      const vv = window.visualViewport;
      if (!vv) return;

      // How much the keyboard is pushing up
      const keyboardHeight = window.innerHeight - vv.height - vv.offsetTop;

      if (keyboardHeight > 100) {
        // Keyboard is open — move sheet above it
        modalSheet.style.bottom = keyboardHeight + 'px';
        modalSheet.style.maxHeight = (vv.height - 10) + 'px';
        // Scroll the focused input into view within the modal
        const active = document.activeElement;
        if (active && modalSheet.contains(active)) {
          setTimeout(() => active.scrollIntoView({ block: 'center', behavior: 'smooth' }), 50);
        }
      } else {
        // Keyboard closed — reset
        modalSheet.style.bottom = '0';
        modalSheet.style.maxHeight = '90vh';
      }
    }

    if (window.visualViewport) {
      window.visualViewport.addEventListener('resize', adjustModalForKeyboard);
      window.visualViewport.addEventListener('scroll', adjustModalForKeyboard);
    }

    // Fallback for browsers without visualViewport: scroll focused input into view
    modalSheet?.addEventListener('focusin', (e) => {
      if (isMobile() && !window.visualViewport) {
        setTimeout(() => {
          e.target.scrollIntoView({ block: 'center', behavior: 'smooth' });
        }, 300);
      }
    });

    // Sticky Save button → open modal
    document.getElementById('zw-sticky-save-btn')?.addEventListener('click', openSaveModal);

    // Close modal
    document.getElementById('zw-save-modal-close')?.addEventListener('click', closeSaveModal);
    modalOverlay?.addEventListener('click', closeSaveModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modalOverlay?.classList.contains('hidden')) closeSaveModal();
    });

    // Modal form submit (reuses same API)
    document.getElementById('zw-modal-email-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('zw-modal-email')?.value;
      const fullName = (document.getElementById('zw-modal-fullname')?.value || '').trim();
      const nameParts = fullName.split(/\s+/);
      const firstName = nameParts[0] || '';
      const lastName = nameParts.length > 1 ? nameParts.slice(1).join(' ') : '';
      const phone = '';

      const breakdown = window._zakatBreakdown || {};
      const spinner = document.getElementById('zw-modal-spinner');
      const msgEl = document.getElementById('zw-modal-email-msg');
      if (spinner) spinner.classList.remove('hidden');
      if (msgEl) msgEl.classList.add('hidden');

      try {
        const res = await fetch('/api/ghl/track-zakat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email, firstName, lastName, phone,
            zakatAmount: breakdown.zakatAmount || 0,
            totalAssets: breakdown.totalAssets || 0,
            totalLiabilities: breakdown.totalLiabilities || 0,
            netWealth: breakdown.netWealth || 0,
            nisabType: breakdown.nisabType || 'silver',
            nisabValue: breakdown.nisabValue || 0,
            assetsBreakdown: breakdown.assets || [],
            liabilitiesBreakdown: breakdown.liabilities || [],
            wantsReminder: false,
          }),
        });
        const result = await res.json();
        if (result.success) {
          if (msgEl) { msgEl.textContent = '✓ Calculation sent! Check your email.'; msgEl.className = 'text-center text-sm text-green-600 font-semibold py-2'; msgEl.classList.remove('hidden'); }
          setTimeout(closeSaveModal, 2000);
        } else {
          if (msgEl) { msgEl.textContent = result.error || 'Failed. Please try again.'; msgEl.className = 'text-center text-xs text-red-600'; msgEl.classList.remove('hidden'); }
        }
      } catch (err) {
        if (msgEl) { msgEl.textContent = 'Network error.'; msgEl.className = 'text-center text-xs text-red-600'; msgEl.classList.remove('hidden'); }
      } finally {
        if (spinner) spinner.classList.add('hidden');
      }
    });

    // Fetch live prices
    fetchMetalPrices();
  });

  // ===== FETCH METAL PRICES =====
  async function fetchMetalPrices() {
    try {
      const res = await fetch('/api/metal-prices');
      if (!res.ok) return;
      const data = await res.json();
      if (!data.success) return;

      goldPerGram = data.gold;
      silverPerGram = data.silver;
      nisabGold = goldPerGram * cfg.nisabGoldGrams;
      nisabSilver = silverPerGram * cfg.nisabSilverGrams;

      document.getElementById('zw-nisab-gold-display').textContent = fmtShort(nisabGold);
      document.getElementById('zw-nisab-silver-display').textContent = fmtShort(nisabSilver);

      if (!data.fallback) {
        const dot = document.getElementById('zw-live-dot');
        if (dot) dot.classList.remove('hidden');
      }

      const d = data.timestamp ? new Date(data.timestamp) : new Date();
      const dateEl = document.getElementById('zw-price-date');
      if (dateEl) dateEl.textContent = 'Prices as of ' + d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    } catch (e) {
      // Use fallback prices — already set
      document.getElementById('zw-nisab-gold-display').textContent = fmtShort(nisabGold);
      document.getElementById('zw-nisab-silver-display').textContent = fmtShort(nisabSilver);
    }
  }
</script>
