          <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <!-- Zakat Amount Display -->
        <div class="text-center mb-4">
          <p class="text-xs uppercase tracking-wider text-gray-400 mb-1 font-semibold">Your Zakat Amount</p>
          <p id="zw-modal-amount" class="text-3xl md:text-4xl font-bold text-[#024139]" style="font-family: 'Signika', sans-serif;">$0</p>
