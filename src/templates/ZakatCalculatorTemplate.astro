        <h2 class="text-lg md:text-xl font-bold text-gray-900 mb-1 text-center pr-0" style="font-family: 'Signika', sans-serif;">Send My Zakat Calculation</h2>
        <p class="text-sm text-gray-500 mb-5 text-center">Enter your email and we'll send your breakdown and a secure donation link.</p>

        <form id="zw-modal-email-form" class="space-y-3">
          <div>
            <input type="text" id="zw-modal-fullname" placeholder="Full name" class="w-full px-4 py-3.5 rounded-xl border-2 border-gray-200 text-base focus:outline-none focus:border-[#024139] bg-gray-50 focus:bg-white transition" />
          </div>
          <div>
            <input type="email" id="zw-modal-email" placeholder="Email address" required class="w-full px-4 py-3.5 rounded-xl border-2 border-gray-200 text-base focus:outline-none focus:border-[#024139] bg-gray-50 focus:bg-white transition" />
          </div>
          <p class="text-xs text-gray-400 text-center !mt-1">We'll also send you a secure link to complete your Zakat donation anytime.</p>
          <button type="submit" class="w-full bg-[#024139] hover:bg-[#01302b] text-white font-bold py-3.5 rounded-xl text-sm md:text-base transition flex items-center justify-center gap-2" style="font-family: 'Signika', sans-serif;">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <span>Send me my calculation</span>
            <svg class="w-4 h-4 hidden animate-spin" id="zw-modal-spinner" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
          </button>
          <p class="text-center text-[11px] text-gray-400 flex items-center justify-center gap-1 !mt-2">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            We respect your privacy. No spam.
          </p>
          <p id="zw-modal-email-msg" class="hidden text-center text-xs"></p>
        </form>
      </div>
  </div>
  <!-- end save modal -->

  <!-- ===== SOCIAL PROOF / IMPACT SECTION ===== -->
  <section class="py-14 bg-gradient-to-br from-[#024139] to-[#01201c] no-print">
    <div class="max-w-3xl mx-auto px-4">
