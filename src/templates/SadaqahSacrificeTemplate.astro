---
/**
 * SADAQAH SACRIFICE TEMPLATE
 *
 * Content-rich Islamic educational page with inline donation calculator.
 * Covers: What is Sadaqah, types, benefits, impact, FAQs.
 *
 * Color Palette:
 * - Brand Teal: #01534d
 * - Brand Orange: #ef7c01, #d97706
 * - Headings: Signika
 * - Body: Lato
 *
 * SEO targets: sadaqah, sadaqah meaning, sadaqah in islam,
 * types of sadaqah, benefits of sadaqah, sadaqah vs zakat
 */

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  campaign: {
    id: string;
    name: string;
    slug: string;
    title: string;
    description: string;
    featured_image: string;
    template_config: any;
    content_sections: any[];
    donation_options: any[];
  };
  donationBoxTemplate: string;
}

const { campaign, donationBoxTemplate } = Astro.props;

const contentSections = campaign.content_sections || [];
const donationOptions = campaign.donation_options || [];
const pageContent = campaign.template_config?.pageContent || {};

// FAQ items from template_config or fallback
const faqItems = pageContent?.faq?.items || [
  {
    question: 'What is the difference between Sadaqah and Zakat?',
    answer: 'Zakat is an obligatory form of charity that every eligible Muslim must pay, calculated as 2.5% of qualifying wealth. Sadaqah, on the other hand, is voluntary charity given out of generosity and compassion. While Zakat has strict rules on who can receive it, Sadaqah can be given to anyone in need and in any amount.',
  },
  {
    question: 'Can Sadaqah be given to non-Muslims?',
    answer: 'Yes, Sadaqah can be given to anyone regardless of their faith. Islam encourages kindness and generosity towards all of creation. The Prophet Muhammad (peace be upon him) emphasized that there is a reward in doing good to every living being.',
  },
  {
    question: 'Is there a minimum amount for Sadaqah?',
    answer: 'No, there is no minimum amount for Sadaqah. Even the smallest act of kindness counts as Sadaqah. The Prophet Muhammad (peace be upon him) said that even a smile is considered Sadaqah. What matters is the sincerity behind the giving.',
  },
  {
    question: 'Can I give Sadaqah on behalf of someone else?',
    answer: 'Yes, you can give Sadaqah on behalf of a living or deceased person. The reward will reach them and you will also be rewarded for your generosity. This is especially encouraged for deceased loved ones.',
  },
  {
    question: 'What is the best time to give Sadaqah?',
    answer: 'Sadaqah can be given at any time. However, giving during blessed times such as Ramadan, Dhul Hijjah, and Fridays carries additional reward. Giving during times of hardship and calamity is also highly encouraged.',
  },
  {
    question: 'Does Sadaqah have to be money?',
    answer: 'No, Sadaqah is not limited to monetary giving. It includes any act of kindness such as helping someone, sharing knowledge, removing harm from a path, speaking a kind word, or even smiling at another person.',
  },
];

// Impact cards config
const impactCards = pageContent?.impactCards || [
  { title: 'Food Aid', description: 'Feed families in crisis with nutritious meals and essential food packages.', amount: 50, icon: 'food' },
  { title: 'Clean Water', description: 'Provide safe drinking water through wells and filtration systems.', amount: 100, icon: 'water' },
  { title: 'Orphan Care', description: 'Support vulnerable children with education, nutrition, and shelter.', amount: 35, icon: 'orphan' },
  { title: 'Emergency Relief', description: 'Respond to disasters with immediate humanitarian aid and supplies.', amount: 75, icon: 'emergency' },
];

// Default donation amounts
const defaultAmounts = [10, 25, 50, 100, 250, 500];
const amounts = donationOptions.length > 0
  ? donationOptions.map((opt: any) => opt.amount || opt)
  : defaultAmounts;

const campaignSlug = campaign.slug;

// Section content with fallbacks
const whatIsSadaqah = contentSections.find((s: any) => s.title?.toLowerCase().includes('what is')) || {
  title: 'What is Sadaqah?',
  content: 'Sadaqah is one of the most beautiful acts of worship in Islam. It refers to voluntary charity given purely for the sake of Allah, without any obligation or expectation of return. Unlike Zakat, which is a mandatory pillar of Islam with specific calculations and recipients, Sadaqah is open-ended and limitless in its scope and reward.\n\nEvery Muslim is encouraged to give Sadaqah as often as possible. It is not limited to monetary giving; a kind word, a smile, removing an obstacle from someone\'s path, and sharing knowledge are all forms of Sadaqah. The Prophet Muhammad (peace be upon him) taught that every act of goodness is charity, making it accessible to everyone regardless of their financial situation.',
};

const sadaqahMeaning = contentSections.find((s: any) => s.title?.toLowerCase().includes('meaning')) || {
  title: 'What does Sadaqah mean?',
  content: 'The word Sadaqah comes from the Arabic root "sidq," which means sincerity and truthfulness. This etymology reveals the essence of Sadaqah: it is an act of giving that reflects the sincerity of one\'s faith and the truthfulness of one\'s devotion to Allah.\n\nWhen a person gives Sadaqah, they are demonstrating the truth of their belief through action. It is a tangible expression of gratitude to Allah for His blessings and a means of purifying one\'s wealth and soul.',
};

const impactSection = contentSections.find((s: any) => s.title?.toLowerCase().includes('impact')) || {
  title: 'The Impact of Sadaqah',
  content: 'Your Sadaqah has the power to transform lives across the globe. Through Qurbani Foundation, every dollar of your voluntary charity is directed towards those who need it most. From providing clean water in remote villages to feeding families in conflict zones, your generosity creates ripples of positive change that extend far beyond the initial act of giving.\n\nWe work with trusted partners on the ground in over 20 countries to ensure your Sadaqah reaches its intended recipients efficiently and with full transparency. Every project is carefully vetted, monitored, and reported on so you can see the tangible impact of your giving.',
};

const metaTitle = campaign.template_config?.metaTitle || `${campaign.title} | Qurbani Foundation USA`;
const metaDescription = campaign.template_config?.metaDescription || campaign.description || 'Give Sadaqah for the sake of Allah. Your voluntary charity provides food, clean water, orphan care, and emergency relief to those in need. Donate today with Qurbani Foundation.';
---

<Layout title={metaTitle} description={metaDescription}>
  <Navbar />

  <style>
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .sq-fade-in { animation: fadeInUp 0.6s ease-out both; }
    .sq-fade-in-d1 { animation: fadeInUp 0.6s ease-out 0.1s both; }
    .sq-fade-in-d2 { animation: fadeInUp 0.6s ease-out 0.2s both; }
    .sq-fade-in-d3 { animation: fadeInUp 0.6s ease-out 0.3s both; }
    .sq-amount-btn {
      transition: all 0.2s ease;
    }
    .sq-amount-btn.active {
      background: #01534d !important;
      color: #fff !important;
      border-color: #01534d !important;
    }
    .sq-freq-btn {
      transition: all 0.2s ease;
    }
    .sq-freq-btn.active {
      background: #01534d !important;
      color: #fff !important;
    }
    .sq-benefit-card {
      transition: all 0.25s ease;
    }
    .sq-benefit-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }
    .sq-impact-card {
      transition: all 0.25s ease;
    }
    .sq-impact-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 30px rgba(0,0,0,0.12);
    }
    .sq-type-card {
      transition: all 0.2s ease;
    }
    .sq-type-card:hover {
      background: #f0fdf4;
      border-color: #01534d;
    }
    details summary::-webkit-details-marker { display: none; }
    details summary { list-style: none; }
  </style>

  <!-- ===== 1. HERO SECTION ===== -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #01534d 0%, #024a44 50%, #013d38 100%);">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 pt-28 sm:pt-36 pb-16 sm:pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <!-- Left: Text Content -->
        <div class="text-center lg:text-left sq-fade-in">
          <!-- Breadcrumb -->
          <nav class="mb-6" aria-label="Breadcrumb">
            <ol class="flex items-center justify-center lg:justify-start space-x-2 text-sm text-white/60">
              <li><a href="/" class="hover:text-white/90 transition">Home</a></li>
              <li><span>/</span></li>
              <li><a href="/donate" class="hover:text-white/90 transition">Islamic Giving</a></li>
              <li><span>/</span></li>
              <li class="text-white/90 font-medium">Sadaqah</li>
            </ol>
          </nav>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight" style="font-family: 'Signika', sans-serif;">
            {campaign.title || 'Sadaqah'}
          </h1>

          <!-- Scholar Verified Badge -->
          <div class="inline-flex items-center gap-2 bg-emerald-500/20 border border-emerald-400/30 rounded-full px-4 py-2 mb-6">
            <svg class="w-5 h-5 text-emerald-300" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-emerald-200 text-sm font-medium">Scholar Verified</span>
          </div>

          <p class="text-lg sm:text-xl text-white/80 leading-relaxed max-w-xl mx-auto lg:mx-0" style="font-family: 'Lato', sans-serif;">
            {campaign.description || 'Sadaqah is an act of voluntary charity given for the sake of Allah. Your generosity provides relief, sustenance, and hope to those in need around the world.'}
          </p>
        </div>

        <!-- Right: Featured Image -->
        {campaign.featured_image && (
          <div class="sq-fade-in-d2">
            <div class="relative rounded-2xl overflow-hidden shadow-2xl">
              <img
                src={campaign.featured_image}
                alt={campaign.title || 'Sadaqah - Voluntary Charity'}
                class="w-full h-auto object-cover"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ===== MAIN 2-COLUMN LAYOUT ===== -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12 items-start">

        <!-- RIGHT COLUMN: Sticky Donation Box (1/3 width) — rendered first for mobile -->
        <div class="lg:col-span-1 order-first lg:order-last">
          <div class="lg:sticky lg:top-24">
      <div id="sq-donate-box" class="bg-white rounded-2xl shadow-lg p-6 sm:p-8 border border-gray-100">
        <div class="text-center mb-6">
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2" style="font-family: 'Signika', sans-serif;">
            Give Your Sadaqah
          </h2>
          <p class="text-gray-500" style="font-family: 'Lato', sans-serif;">
            An act of voluntary charity given for the sake of Allah
          </p>
        </div>

        <!-- Amount Presets -->
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-3 mb-5">
          {amounts.map((amt: number) => (
            <button
              class="sq-amount-btn border-2 border-gray-200 rounded-xl py-3 px-2 text-center font-bold text-gray-700 hover:border-[#01534d] hover:text-[#01534d] focus:outline-none"
              data-amount={amt}
              style="font-family: 'Signika', sans-serif;"
            >
              ${amt}
            </button>
          ))}
        </div>

        <!-- Custom Amount -->
        <div class="mb-5">
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-bold text-lg">$</span>
            <input
              type="number"
              id="sq-custom-amount"
              placeholder="Enter custom amount"
              min="1"
              class="w-full border-2 border-gray-200 rounded-xl py-3 pl-9 pr-4 text-lg font-medium text-gray-800 focus:border-[#01534d] focus:ring-2 focus:ring-[#01534d]/20 focus:outline-none transition"
              style="font-family: 'Lato', sans-serif;"
            />
          </div>
        </div>

        <!-- Frequency Toggle -->
        <div class="flex bg-gray-100 rounded-xl p-1 mb-6">
          <button class="sq-freq-btn active flex-1 py-3 rounded-lg text-sm font-bold text-gray-600 focus:outline-none" data-freq="single" style="font-family: 'Signika', sans-serif;">
            One-Time
          </button>
          <button class="sq-freq-btn flex-1 py-3 rounded-lg text-sm font-bold text-gray-600 focus:outline-none" data-freq="monthly" style="font-family: 'Signika', sans-serif;">
            Monthly
          </button>
        </div>

        <!-- Total Display -->
        <div class="bg-gray-50 rounded-xl p-4 mb-6 flex items-center justify-between">
          <span class="text-gray-600 font-medium" style="font-family: 'Lato', sans-serif;">Your Donation:</span>
          <span id="sq-total-display" class="text-2xl font-bold text-[#01534d]" style="font-family: 'Signika', sans-serif;">$0</span>
        </div>

        <!-- Donate Button -->
        <button
          id="sq-donate-btn"
          class="w-full py-4 rounded-xl text-white font-bold text-lg shadow-lg hover:shadow-xl transition-all focus:outline-none focus:ring-4 focus:ring-orange-300/50"
          style="background: linear-gradient(135deg, #ef7c01 0%, #d97706 100%); font-family: 'Signika', sans-serif;"
        >
          DONATE
        </button>

        <!-- Trust Badges -->
        <div class="flex items-center justify-center gap-4 mt-4 text-xs text-gray-400">
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            Secure
          </span>
          <span>|</span>
          <span>Powered by Stripe</span>
        </div>
      </div>
          </div><!-- end sticky wrapper -->
        </div><!-- end right column -->

        <!-- LEFT COLUMN: All Content (2/3 width) -->
        <div class="lg:col-span-2 order-last lg:order-first">
      <p class="text-lg md:text-xl text-gray-700 italic leading-relaxed mb-4" style="font-family: Georgia, serif;">
        "Sadaqah extinguishes sin as water extinguishes fire."
      </p>
      <p class="text-sm text-[#01534d] font-semibold">
        -- Hadith (Tirmidhi)
      </p>
    </div>
  </div>

  <!-- ===== 4. WHAT IS SADAQAH ===== -->
  <section class="py-12 sm:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-14 items-start">
        <!-- Left: Main Text (3 cols) -->
        <div class="lg:col-span-3">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6" style="font-family: 'Signika', sans-serif;">
            {whatIsSadaqah.title}
          </h2>
          <div class="prose prose-lg max-w-none text-gray-600 leading-relaxed" style="font-family: 'Lato', sans-serif;">
            {(whatIsSadaqah.content || '').split('\n\n').map((para: string) => (
              <p class="mb-4">{para}</p>
            ))}
          </div>
        </div>

        <!-- Right: Key Facts Box (2 cols) -->
        <div class="lg:col-span-2">
          <div class="bg-[#01534d] rounded-2xl p-6 sm:p-8 text-white">
            <h3 class="text-xl font-bold mb-5" style="font-family: 'Signika', sans-serif;">Key Facts About Sadaqah</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-emerald-300 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="text-white/90 text-sm leading-relaxed">Sadaqah is voluntary and has no minimum amount</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-emerald-300 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="text-white/90 text-sm leading-relaxed">Can be given to anyone in need, Muslim or non-Muslim</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-emerald-300 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="text-white/90 text-sm leading-relaxed">Not limited to money -- includes kind words, smiles, and acts of service</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-emerald-300 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="text-white/90 text-sm leading-relaxed">Protects from calamity and extinguishes sins</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-emerald-300 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="text-white/90 text-sm leading-relaxed">Rewards multiply up to 700 times or more</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-emerald-300 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="text-white/90 text-sm leading-relaxed">Can be given on behalf of the deceased</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 5. WHAT DOES SADAQAH MEAN ===== -->
  <section class="py-12 sm:py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6" style="font-family: 'Signika', sans-serif;">
        {sadaqahMeaning.title}
      </h2>
      <div class="prose prose-lg max-w-none text-gray-600 leading-relaxed mb-8" style="font-family: 'Lato', sans-serif;">
        {(sadaqahMeaning.content || '').split('\n\n').map((para: string) => (
          <p class="mb-4">{para}</p>
        ))}
      </div>

      <!-- Types of Sadaqah quick list -->
      <div class="bg-white rounded-xl p-6 border border-gray-100">
        <h3 class="text-lg font-bold text-gray-800 mb-4" style="font-family: 'Signika', sans-serif;">
          Forms of Sadaqah in Daily Life
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="flex items-center gap-3 text-gray-600 text-sm">
            <div class="w-2 h-2 bg-[#01534d] rounded-full shrink-0"></div>
            <span>Giving money, food, or clothing to those in need</span>
          </div>
          <div class="flex items-center gap-3 text-gray-600 text-sm">
            <div class="w-2 h-2 bg-[#01534d] rounded-full shrink-0"></div>
            <span>Sharing knowledge or teaching others</span>
          </div>
          <div class="flex items-center gap-3 text-gray-600 text-sm">
            <div class="w-2 h-2 bg-[#01534d] rounded-full shrink-0"></div>
            <span>Speaking a kind or encouraging word</span>
          </div>
          <div class="flex items-center gap-3 text-gray-600 text-sm">
            <div class="w-2 h-2 bg-[#01534d] rounded-full shrink-0"></div>
            <span>Helping someone physically with a task</span>
          </div>
          <div class="flex items-center gap-3 text-gray-600 text-sm">
            <div class="w-2 h-2 bg-[#01534d] rounded-full shrink-0"></div>
            <span>Removing harm or obstacles from a path</span>
          </div>
          <div class="flex items-center gap-3 text-gray-600 text-sm">
            <div class="w-2 h-2 bg-[#01534d] rounded-full shrink-0"></div>
            <span>Greeting others with a warm smile</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 6. HADITH QUOTE 2 (QURAN 2:261) ===== -->
  <div class="my-12 mx-auto max-w-3xl px-4">
    <div class="bg-[#f8faf9] border-l-4 border-[#01534d] rounded-r-xl p-8">
      <svg class="w-8 h-8 text-[#01534d]/30 mb-3" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.998 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.986z"/>
      </svg>
      <p class="text-lg md:text-xl text-gray-700 italic leading-relaxed mb-4" style="font-family: Georgia, serif;">
        "The example of those who spend their wealth in the Way of Allah is that of a grain of corn that sprouts seven ears, and in every ear there are a hundred grains. Thus Allah multiplies the action of whomsoever He wills."
      </p>
      <p class="text-sm text-[#01534d] font-semibold">
        -- Quran 2:261
      </p>
    </div>
  </div>

  <!-- ===== 7. THE IMPACT OF SADAQAH ===== -->
  <section class="py-12 sm:py-16">
    <div class="max-w-4xl mx-auto px-4">
