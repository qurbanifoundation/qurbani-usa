              </svg>
            </div>
            <div>
              <h4 class="font-bold text-gray-800 mb-1" style="font-family: 'Signika', sans-serif;">Removing Harm from the Path</h4>
              <p class="text-gray-500 text-sm leading-relaxed">Clearing obstacles, debris, or anything harmful from a walkway is an act of Sadaqah that benefits everyone.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 13. FAQ SECTION ===== -->
  <section class="py-12 sm:py-16">
    <div class="max-w-3xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3" style="font-family: 'Signika', sans-serif;">
          Frequently Asked Questions
        </h2>
        <p class="text-gray-500" style="font-family: 'Lato', sans-serif;">
          Common questions about Sadaqah in Islam
        </p>
      </div>

      <div class="space-y-3">
        {faqItems.map((faq: any) => (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
            <button class="sq-faq-toggle w-full flex items-center justify-between p-5 text-left hover:bg-gray-50 transition focus:outline-none">
              <span class="font-semibold text-gray-800 pr-4" style="font-family: 'Signika', sans-serif;">{faq.question}</span>
              <span class="sq-faq-icon text-[#01534d] text-xl font-bold shrink-0 w-6 h-6 flex items-center justify-center">+</span>
            </button>
            <div class="hidden px-5 pb-5">
              <p class="text-gray-600 leading-relaxed" style="font-family: 'Lato', sans-serif;">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

        </div><!-- end left column -->
      </div><!-- end grid -->
    </div>
  </section><!-- end 2-column layout -->

  <!-- ===== 14. FINAL CTA SECTION ===== -->
  <section class="py-16 sm:py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4" style="font-family: 'Signika', sans-serif;">
        Start Your Sadaqah Today
      </h2>
      <p class="text-gray-600 text-lg mb-8 max-w-xl mx-auto" style="font-family: 'Lato', sans-serif;">
        No amount is too small. Whether it is a dollar or a smile, every act of goodness counts as Sadaqah. Take the first step today and experience the blessings of giving.
      </p>
      <button
        data-scroll-to-donate
        class="inline-flex items-center gap-2 px-10 py-4 rounded-xl text-white font-bold text-lg shadow-lg hover:shadow-xl transition-all focus:outline-none focus:ring-4 focus:ring-orange-300/50"
        style="background: linear-gradient(135deg, #ef7c01 0%, #d97706 100%); font-family: 'Signika', sans-serif;"
      >
        Give Sadaqah Now
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/>
        </svg>
      </button>
    </div>
  </section>

  <Footer />

  <script define:vars={{ campaignSlug }}>
    document.addEventListener('DOMContentLoaded', function() {
      var selectedAmount = 0;
      var frequency = 'single';

      // Amount buttons
      document.querySelectorAll('.sq-amount-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          selectedAmount = parseInt(btn.dataset.amount);
          // Clear custom input
          var customInput = document.getElementById('sq-custom-amount');
          if (customInput) customInput.value = '';
          // Update active state
          document.querySelectorAll('.sq-amount-btn').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          // Update total
          updateTotal();
        });
      });

      // Custom amount input
      var customInput = document.getElementById('sq-custom-amount');
      if (customInput) {
        customInput.addEventListener('input', function() {
          selectedAmount = parseInt(customInput.value) || 0;
          // Remove active from preset buttons
          document.querySelectorAll('.sq-amount-btn').forEach(function(b) { b.classList.remove('active'); });
          updateTotal();
        });
        customInput.addEventListener('focus', function() {
          document.querySelectorAll('.sq-amount-btn').forEach(function(b) { b.classList.remove('active'); });
        });
      }

      // Frequency toggle
      document.querySelectorAll('.sq-freq-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          frequency = btn.dataset.freq;
          document.querySelectorAll('.sq-freq-btn').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          updateTotal();
        });
      });

      function updateTotal() {
        var display = document.getElementById('sq-total-display');
        if (display) {
          var suffix = frequency === 'monthly' ? '/mo' : '';
          display.textContent = '$' + (selectedAmount || 0) + suffix;
        }
      }

      // Donate button
      var donateBtn = document.getElementById('sq-donate-btn');
      if (donateBtn) {
        donateBtn.addEventListener('click', function() {
          if (selectedAmount <= 0) return;
          if (typeof window.addToCart === 'function') {
            window.addToCart({
              id: 'sadaqah-' + selectedAmount + '-' + Date.now(),
              name: 'Sadaqah',
              amount: selectedAmount,
              quantity: 1,
              type: frequency === 'monthly' ? 'monthly' : 'single',
              campaign: campaignSlug,
              description: 'Sadaqah - $' + selectedAmount
            });
          }
        });
      }

      // FAQ accordion
      document.querySelectorAll('.sq-faq-toggle').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var answer = btn.nextElementSibling;
          var icon = btn.querySelector('.sq-faq-icon');
          if (answer) answer.classList.toggle('hidden');
          if (icon) icon.textContent = (answer && answer.classList.contains('hidden')) ? '+' : '-';
        });
      });

      // Scroll CTA buttons
      document.querySelectorAll('[data-scroll-to-donate]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var donateBox = document.getElementById('sq-donate-box');
          if (donateBox) donateBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      });
    });
  </script>
</Layout>
