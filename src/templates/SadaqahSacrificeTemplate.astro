              <p class="text-gray-500 text-sm leading-relaxed">Giving money, food, clothing, or material resources to those in need.</p>
            </div>
          </div>
        </div>

        <!-- Knowledge -->
        <div class="sq-type-card bg-white rounded-xl p-6 border-2 border-gray-100">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 bg-blue-50 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
