              <h4 class="font-bold text-gray-800 mb-1" style="font-family: 'Signika', sans-serif;">Sadaqah of Knowledge</h4>
              <p class="text-gray-500 text-sm leading-relaxed">Teaching others, sharing beneficial knowledge, and guiding someone to good.</p>
            </div>
          </div>
        </div>

        <!-- Body -->
        <div class="sq-type-card bg-white rounded-xl p-6 border-2 border-gray-100">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 bg-green-50 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
              </svg>
            </div>
            <div>
              <h4 class="font-bold text-gray-800 mb-1" style="font-family: 'Signika', sans-serif;">Sadaqah of Body</h4>
              <p class="text-gray-500 text-sm leading-relaxed">Helping someone physically, volunteering your time, or assisting with labor.</p>
            </div>
          </div>
        </div>

        <!-- Speech -->
        <div class="sq-type-card bg-white rounded-xl p-6 border-2 border-gray-100">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 bg-purple-50 rounded-lg flex items-center justify-center shrink-0">
