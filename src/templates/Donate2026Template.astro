  }

  // ========================================
  // EVENT BINDING
  // ========================================
  function bindPanelEvents(causeId, config) {
    var activeConfig = config._subConfig || config;

    // Change cause link
    var changeLinks = panelEl.querySelectorAll('[data-action="change-cause"]');
    for (var i = 0; i < changeLinks.length; i++) {
      changeLinks[i].addEventListener('click', function() {
        // Scroll to cause grid on mobile
        if (window.innerWidth < 1024) {
          causeGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }

    // Frequency toggle
    var freqBtns = panelEl.querySelectorAll('.dp-freq-btn[data-freq]');
    for (var i = 0; i < freqBtns.length; i++) {
      freqBtns[i].addEventListener('click', function() {
        state.frequency = this.getAttribute('data-freq');
        state.selectedAmount = null;
        state.customAmount = '';
        // Re-render entire panel to update badge, suffixes, labels
        renderPanel(activeCause, causeData[activeCause]);
      });
    }

    // Amount buttons
    var amountBtns = panelEl.querySelectorAll('.dp-amount-btn');
    for (var i = 0; i < amountBtns.length; i++) {
      amountBtns[i].addEventListener('click', function() {
        var amtVal = this.getAttribute('data-amount');
        var customWrap = document.getElementById('dpCustomWrap');
        if (amtVal === 'other') {
          // Show custom input, hide Other button
          if (customWrap) customWrap.style.display = '';
          this.style.display = 'none';
          state.selectedAmount = 0;
          state.customAmount = '';
          var ci = document.getElementById('dpCustomAmount');
          if (ci) ci.focus();
          for (var j = 0; j < amountBtns.length; j++) {
            amountBtns[j].classList.remove('dp-amount-selected');
          }
          return;
        }
        var amt = parseInt(amtVal);
        state.selectedAmount = amt;
        state.customAmount = '';
        var customInput = document.getElementById('dpCustomAmount');
        if (customInput) customInput.value = '';
        // Hide custom, show Other btn
        if (customWrap) customWrap.style.display = 'none';
        var otherBtn = panelEl.querySelector('.dp-other-btn');
        if (otherBtn) otherBtn.style.display = '';
        for (var j = 0; j < amountBtns.length; j++) {
          amountBtns[j].classList.toggle('dp-amount-selected', amountBtns[j] === this);
        }
        var impactEl = document.getElementById('dpImpact');
        if (impactEl) impactEl.textContent = getImpactText(amt);
      });
    }

    // Custom amount input
    var customInput = document.getElementById('dpCustomAmount');
    if (customInput) {
      customInput.addEventListener('input', function() {
        var val = parseInt(this.value) || 0;
        if (val > 0) {
          state.selectedAmount = val;
          state.customAmount = this.value;
          // Deselect amount buttons
          for (var j = 0; j < amountBtns.length; j++) {
            amountBtns[j].classList.remove('dp-amount-selected');
          }
          var impactEl = document.getElementById('dpImpact');
          if (impactEl) impactEl.textContent = getImpactText(val);
        }
      });
    }

    // Sub-campaign select buttons
    var scBtns = panelEl.querySelectorAll('.dp-subcampaign-select');
    for (var i = 0; i < scBtns.length; i++) {
      scBtns[i].addEventListener('click', function() {
        state.selectedSubCampaign = this.getAttribute('data-slug');
        renderPanel(causeId, config);
      });
    }

    // Tier cards
    var tierBtns = panelEl.querySelectorAll('.dp-tier-card');
    for (var i = 0; i < tierBtns.length; i++) {
      tierBtns[i].addEventListener('click', function() {
        state.selectedTier = parseInt(this.getAttribute('data-tier'));
        for (var j = 0; j < tierBtns.length; j++) {
          tierBtns[j].classList.toggle('dp-tier-selected', tierBtns[j] === this);
        }
        var donateBtn = document.getElementById('dpDonateBtn');
        if (donateBtn) donateBtn.removeAttribute('disabled');
      });
    }

    // Orphan country pills
    var countryPills = panelEl.querySelectorAll('.dp-pill[data-country]');
    for (var i = 0; i < countryPills.length; i++) {
      countryPills[i].addEventListener('click', function() {
        state.orphanCountry = this.getAttribute('data-country');
        renderPanel(causeId, config);
      });
    }

    // Orphan qty pills
    var qtyPills = panelEl.querySelectorAll('.dp-pill[data-qty]');
    for (var i = 0; i < qtyPills.length; i++) {
      qtyPills[i].addEventListener('click', function() {
        state.orphanQty = parseInt(this.getAttribute('data-qty'));
        renderPanel(causeId, config);
      });
    }

    // Orphan frequency toggle
    var ofreqBtns = panelEl.querySelectorAll('.dp-freq-btn[data-ofreq]');
    for (var i = 0; i < ofreqBtns.length; i++) {
      ofreqBtns[i].addEventListener('click', function() {
        state.orphanFreq = this.getAttribute('data-ofreq');
        renderPanel(causeId, config);
      });
    }

    // Aqiqah package cards
    var aqPkgBtns = panelEl.querySelectorAll('.dp-aqiqah-card');
    for (var i = 0; i < aqPkgBtns.length; i++) {
      aqPkgBtns[i].addEventListener('click', function() {
        state.aqiqahPackage = this.getAttribute('data-pkg');
        renderPanel(causeId, config);
      });
    }

    // Aqiqah child name
    var childNameInput = document.getElementById('dpChildName');
    if (childNameInput) {
      childNameInput.addEventListener('input', function() {
        state.aqiqahChildName = this.value;
      });
    }

    // Aqiqah for select
    var aqForSelect = document.getElementById('dpAqiqahFor');
    if (aqForSelect) {
      aqForSelect.addEventListener('change', function() {
        state.aqiqahFor = this.value;
      });
    }

    // Donate button
    var donateBtn = document.getElementById('dpDonateBtn');
    if (donateBtn) {
      donateBtn.addEventListener('click', function() {
        handleDonate(causeId, activeConfig, config);
      });
    }

    // Mobile donate button
    if (mobileDonateBtn) {
      mobileDonateBtn.onclick = function() {
        handleDonate(causeId, activeConfig, config);
      };
    }
  }

  // ========================================
  // HANDLE DONATE
  // ========================================
  function handleDonate(causeId, activeConfig, parentConfig) {
    if (typeof window.addToCart !== 'function') {
      console.error('addToCart not available');
      return;
    }

    var config = parentConfig._subConfig || activeConfig;

    switch (config.type) {
      case 'preset-amounts': {
        var amount = state.selectedAmount || (state.customAmount ? parseInt(state.customAmount) : null);
        if (!amount || amount <= 0) {
          highlightMissing('.dp-amount-grid');
          return;
        }
        var freq = state.frequency;
        var slug = config.campaignSlug || 'general';
        var name = config.campaignName || 'Donation';
        window.addToCart({
          id: 'donate-' + slug + '-' + amount + '-' + freq + '-' + Date.now(),
          name: name,
          amount: amount,
          quantity: 1,
          type: freq === 'monthly' ? 'monthly' : 'single',
          campaign: slug
        });
        break;
      }
      case 'zakat': {
        var amount = state.selectedAmount || (state.customAmount ? parseInt(state.customAmount) : null);
        if (!amount || amount <= 0) {
          highlightMissing('.dp-amount-grid');
          return;
        }
        window.addToCart({
          id: 'zakat-' + amount + '-' + Date.now(),
          name: 'Zakat',
          amount: amount,
          quantity: 1,
          type: 'single',
          campaign: config.campaignSlug || 'zakat'
        });
        break;
      }
      case 'tiered-projects': {
        if (state.selectedTier === null) return;
        var tiers = config.tiers || [];
        var tier = tiers[state.selectedTier];
        if (!tier) return;
        window.addToCart({
          id: 'water-' + tier.name.toLowerCase().replace(/\s+/g, '-') + '-' + tier.amount + '-' + Date.now(),
          name: tier.name,
          amount: tier.amount,
          quantity: 1,
          type: 'single',
          campaign: config.campaignSlug || 'thirst-relief'
        });
        break;
      }
      case 'orphan-sponsorship': {
        var basePrice = (state.orphanCountry === 'palestine') ? (parentConfig.palestinePrice || 100) : (parentConfig.basePrice || 45);
        var total = basePrice * state.orphanQty;
        var isMonthly = (state.orphanFreq === 'monthly');
        if (!isMonthly) total = total * 12;
        var countryNames = { 'greatest-need': 'Greatest Need', 'pakistan': 'Pakistan', 'palestine': 'Palestine', 'yemen': 'Yemen', 'kenya': 'Kenya' };
        var countryName = countryNames[state.orphanCountry] || state.orphanCountry;
        window.addToCart({
          id: 'orphan-' + state.orphanCountry + '-' + state.orphanQty + '-' + Date.now(),
          name: 'Orphan Sponsorship - ' + countryName + ' (' + state.orphanQty + ' ' + (state.orphanQty === 1 ? 'Child' : 'Children') + ')',
          amount: total,
          quantity: 1,
          type: isMonthly ? 'monthly' : 'single',
          campaign: parentConfig.campaignSlug || 'sponsor-an-orphan'
        });
        break;
      }
      case 'aqiqah': {
        if (!state.aqiqahPackage) return;
        var pkg = null;
        var packages = config.packages || [];
        for (var i = 0; i < packages.length; i++) {
          var pkgId = (packages[i].label || '').toLowerCase().replace(/\s+/g, '-');
          if (pkgId === state.aqiqahPackage) { pkg = packages[i]; break; }
        }
        if (!pkg) return;
        var childNameInput = document.getElementById('dpChildName');
        var aqForSelect = document.getElementById('dpAqiqahFor');
        var childName = childNameInput ? childNameInput.value : state.aqiqahChildName;
        var aqFor = aqForSelect ? aqForSelect.value : state.aqiqahFor;
        window.addToCart({
          id: 'aqiqah-' + state.aqiqahPackage + '-' + Date.now(),
          name: pkg.label + ' Aqiqah',
          amount: pkg.amount,
          quantity: 1,
          type: 'single',
          campaign: config.campaignSlug || 'aqiqah',
          metadata: {
            childName: childName,
            aqiqahFor: aqFor,
            packageType: state.aqiqahPackage
          }
        });
        break;
      }
    }
  }

  // ========================================
  // UTILITY
  // ========================================
  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function formatNum(n) {
    return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function highlightMissing(selector) {
    var el = panelEl.querySelector(selector);
    if (el) {
      el.style.outline = '2px solid #ef4444';
      el.style.borderRadius = '0.75rem';
      setTimeout(function() { el.style.outline = 'none'; }, 2000);
    }
  }

  // ========================================
  // CAUSE CARD CLICK HANDLERS
  // ========================================
  var causeCards = causeGrid.querySelectorAll('.cause-card');
  for (var i = 0; i < causeCards.length; i++) {
    causeCards[i].addEventListener('click', function() {
      var id = this.getAttribute('data-cause');
      if (id) switchCause(id);
    });
  }

  // ========================================
  // URL PARAM CHECK
  // ========================================
  var params = new URLSearchParams(window.location.search);
  var causeParam = params.get('cause');
  if (causeParam && causeData[causeParam]) {
    switchCause(causeParam);
  } else {
    switchCause('most-needed');
  }

  // Mobile sticky visibility
  window.addEventListener('resize', function() {
    if (mobileStickyBtn) {
      mobileStickyBtn.style.display = (window.innerWidth < 1024) ? 'block' : 'none';
    }
  });
  if (window.innerWidth < 1024 && mobileStickyBtn) {
    mobileStickyBtn.style.display = 'block';
  }

})();
</script>

