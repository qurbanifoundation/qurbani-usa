  // ========================================
  // ORPHAN SPONSORSHIP PANEL
  // ========================================
  function renderOrphanSponsorship(causeId, config) {
    var html = panelHeader('Orphan Care', true);

    // Country pills
    var countries = [
      { id: 'greatest-need', label: 'Greatest Need' },
      { id: 'pakistan', label: 'Pakistan' },
      { id: 'palestine', label: 'Palestine' },
