    html += '<div class="dp-pill-row">';
    for (var i = 0; i < countries.length; i++) {
      var c = countries[i];
      var sel = (state.orphanCountry === c.id) ? ' dp-pill-active' : '';
      html += '<button type="button" class="dp-pill' + sel + '" data-country="' + c.id + '">' + escapeHtml(c.label) + '</button>';
    }
    html += '</div>';

    // Quantity
    var qtys = [1, 2, 3, 5];
    html += '<label class="dp-field-label">Number of Children</label>';
    html += '<div class="dp-pill-row">';
    for (var i = 0; i < qtys.length; i++) {
      var q = qtys[i];
      var sel = (state.orphanQty === q) ? ' dp-pill-active' : '';
      html += '<button type="button" class="dp-pill' + sel + '" data-qty="' + q + '">' + q + '</button>';
    }
    html += '</div>';

    // Monthly / Yearly toggle
    html += '<label class="dp-field-label">Frequency</label>';
    html += '<div class="dp-freq-toggle">';
    html += '<button type="button" class="dp-freq-btn' + (state.orphanFreq === 'monthly' ? ' active' : '') + '" data-ofreq="monthly">Monthly</button>';
    html += '<button type="button" class="dp-freq-btn' + (state.orphanFreq === 'yearly' ? ' active' : '') + '" data-ofreq="yearly">Yearly</button>';
    html += '</div>';

    // Price calculation
    var basePrice = (state.orphanCountry === 'palestine') ? (config.palestinePrice || 100) : (config.basePrice || 45);
    var total = basePrice * state.orphanQty;
    if (state.orphanFreq === 'yearly') total = total * 12;
    var perLabel = state.orphanFreq === 'monthly' ? '/mo' : '/yr';

    html += '<div class="dp-orphan-price">';
    html += '<span class="dp-orphan-total">$' + formatNum(total) + '<span class="dp-orphan-per">' + perLabel + '</span></span>';
    html += '<span class="dp-orphan-breakdown">' + state.orphanQty + ' ' + (state.orphanQty === 1 ? 'child' : 'children') + ' x $' + formatNum(basePrice) + '/mo</span>';
    html += '</div>';

    // CTA
    html += '<button type="button" class="dp-cta-btn" id="dpDonateBtn">Sponsor Now <span class="dp-arrow">&rarr;</span></button>';

    html += trustLine();
    return html;
  }

