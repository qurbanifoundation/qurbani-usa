  // ─── Campaign Cache ───
  var campaignCache = null;
  var campaignCacheTime = 0;

  function fetchCampaigns(cb) {
    var now = Date.now();
    if (campaignCache && (now - campaignCacheTime) < 300000) { cb(campaignCache); return; }
    fetch('/api/campaigns')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var list = Array.isArray(d) ? d : (d.campaigns || []);
        campaignCache = list; campaignCacheTime = Date.now();
        cb(list);
      })
      .catch(function() { cb(campaignCache || []); });
  }

  function findCampaign(campaigns, slug) {
    if (!slug || !campaigns) return null;
    slug = slug.toLowerCase();
    for (var i = 0; i < campaigns.length; i++) {
      if ((campaigns[i].slug || '').toLowerCase() === slug) return campaigns[i];
    }
    for (var i = 0; i < campaigns.length; i++) {
      var s = (campaigns[i].name || '').toLowerCase().replace(/\s+/g, '-');
      if (s === slug || s.indexOf(slug) !== -1 || slug.indexOf(s) !== -1) return campaigns[i];
    }
    return null;
  }

  // ─── Emoji for campaign slug ───
  function getEmoji(slug) {
    var s = (slug || '').toLowerCase();
    if (s.indexOf('water') !== -1 || s.indexOf('well') !== -1) return '💧';
    if (s.indexOf('gaza') !== -1 || s.indexOf('palestin') !== -1) return '🇵🇸';
    if (s.indexOf('sudan') !== -1) return '🇸🇩';
    if (s.indexOf('syria') !== -1) return '🇸🇾';
    if (s.indexOf('yemen') !== -1) return '🇾🇪';
    if (s.indexOf('zakat') !== -1) return '🤲';
    if (s.indexOf('ramadan') !== -1 || s.indexOf('iftar') !== -1 || s.indexOf('fidya') !== -1) return '🌙';
    if (s.indexOf('orphan') !== -1) return '👶';
    if (s.indexOf('food') !== -1 || s.indexOf('meal') !== -1 || s.indexOf('feed') !== -1) return '🍽️';
    if (s.indexOf('qurbani') !== -1 || s.indexOf('aqiqah') !== -1) return '🐑';
    if (s.indexOf('mosque') !== -1 || s.indexOf('masjid') !== -1) return '🕌';
    if (s.indexOf('sadaqah') !== -1 || s.indexOf('jariyah') !== -1) return '🌱';
    if (s.indexOf('emergency') !== -1 || s.indexOf('relief') !== -1 || s.indexOf('crisis') !== -1) return '🆘';
    if (s.indexOf('education') !== -1 || s.indexOf('school') !== -1) return '📚';
    return 'heart';
  }

  // ─── Impact text generator ───
  function generateImpact(slug, freq, amount) {
    if (freq === 'monthly') {
      if (amount >= 100) return 'Provides <strong>comprehensive monthly support</strong> to families in need';
      if (amount >= 40) return 'Delivers <strong>essential supplies</strong> to a family every month';
      if (amount >= 20) return 'Provides <strong>regular meals</strong> to families in need';
      return 'Makes a <strong>lasting monthly impact</strong> for those in need';
    }
    if (amount >= 200) return 'Delivers <strong>life-changing aid</strong> to families in need';
    if (amount >= 150) return 'Provides <strong>essential support</strong> to those in crisis';
    if (amount >= 100) return 'Helps <strong>transform lives</strong> with critical assistance';
    if (amount >= 50) return 'Delivers <strong>emergency aid</strong> to families in need';
    return 'Makes an <strong>immediate impact</strong> for those in need';
  }

  // ─── Notification Helpers ───
  function escapeHtml(s) {
    if (!s) return '';
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderNotification(notif) {
    var html = '<div class="flex items-center gap-3">';
    html += '<div class="flex-1 min-w-0">';
    html += '<p class="text-sm text-gray-900 leading-snug">';
    html += '<span class="font-semibold">' + escapeHtml(notif.name) + '</span>';
    html += ' donated <span class="font-bold text-[#01534d]">$' + notif.amount.toLocaleString('en-US') + '</span>';
    html += '</p>';
    html += '<p class="text-xs text-gray-500 mt-0.5">to <span class="font-medium text-gray-700">' + escapeHtml(notif.campaign) + '</span></p>';
    html += '<p class="text-[11px] text-gray-400 mt-0.5">' + notif.flag + ' ' + escapeHtml(notif.city) + ', ' + escapeHtml(notif.country) + '</p>';
    html += '</div>';
    html += '<button type="button" class="sp-donate-trigger flex-shrink-0 inline-flex items-center px-5 py-2.5 bg-[#e1861d] text-white text-sm font-bold rounded-lg hover:bg-[#c97318] transition shadow-sm cursor-pointer tracking-wide">Donate</button>';
    html += '<button type="button" id="social-proof-close" class="flex-shrink-0 w-7 h-7 flex items-center justify-center rounded-full text-gray-300 hover:text-gray-500 hover:bg-gray-100 transition ml-1" aria-label="Dismiss">';
    html += '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>';
    html += '</button>';
    html += '</div>';
    return html;
  }

  // ─── Notification Show/Hide ───
  function showPopup() {
    if (isDismissed || !notifications.length) return;
    if (modalOpen) return; // Never show while donation modal is open
    if (donationInteracting) { pendingShow = true; return; } // Pause during donation interaction
    if (notifShownCount >= MAX_PER_SESSION) return;
    if (document.hidden) return;

    // Check if user is typing in a form field
    var activeEl = document.activeElement;
    if (activeEl && (activeEl.tagName === 'INPUT' || activeEl.tagName === 'TEXTAREA' || activeEl.tagName === 'SELECT')) {
      pendingShow = true;
      return;
    }

    // Idle check: if user is actively clicking/scrolling, defer
    if (!userIsIdle) {
      pendingShow = true;
      return;
    }

    // Clear hybrid trigger state (timer or idle won — doesn't matter which)
    pendingShow = false;
    hybridIdleActive = false;
    if (pauseTimer) { clearTimeout(pauseTimer); pauseTimer = null; }

    var notif = notifications[currentIndex % notifications.length];
    contentEl.innerHTML = renderNotification(notif);
    // Re-resolve close button (rendered dynamically in each notification)
    closeBtn = document.getElementById('social-proof-close');
    if (closeBtn) {
      closeBtn.addEventListener('click', function(e) { e.stopPropagation(); dismiss(); });
    }
    popup.style.opacity = '1';
    popup.style.transform = 'translateX(0)';
    isVisible = true;

    progressEl.style.transition = 'none';
    progressEl.style.width = '0%';
    void progressEl.offsetWidth;
    progressEl.style.transition = 'width ' + SHOW_DURATION + 'ms linear';
    progressEl.style.width = '100%';

    notifShownCount++;
    sessionStorage.setItem(SESSION_COUNT_KEY, String(notifShownCount));
    showTimer = setTimeout(hidePopup, SHOW_DURATION);
  }

  function hidePopup() {
    popup.style.opacity = '0';
    popup.style.transform = 'translateX(-120%)';
    isVisible = false;
    currentIndex++;
    sessionStorage.setItem(INDEX_KEY, String(currentIndex));
    progressEl.style.transition = 'none';
    progressEl.style.width = '0%';
    // Schedule next popup using hybrid triggers (timer OR idle)
    scheduleNextHybrid();
  }

  function dismiss() {
    // Just dismiss the popup silently — lead capture only triggers from donate modal X
    isDismissed = true;
    if (showTimer) clearTimeout(showTimer);
    if (pauseTimer) clearTimeout(pauseTimer);
    localStorage.setItem(COOLDOWN_KEY, String(Date.now()));
    popup.style.opacity = '0';
    popup.style.transform = 'translateX(-120%)';
    isVisible = false;
  }

  // ═══════════════════════════════════════════════
  // CW DONATION BOX — BUILD AMOUNT GRID (3-col)
  // ═══════════════════════════════════════════════
  function buildAmountGrid(container, amounts, freqKey, suffix, defaultIdx) {
    if (!container) return;
    container.innerHTML = '';
    var rows = [];
    for (var i = 0; i < amounts.length; i += 3) { rows.push(amounts.slice(i, i + 3)); }
    var lastRow = rows[rows.length - 1] || [];
    var lastRowFull = lastRow.length === 3;
    var otherColSpan = lastRowFull ? 3 : (3 - lastRow.length);

    for (var ri = 0; ri < rows.length; ri++) {
      var row = rows[ri];
      var isLastRow = ri === rows.length - 1;
      var showOtherInRow = isLastRow && !lastRowFull;
      var rowDiv = document.createElement('div');
      rowDiv.className = 'grid grid-cols-3 gap-2.5' + (ri < rows.length - 1 || showOtherInRow || lastRowFull ? ' mb-2.5' : '');

      for (var ci = 0; ci < row.length; ci++) {
        var amt = row[ci];
        var idx = amounts.indexOf(amt);
        var isDefault = idx === defaultIdx;
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'sp-cw-amt-btn relative rounded py-3 px-1 text-center transition-all border border-[#e0e1dc]' + (isDefault ? ' sp-cw-amt-selected' : '');
        btn.setAttribute('data-amount', amt);
        btn.setAttribute('data-freq', freqKey);
        if (isDefault) {
          btn.style.backgroundColor = currentAccentColor;
          btn.style.borderColor = currentAccentColor;
          btn.style.color = currentAccentTextColor;
        } else {
          btn.style.backgroundColor = '#f4f5f0';
        }
        btn.innerHTML = '<span class="text-[17px] font-bold' + (isDefault ? '' : ' text-gray-400') + '">$' + amt + '</span>' +
                         '<span class="text-[11px] ml-0.5 font-medium' + (isDefault ? ' opacity-70' : ' text-gray-400') + '">' + suffix + '</span>';
        rowDiv.appendChild(btn);
      }

      if (showOtherInRow) {
        var spanClass = otherColSpan === 2 ? 'col-span-2' : otherColSpan === 3 ? 'col-span-3' : '';
        var otherBtn = document.createElement('button');
        otherBtn.type = 'button';
        otherBtn.className = 'sp-cw-other-btn ' + spanClass + ' rounded py-3 px-3 text-center border border-[#e0e1dc] transition-all text-gray-400 font-bold text-[17px]';
        otherBtn.style.backgroundColor = '#f4f5f0';
        otherBtn.textContent = 'Other';
        rowDiv.appendChild(otherBtn);
        var customWrap = document.createElement('div');
        customWrap.className = 'sp-cw-custom-wrap ' + spanClass + ' hidden';
        customWrap.innerHTML = '<div class="relative rounded border border-[#e0e1dc] overflow-hidden" style="background-color:#f4f5f0;">' +
          '<span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-bold text-[17px]">$</span>' +
          '<input type="text" inputmode="numeric" pattern="[0-9]*\\.?[0-9]*" class="sp-cw-custom w-full pl-8 pr-16 py-3 bg-transparent text-[17px] font-bold text-gray-800 focus:outline-none placeholder-gray-400" placeholder="Other" />' +
          '<span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 text-[11px] font-medium">' + suffix + '</span></div>';
        rowDiv.appendChild(customWrap);
      }
      container.appendChild(rowDiv);
    }

    if (lastRowFull) {
      var otherRow = document.createElement('div');
      otherRow.className = 'grid grid-cols-3 gap-2.5';
      var otherBtn2 = document.createElement('button');
      otherBtn2.type = 'button';
      otherBtn2.className = 'sp-cw-other-btn col-span-3 rounded py-3 px-3 text-center border border-[#e0e1dc] transition-all text-gray-400 font-bold text-[17px]';
      otherBtn2.style.backgroundColor = '#f4f5f0';
      otherBtn2.textContent = 'Other';
      otherRow.appendChild(otherBtn2);
      var customWrap2 = document.createElement('div');
      customWrap2.className = 'sp-cw-custom-wrap col-span-3 hidden';
      customWrap2.innerHTML = '<div class="relative rounded border border-[#e0e1dc] overflow-hidden" style="background-color:#f4f5f0;">' +
        '<span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-bold text-[17px]">$</span>' +
        '<input type="text" inputmode="numeric" pattern="[0-9]*\\.?[0-9]*" class="sp-cw-custom w-full pl-8 pr-16 py-3 bg-transparent text-[17px] font-bold text-gray-800 focus:outline-none placeholder-gray-400" placeholder="Other" />' +
        '<span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 text-[11px] font-medium">' + suffix + '</span></div>';
      otherRow.appendChild(customWrap2);
      container.appendChild(otherRow);
    }
    wireGridEvents(container, freqKey);
  }

  function wireGridEvents(grid, freqKey) {
    var btns = grid.querySelectorAll('.sp-cw-amt-btn');
    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        selectedAmount = parseFloat(this.dataset.amount);
        var ci = grid.querySelector('.sp-cw-custom');
        var cw = grid.querySelector('.sp-cw-custom-wrap');
        var ob = grid.querySelector('.sp-cw-other-btn');
        if (ci) ci.value = '';
        if (cw) cw.classList.add('hidden');
        if (ob) ob.classList.remove('hidden');
        clearGridSelection(grid);
        highlightAmtBtn(this);
        updateCwImpact();
      });
    });
    var otherBtn = grid.querySelector('.sp-cw-other-btn');
    if (otherBtn) {
      otherBtn.addEventListener('click', function() {
        var cw = grid.querySelector('.sp-cw-custom-wrap');
        var ci = grid.querySelector('.sp-cw-custom');
        if (cw) cw.classList.remove('hidden');
        otherBtn.classList.add('hidden');
        clearGridSelection(grid);
        selectedAmount = 0;
        updateCwImpact();
        if (ci) ci.focus();
      });
    }
    var customInput = grid.querySelector('.sp-cw-custom');
    if (customInput) {
      customInput.addEventListener('input', function() {
        if (this.value) {
          selectedAmount = parseFloat(this.value) || 0;
          clearGridSelection(grid);
          updateCwImpact();
        }
      });
    }
  }

  function clearGridSelection(grid) {
    if (!grid) return;
    var btns = grid.querySelectorAll('.sp-cw-amt-btn');
    btns.forEach(function(b) {
      b.style.backgroundColor = '#f4f5f0';
      b.style.color = '';
      b.style.borderColor = '#e0e1dc';
      b.classList.remove('sp-cw-amt-selected');
      var spans = b.querySelectorAll('span');
      if (spans[0]) spans[0].className = 'text-[17px] font-bold text-gray-400';
      if (spans[1]) spans[1].className = 'text-[11px] ml-0.5 font-medium text-gray-400';
    });
  }

  function highlightAmtBtn(btn) {
    btn.style.backgroundColor = currentAccentColor;
    btn.style.color = currentAccentTextColor;
    btn.style.borderColor = currentAccentColor;
    btn.classList.add('sp-cw-amt-selected');
    var spans = btn.querySelectorAll('span');
    if (spans[0]) spans[0].className = 'text-[17px] font-bold';
    if (spans[1]) spans[1].className = 'text-[11px] ml-0.5 font-medium opacity-70';
  }

  function updateCwImpact() {
    if (!cwImpactText) return;
    cwImpactText.innerHTML = generateImpact(currentModalSlug, activeFreqKey, selectedAmount);
  }

  // ─── Checkout State ───
  var spCheckoutStep1 = document.getElementById('sp-checkout-step1');
  var spCheckoutStep2 = document.getElementById('sp-checkout-step2');
  var spCheckoutAmount = 0;
  var spCheckoutType = 'single';
  var spStripeElements = null;
  var spStripe = null;
  var spPaymentReady = false;
  var spProcessing = false;
  var spCurrentStep = 0; // 0 = not in checkout, 1 = details, 2 = payment

  // ── Checkout header step indicator helpers ──
  function updateCheckoutHeaderSteps(step) {
    var circle1 = document.getElementById('sp-ck-step1-circle');
    var label1 = document.getElementById('sp-ck-step1-label');
    var line = document.getElementById('sp-ck-step-line');
    var circle2 = document.getElementById('sp-ck-step2-circle');
    var label2 = document.getElementById('sp-ck-step2-label');

    if (step === 1) {
      // Step 1 active, Step 2 inactive
      if (circle1) { circle1.style.backgroundColor = '#d97706'; circle1.className = 'w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold text-white'; circle1.innerHTML = '1'; }
      if (label1) { label1.className = 'text-sm font-semibold text-gray-800'; label1.textContent = 'Your Details'; }
      if (line) { line.style.backgroundColor = ''; line.className = 'flex-1 h-px bg-gray-200'; }
      if (circle2) { circle2.className = 'w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold text-gray-400 bg-gray-100'; circle2.style.backgroundColor = ''; circle2.innerHTML = '2'; }
      if (label2) { label2.className = 'text-sm text-gray-400'; label2.textContent = 'Payment'; }
    } else if (step === 2) {
      // Step 1 completed (green check), Step 2 active
      if (circle1) { circle1.style.backgroundColor = ''; circle1.className = 'w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold text-white bg-green-500'; circle1.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>'; }
      if (label1) { label1.className = 'text-sm text-green-600 font-medium'; label1.textContent = 'Details'; }
      if (line) { line.style.backgroundColor = '#d97706'; line.className = 'flex-1 h-px'; }
      if (circle2) { circle2.className = 'w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold text-white'; circle2.style.backgroundColor = '#d97706'; circle2.innerHTML = '2'; }
      if (label2) { label2.className = 'text-sm font-semibold text-gray-800'; label2.textContent = 'Payment'; }
    }
  }

  // ─── Mobile helpers: hide/show image column during checkout ───
  function isMobileView() { return window.innerWidth < 768; }
  function hideImageOnMobile() {
    if (isMobileView() && imageCol) imageCol.style.display = 'none';
  }
  function showImageOnMobile() {
    if (imageCol) imageCol.style.display = '';
  }

  function showCheckoutView(amount, type) {
    spCheckoutAmount = amount;
    spCheckoutType = type;
    spCurrentStep = 1;

    // On mobile, hide image column to maximize form space
    hideImageOnMobile();

    // Hide form + upsell views
    if (cwFormView) cwFormView.classList.add('hidden');
    if (cwUpsellView) cwUpsellView.classList.add('hidden');
    var fh = document.getElementById('sp-cw-form-header');
    var uh = document.getElementById('sp-cw-upsell-header');
    var ch = document.getElementById('sp-cw-checkout-header');
    if (fh) fh.classList.add('hidden');
    if (uh) uh.classList.add('hidden');

    // Show checkout header with amount + step indicator
    if (ch) ch.classList.remove('hidden');
    var hamount = document.getElementById('sp-ck-header-amount');
    var hperiod = document.getElementById('sp-ck-header-period');
    if (hamount) hamount.textContent = '$' + amount + ' USD';
    if (hperiod) hperiod.textContent = type === 'monthly' ? ' per month' : '';
    updateCheckoutHeaderSteps(1);

    // Show Step 1 (Your Details), hide Step 2
    if (spCheckoutStep1) { spCheckoutStep1.classList.remove('hidden'); spCheckoutStep1.style.display = 'flex'; }
    if (spCheckoutStep2) { spCheckoutStep2.classList.add('hidden'); spCheckoutStep2.style.display = 'none'; }
  }

  function showCheckoutStep2() {
    spCurrentStep = 2;

    // Hide Step 1, Show Step 2
    if (spCheckoutStep1) { spCheckoutStep1.classList.add('hidden'); spCheckoutStep1.style.display = 'none'; }
    if (spCheckoutStep2) { spCheckoutStep2.classList.remove('hidden'); spCheckoutStep2.style.display = 'flex'; }

    // Update header step indicator to Step 2
    updateCheckoutHeaderSteps(2);

    // Update fee display
    updateSPFeeDisplay();

    // Mount Stripe Payment Element (lazy — only on Step 2)
    mountSPPaymentElement();

    // Init Google Places (delay to ensure address input is fully rendered/visible)
    _spPlacesRetries = 0; // reset retries for fresh attempt
    setTimeout(function() { initSPPlaces(); }, 300);
  }

  function goBackToStep1() {
    if (spProcessing) return;
    spCurrentStep = 1;
    if (spCheckoutStep2) { spCheckoutStep2.classList.add('hidden'); spCheckoutStep2.style.display = 'none'; }
    if (spCheckoutStep1) { spCheckoutStep1.classList.remove('hidden'); spCheckoutStep1.style.display = 'flex'; }
    // Update header step indicator back to Step 1
    updateCheckoutHeaderSteps(1);
  }

  function hideSPCheckout() {
    if (spCheckoutStep1) { spCheckoutStep1.classList.add('hidden'); spCheckoutStep1.style.display = 'none'; }
    if (spCheckoutStep2) { spCheckoutStep2.classList.add('hidden'); spCheckoutStep2.style.display = 'none'; }
    var fh = document.getElementById('sp-cw-form-header');
    var ch = document.getElementById('sp-cw-checkout-header');
    if (fh) fh.classList.remove('hidden');
    if (ch) ch.classList.add('hidden');
    if (cwFormView) cwFormView.classList.remove('hidden');
    // Restore image column on mobile when going back to form
    showImageOnMobile();
    // Clean up Stripe elements
    spStripeElements = null;
    spPaymentReady = false;
    spCurrentStep = 0;
  }

  // ═══════════════════════════════════════════════
  // CW BOX — TAB SWITCHING
  // ═══════════════════════════════════════════════
  function switchTab(freqKey) {
    activeFreqKey = freqKey;
    if (cwTabMonthly) {
      if (freqKey === 'monthly') {
        cwTabMonthly.style.backgroundColor = currentAccentColor;
        cwTabMonthly.style.color = currentAccentTextColor;
        cwTabMonthly.style.borderColor = currentAccentColor;
      } else {
        cwTabMonthly.style.backgroundColor = 'transparent';
        cwTabMonthly.style.color = '#9ca3af';
        cwTabMonthly.style.borderColor = 'transparent';
      }
    }
    if (cwTabSingle) {
      if (freqKey === 'single') {
        cwTabSingle.style.backgroundColor = currentAccentColor;
        cwTabSingle.style.color = currentAccentTextColor;
        cwTabSingle.style.borderColor = currentAccentColor;
      } else {
        cwTabSingle.style.backgroundColor = 'transparent';
        cwTabSingle.style.color = '#9ca3af';
        cwTabSingle.style.borderColor = 'transparent';
      }
    }
    if (cwGridMonthly) cwGridMonthly.classList.toggle('hidden', freqKey !== 'monthly');
    if (cwGridSingle) cwGridSingle.classList.toggle('hidden', freqKey !== 'single');
    var grids = modal ? modal.querySelectorAll('.sp-cw-freq-grid') : [];
    grids.forEach(function(g) {
      var cw = g.querySelector('.sp-cw-custom-wrap');
      var ci = g.querySelector('.sp-cw-custom');
      var ob = g.querySelector('.sp-cw-other-btn');
      if (cw) cw.classList.add('hidden');
      if (ci) ci.value = '';
      if (ob) ob.classList.remove('hidden');
    });
    var grid = freqKey === 'monthly' ? cwGridMonthly : cwGridSingle;
    if (grid) {
      var firstSelected = grid.querySelector('.sp-cw-amt-selected');
      if (firstSelected) {
        selectedAmount = parseFloat(firstSelected.dataset.amount) || 0;
      } else {
        var btns = grid.querySelectorAll('.sp-cw-amt-btn');
        var defIdx = freqKey === 'monthly' ? 2 : 1;
        if (defIdx >= btns.length) defIdx = 0;
        if (btns[defIdx]) {
          selectedAmount = parseFloat(btns[defIdx].dataset.amount) || 0;
          clearGridSelection(grid);
          highlightAmtBtn(btns[defIdx]);
        }
      }
    }
    // Button text: "JOIN TODAY" for recurring, "GIVE NOW" for one-time
    // When tabs are swapped (e.g. Zakat), monthly position = single content
    if (cwDonateBtn) {
      var isRecurring = tabsSwapped ? (freqKey === 'single') : (freqKey === 'monthly');
      cwDonateBtn.textContent = isRecurring ? 'JOIN TODAY' : 'GIVE NOW';
    }
    updateCwImpact();
  }

  if (cwTabMonthly) cwTabMonthly.addEventListener('click', function() { switchTab('monthly'); });
  if (cwTabSingle) cwTabSingle.addEventListener('click', function() { switchTab('single'); });

  // ═══════════════════════════════════════════════
  // CW BOX — CTA BUTTON
  // ═══════════════════════════════════════════════
  if (cwDonateBtn) {
    cwDonateBtn.addEventListener('click', function() {
      var amt = selectedAmount;
      // Check custom input
      var grid = activeFreqKey === 'monthly' ? cwGridMonthly : cwGridSingle;
      if (grid) {
        var ci = grid.querySelector('.sp-cw-custom');
        if (ci && ci.value) amt = parseFloat(ci.value) || amt;
      }

      if (!amt || amt < 1) {
        alert('Please select or enter a donation amount');
        return;
      }

      // Redirect campaigns → go to actual campaign page instead of popup checkout
      // Uses custom URL from admin if set, otherwise the campaign page URL
      if (redirectToCampaignPage) {
        var redirectUrl = currentPageUrl || '/';
        if (redirectUrl) {
          window.location.href = redirectUrl;
          return;
        }
      }

      // For monthly: go to checkout
      if (activeFreqKey === 'monthly') {
        showCheckoutView(amt, 'monthly');
        return;
      }

      // For single ≤$200: show upsell
      if (amt <= 200) {
        showUpsell(amt);
        return;
      }

      // Single > $200: straight to checkout
      showCheckoutView(amt, 'single');
    });
  }

  // ═══════════════════════════════════════════════
  // CW BOX — UPSELL
  // ═══════════════════════════════════════════════
  function showUpsell(amount) {
    var suggestedMonthly = Math.round(amount * UPSELL_MONTHLY_RATIO);
    if (suggestedMonthly < 5) suggestedMonthly = 5;

    upsellOneTimeAmount = amount;
    upsellMonthlyAmount = suggestedMonthly;
    upsellMonthlyActive = false;

    if (cwFormView) cwFormView.classList.add('hidden');
    if (cwUpsellView) cwUpsellView.classList.remove('hidden');
    if (cwFormHeader) cwFormHeader.classList.add('hidden');
    if (cwUpsellHeader) cwUpsellHeader.classList.remove('hidden');

    if (cwUpsellAmountEl) cwUpsellAmountEl.textContent = '$' + amount + ' USD';
    if (cwUpsellPeriodEl) cwUpsellPeriodEl.textContent = '';

    if (cwUpsellBodyEl) {
      cwUpsellBodyEl.textContent = "By making a monthly donation, you'll empower us to make long-term investments to bring lasting change to more families around the world.";
    }
    if (cwUpsellSubtextEl) {
      cwUpsellSubtextEl.textContent = 'Please consider joining our monthly giving community. Monthly donors are our most impactful and committed supporters.';
    }
    if (cwUpsellMonthlyLabel) {
      cwUpsellMonthlyLabel.textContent = 'Give $' + suggestedMonthly + ' per month instead';
    }
    if (cwUpsellBtn) cwUpsellBtn.textContent = 'GIVE $' + amount;

    // Reset toggle
    if (cwUpsellToggle) {
      cwUpsellToggle.setAttribute('aria-checked', 'false');
      cwUpsellToggle.style.backgroundColor = '#d1d5db';
    }
    if (cwUpsellToggleDot) {
      cwUpsellToggleDot.style.transform = 'translateX(0)';
      cwUpsellToggleDot.style.backgroundColor = '#ffffff';
    }
    var tX = cwUpsellToggleDot ? cwUpsellToggleDot.querySelector('.sp-toggle-x') : null;
    var tC = cwUpsellToggleDot ? cwUpsellToggleDot.querySelector('.sp-toggle-check') : null;
    if (tX) tX.classList.remove('hidden');
    if (tC) tC.classList.add('hidden');
  }

  // Edit link → back to form
  if (cwEditLink) {
    cwEditLink.addEventListener('click', function() {
      if (cwUpsellView) cwUpsellView.classList.add('hidden');
      if (cwFormView) cwFormView.classList.remove('hidden');
      if (cwUpsellHeader) cwUpsellHeader.classList.add('hidden');
      if (cwFormHeader) cwFormHeader.classList.remove('hidden');
      switchTab('single');
    });
  }

  // Upsell toggle switch
  if (cwUpsellToggle) {
    cwUpsellToggle.addEventListener('click', function() {
      upsellMonthlyActive = !upsellMonthlyActive;
      this.setAttribute('aria-checked', upsellMonthlyActive ? 'true' : 'false');
      var tX = cwUpsellToggleDot ? cwUpsellToggleDot.querySelector('.sp-toggle-x') : null;
      var tC = cwUpsellToggleDot ? cwUpsellToggleDot.querySelector('.sp-toggle-check') : null;

      if (upsellMonthlyActive) {
        this.style.backgroundColor = currentAccentColor;
        if (cwUpsellToggleDot) {
          cwUpsellToggleDot.style.transform = 'translateX(28px)';
          cwUpsellToggleDot.style.backgroundColor = currentAccentColor;
        }
        if (tX) tX.classList.add('hidden');
        if (tC) tC.classList.remove('hidden');
        if (cwUpsellBtn) cwUpsellBtn.textContent = 'GIVE $' + upsellMonthlyAmount;
        if (cwUpsellAmountEl) cwUpsellAmountEl.textContent = '$' + upsellMonthlyAmount + ' USD';
        if (cwUpsellPeriodEl) cwUpsellPeriodEl.textContent = ' per month';
      } else {
        this.style.backgroundColor = '#d1d5db';
        if (cwUpsellToggleDot) {
          cwUpsellToggleDot.style.transform = 'translateX(0)';
          cwUpsellToggleDot.style.backgroundColor = '#ffffff';
        }
        if (tX) tX.classList.remove('hidden');
        if (tC) tC.classList.add('hidden');
        if (cwUpsellBtn) cwUpsellBtn.textContent = 'GIVE $' + upsellOneTimeAmount;
        if (cwUpsellAmountEl) cwUpsellAmountEl.textContent = '$' + upsellOneTimeAmount + ' USD';
        if (cwUpsellPeriodEl) cwUpsellPeriodEl.textContent = '';
      }
    });
  }

  // Upsell CTA
  if (cwUpsellBtn) {
    cwUpsellBtn.addEventListener('click', function() {
      if (upsellMonthlyActive) {
        showCheckoutView(upsellMonthlyAmount, 'monthly');
      } else {
        showCheckoutView(upsellOneTimeAmount, 'single');
      }
    });
  }

  // ═══════════════════════════════════════════════
  // MODAL OPEN / CLOSE
  // ═══════════════════════════════════════════════
  function openDonateModal(notif) {
    if (!modal || modalOpen) return;
    leadCaptureShownThisOpen = false;
    hideLeadCapture();
    showImageOnMobile(); // Restore image column from any previous checkout

    // Pause notifications
    if (showTimer) { clearTimeout(showTimer); showTimer = null; }
    if (pauseTimer) { clearTimeout(pauseTimer); pauseTimer = null; }
    popup.style.opacity = '0';
    popup.style.transform = 'translateX(-120%)';
    isVisible = false;
    progressEl.style.transition = 'none';
    progressEl.style.width = '0%';

    var slug = notif.slug || notif.campaign.toLowerCase().replace(/\s+/g, '-');
    currentModalSlug = slug;
    currentModalNotif = notif;

    fetchCampaigns(function(campaigns) {
      var campaign = findCampaign(campaigns, slug);
      currentModalCampaign = campaign;
      populateModal(campaign, notif);

      var trustLinks = document.getElementById('sp-modal-trust');

      modal.classList.remove('hidden');
      void modal.offsetWidth;
      mBackdrop.style.opacity = '1';
      mCard.style.opacity = '1';
      mCard.style.transform = 'scale(1)';
      if (mCloseBtn) mCloseBtn.style.opacity = '1';
      if (trustLinks) trustLinks.style.opacity = '1';
      document.body.style.overflow = 'hidden';
      modalOpen = true;
    });
  }

  function closeDonateModal() {
    if (!modal || !modalOpen) return;
    if (spProcessing) return; // Block close during payment processing
    hideLeadCapture();
    hideSPCheckout();
    var trustLinks = document.getElementById('sp-modal-trust');
    mBackdrop.style.opacity = '0';
    mCard.style.opacity = '0';
    mCard.style.transform = 'scale(0.97)';
    if (mCloseBtn) mCloseBtn.style.opacity = '0';
    if (trustLinks) trustLinks.style.opacity = '0';
    document.body.style.overflow = '';
    modalOpen = false;

    setTimeout(function() {
      modal.classList.add('hidden');
      if (!isDismissed && notifications.length && notifShownCount < MAX_PER_SESSION) {
        currentIndex++;
        sessionStorage.setItem(INDEX_KEY, String(currentIndex));
        scheduleNextHybrid();
      }
    }, 300);
  }

  function populateModal(campaign, notif) {
    // Image — prefer notif.image (from API, always correct), then campaign lookup, then fallback
    var img = notif.image
      || (campaign && (campaign.featured_image || campaign.hero_image_url || campaign.image_url))
      || DEFAULT_IMAGE;
    if (mImage) mImage.style.backgroundImage = 'url(' + img + ')';

    // Title & description
    var title = (campaign && (campaign.name || campaign.title)) || notif.campaign;
    if (mTitle) mTitle.textContent = title;
    var desc = (campaign && (campaign.description || campaign.long_description)) || '';
    if (mDesc) { mDesc.textContent = desc; mDesc.style.display = desc ? '' : 'none'; }

    // Link — prefer admin custom URL, then notif.url, then campaign.url_path, then fallback
    var pageUrl = (campaign && campaign.social_proof_url)
      || notif.url
      || (campaign && campaign.url_path)
      || '/appeals/' + currentModalSlug;
    currentPageUrl = pageUrl;
    if (mLink) {
      mLink.href = pageUrl;
      mLink.textContent = 'Visit our ' + title + ' page';
    }

    // Accent color from campaign or default
    var tc = (campaign && campaign.template_config) || {};
    currentAccentColor = (tc.accentColor) || '#e1861d';
    currentAccentTextColor = (tc.accentTextColor) || '#ffffff';

    // Update button colors
    if (cwDonateBtn) { cwDonateBtn.style.backgroundColor = currentAccentColor; cwDonateBtn.style.color = currentAccentTextColor; }
    if (cwUpsellBtn) { cwUpsellBtn.style.backgroundColor = currentAccentColor; cwUpsellBtn.style.color = currentAccentTextColor; }

    // Emoji
    var emoji = getEmoji(currentModalSlug);
    var useHeart = emoji === 'heart';
    if (cwImpactEmoji) {
      if (useHeart) {
        cwImpactEmoji.innerHTML = '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="' + currentAccentColor + '"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>';
      } else {
        cwImpactEmoji.textContent = emoji;
      }
    }

    // Tab emoji
    if (cwTabMonthly) {
      var emojiSpan = useHeart
        ? '<svg class="w-4 h-4 inline-block" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>'
        : '<span class="text-base">' + emoji + '</span>';
      cwTabMonthly.innerHTML = 'MONTHLY ' + emojiSpan;
    }

    // Get amounts from campaign — match CW donation box behavior
    // Priority: DB frequencies > DB legacy amounts > CAMPAIGN_AMOUNTS map > defaults
    var monthlyAmts = MONTHLY_AMOUNTS_DEFAULT;
    var singleAmts = SINGLE_AMOUNTS_DEFAULT;
    var monthlySuffix = 'USD/mo';
    var singleSuffix = 'USD';
    var monthlyLabel = '';
    var singleLabel = '';
    var amountsResolved = false;
    var hideMonthlyTab = false;

    if (campaign && campaign.template_config) {
      var cwd = tc.cwDonation || {};

      // Check frequencies array first (newer format used by ZakatHub, etc.)
      if (cwd.frequencies && cwd.frequencies.length) {
        var foundRecurring = false;
        var foundSingle = false;
        var firstFreqType = cwd.frequencies[0].type;
        for (var fi = 0; fi < cwd.frequencies.length; fi++) {
          var freq = cwd.frequencies[fi];
          if (freq.type === 'single' && freq.amounts && freq.amounts.length && !foundSingle) {
            singleAmts = freq.amounts;
            singleSuffix = freq.suffix || 'USD';
            singleLabel = freq.label || '';
            foundSingle = true;
          } else if (freq.type === 'recurring' && freq.amounts && freq.amounts.length && !foundRecurring) {
            monthlyAmts = freq.amounts;
            monthlySuffix = freq.suffix || 'USD/mo';
            monthlyLabel = freq.label || '';
            foundRecurring = true;
          }
        }
        // If single is first in the array, swap tabs so Tab1=GIVE ONCE, Tab2=Recurring
        if (firstFreqType === 'single' && foundSingle && foundRecurring) {
          // Swap: tab1 (monthly position) gets single, tab2 (single position) gets recurring
          var tmpAmts = monthlyAmts; monthlyAmts = singleAmts; singleAmts = tmpAmts;
          var tmpSuffix = monthlySuffix; monthlySuffix = singleSuffix; singleSuffix = tmpSuffix;
          var tmpLabel = monthlyLabel; monthlyLabel = singleLabel; singleLabel = tmpLabel;
          tabsSwapped = true;
        } else {
          tabsSwapped = false;
        }
        // If no recurring frequency found, use single amounts for monthly tab too
        if (!foundRecurring && foundSingle) {
          monthlyAmts = singleAmts;
          monthlySuffix = singleSuffix;
        }
        amountsResolved = true;
      } else {
        // Legacy format: monthlyAmounts / oneTimeAmounts
        var hasLegacy = false;
        if (cwd.monthlyAmounts && cwd.monthlyAmounts.length) { monthlyAmts = cwd.monthlyAmounts; hasLegacy = true; }
        else if (tc.monthlyAmounts && tc.monthlyAmounts.length) { monthlyAmts = tc.monthlyAmounts; hasLegacy = true; }
        if (cwd.oneTimeAmounts && cwd.oneTimeAmounts.length) { singleAmts = cwd.oneTimeAmounts; hasLegacy = true; }
        else if (tc.oneTimeAmounts && tc.oneTimeAmounts.length) { singleAmts = tc.oneTimeAmounts; hasLegacy = true; }
        if (hasLegacy) amountsResolved = true;
      }
    }

    // Fallback to CAMPAIGN_AMOUNTS map if no DB config found
    if (!amountsResolved) tabsSwapped = false;
    if (!amountsResolved && currentModalSlug && CAMPAIGN_AMOUNTS[currentModalSlug]) {
      var campOverride = CAMPAIGN_AMOUNTS[currentModalSlug];
      if (campOverride.monthly) {
        monthlyAmts = campOverride.monthly.amounts;
        monthlySuffix = campOverride.monthly.suffix || 'USD/mo';
        monthlyLabel = campOverride.monthly.label || '';
        // If monthly type is 'single', both tabs show one-time amounts (no recurring)
        if (campOverride.monthly.type === 'single') hideMonthlyTab = true;
      }
      if (campOverride.single) {
        singleAmts = campOverride.single.amounts;
        singleSuffix = campOverride.single.suffix || 'USD';
        singleLabel = campOverride.single.label || '';
      }
    }

    // Determine redirect behavior from DB social_proof_action (set in admin > Promotions & Popups)
    // 'popup' = use quick-donate in modal, 'redirect' = go to campaign page
    var dbAction = (campaign && campaign.social_proof_action) || (notif && notif.action) || 'redirect';
    var dbCustomUrl = (campaign && campaign.social_proof_url) || '';
    redirectToCampaignPage = dbAction === 'redirect' || hideMonthlyTab;

    // For single-only campaigns (Kaffarah, Fidya, etc.): hide monthly tab, show only GIVE ONCE
    if (hideMonthlyTab) {
      singleOnlyCampaign = true;
      // Show form header but hide Monthly tab, make Give Once full-width
      if (cwFormHeader) {
        cwFormHeader.classList.remove('hidden');
        cwFormHeader.style.gridTemplateColumns = '1fr';
      }
      if (cwTabMonthly) cwTabMonthly.style.display = 'none';
      if (cwTabSingle) {
        cwTabSingle.style.display = '';
        cwTabSingle.textContent = singleLabel || 'GIVE ONCE';
        cwTabSingle.style.backgroundColor = currentAccentColor;
        cwTabSingle.style.color = currentAccentTextColor;
        cwTabSingle.style.borderColor = currentAccentColor;
      }
      if (cwGridMonthly) cwGridMonthly.classList.add('hidden');
      if (cwGridSingle) cwGridSingle.classList.remove('hidden');
      activeFreqKey = 'single';
      tabsSwapped = false;
      if (cwDonateBtn) cwDonateBtn.textContent = 'GIVE NOW';
    } else {
      singleOnlyCampaign = false;
      // Show both tabs for campaigns with monthly + one-time
      if (cwFormHeader) {
        cwFormHeader.classList.remove('hidden');
        cwFormHeader.style.gridTemplateColumns = '';
      }
      if (cwTabMonthly) {
        cwTabMonthly.style.display = '';
        var emojiHtml = useHeart
          ? '<svg class="w-4 h-4 inline-block" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>'
          : '<span class="text-base">' + emoji + '</span>';
        cwTabMonthly.innerHTML = (monthlyLabel || 'MONTHLY') + ' ' + emojiHtml;
      }
      if (cwTabSingle) {
        cwTabSingle.style.display = '';
        if (singleLabel) cwTabSingle.textContent = singleLabel;
      }
      // Default to monthly tab
      if (cwTabMonthly) cwTabMonthly.click();
    }

    // Build 3-col grids
    buildAmountGrid(cwGridMonthly, monthlyAmts, 'monthly', monthlySuffix, 2);
    buildAmountGrid(cwGridSingle, singleAmts, 'single', singleSuffix, 1);

    // Redirect campaigns: update button to indicate page navigation
    if (redirectToCampaignPage && cwDonateBtn) {
      cwDonateBtn.textContent = 'DONATE NOW';
    }

    // Reset to form view (hide upsell + checkout steps + checkout header)
    if (cwFormView) cwFormView.classList.remove('hidden');
    if (cwUpsellView) cwUpsellView.classList.add('hidden');
    // Form header is already configured above (single tab or dual tabs)
    if (cwFormHeader) cwFormHeader.classList.remove('hidden');
    if (cwUpsellHeader) cwUpsellHeader.classList.add('hidden');
    var ckHeader = document.getElementById('sp-cw-checkout-header');
    if (ckHeader) ckHeader.classList.add('hidden');
    if (spCheckoutStep1) { spCheckoutStep1.classList.add('hidden'); spCheckoutStep1.style.display = 'none'; }
    if (spCheckoutStep2) { spCheckoutStep2.classList.add('hidden'); spCheckoutStep2.style.display = 'none'; }
    spCurrentStep = 0;

    // Show campaign view, hide FAQ
    if (rightCampaign) rightCampaign.classList.remove('hidden');
    if (rightFaq) rightFaq.classList.add('hidden');

    // Default tab + select default amount
    // MUST always call switchTab to set selectedAmount from the visually highlighted button
    if (hideMonthlyTab) {
      switchTab('single');
    } else {
      switchTab('monthly');
    }
  }

  // ═══════════════════════════════════════════════
  // FAQ PANEL TOGGLE + ACCORDION
  // ═══════════════════════════════════════════════
  if (faqLink) {
    faqLink.addEventListener('click', function() {
      if (rightCampaign) rightCampaign.classList.add('hidden');
      if (rightFaq) rightFaq.classList.remove('hidden');
    });
  }
  if (faqCloseBtn) {
    faqCloseBtn.addEventListener('click', function() {
      if (rightFaq) rightFaq.classList.add('hidden');
      if (rightCampaign) rightCampaign.classList.remove('hidden');
    });
  }

  // Fix "Visit our page" link — explicit click handler to ensure navigation
  if (mLink) {
    mLink.addEventListener('click', function(e) {
      e.stopPropagation();
      var href = mLink.getAttribute('href');
      if (href && href !== '#') {
        e.preventDefault();
        window.open(href, '_blank', 'noopener');
      }
    });
  }

  // FAQ accordion
  if (modal) {
    var faqTriggers = modal.querySelectorAll('.sp-faq-trigger');
    faqTriggers.forEach(function(trigger) {
      trigger.addEventListener('click', function() {
        var item = this.closest('.sp-faq-item');
        var body = item ? item.querySelector('.sp-faq-body') : null;
        var arrow = this.querySelector('.sp-faq-arrow');
        if (!body) return;

        var isOpen = !body.classList.contains('hidden');

        // Close all
        var allBodies = modal.querySelectorAll('.sp-faq-body');
        var allArrows = modal.querySelectorAll('.sp-faq-arrow');
        allBodies.forEach(function(b) { b.classList.add('hidden'); });
        allArrows.forEach(function(a) { a.style.transform = ''; });

        // Toggle this one
        if (!isOpen) {
          body.classList.remove('hidden');
          if (arrow) arrow.style.transform = 'rotate(180deg)';
        }
      });
    });
  }

  // ═══════════════════════════════════════════════
  // LEAD CAPTURE (shown when X is clicked)
  // ═══════════════════════════════════════════════
  var LEAD_CAPTURED_KEY = 'sp_lead_captured';
  var LEAD_CAPTURED_AT_KEY = 'sp_lead_captured_at';
  // Lead capture expires after 7 days so returning visitors see it again
  var leadCapturedAt = parseInt(localStorage.getItem(LEAD_CAPTURED_AT_KEY) || '0', 10);
  var LEAD_EXPIRY_MS = 7 * 24 * 60 * 60 * 1000;
  var alreadyCapturedLead = localStorage.getItem(LEAD_CAPTURED_KEY) === 'true' && (Date.now() - leadCapturedAt) < LEAD_EXPIRY_MS;
  // Clear expired flag
  if (localStorage.getItem(LEAD_CAPTURED_KEY) === 'true' && !alreadyCapturedLead) {
    localStorage.removeItem(LEAD_CAPTURED_KEY);
    localStorage.removeItem(LEAD_CAPTURED_AT_KEY);
  }
  var leadCaptureShownThisOpen = false;

  var leadOverlay = document.getElementById('sp-lead-capture');
  var leadImage = document.getElementById('sp-lead-image');
  var leadBackBtn = document.getElementById('sp-lead-back');
  var leadEmailInput = document.getElementById('sp-lead-email');
  var leadSubmitBtn = document.getElementById('sp-lead-submit');
  var leadSkipBtn = document.getElementById('sp-lead-skip');
  var leadInterestLabels = leadOverlay ? leadOverlay.querySelectorAll('.sp-lead-interest') : [];

  // ── Checkbox visual toggle ──
  leadInterestLabels.forEach(function(label) {
    var cb = label.querySelector('input[type="checkbox"]');
    if (!cb) return;
    cb.addEventListener('change', function() {
      var box = label.querySelector('.sp-lead-check');
      var tick = box ? box.querySelector('svg') : null;
      if (cb.checked) {
        label.style.borderColor = '#e1861d';
        label.style.backgroundColor = 'rgba(225,134,29,0.08)';
        if (box) { box.style.backgroundColor = '#e1861d'; box.style.borderColor = '#e1861d'; }
        if (tick) tick.style.opacity = '1';
      } else {
        label.style.borderColor = '';
        label.style.backgroundColor = '';
        if (box) { box.style.backgroundColor = ''; box.style.borderColor = ''; }
        if (tick) tick.style.opacity = '0';
      }
    });
  });

  function getSelectedInterests() {
    var selected = [];
    leadInterestLabels.forEach(function(label) {
      var cb = label.querySelector('input[type="checkbox"]');
      if (cb && cb.checked) selected.push(cb.value);
    });
    return selected;
  }

  function showLeadCapture() {
    if (!leadOverlay) return;
    leadCaptureShownThisOpen = true;
    // Copy campaign image to lead overlay
    if (leadImage && mImage) {
      leadImage.style.backgroundImage = mImage.style.backgroundImage;
    }
    // Reset form state
    if (leadEmailInput) { leadEmailInput.value = ''; leadEmailInput.style.borderColor = ''; }
    if (leadSubmitBtn) { leadSubmitBtn.textContent = 'Send Me Updates'; leadSubmitBtn.disabled = false; leadSubmitBtn.style.backgroundColor = '#e1861d'; }
    // Reset checkboxes — pre-select Emergency Appeals only
    var preselected = ['emergency'];
    leadInterestLabels.forEach(function(label) {
      var cb = label.querySelector('input[type="checkbox"]');
      var box = label.querySelector('.sp-lead-check');
      var tick = box ? box.querySelector('svg') : null;
      var isPreselected = cb && preselected.indexOf(cb.value) !== -1;
      if (cb) cb.checked = isPreselected;
      label.style.borderColor = isPreselected ? '#e1861d' : '';
      label.style.backgroundColor = isPreselected ? 'rgba(225,134,29,0.08)' : '';
      if (box) { box.style.backgroundColor = isPreselected ? '#e1861d' : ''; box.style.borderColor = isPreselected ? '#e1861d' : ''; }
      if (tick) tick.style.opacity = isPreselected ? '1' : '0';
    });
    leadOverlay.classList.remove('hidden');
  }

  function hideLeadCapture() {
    if (leadOverlay) leadOverlay.classList.add('hidden');
  }

  // Back button → return to donation form
  if (leadBackBtn) {
    leadBackBtn.addEventListener('click', hideLeadCapture);
  }

  // "No, thanks" → close modal
  if (leadSkipBtn) {
    leadSkipBtn.addEventListener('click', function() {
      hideLeadCapture();
      closeDonateModal();
    });
  }

  // Email input — reset border on type
  if (leadEmailInput) {
    leadEmailInput.addEventListener('input', function() {
      this.style.borderColor = '';
    });
    leadEmailInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && leadSubmitBtn) leadSubmitBtn.click();
    });
  }

  // "Send Me Updates" → capture lead with interests, then close
  if (leadSubmitBtn) {
    leadSubmitBtn.addEventListener('click', function() {
      var email = leadEmailInput ? leadEmailInput.value.trim() : '';
      if (!email || email.indexOf('@') === -1 || email.indexOf('.') === -1) {
        if (leadEmailInput) { leadEmailInput.style.borderColor = '#ef4444'; leadEmailInput.focus(); }
        return;
      }

      // Collect selected interest tags (underscore format for GHL)
      var interests = getSelectedInterests();
      var tags = ['lead_exit_signup', 'source:social-proof'];
      interests.forEach(function(i) { tags.push('interest_' + i); });

      leadSubmitBtn.textContent = 'Saving...';
      leadSubmitBtn.disabled = true;

      fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: email,
          source: 'social-proof-popup',
          campaign: currentModalSlug,
          tags: tags
        })
      })
      .then(function() {
        localStorage.setItem(LEAD_CAPTURED_KEY, 'true');
        localStorage.setItem(LEAD_CAPTURED_AT_KEY, String(Date.now()));
        alreadyCapturedLead = true;
        leadSubmitBtn.textContent = 'Thank you! ✓';
        leadSubmitBtn.style.backgroundColor = '#16a34a';
        setTimeout(function() {
          hideLeadCapture();
          closeDonateModal();
        }, 1500);
      })
      .catch(function() {
        // Still mark as captured to avoid annoying the user
        localStorage.setItem(LEAD_CAPTURED_KEY, 'true');
        localStorage.setItem(LEAD_CAPTURED_AT_KEY, String(Date.now()));
        alreadyCapturedLead = true;
        leadSubmitBtn.textContent = 'Thank you! ✓';
        leadSubmitBtn.style.backgroundColor = '#16a34a';
        setTimeout(function() {
          hideLeadCapture();
          closeDonateModal();
        }, 1500);
      });
    });
  }

  // ═══════════════════════════════════════════════
  // NOTIFICATION EVENTS (delegated — closeBtn is dynamic)
  // ═══════════════════════════════════════════════
  popup.querySelector('.pointer-events-auto').addEventListener('click', function(e) {
    // Check if close button was clicked (dynamic element)
    var closeTgt = e.target.closest ? e.target.closest('#social-proof-close') : null;
    if (closeTgt) { e.stopPropagation(); dismiss(); return; }

    var triggerBtn = e.target.closest ? e.target.closest('.sp-donate-trigger') : null;
    if (!triggerBtn && e.target.classList && e.target.classList.contains('sp-donate-trigger')) triggerBtn = e.target;

    if (triggerBtn) {
      e.preventDefault();
      e.stopPropagation();
      var notif = notifications[currentIndex % notifications.length];
      if (notif) {
        // Check if user is already on the same campaign page
        var currentPath = window.location.pathname.toLowerCase();
        var notifSlug = (notif.slug || '').toLowerCase();
        var isOnSameCampaign = notifSlug && (
          currentPath === '/appeals/' + notifSlug ||
          currentPath === '/appeals/' + notifSlug + '/' ||
          currentPath === '/' + notifSlug ||
          currentPath === '/' + notifSlug + '/' ||
          currentPath.indexOf('/appeals/' + notifSlug) === 0
        );

        if (isOnSameCampaign) {
          // User is already on this campaign page — scroll to donation box
          hidePopup();
          scrollToDonationBox();
        } else if (notif.action === 'redirect') {
          // Redirect campaigns: go to campaign page with ?donate=true to auto-scroll
          var targetUrl = notif.url || '/appeals/' + (notif.slug || '');
          window.location.href = targetUrl + (targetUrl.indexOf('?') === -1 ? '?' : '&') + 'donate=true';
        } else {
          // Popup action: open the quick donation modal
          openDonateModal(notif);
        }
      }
      return;
    }

    // Clicking the popup itself (not the button) always goes to campaign page
    var notif = notifications[currentIndex % notifications.length];
    if (notif) {
      var targetUrl = notif.url || '/appeals/' + (notif.slug || notif.campaign.toLowerCase().replace(/\s+/g, '-'));
      window.location.href = targetUrl + (targetUrl.indexOf('?') === -1 ? '?' : '&') + 'donate=true';
    }
  });

  // ── Attempt close — shows lead capture first if not already shown ──
  function attemptCloseModal() {
    if (!modalOpen || spProcessing) return;
    // If lead capture overlay is already visible → clicking X/Esc/backdrop closes it + modal
    if (leadOverlay && !leadOverlay.classList.contains('hidden')) {
      hideLeadCapture();
      closeDonateModal();
      return;
    }
    // Show lead capture once per modal open, if not already captured
    if (!alreadyCapturedLead && !leadCaptureShownThisOpen && leadOverlay) {
      showLeadCapture();
      return;
    }
    // Already shown or already captured → close for real
    closeDonateModal();
  }

  // Modal close events — all go through attemptCloseModal()
  if (mCloseBtn) {
    mCloseBtn.addEventListener('click', function() {
      attemptCloseModal();
    });
  }
  if (mBackdrop) mBackdrop.addEventListener('click', function() { attemptCloseModal(); });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modalOpen) attemptCloseModal();
  });

  // Pause when hidden
  document.addEventListener('visibilitychange', function() {
    if (document.hidden) {
      if (showTimer) { clearTimeout(showTimer); showTimer = null; }
      if (pauseTimer) { clearTimeout(pauseTimer); pauseTimer = null; }
    } else if (!isDismissed && notifications.length && !modalOpen) {
      if (!isVisible) pauseTimer = setTimeout(showPopup, 3000);
    }
  });

  // ═══════════════════════════════════════════════
  // IN-MODAL CHECKOUT — STRIPE + PAYMENT PROCESSING
  // ═══════════════════════════════════════════════

  // ── GA4 helpers (reuse from donationCart if available) ──
  function spGetGA4ClientId() {
    try {
      if (window.donationCart && typeof window.donationCart.getGA4ClientId === 'function') {
        return window.donationCart.getGA4ClientId();
      }
      var match = document.cookie.match(/_ga=GA\d+\.\d+\.(.+)/);
      if (match && match[1]) return match[1];
      if (typeof window.gtag === 'function') {
        var cid = null;
        window.gtag('get', 'G-0WC0W1PBKC', 'client_id', function(id) { cid = id; });
        if (cid) return cid;
      }
    } catch(e) {}
    return null;
  }

  function spGetGA4SessionId() {
    try {
      if (window.donationCart && typeof window.donationCart.getGA4SessionId === 'function') {
        return window.donationCart.getGA4SessionId();
      }
      var match = document.cookie.match(/_ga_0WC0W1PBKC=GS\d+\.\d+\.(\d+)/);
      if (match && match[1]) return match[1];
      if (typeof window.gtag === 'function') {
        var sid = null;
        window.gtag('get', 'G-0WC0W1PBKC', 'session_id', function(id) { sid = id; });
        if (sid) return String(sid);
      }
    } catch(e) {}
    return null;
  }

  // ── Stripe decline code → friendly message ──
  function spGetDeclineMessage(error) {
    if (!error) return 'Payment failed. Please try again.';
    var code = error.decline_code || error.code || '';
    var msgs = {
      'insufficient_funds': 'Insufficient funds on this card. Please try a different card.',
      'do_not_honor': 'Your bank declined this transaction. Please call the number on your card or try a different card.',
      'card_velocity_exceeded': 'Too many attempts on this card. Please wait 15-30 minutes or use a different card.',
      'card_declined': 'Your card was declined. Please try a different card.',
      'expired_card': 'This card has expired. Please use a different card.',
      'incorrect_cvc': 'The security code (CVC) is incorrect. Please check and try again.',
      'processing_error': 'A processing error occurred. Please try again in a few moments.',
      'incorrect_number': 'The card number is incorrect. Please check and try again.',
      'authentication_required': 'Your bank requires authentication. Please try again and complete the verification.',
    };
    return msgs[code] || (error.message || 'Your card was declined. Please try a different card or contact your bank.');
  }

  // ── Fee display ──
  function updateSPFeeDisplay() {
    var feeDesc = document.getElementById('sp-ck-fee-desc');
    var base = spCheckoutAmount;
    var fee = Math.round(base * 0.03 * 100) / 100;
    if (feeDesc) {
      feeDesc.textContent = 'Add $' + fee.toFixed(2) + ' to ensure 100% of your donation goes directly to families in need.';
    }
  }

  function getSPCheckoutTotal() {
    var base = spCheckoutAmount;
    var cb = document.getElementById('sp-ck-cover-fees');
    if (cb && cb.checked) return base + Math.round(base * 0.03 * 100) / 100;
    return base;
  }

  // ── Abandoned Checkout Capture (matches DonationCart behavior) ──
  var _spHeartbeatInterval = null;
  var _spLastCaptureFingerprint = '';

  function spStartHeartbeat() {
    if (_spHeartbeatInterval) return;
    _spHeartbeatInterval = setInterval(function() {
      var token = localStorage.getItem('qurbani_resume_token');
      if (!token) return;
      try {
        navigator.sendBeacon('/api/abandoned-checkout/heartbeat', JSON.stringify({ resume_token: token }));
      } catch(e) { /* silent */ }
    }, 5 * 60 * 1000); // every 5 minutes
  }

  function spStopHeartbeat() {
    if (_spHeartbeatInterval) { clearInterval(_spHeartbeatInterval); _spHeartbeatInterval = null; }
  }

  function spCaptureAbandonedCheckout() {
    var email = (document.getElementById('sp-ck-email').value || '').trim().toLowerCase();
    if (!email || email.indexOf('@') < 1 || email.indexOf('.', email.indexOf('@')) < 0) return;

    var firstName = (document.getElementById('sp-ck-firstName').value || '').trim();
    var lastName = (document.getElementById('sp-ck-lastName').value || '').trim();
    var phone = (document.getElementById('sp-ck-phone').value || '').trim();
    var country = (document.getElementById('sp-ck-country') && document.getElementById('sp-ck-country').value) || 'US';
    var amount = spCheckoutAmount || 0;
    var campaignSlug = currentModalSlug || 'general';

    // Debounce: don't re-fire if same fingerprint
    var fingerprint = email + ':' + amount + ':' + campaignSlug + ':' + spCheckoutType;
    if (_spLastCaptureFingerprint === fingerprint) return;
    _spLastCaptureFingerprint = fingerprint;

    // Read UTMs
    var params = new URLSearchParams(window.location.search);
    var storedUtm = window.getStoredUTM ? window.getStoredUTM() : null;

    var payload = {
      email: email,
      first_name: firstName || undefined,
      last_name: lastName || undefined,
      phone: phone || undefined,
      amount: amount || undefined,
      currency: 'USD',
      campaign_type: spCheckoutType === 'monthly' ? 'recurring' : 'single',
      campaign_slug: campaignSlug,
      country: country,
      utm_source: params.get('utm_source') || (storedUtm && storedUtm.utm_source) || undefined,
      utm_medium: params.get('utm_medium') || (storedUtm && storedUtm.utm_medium) || undefined,
      utm_campaign: params.get('utm_campaign') || (storedUtm && storedUtm.utm_campaign) || undefined,
      utm_content: params.get('utm_content') || (storedUtm && storedUtm.utm_content) || undefined,
      utm_term: params.get('utm_term') || (storedUtm && storedUtm.utm_term) || undefined,
    };

    fetch('/api/abandoned-checkout/capture', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.resume_token) {
        localStorage.setItem('qurbani_resume_token', data.resume_token);
        spStartHeartbeat();
      }
    })
    .catch(function() { /* silent — never disrupt checkout */ });
  }

  // ── Mount Stripe Payment Element (deferred mode) ──
  function mountSPPaymentElement() {
    // Ensure Stripe is available
    if (!spStripe) {
      if (window.donationCart && window.donationCart.stripe) {
        spStripe = window.donationCart.stripe;
      } else if (typeof Stripe !== 'undefined') {
        // Fallback: read publishable key from site-level data
        var metaKey = document.querySelector('meta[name="stripe-publishable-key"]');
        var key = metaKey ? metaKey.getAttribute('content') : null;
        if (!key && window.__STRIPE_PK) key = window.__STRIPE_PK;
        if (key) {
          spStripe = Stripe(key);
        }
      }
    }
    if (!spStripe) {
      var cardEl = document.getElementById('sp-ck-card-element');
      if (cardEl) cardEl.innerHTML = '<p class="text-red-500 text-sm text-center py-3">Payment system unavailable. Please try refreshing the page.</p>';
      return;
    }

    var isRecurring = spCheckoutType === 'monthly';
    var total = getSPCheckoutTotal();

    var elementsConfig = {
      mode: isRecurring ? 'setup' : 'payment',
      currency: 'usd',
      appearance: {
        theme: 'stripe',
        variables: {
          colorPrimary: '#d97706',
          fontFamily: 'system-ui, sans-serif',
          borderRadius: '6px',
        },
      },
    };

    if (!isRecurring) {
      elementsConfig.amount = Math.round(total * 100);
    }

    spStripeElements = spStripe.elements(elementsConfig);
    var paymentElement = spStripeElements.create('payment', {
      layout: 'tabs',
      terms: { card: 'never' },
      wallets: { applePay: 'auto', googlePay: 'auto', link: 'never' },
      fields: {
        billingDetails: {
          address: {
            country: 'never',
            postalCode: 'never',
          }
        }
      }
    });

    var cardEl = document.getElementById('sp-ck-card-element');
    if (cardEl) {
      cardEl.innerHTML = '';
      paymentElement.mount(cardEl);
    }

    spPaymentReady = true;

    // Enable pay button once mounted
    var payBtn = document.getElementById('sp-ck-pay-btn');
    if (payBtn) payBtn.disabled = false;

    // Handle card errors
    paymentElement.on('change', function(event) {
      var errEl = document.getElementById('sp-ck-card-errors');
      if (errEl) {
        if (event.error) {
          errEl.textContent = event.error.message;
          errEl.classList.remove('hidden');
        } else {
          errEl.textContent = '';
          errEl.classList.add('hidden');
        }
      }
    });
  }

  // ── Google Places Autocomplete ──
  var _spPlacesRetries = 0;
  function initSPPlaces() {
    var addressInput = document.getElementById('sp-ck-address');
    if (!addressInput) return;
    if (addressInput._spPlacesInit) return;

    // Retry if Google Places API hasn't loaded yet (max 10 retries = ~5 seconds)
    if (!window.google || !window.google.maps || !window.google.maps.places) {
      if (_spPlacesRetries < 10) {
        _spPlacesRetries++;
        setTimeout(initSPPlaces, 500);
      }
      return;
    }
    addressInput._spPlacesInit = true;

    var autocomplete = new google.maps.places.Autocomplete(addressInput, {
      types: ['address'],
      componentRestrictions: { country: ['us', 'ca', 'gb', 'au', 'pk', 'in', 'bd'] },
      fields: ['address_components', 'formatted_address'],
    });

    autocomplete.addListener('place_changed', function() {
      var place = autocomplete.getPlace();
      if (!place || !place.address_components) return;

      var street = '', route = '', city = '', state = '', zip = '', country = '';
      for (var i = 0; i < place.address_components.length; i++) {
        var comp = place.address_components[i];
        var types = comp.types || [];
        if (types.indexOf('street_number') !== -1) street = comp.long_name;
        if (types.indexOf('route') !== -1) route = comp.short_name;
        if (types.indexOf('locality') !== -1) city = comp.long_name;
        if (types.indexOf('sublocality_level_1') !== -1 && !city) city = comp.long_name;
        if (types.indexOf('administrative_area_level_1') !== -1) state = comp.short_name;
        if (types.indexOf('postal_code') !== -1) zip = comp.long_name;
        if (types.indexOf('country') !== -1) country = comp.short_name;
      }

      addressInput.value = (street ? street + ' ' : '') + route;
      var cityEl = document.getElementById('sp-ck-city');
      var stateEl = document.getElementById('sp-ck-state');
      var zipEl = document.getElementById('sp-ck-zip');
      var countryEl = document.getElementById('sp-ck-country');
      if (cityEl) cityEl.value = city;
      if (stateEl) stateEl.value = state;
      if (zipEl) zipEl.value = zip;
      if (countryEl && country) {
        // Set country dropdown if value exists
        for (var j = 0; j < countryEl.options.length; j++) {
          if (countryEl.options[j].value === country) {
            countryEl.value = country;
            break;
          }
        }
      }
    });
  }

  // ── Validate checkout fields (Step 2 — billing address) ──
  function validateSPCheckout() {
    // Personal details already validated in Step 1, but double-check
    var firstName = (document.getElementById('sp-ck-firstName').value || '').trim();
    var lastName = (document.getElementById('sp-ck-lastName').value || '').trim();
    var email = (document.getElementById('sp-ck-email').value || '').trim();
    if (!firstName || !lastName) return 'Please go back and enter your name.';
    if (!email || email.indexOf('@') < 1) return 'Please go back and enter a valid email.';

    // Billing address fields (Step 2)
    var address = (document.getElementById('sp-ck-address').value || '').trim();
    var city = (document.getElementById('sp-ck-city').value || '').trim();
    var state = (document.getElementById('sp-ck-state').value || '').trim();
    var zip = (document.getElementById('sp-ck-zip').value || '').trim();

    if (!address) return 'Please enter your billing address.';
    if (!city) return 'Please enter your city.';
    if (!state) return 'Please enter your state.';
    if (!zip) return 'Please enter your ZIP code.';
    return null;
  }

  // ── Show/hide payment error ──
  function showSPPaymentError(msg) {
    var errDiv = document.getElementById('sp-ck-payment-error');
    var errText = document.getElementById('sp-ck-payment-error-text');
    if (errDiv && errText) {
      errText.textContent = msg;
      errDiv.classList.remove('hidden');
    }
  }

  function hideSPPaymentError() {
    var errDiv = document.getElementById('sp-ck-payment-error');
    if (errDiv) errDiv.classList.add('hidden');
  }

  // ── Process Payment ──
  function processSPPayment() {
    if (spProcessing || !spPaymentReady || !spStripeElements || !spStripe) return;

    // Validate
    var validationError = validateSPCheckout();
    if (validationError) {
      showSPPaymentError(validationError);
      return;
    }

    hideSPPaymentError();
    spProcessing = true;

    var payBtn = document.getElementById('sp-ck-pay-btn');
    var payText = document.getElementById('sp-ck-pay-btn-text');
    var paySpinner = document.getElementById('sp-ck-pay-btn-spinner');
    if (payBtn) payBtn.disabled = true;
    if (payText) payText.classList.add('hidden');
    if (paySpinner) paySpinner.classList.remove('hidden');

    // Gather form data
    var customer = {
      firstName: (document.getElementById('sp-ck-firstName').value || '').trim(),
      lastName: (document.getElementById('sp-ck-lastName').value || '').trim(),
      email: (document.getElementById('sp-ck-email').value || '').trim(),
      phone: (document.getElementById('sp-ck-phone').value || '').trim(),
    };

    var billingAddress = {
      line1: (document.getElementById('sp-ck-address').value || '').trim(),
      city: (document.getElementById('sp-ck-city').value || '').trim(),
      state: (document.getElementById('sp-ck-state').value || '').trim(),
      postal_code: (document.getElementById('sp-ck-zip').value || '').trim(),
      country: (document.getElementById('sp-ck-country').value || 'US').trim(),
    };

    var coverFees = document.getElementById('sp-ck-cover-fees') ? document.getElementById('sp-ck-cover-fees').checked : false;
    var total = getSPCheckoutTotal();
    var feeAmount = coverFees ? Math.round(spCheckoutAmount * 0.03 * 100) / 100 : 0;
    var baseAmount = spCheckoutAmount;

    var campaignName = (currentModalCampaign && (currentModalCampaign.name || currentModalCampaign.title)) || (currentModalNotif ? currentModalNotif.campaign : 'Donation');
    var items = [{
      id: currentModalSlug + '-' + spCheckoutAmount + '-' + spCheckoutType,
      name: campaignName,
      amount: spCheckoutAmount,
      quantity: 1,
      type: spCheckoutType,
      campaign: currentModalSlug,
      label: '$' + spCheckoutAmount + (spCheckoutType === 'monthly' ? '/mo Monthly' : ' One-Time') + ' Donation'
    }];

    var isRecurring = spCheckoutType === 'monthly';
    var prefEmail = document.getElementById('sp-ck-pref-email') ? document.getElementById('sp-ck-pref-email').checked : false;
    var prefSms = document.getElementById('sp-ck-pref-sms') ? document.getElementById('sp-ck-pref-sms').checked : false;

    // Gather UTM + journey for attribution tracking (same as DonationCart)
    var storedUtm = window.getStoredUTM ? window.getStoredUTM() : {};
    var spUtmSource = (storedUtm && storedUtm.utm_source) || undefined;
    var spUtmMedium = (storedUtm && storedUtm.utm_medium) || undefined;
    var spUtmCampaign = (storedUtm && storedUtm.utm_campaign) || undefined;
    var spUtmContent = (storedUtm && storedUtm.utm_content) || undefined;

    // Build journey object (matches buildDonationJourney in DonationCart)
    var spJourney = undefined;
    try {
      var rawJ = window.getStoredJourney ? window.getStoredJourney() : null;
      if (rawJ) {
        rawJ.checkout = {
          amount: total,
          frequency: spCheckoutType || 'single',
          items: campaignName,
          last_page_before_checkout: rawJ.pages && rawJ.pages.length > 1 ? rawJ.pages[rawJ.pages.length - 2].p : rawJ.pages && rawJ.pages.length === 1 ? rawJ.pages[0].p : '/',
          donation_started_at: Date.now()
        };
        spJourney = JSON.stringify(rawJ);
      }
    } catch(e) { /* silent */ }

    var spResumeToken = localStorage.getItem('qurbani_resume_token') || undefined;

    // Step 1: Validate card with Stripe
    spStripeElements.submit()
      .then(function(submitResult) {
        if (submitResult.error) {
          throw new Error(submitResult.error.message);
        }

        if (isRecurring) {
          // ── RECURRING: SetupIntent → confirmSetup → create-subscription ──
          if (paySpinner) paySpinner.innerHTML = '<svg class="animate-spin inline w-5 h-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Securing payment...';

          return fetch('/api/payments/create-setup-intent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              customer: customer,
              billingAddress: billingAddress,
            }),
          })
          .then(function(res) { return res.json().then(function(d) { return { ok: res.ok, data: d }; }); })
          .then(function(r) {
            if (!r.ok) throw new Error(r.data.error || 'Failed to initialize payment. Please try again.');

            return spStripe.confirmSetup({
              elements: spStripeElements,
              clientSecret: r.data.clientSecret,
              confirmParams: {
                return_url: window.location.origin + '/donate/success',
                payment_method_data: {
                  billing_details: {
                    name: customer.firstName + ' ' + customer.lastName,
                    email: customer.email,
                    phone: customer.phone,
                    address: billingAddress,
                  },
                },
              },
              redirect: 'if_required',
            })
            .then(function(setupResult) {
              if (setupResult.error) {
                throw { _stripeError: setupResult.error };
              }

              var setupIntent = setupResult.setupIntent;
              if (!setupIntent || !setupIntent.payment_method) {
                throw new Error('Payment setup failed. Please try again.');
              }

              if (paySpinner) paySpinner.innerHTML = '<svg class="animate-spin inline w-5 h-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Creating subscription...';

              return fetch('/api/payments/create-subscription', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  paymentMethodId: setupIntent.payment_method,
                  customerId: r.data.customerId,
                  amount: total,
                  items: items,
                  customer: customer,
                  billingAddress: billingAddress,
                  interval: 'monthly',
                  coverFees: coverFees,
                  feeAmount: feeAmount,
                  baseAmount: baseAmount,
                  communicationPreferences: { email: prefEmail, sms: prefSms },
                  resumeToken: spResumeToken,
                  checkout_source: 'social-proof-popup',
                  ga_client_id: spGetGA4ClientId(),
                  ga_session_id: spGetGA4SessionId(),
                  utm_source: spUtmSource,
                  utm_medium: spUtmMedium,
                  utm_campaign: spUtmCampaign,
                  utm_content: spUtmContent,
                  journey: spJourney,
                }),
              })
              .then(function(subRes) { return subRes.json().then(function(d) { return { ok: subRes.ok, data: d }; }); })
              .then(function(subR) {
                if (!subR.ok) throw new Error(subR.data.error || 'Failed to create subscription. Please try again.');

                // Store success data
                var successData = {
                  transaction_id: subR.data.paymentIntentId || setupIntent.id,
                  donation_id: subR.data.donationId || '',
                  total: total,
                  items: items.map(function(item) {
                    return { id: item.id, name: item.name, category: item.campaign, amount: item.amount, quantity: 1, type: item.type };
                  }),
                  cover_fees: coverFees && feeAmount > 0,
                  fee_amount: feeAmount,
                  is_subscription: true,
                  subscription_id: subR.data.subscriptionId || '',
                  interval: 'monthly',
                  next_billing_date: subR.data.nextBillingDate || '',
                  donor_email: customer.email,
                  timestamp: Date.now()
                };
                sessionStorage.setItem('qurbani_purchase', JSON.stringify(successData));

                // Clean up abandoned checkout tracking
                spStopHeartbeat();
                localStorage.removeItem('qurbani_resume_token');

                // Redirect to success
                spProcessing = false;
                window.location.href = '/donate/success?donation_id=' + (subR.data.donationId || '') + '&subscription_id=' + (subR.data.subscriptionId || '');
              });
            });
          });

        } else {
          // ── ONE-TIME: PaymentIntent → confirmPayment ──
          if (paySpinner) paySpinner.innerHTML = '<svg class="animate-spin inline w-5 h-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Processing payment...';

          return fetch('/api/payments/create-intent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              amount: total,
              items: items,
              customer: customer,
              billingAddress: billingAddress,
              type: 'single',
              coverFees: coverFees,
              feeAmount: feeAmount,
              baseAmount: baseAmount,
              communicationPreferences: { email: prefEmail, sms: prefSms },
              resumeToken: spResumeToken,
              checkout_source: 'social-proof-popup',
              ga_client_id: spGetGA4ClientId(),
              ga_session_id: spGetGA4SessionId(),
              utm_source: spUtmSource,
              utm_medium: spUtmMedium,
              utm_campaign: spUtmCampaign,
              utm_content: spUtmContent,
              journey: spJourney,
            }),
          })
          .then(function(res) { return res.json().then(function(d) { return { ok: res.ok, data: d }; }); })
          .then(function(r) {
            if (!r.ok) throw new Error(r.data.error || 'Failed to create payment. Please try again.');

            return spStripe.confirmPayment({
              elements: spStripeElements,
              clientSecret: r.data.clientSecret,
              confirmParams: {
                return_url: window.location.origin + '/donate/success?donation_id=' + (r.data.donationId || '') + '&type=single',
                payment_method_data: {
                  billing_details: {
                    name: customer.firstName + ' ' + customer.lastName,
                    email: customer.email,
                    phone: customer.phone,
                    address: billingAddress,
                  },
                },
              },
              redirect: 'if_required',
            })
            .then(function(result) {
              if (result.error) {
                throw { _stripeError: result.error };
              }

              var paymentIntent = result.paymentIntent;
              if (!paymentIntent) throw new Error('Payment confirmation failed. Please try again.');

              // Store success data
              var successData = {
                transaction_id: paymentIntent.id,
                donation_id: r.data.donationId || '',
                total: total,
                items: items.map(function(item) {
                  return { id: item.id, name: item.name, category: item.campaign, amount: item.amount, quantity: 1, type: item.type };
                }),
                cover_fees: coverFees && feeAmount > 0,
                fee_amount: feeAmount,
                is_subscription: false,
                donor_email: customer.email,
                timestamp: Date.now()
              };
              sessionStorage.setItem('qurbani_purchase', JSON.stringify(successData));

              // Clean up abandoned checkout tracking
              spStopHeartbeat();
              localStorage.removeItem('qurbani_resume_token');

              // Redirect to success
              spProcessing = false;
              window.location.href = '/donate/success?donation_id=' + (r.data.donationId || '') + '&type=single';
            });
          });
        }
      })
      .catch(function(err) {
        spProcessing = false;
        if (payBtn) payBtn.disabled = false;
        if (payText) payText.classList.remove('hidden');
        if (paySpinner) { paySpinner.classList.add('hidden'); paySpinner.innerHTML = '<svg class="animate-spin inline w-5 h-5 ml-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Processing...'; }

        var msg = 'Payment failed. Please try again.';
        if (err && err._stripeError) {
          msg = spGetDeclineMessage(err._stripeError);
        } else if (err && err.message) {
          msg = err.message;
        }
        showSPPaymentError(msg);
      });
  }

  // ── Checkout Event Listeners ──

  // Header BACK button — context-aware: Step 2 → Step 1, Step 1 → amount selection
  var spCkHeaderBack = document.getElementById('sp-ck-header-back');
  if (spCkHeaderBack) {
    spCkHeaderBack.addEventListener('click', function() {
      if (spProcessing) return;
      if (spCurrentStep === 2) {
        goBackToStep1();
      } else {
        hideSPCheckout();
      }
    });
  }

  // CONTINUE button (Step 1 → Step 2) — validate details first
  var spCkContinueBtn = document.getElementById('sp-ck-continue-btn');
  if (spCkContinueBtn) {
    spCkContinueBtn.addEventListener('click', function() {
      // Validate Step 1 fields
      var firstName = (document.getElementById('sp-ck-firstName').value || '').trim();
      var lastName = (document.getElementById('sp-ck-lastName').value || '').trim();
      var email = (document.getElementById('sp-ck-email').value || '').trim();

      var errDiv = document.getElementById('sp-ck-step1-error');
      var errText = document.getElementById('sp-ck-step1-error-text');

      if (!firstName || !lastName) {
        if (errDiv && errText) { errText.textContent = 'Please enter your first and last name.'; errDiv.classList.remove('hidden'); }
        document.getElementById('sp-ck-firstName').focus();
        return;
      }
      if (!email || email.indexOf('@') < 1 || email.indexOf('.') < 3) {
        if (errDiv && errText) { errText.textContent = 'Please enter a valid email address.'; errDiv.classList.remove('hidden'); }
        document.getElementById('sp-ck-email').focus();
        return;
      }

      // Clear error and proceed to Step 2
      if (errDiv) errDiv.classList.add('hidden');

      // Capture abandoned checkout lead (same as GG one-step)
      spCaptureAbandonedCheckout();

      showCheckoutStep2();
    });
  }

  // Capture lead on email/phone blur (early capture before Step 2)
  var spCkEmailField = document.getElementById('sp-ck-email');
  if (spCkEmailField) {
    spCkEmailField.addEventListener('blur', function() { spCaptureAbandonedCheckout(); });
  }
  var spCkPhoneField = document.getElementById('sp-ck-phone');
  if (spCkPhoneField) {
    spCkPhoneField.addEventListener('blur', function() { spCaptureAbandonedCheckout(); });
  }

  // Resume heartbeat if resume token already exists (e.g. page reload during checkout)
  if (localStorage.getItem('qurbani_resume_token')) spStartHeartbeat();

  // Cover fees checkbox → update fee display + Stripe amount
  var spCkCoverFees = document.getElementById('sp-ck-cover-fees');
  if (spCkCoverFees) {
    spCkCoverFees.addEventListener('change', function() {
      updateSPFeeDisplay();
      // Update Stripe elements amount for one-time payments
      if (spStripeElements && spCheckoutType !== 'monthly') {
        var newTotal = getSPCheckoutTotal();
        spStripeElements.update({ amount: Math.round(newTotal * 100) });
      }
    });
  }

  // Pay button → process payment
  var spCkPayBtn = document.getElementById('sp-ck-pay-btn');
  if (spCkPayBtn) {
    spCkPayBtn.addEventListener('click', function() {
      processSPPayment();
    });
  }

  // ─── Scroll to Donation Box ───
  // Finds the donation form on the current page and scrolls to it smoothly.
  // Uses actual data attributes from codebase: data-donation-box, data-mobile-donate, etc.
  function scrollToDonationBox() {
    var isMobile = window.innerWidth < 768;

    // Selectors in priority order — on mobile prefer mobile-specific markers first
    var selectors = isMobile
      ? ['[data-mobile-donate]', '[data-donation-box]', '#donate', '#select-qurbani', '#packages']
      : ['[data-donation-box]', '[data-mobile-donate]', '#donate', '#select-qurbani', '#packages'];

    for (var si = 0; si < selectors.length; si++) {
      // Find ALL matching elements, pick the first visible one
      var els = document.querySelectorAll(selectors[si]);
      for (var ei = 0; ei < els.length; ei++) {
        var el = els[ei];
        // Skip hidden elements (display:none, zero-size, or position:fixed sidebar)
        if (el.offsetWidth === 0 || el.offsetHeight === 0) continue;
        if (el.id === 'fixed-donate-box') continue; // Fixed sidebar — can't scroll to it

        var rect = el.getBoundingClientRect();

        // If already in upper half of viewport, just glow — no need to scroll
        if (rect.top >= -20 && rect.top < window.innerHeight * 0.5) {
          glowDonationBox(el);
          return;
        }

        // Scroll with 80px offset from top for breathing room
        var scrollTarget = window.pageYOffset + rect.top - 80;
        window.scrollTo({ top: Math.max(0, scrollTarget), behavior: 'smooth' });
        var capturedEl = el;
        setTimeout(function() { glowDonationBox(capturedEl); }, 700);
        return;
      }
    }
    // Fallback: scroll to top (most campaign pages have donation box in hero)
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ─── Orange Glow Effect on Donation Box ───
  // Adds a warm orange pulse glow around the donation box to draw attention
  function glowDonationBox(el) {
    // Find the actual donation box container (white card with shadow)
    var box = el.querySelector('[data-donation-box]') || el;
    if (!box) return;

    // Inject keyframes if not already present
    if (!document.getElementById('sp-glow-style')) {
      var style = document.createElement('style');
      style.id = 'sp-glow-style';
      style.textContent = '@keyframes sp-orange-glow{0%{box-shadow:0 0 5px rgba(225,134,29,0.3),0 0 15px rgba(225,134,29,0.15)}50%{box-shadow:0 0 15px rgba(225,134,29,0.6),0 0 30px rgba(225,134,29,0.3)}100%{box-shadow:0 0 5px rgba(225,134,29,0.3),0 0 15px rgba(225,134,29,0.15)}}';
      document.head.appendChild(style);
    }

    // Store original box-shadow to restore later
    var origShadow = box.style.boxShadow || '';
    var origTransition = box.style.transition || '';

    // Apply glow animation — 3 pulses over 2.4s
    box.style.animation = 'sp-orange-glow 0.8s ease-in-out 3';
    box.style.borderRadius = box.style.borderRadius || getComputedStyle(box).borderRadius;

    // Clean up after animation
    box.addEventListener('animationend', function cleanup() {
      box.removeEventListener('animationend', cleanup);
      box.style.animation = '';
      box.style.boxShadow = origShadow;
      box.style.transition = origTransition;
    });
  }

  // ─── Auto-scroll on ?donate=true (from social proof redirect) ───
  if (window.location.search.indexOf('donate=true') !== -1) {
    // Wait for page to fully load, then scroll to donation box
    if (document.readyState === 'complete') {
      setTimeout(scrollToDonationBox, 500);
    } else {
      window.addEventListener('load', function() { setTimeout(scrollToDonationBox, 500); });
    }
  }

  // ─── Relevance Sorting ───
  // Prioritize campaigns matching the current page the user is viewing
  function sortByCampaignRelevance(items) {
    var path = window.location.pathname.toLowerCase();
    // Try to extract slug from various URL patterns
    var slug = '';
    var match = path.match(/\/appeals\/([^\/]+)/);
    if (match) slug = match[1];
    else if (path.match(/^\/(zakat|ramadan|orphans?|water|qurbani|aqiqah|sadaqah)/)) {
      slug = path.replace(/^\//, '').replace(/\/$/, '').split('/')[0];
    }
    if (!slug) return items;

    // Split into matching (current campaign) and others
    var matching = [], others = [];
    for (var i = 0; i < items.length; i++) {
      var cs = (items[i].slug || items[i].campaign.toLowerCase().replace(/\s+/g, '-'));
      if (cs.indexOf(slug) !== -1 || slug.indexOf(cs) !== -1) matching.push(items[i]);
      else others.push(items[i]);
    }

    // If on a campaign page, show 60%+ matching, mix in some variety
    // Interleave: matching first, then intersperse others
    if (matching.length > 0 && others.length > 0) {
      var result = [];
      var mi = 0, oi = 0;
      // Put 2 matching then 1 other — keeps it relevant but varied
      while (mi < matching.length || oi < others.length) {
        if (mi < matching.length) result.push(matching[mi++]);
        if (mi < matching.length) result.push(matching[mi++]);
        if (oi < others.length) result.push(others[oi++]);
      }
      return result;
    }

    return matching.concat(others);
  }

  // ─── Deduplicate by campaign slug (keep first per slug) ───
  function deduplicateByCampaign(items) {
    var seen = {};
    var result = [];
    for (var i = 0; i < items.length; i++) {
      var slug = items[i].slug || '';
      if (!seen[slug]) {
        seen[slug] = true;
        result.push(items[i]);
      }
    }
    return result;
  }

  // ─── Pause on Page Visibility Change ───
  document.addEventListener('visibilitychange', function() {
    if (document.hidden) {
      // Page hidden — pause timers
      if (showTimer) { clearTimeout(showTimer); showTimer = null; }
      if (pauseTimer) { clearTimeout(pauseTimer); pauseTimer = null; }
      hybridIdleActive = false;
      if (isVisible) hidePopup();
    } else {
      // Page visible again — schedule next via hybrid triggers
      if (!isDismissed && !modalOpen && !donationInteracting && notifications.length && notifShownCount < MAX_PER_SESSION && !isVisible) {
        scheduleNextHybrid();
      }
    }
  });

  // ─── Init ───
  setTimeout(function() {
    fetch('/api/social-proof')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.notifications || !d.notifications.length) return;
        var sorted = sortByCampaignRelevance(d.notifications);
        notifications = deduplicateByCampaign(sorted);
        showPopup();
      })
      .catch(function() {});
  }, DELAY_BEFORE_FIRST);
})();
</script>
