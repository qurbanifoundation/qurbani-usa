<script is:inline>
(function() {
  // ─── Config ───
  var DELAY_BEFORE_FIRST = 5000; // 5s — first popup
  var SHOW_DURATION = 7000; // how long each notification stays visible
  var MAX_PER_SESSION = 4;
  var COOLDOWN_KEY = 'social_proof_dismissed';
  var SESSION_COUNT_KEY = 'social_proof_count';
  var INDEX_KEY = 'social_proof_index';
  var COOLDOWN_MS = 4 * 60 * 60 * 1000;
  var pageLoadTime = Date.now();

  // ─── Hybrid Triggers (popup 2, 3, 4) ───
  // Each: { absMs: absolute ms from page load, idleMs: idle ms to trigger }
  // Whichever condition fires first wins.
  var HYBRID_TRIGGERS = [
    { absMs: 25000 + Math.floor(Math.random() * 10000), idleMs: 4000 + Math.floor(Math.random() * 1000) }, // 2nd: 25-35s OR 4-5s idle
    { absMs: 50000, idleMs: 5000 }, // 3rd: 50s OR 5s idle
    { absMs: 90000, idleMs: 5000 }, // 4th: 90s OR 5s idle
  ];

  // ─── Idle Detection Config ───
  var IDLE_THRESHOLD = 2000; // 2s of inactivity = idle (for first popup deferred show)
  var lastActivityTime = Date.now();
  var userIsIdle = true;
  var pendingShow = false; // true when we want to show but user isn't idle
  var idleCheckInterval = null;

  // ─── Hybrid idle state ───
  var hybridIdleActive = false; // true when waiting for idle trigger
  var hybridIdleMs = 0; // idle ms threshold for current hybrid trigger

  // ─── Donation interaction pause ───
  var donationInteracting = false; // true when user is interacting with donation box/checkout

  // ─── Early Exit ───
  if (window.location.pathname.indexOf('/admin') === 0) return;
  var lastDismissed = localStorage.getItem(COOLDOWN_KEY);
  if (lastDismissed && (Date.now() - parseInt(lastDismissed, 10)) < COOLDOWN_MS) return;
  var sessionCount = parseInt(sessionStorage.getItem(SESSION_COUNT_KEY) || '0', 10);
  if (sessionCount >= MAX_PER_SESSION) return;

  // ─── Notification DOM ───
  var popup = document.getElementById('social-proof-popup');
  var contentEl = document.getElementById('social-proof-content');
  var progressEl = document.getElementById('social-proof-progress');
  // closeBtn is now rendered dynamically inside each notification — use event delegation
  var closeBtn = null; // will be resolved after each render
  if (!popup || !contentEl || !progressEl) return;

  var notifications = [];
  var currentIndex = parseInt(sessionStorage.getItem(INDEX_KEY) || '0', 10);
  var notifShownCount = parseInt(sessionStorage.getItem(SESSION_COUNT_KEY) || '0', 10); // how many shown so far this session
  var showTimer = null;
  var pauseTimer = null;
  var isVisible = false;
  var isDismissed = false;

  // ─── Idle Detection ───
  // Track user activity — social proof only appears when user is idle (reading)
  function markActive() { lastActivityTime = Date.now(); userIsIdle = false; }
  function checkIdle() {
    var now = Date.now();
    var idleDuration = now - lastActivityTime;

    if (idleDuration >= IDLE_THRESHOLD) {
      userIsIdle = true;
      // If a notification was waiting (deferred from showPopup), show it now
      if (pendingShow && !isVisible && !isDismissed && !modalOpen && !donationInteracting) {
        pendingShow = false;
        showPopup();
      }
      // Hybrid idle trigger — if waiting for idle and threshold met, fire popup
      if (hybridIdleActive && idleDuration >= hybridIdleMs && !isVisible && !isDismissed && !modalOpen && !donationInteracting && notifShownCount < MAX_PER_SESSION) {
        hybridIdleActive = false;
        if (pauseTimer) { clearTimeout(pauseTimer); pauseTimer = null; }
        showPopup();
      }
    } else {
      userIsIdle = false;
    }
  }

  // ─── Schedule next popup (hybrid: timer OR idle, whichever fires first) ───
  function scheduleNextHybrid() {
    if (isDismissed || modalOpen || donationInteracting || notifShownCount >= MAX_PER_SESSION) return;

    var triggerIdx = Math.min(notifShownCount - 1, HYBRID_TRIGGERS.length - 1);
    var trigger = HYBRID_TRIGGERS[triggerIdx];

    // Timer trigger — absolute time from page load (minimum 2s gap)
    var elapsed = Date.now() - pageLoadTime;
    var absRemaining = Math.max(2000, trigger.absMs - elapsed);
    pauseTimer = setTimeout(showPopup, absRemaining);

    // Reset idle clock so idle trigger counts from NOW, not from before the popup showed
    lastActivityTime = Date.now();
    userIsIdle = false;

    // Idle trigger — user must be idle for idleMs AFTER previous popup disappears
    hybridIdleActive = true;
    hybridIdleMs = trigger.idleMs;
  }

  // ─── Donation Interaction Detection ───
  // Pause all social proof when user interacts with donation box, checkout, or forms
  function markDonationInteraction() {
    donationInteracting = true;
    // Clear any pending popup timers
    if (pauseTimer) { clearTimeout(pauseTimer); pauseTimer = null; }
    hybridIdleActive = false;
    pendingShow = false;
  }
  function clearDonationInteraction() {
    if (!donationInteracting) return;
    donationInteracting = false;
    // Resume scheduling if we haven't reached max
    if (!isDismissed && !modalOpen && notifications.length && notifShownCount < MAX_PER_SESSION && !isVisible) {
      scheduleNextHybrid();
    }
  }

  // Detect clicks on donation amount buttons & donation box interactions
  document.addEventListener('click', function(e) {
    var t = e.target;
    if (!t) return;
    // Check if click is inside a donation box or on amount buttons
    var inDonationBox = t.closest && (t.closest('[data-donation-box]') || t.closest('#fixed-donate-box') || t.closest('[data-mobile-donate]'));
    if (inDonationBox) {
      markDonationInteraction();
      // Auto-clear after 30s of no further donation interaction
      clearTimeout(window._spDonationTimeout);
      window._spDonationTimeout = setTimeout(clearDonationInteraction, 30000);
    }
  }, { passive: true });

  // Detect focus on any form field (including checkout forms)
  document.addEventListener('focus', function(e) {
    var t = e.target;
    if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.tagName === 'SELECT')) {
      markDonationInteraction();
      // Auto-clear when user leaves all form fields
    }
  }, true);
  document.addEventListener('blur', function(e) {
    var t = e.target;
    if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.tagName === 'SELECT')) {
      // Small delay to check if focus moved to another field
      setTimeout(function() {
        var active = document.activeElement;
        if (!active || (active.tagName !== 'INPUT' && active.tagName !== 'TEXTAREA' && active.tagName !== 'SELECT')) {
          clearDonationInteraction();
        }
      }, 300);
    }
  }, true);

  // Activity listeners — detect clicks, typing, fast scrolling
  var scrollTimeout = null;
  document.addEventListener('click', markActive, { passive: true });
  document.addEventListener('keydown', markActive, { passive: true });
  document.addEventListener('input', markActive, { passive: true });
  document.addEventListener('scroll', function() {
    markActive();
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(function() { /* scroll ended */ }, 200);
  }, { passive: true });

  // Check idle state every 500ms
  idleCheckInterval = setInterval(checkIdle, 500);

  // ─── CW Modal DOM ───
  var modal = document.getElementById('sp-donate-modal');
  var mBackdrop = document.getElementById('sp-modal-backdrop');
  var mCard = document.getElementById('sp-modal-card');
  var mCloseBtn = document.getElementById('sp-modal-close');
  var mImage = document.getElementById('sp-modal-image');
  var mTitle = document.getElementById('sp-modal-title');
  var mDesc = document.getElementById('sp-modal-desc');
  var mLink = document.getElementById('sp-modal-link');

  // CW box elements
  var cwFormHeader = document.getElementById('sp-cw-form-header');
  var cwUpsellHeader = document.getElementById('sp-cw-upsell-header');
  var cwFormView = document.getElementById('sp-cw-form-view');
  var cwUpsellView = document.getElementById('sp-cw-upsell-view');
  var cwGridMonthly = document.getElementById('sp-cw-grid-monthly');
  var cwGridSingle = document.getElementById('sp-cw-grid-single');
  var cwImpactEmoji = document.getElementById('sp-cw-impact-emoji');
  var cwImpactText = document.getElementById('sp-cw-impact-text');
  var cwDonateBtn = document.getElementById('sp-cw-donate-btn');
  var cwTabMonthly = document.getElementById('sp-cw-tab-monthly');
  var cwTabSingle = document.getElementById('sp-cw-tab-single');

  // Right side panels
  var rightCampaign = document.getElementById('sp-right-campaign');
  var rightFaq = document.getElementById('sp-right-faq');
  var imageCol = document.getElementById('sp-image-col');
  var faqLink = document.getElementById('sp-faq-link');
  var faqCloseBtn = document.getElementById('sp-faq-close');

  // Upsell elements
  var cwUpsellAmountEl = document.getElementById('sp-cw-upsell-amount');
  var cwUpsellPeriodEl = document.getElementById('sp-cw-upsell-period');
  var cwUpsellBodyEl = document.getElementById('sp-cw-upsell-body');
  var cwUpsellSubtextEl = document.getElementById('sp-cw-upsell-subtext');
  var cwUpsellToggle = document.getElementById('sp-cw-upsell-toggle');
  var cwUpsellToggleDot = document.getElementById('sp-cw-upsell-toggle-dot');
  var cwUpsellMonthlyLabel = document.getElementById('sp-cw-upsell-monthly-label');
  var cwUpsellBtn = document.getElementById('sp-cw-upsell-btn');
  var cwEditLink = document.getElementById('sp-cw-edit-link');

  // ─── CW State ───
  var modalOpen = false;
  var activeFreqKey = 'monthly';
  var tabsSwapped = false; // true when Tab1=single, Tab2=recurring (e.g., Zakat)
  var selectedAmount = 0;
  var upsellMonthlyActive = false;
  var upsellOneTimeAmount = 0;
  var upsellMonthlyAmount = 0;
  var currentModalCampaign = null;
  var currentModalNotif = null;
  var currentModalSlug = '';
  var currentPageUrl = '';
  var currentAccentColor = '#e1861d';
  var currentAccentTextColor = '#ffffff';
  var singleOnlyCampaign = false; // true for Kaffarah, Fidya, etc. — no monthly tab
  var redirectToCampaignPage = false; // true for campaigns that should redirect to their page on donate

  var MONTHLY_AMOUNTS_DEFAULT = [10, 20, 40, 100];
  var SINGLE_AMOUNTS_DEFAULT = [50, 100, 150, 200];
