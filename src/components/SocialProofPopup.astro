---
/**
 * Social Proof Popup + Quick Donation Modal
 * Shows recent donation notifications in the bottom-left corner.
 * Clicking "Donate" opens a modal with campaign info + CW donation box.
 * Fetches from /api/social-proof (real + fabricated mix).
 * Follows RamadanPopup.astro pattern: is:inline script, IIFE, localStorage cooldown.
 */
---

<!-- Social Proof Notification Container -->
<div
  id="social-proof-popup"
  class="fixed bottom-4 left-6 right-3 md:right-auto md:left-4 z-40 pointer-events-none"
  style="opacity: 0; transform: translateX(-120%); transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.34,1.56,0.64,1);"
  role="status"
  aria-live="polite"
>
  <div class="pointer-events-auto bg-white rounded-xl shadow-lg border border-gray-200 w-full md:w-[420px] overflow-hidden hover:shadow-xl transition-shadow relative">
    <div id="social-proof-content" class="p-3.5"></div>
    <div class="h-[2px] bg-gray-100">
      <div id="social-proof-progress" class="h-full bg-[#01534d] transition-all" style="width: 0%; transition: width linear;"></div>
    </div>
  </div>
</div>

<!-- Quick Donation Modal -->
<div
  id="sp-donate-modal"
  class="fixed inset-0 z-[65] hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Quick Donation"
>
  <div id="sp-modal-backdrop" class="absolute inset-0 bg-black/50" style="opacity:0; transition:opacity .3s ease;"></div>

  <!-- Close button — pinned to top-right of viewport -->
  <button id="sp-modal-close" class="fixed top-4 right-4 z-[70] w-10 h-10 flex items-center justify-center rounded-full bg-white shadow-lg hover:bg-gray-100 transition text-gray-600 hover:text-gray-900" aria-label="Close" style="opacity:0; transition:opacity .3s ease;">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>

  <div class="absolute inset-0 flex flex-col items-center justify-center p-0 md:p-8 overflow-y-auto">
    <div id="sp-modal-card" class="relative w-full max-w-full md:max-w-[1200px] bg-white rounded-none md:rounded-2xl shadow-2xl overflow-hidden h-full md:h-auto" style="opacity:0; transform:scale(.97); transition:opacity .3s ease, transform .3s ease;">

      <div id="sp-modal-inner" class="flex flex-col-reverse md:flex-row md:min-h-[660px] h-full md:h-auto max-h-[100dvh] md:max-h-[90vh] overflow-y-auto md:overflow-hidden">
        <!-- RIGHT (visually): CW Donation Box — order-2 on desktop -->
        <div class="md:w-[48%] md:order-2 border-l border-gray-100 md:max-h-[85vh] flex flex-col flex-1 md:flex-shrink-0 min-h-0 overflow-x-hidden">
          <div class="bg-white overflow-y-auto overflow-x-hidden md:overflow-hidden w-full h-full flex flex-col min-h-0">

            <!-- Tab header area -->
            <div class="px-5 pt-5 pb-3 sm:px-8 sm:pt-8 sm:pb-5" style="background-color:#F4F5F0;">
              <div>
                <!-- Form tabs -->
                <div id="sp-cw-form-header" class="grid grid-cols-2 gap-2">
                  <button type="button" id="sp-cw-tab-monthly" class="sp-cw-toggle flex items-center justify-center gap-1 py-3 rounded text-[13px] font-bold uppercase tracking-wider transition-all border-2" data-type="monthly" style="background-color:#e1861d; color:#fff; border-color:#e1861d;">
                    MONTHLY <svg class="w-4 h-4 inline-block" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                  </button>
                  <button type="button" id="sp-cw-tab-single" class="sp-cw-toggle flex items-center justify-center gap-1 py-3 rounded text-[13px] font-bold uppercase tracking-wider transition-all border-2" data-type="single" style="background-color:transparent; color:#9ca3af; border-color:transparent;">
                    GIVE ONCE
                  </button>
                </div>
                <!-- Upsell header (replaces tabs in upsell state) -->
                <div id="sp-cw-upsell-header" class="hidden">
                  <p class="flex items-center justify-center gap-1.5 text-sm text-gray-500 py-1 whitespace-nowrap">
                    <span>Giving <strong id="sp-cw-upsell-amount" class="text-gray-800 text-base">$50 USD</strong><span id="sp-cw-upsell-period"></span></span>
                    <button type="button" id="sp-cw-edit-link" class="text-[11px] font-bold text-gray-800 uppercase tracking-wide hover:text-gray-600 transition-colors flex-shrink-0" style="border-bottom:1.5px solid currentColor;">EDIT</button>
                  </p>
                </div>
                <!-- Checkout header (amount + EDIT — replaces tabs during checkout) -->
                <div id="sp-cw-checkout-header" class="hidden">
                  <p class="flex items-center justify-center gap-1.5 text-sm text-gray-500 py-1 whitespace-nowrap">
                    <span>Giving <strong id="sp-ck-header-amount" class="text-gray-800 text-base">$50 USD</strong><span id="sp-ck-header-period"></span></span>
                    <button type="button" id="sp-ck-header-back" class="text-[11px] font-bold text-gray-800 uppercase tracking-wide hover:text-gray-600 transition-colors flex-shrink-0" style="border-bottom:1.5px solid currentColor;">EDIT</button>
                  </p>
                  <!-- Step indicator (hidden — kept for JS references) -->
                  <div id="sp-ck-header-steps" class="hidden">
                    <div class="flex items-center gap-1.5">
                      <span id="sp-ck-step1-circle"></span>
                      <span id="sp-ck-step1-label"></span>
                    </div>
                    <div id="sp-ck-step-line"></div>
                    <div class="flex items-center gap-1.5">
                      <span id="sp-ck-step2-circle"></span>
                      <span id="sp-ck-step2-label"></span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="px-5 pt-4 pb-5 sm:px-8 sm:pt-6 sm:pb-8 flex-1 flex flex-col overflow-y-auto min-h-0">
              <!-- ═══ FORM VIEW ═══ -->
              <div id="sp-cw-form-view" class="flex flex-col flex-1">
                <!-- Monthly grid -->
                <div id="sp-cw-grid-monthly" class="sp-cw-freq-grid" data-freq-key="monthly"></div>
                <!-- Single grid -->
                <div id="sp-cw-grid-single" class="sp-cw-freq-grid hidden" data-freq-key="single"></div>

                <!-- Impact line -->
                <div class="flex items-start gap-2 mt-4 mb-4">
                  <span id="sp-cw-impact-emoji" class="text-sm mt-0.5 flex-shrink-0">❤️</span>
                  <p id="sp-cw-impact-text" class="text-[13px] text-gray-500 leading-relaxed"></p>
                </div>

                <!-- CTA Button — flush below content on mobile, pushed to bottom on desktop -->
                <div class="mt-4 md:mt-auto pt-1">
                  <button type="button" id="sp-cw-donate-btn" class="w-full py-3.5 sm:py-4 rounded font-extrabold text-[15px] uppercase tracking-[0.1em] transition-all active:scale-[0.99]" style="background-color:#e1861d; color:#fff;">
                    JOIN TODAY
                  </button>
                  <p class="text-center text-[11px] text-gray-400 mt-2">Secure donation &middot; Tax deductible &middot; Takes less than 30 seconds</p>
                </div>
              </div>

              <!-- ═══ UPSELL VIEW ═══ -->
              <div id="sp-cw-upsell-view" class="hidden flex flex-col flex-1">
                <h3 class="text-xl font-bold text-gray-800 text-center mb-3" style="font-family:'Signika',sans-serif;">
                  Would you consider something?
                </h3>
                <p id="sp-cw-upsell-body" class="text-sm text-gray-500 leading-relaxed mb-5 text-center"></p>

                <!-- Monthly toggle card -->
                <div class="rounded-lg p-4 mb-5 border border-gray-200" style="background-color:#f9f9f7;">
                  <div class="flex items-center gap-3">
                    <button type="button" id="sp-cw-upsell-toggle" class="relative w-14 h-7 rounded-full bg-gray-300 transition-colors flex-shrink-0" role="switch" aria-checked="false">
                      <span id="sp-cw-upsell-toggle-dot" class="absolute top-0.5 left-0.5 w-6 h-6 bg-white rounded-full shadow-md transition-transform flex items-center justify-center">
                        <svg class="sp-toggle-x w-3 h-3 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
                        <svg class="sp-toggle-check w-3.5 h-3.5 text-white hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      </span>
                    </button>
                    <span id="sp-cw-upsell-monthly-label" class="text-sm font-semibold text-gray-700">
                      Give $20 per month instead
                    </span>
                  </div>
                  <p id="sp-cw-upsell-subtext" class="text-xs text-gray-400 mt-2.5 leading-relaxed"></p>
                </div>

                <!-- Upsell CTA — flush below content on mobile, pushed to bottom on desktop -->
                <div class="mt-4 md:mt-auto pt-2">
                  <button type="button" id="sp-cw-upsell-btn" class="w-full py-4 rounded font-extrabold text-[15px] uppercase tracking-[0.1em] transition-all active:scale-[0.99]" style="background-color:#e1861d; color:#fff;">
                    GIVE $50
                  </button>
                </div>
              </div>

              <!-- ═══ CHECKOUT STEP 1: YOUR DETAILS ═══ -->
              <div id="sp-checkout-step1" class="hidden flex-col flex-1" style="display:none;">

                <!-- Your Details -->
                <div class="space-y-3.5 flex-1">
                  <div class="grid grid-cols-2 gap-2.5">
                    <input type="text" id="sp-ck-firstName" name="given-name" autocomplete="given-name" placeholder="First Name" required class="w-full px-3 py-3 border border-gray-300 rounded-lg text-base text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#d97706] focus:border-transparent placeholder-gray-400" />
                    <input type="text" id="sp-ck-lastName" name="family-name" autocomplete="family-name" placeholder="Last Name" required class="w-full px-3 py-3 border border-gray-300 rounded-lg text-base text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#d97706] focus:border-transparent placeholder-gray-400" />
                  </div>
                  <input type="email" id="sp-ck-email" name="email" autocomplete="email" placeholder="Email" required class="w-full px-3 py-3 border border-gray-300 rounded-lg text-base text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#d97706] focus:border-transparent placeholder-gray-400" />
                  <input type="tel" id="sp-ck-phone" name="tel" autocomplete="tel" placeholder="Phone Number" class="w-full px-3 py-3 border border-gray-300 rounded-lg text-base text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#d97706] focus:border-transparent placeholder-gray-400" />
                </div>

                <!-- Step 1 error -->
                <div id="sp-ck-step1-error" class="hidden mt-3 p-3 bg-red-50 border border-red-200 rounded-lg">
                  <p id="sp-ck-step1-error-text" class="text-red-600 text-sm"></p>
                </div>

                <!-- Continue CTA — pushed to bottom -->
                <div class="mt-auto pt-5">
                  <button type="button" id="sp-ck-continue-btn" class="w-full py-4 rounded-lg font-extrabold text-[15px] uppercase tracking-[0.08em] transition-all active:scale-[0.99] shadow-md flex items-center justify-center gap-2" style="background-color:#d97706; color:#fff;">
                    CONTINUE TO SECURE CHECKOUT
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </button>
                  <div class="flex items-center justify-center gap-2 mt-3 text-[11px] text-gray-400">
                    <svg class="w-3.5 h-3.5 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <span>256-bit SSL encrypted &middot; Your information is safe</span>
                  </div>
                </div>
              </div>

              <!-- ═══ CHECKOUT STEP 2: SECURE PAYMENT ═══ -->
              <div id="sp-checkout-step2" class="hidden flex-col flex-1" style="display:none;">

                <!-- Stripe Payment Element -->
                <div class="mb-4">
                  <div id="sp-ck-card-element" class="p-3 border border-gray-300 rounded-lg bg-white min-h-[50px]">
                    <div class="animate-pulse text-gray-400 text-sm text-center py-2">Loading secure payment...</div>
                  </div>
                  <div id="sp-ck-card-errors" class="text-red-500 text-xs mt-1.5 hidden" role="alert"></div>
                </div>

                <!-- Billing Address -->
                <h4 class="text-sm font-semibold text-gray-700 mb-2">Billing Address</h4>
                <div class="space-y-3 mb-4">
                  <input type="text" id="sp-ck-address" name="street-address" autocomplete="off" placeholder="Street Address" required class="w-full px-4 py-3 border border-gray-300 rounded-lg text-[15px] text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#d97706] focus:border-transparent placeholder-gray-400" />
                  <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                    <input type="text" id="sp-ck-city" name="address-level2" autocomplete="address-level2" placeholder="City" required class="w-full px-3 py-3 border border-gray-300 rounded-lg text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#d97706] focus:border-transparent placeholder-gray-400" />
                    <input type="text" id="sp-ck-state" name="address-level1" autocomplete="address-level1" placeholder="State" required class="w-full px-3 py-3 border border-gray-300 rounded-lg text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#d97706] focus:border-transparent placeholder-gray-400" />
                    <input type="text" id="sp-ck-zip" name="postal-code" autocomplete="postal-code" placeholder="ZIP" required class="w-full px-3 py-3 border border-gray-300 rounded-lg text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#d97706] focus:border-transparent placeholder-gray-400" />
                    <select id="sp-ck-country" required class="w-full px-2 py-2.5 border border-gray-300 rounded-lg text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#d97706] focus:border-transparent bg-white">
                      <option value="US" selected>United States</option>
                      <option value="CA">Canada</option>
                      <option value="GB">United Kingdom</option>
                      <option value="AU">Australia</option>
                      <option value="PK">Pakistan</option>
                      <option value="IN">India</option>
                      <option value="BD">Bangladesh</option>
                    </select>
                  </div>
                </div>

                <!-- Communication preferences -->
                <div class="mb-3 space-y-2 bg-white rounded-lg border border-gray-200 p-3">
                  <label class="flex items-start gap-2 cursor-pointer">
                    <input type="checkbox" id="sp-ck-pref-email" checked class="w-4 h-4 mt-0.5 rounded accent-[#d97706]" />
                    <span class="text-xs text-gray-600 leading-relaxed">Email me periodic reports from the projects I supported.</span>
                  </label>
                  <label class="flex items-start gap-2 cursor-pointer">
                    <input type="checkbox" id="sp-ck-pref-sms" checked class="w-4 h-4 mt-0.5 rounded accent-[#d97706]" />
                    <span class="text-xs text-gray-600 leading-relaxed">Plus, email me inspiring stories, exclusive promotions, and donation match opportunities to amplify my impact!</span>
                  </label>
                </div>

                <!-- Cover transaction fees -->
                <div class="mb-4 p-3 bg-white rounded-lg border border-gray-200">
                  <label class="flex items-start gap-3 cursor-pointer">
                    <input type="checkbox" id="sp-ck-cover-fees" class="w-5 h-5 mt-0.5 rounded accent-[#d97706]" />
                    <div>
                      <span class="font-semibold text-gray-800 text-sm">Cover transaction fees</span>
                      <span id="sp-ck-fee-badge" class="ml-1 px-1.5 py-0.5 bg-amber-200 text-amber-800 text-[10px] font-bold rounded-sm">+3%</span>
                      <p id="sp-ck-fee-desc" class="text-[11px] text-gray-500 mt-0.5">Add $0.00 to ensure 100% of your donation goes directly to families in need.</p>
                    </div>
                  </label>
                </div>

                <!-- Payment error -->
                <div id="sp-ck-payment-error" class="hidden mb-3 p-3 bg-red-50 border border-red-200 rounded-lg">
                  <p id="sp-ck-payment-error-text" class="text-red-600 text-sm"></p>
                </div>

                <!-- CTA -->
                <button type="button" id="sp-ck-pay-btn" disabled class="w-full py-4 rounded-lg font-extrabold text-[15px] uppercase tracking-[0.08em] transition-all active:scale-[0.99] disabled:opacity-50 disabled:cursor-not-allowed shadow-md" style="background-color:#d97706; color:#fff;">
                  <span id="sp-ck-pay-btn-text">COMPLETE SECURE DONATION</span>
                  <span id="sp-ck-pay-btn-spinner" class="hidden"><svg class="animate-spin inline w-5 h-5 ml-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Processing...</span>
                </button>

                <!-- Terms -->
                <p class="mt-3 text-[10px] text-gray-400 text-center leading-relaxed">
                  By making a donation to Qurbani Foundation, you agree to our
                  <a href="/terms-of-service" target="_blank" class="underline font-semibold hover:text-gray-600">Terms of Service</a>
                  and <a href="/privacy-policy" target="_blank" class="underline font-semibold hover:text-gray-600">Privacy Policy</a>.
                </p>

                <!-- Trust signals -->
                <div class="mt-3 mb-2 bg-white border border-gray-200 rounded-lg p-2.5 flex flex-wrap items-center justify-center gap-3 text-[10px] text-gray-500">
                  <div class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 text-[#d97706]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <span>Secure Payment</span>
                  </div>
                  <div class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 text-[#d97706]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                    <span>Tax-Deductible</span>
                  </div>
                  <div class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 text-[#d97706]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                    <span>Cancel anytime</span>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- LEFT (visually): Full-screen image + FAQ — order-1 on desktop -->
        <div id="sp-image-col" class="h-[40dvh] md:h-auto md:w-[52%] md:order-1 flex flex-col relative overflow-hidden flex-shrink-0">

          <!-- Campaign View (default) — full image with overlay -->
          <div id="sp-right-campaign" class="relative h-full min-h-0 md:min-h-[300px]">
            <div id="sp-modal-image" class="absolute inset-0 bg-gray-200 bg-cover bg-center pointer-events-none"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent pointer-events-none"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 text-center z-10">
              <h3 id="sp-modal-title" class="text-white text-2xl md:text-3xl font-bold leading-tight drop-shadow-lg" style="font-family:'Signika',sans-serif;"></h3>
              <p id="sp-modal-desc" class="hidden"></p>
              <div class="flex items-center justify-center gap-2 mt-3 text-[13px]">
                <button type="button" id="sp-faq-link" class="text-gray-300 hover:text-white transition cursor-pointer">Frequently asked questions</button>
                <span class="text-gray-500">&middot;</span>
                <a id="sp-modal-link" href="#" target="_blank" rel="noopener" class="text-gray-300 hover:text-white transition cursor-pointer">Visit our page</a>
              </div>
            </div>
          </div>

          <!-- FAQ View (hidden, shown when FAQ link clicked) -->
          <div id="sp-right-faq" class="hidden flex flex-col h-full bg-gray-50">
            <div class="p-5 md:p-6 flex-1">
              <div class="flex items-center justify-between mb-6">
                <h3 class="text-lg font-bold text-gray-900" style="font-family:'Signika',sans-serif;">Frequently asked questions</h3>
                <button type="button" id="sp-faq-close" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-200 transition text-gray-500 hover:text-gray-700" aria-label="Back to campaign">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
              </div>
              <div class="space-y-2">
                <!-- FAQ 1 -->
                <div class="sp-faq-item rounded-lg border border-gray-200 bg-white overflow-hidden">
                  <button type="button" class="sp-faq-trigger w-full flex items-center justify-between px-4 py-3 text-left text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
                    Is my donation secure?
                    <svg class="sp-faq-arrow w-4 h-4 text-gray-400 transition-transform flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </button>
                  <div class="sp-faq-body hidden px-4 pb-3 text-sm text-gray-500 leading-relaxed">
                    Yes. All donations are processed through Stripe, a PCI-compliant payment processor. Your financial information is encrypted and never stored on our servers.
                  </div>
                </div>
                <!-- FAQ 2 -->
                <div class="sp-faq-item rounded-lg border border-gray-200 bg-white overflow-hidden">
                  <button type="button" class="sp-faq-trigger w-full flex items-center justify-between px-4 py-3 text-left text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
                    Is this donation tax deductible?
                    <svg class="sp-faq-arrow w-4 h-4 text-gray-400 transition-transform flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </button>
                  <div class="sp-faq-body hidden px-4 pb-3 text-sm text-gray-500 leading-relaxed">
                    Yes. Qurbani Foundation USA is a registered 501(c)(3) nonprofit organization. Your donation is tax-deductible to the extent allowed by law. You will receive a receipt via email.
                  </div>
                </div>
                <!-- FAQ 3 -->
                <div class="sp-faq-item rounded-lg border border-gray-200 bg-white overflow-hidden">
                  <button type="button" class="sp-faq-trigger w-full flex items-center justify-between px-4 py-3 text-left text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
                    Can I cancel my recurring donation?
                    <svg class="sp-faq-arrow w-4 h-4 text-gray-400 transition-transform flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </button>
