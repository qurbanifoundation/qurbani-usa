      const amountBtns = widget.querySelectorAll('.zakat-amount-btn');
      const customInput = widget.querySelector('.quick-donate-input');
      const payBtn = widget.querySelector('.quick-donate-pay');
      const fundTypeSelect = widget.querySelector('.quick-donate-fund-type');
      // Find default amount from the pre-selected button (gradient = selected)
      let selectedAmount = 0;
      amountBtns.forEach(b => { if (b.classList.contains('text-white')) selectedAmount = parseInt(b.dataset.amount); });
      if (!selectedAmount && amountBtns.length) selectedAmount = parseInt(amountBtns[amountBtns.length - 1].dataset.amount);

      // Get the button color from the widget's CTA button
      const widgetColor = payBtn?.style?.background?.match(/#[0-9a-fA-F]{6}/)?.[0] || payBtn?.style?.backgroundColor?.match(/#[0-9a-fA-F]{6}/)?.[0] || '#D97718';

      function resetDynamicBtn(b) {
        b.style.background = 'white';
        b.style.borderColor = '#e5e7eb';
        b.style.color = '#374151';
        b.classList.remove('text-white', 'shadow-lg');
        const badge = b.querySelector('span.absolute');
        if (badge) badge.style.display = 'none';
      }
      function selectDynamicBtn(b) {
        b.style.background = `linear-gradient(135deg, ${widgetColor}, ${widgetColor}dd)`;
        b.style.borderColor = widgetColor;
        b.style.color = 'white';
        b.classList.add('text-white', 'shadow-lg');
        const badge = b.querySelector('span.absolute');
        if (badge) badge.style.display = '';
      }

      amountBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          selectedAmount = parseInt(btn.dataset.amount);
          amountBtns.forEach(b => resetDynamicBtn(b));
          selectDynamicBtn(btn);
          if (customInput) customInput.value = '';
        });
      });

      if (customInput) {
        customInput.addEventListener('input', () => {
          if (parseFloat(customInput.value) > 0) {
            amountBtns.forEach(b => resetDynamicBtn(b));
          }
        });
      }

      if (payBtn) {
        payBtn.addEventListener('click', () => {
          const customVal = customInput ? parseFloat(customInput.value) : 0;
          const amount = (customVal > 0) ? customVal : selectedAmount;
