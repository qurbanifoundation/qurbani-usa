          // Close mega menu
          document.querySelectorAll('.mega-menu-panel').forEach(p => { p.style.display = 'none'; p.style.opacity = '0'; });
          if (typeof window.addToCart === 'function') {
            const fundType = fundTypeSelect ? fundTypeSelect.value : baseFundType;
            const displayName = fundTypeSelect ? fundTypeSelect.options[fundTypeSelect.selectedIndex].text : itemName;
