<script define:vars={{ campaignsJson }}>
  // Parse campaigns data from server
  const campaignsByCategory = JSON.parse(campaignsJson);

  document.addEventListener('DOMContentLoaded', () => {
    // Mobile menu toggle
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const openIcon = mobileBtn?.querySelector('.mobile-menu-open-icon');
    const closeIcon = mobileBtn?.querySelector('.mobile-menu-close-icon');

    const mainPanel = document.getElementById('mobile-panel-main');

    // Helper to close mobile menu and reset state
    function closeMobileMenu() {
      if (!mobileMenu || !mobileBtn) return;
      mobileMenu.style.display = 'none';
      mobileBtn.setAttribute('aria-expanded', 'false');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      // Reset all panels back to main
      mainPanel?.classList.remove('slide-out');
      document.querySelectorAll('.mobile-panel-sub').forEach(sub => {
        sub.classList.remove('slide-in');
        sub.classList.remove('slide-out-l3');
      });
      document.querySelectorAll('.mobile-panel-l3').forEach(l3 => {
        l3.classList.remove('slide-in');
      });
    }

    mobileBtn?.addEventListener('click', () => {
      const isCurrentlyOpen = mobileMenu?.style.display === 'block';
      if (isCurrentlyOpen) {
        closeMobileMenu();
      } else {
        if (mobileMenu) mobileMenu.style.display = 'block';
        mobileBtn.setAttribute('aria-expanded', 'true');
        openIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
      }
    });

    // === LEVEL 1 → LEVEL 2: Menu items that open submenus ===
    document.querySelectorAll('.mobile-menu-item[data-submenu]').forEach(btn => {
      btn.addEventListener('click', () => {
        const submenuId = btn.getAttribute('data-submenu');
        const subPanel = document.getElementById('mobile-sub-' + submenuId);
        if (!subPanel || !mainPanel) return;
        mainPanel.classList.add('slide-out');
        subPanel.classList.add('slide-in');
      });
    });

    // === LEVEL 2 → LEVEL 3: Category buttons that open campaign lists ===
    document.querySelectorAll('.mobile-cat-btn[data-category]').forEach(btn => {
      btn.addEventListener('click', () => {
        const catId = btn.getAttribute('data-category');
        const l3Panel = document.getElementById('mobile-cat-' + catId);
        const parentSub = btn.closest('.mobile-panel-sub');
        if (!l3Panel || !parentSub) return;
        parentSub.classList.add('slide-out-l3');
        l3Panel.classList.add('slide-in');
      });
    });

    // === BACK: Level 2 → Level 1 ===
    document.querySelectorAll('.mobile-back-btn[data-back="main"]').forEach(btn => {
      btn.addEventListener('click', () => {
        mainPanel?.classList.remove('slide-out');
        document.querySelectorAll('.mobile-panel-sub').forEach(sub => {
          sub.classList.remove('slide-in');
          sub.classList.remove('slide-out-l3');
        });
        document.querySelectorAll('.mobile-panel-l3').forEach(l3 => {
          l3.classList.remove('slide-in');
        });
      });
    });

    // === BACK: Level 3 → Level 2 ===
    document.querySelectorAll('.mobile-back-btn[data-back="our-work"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const ourWorkPanel = document.getElementById('mobile-sub-our-work');
        ourWorkPanel?.classList.remove('slide-out-l3');
        document.querySelectorAll('.mobile-panel-l3').forEach(l3 => {
          l3.classList.remove('slide-in');
        });
      });
    });

    // Close mobile menu when clicking a link inside it
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        closeMobileMenu();
      });
    });

    // All donate buttons inside sub-panels and L3 panels
    document.querySelectorAll('.mobile-panel-sub .mobile-donate-btn, .mobile-panel-l3 .mobile-donate-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const amount = parseInt(btn.getAttribute('data-amount') || '0');
        if (!amount || typeof window.addToCart !== 'function') return;
        window.addToCart({ slug: 'general-donation', name: 'General Donation', amount, label: '$' + amount + ' Donation' });
        closeMobileMenu();
        if (typeof window.openCart === 'function') window.openCart();
      });
    });

    // All custom amount donate buttons
    document.querySelectorAll('.mobile-sub-donate-pay').forEach(btn => {
      btn.addEventListener('click', () => {
        const wrapper = btn.closest('.rounded-xl');
        const input = wrapper?.querySelector('.mobile-sub-donate-amount');
        const amount = input ? parseFloat(input.value) : 0;
        if (!amount || amount < 1) { if (input) { input.focus(); input.style.outline = '2px solid #fff'; } return; }
        if (typeof window.addToCart === 'function') {
          window.addToCart({ slug: 'general-donation', name: 'General Donation', amount, label: '$' + amount + ' Donation' });
        }
        closeMobileMenu();
        if (typeof window.openCart === 'function') window.openCart();
      });
    });

    // Our Work Mega Menu (static fallback with campaign grid)
    const ourWorkTrigger = document.getElementById('our-work-trigger');
    const ourWorkBtn = document.getElementById('our-work-btn');
    const ourWorkMegaMenu = document.getElementById('our-work-mega-menu');
    const ourWorkArrow = document.getElementById('our-work-arrow');
    const campaignsGrid = document.getElementById('campaigns-grid');
    const categoryTitle = document.getElementById('category-title');
    const viewAllLink = document.getElementById('view-all-link');
    const noCampaignsMessage = document.getElementById('no-campaigns-message');

    let isMenuOpen = false;
    let closeTimeout;
    let currentCategory = 'emergencies';

    function getCampaignImage(campaign) {
      return campaign.featured_image || campaign.hero_image_url || campaign.image_url || 'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=400';
    }

    function renderCampaigns(categoryId, categoryLabel) {
      // Skip if elements don't exist (when DynamicMegaMenu is used)
      if (!campaignsGrid || !categoryTitle) return;

      const campaigns = campaignsByCategory[categoryId] || [];

      // Update title
      if (categoryTitle) categoryTitle.textContent = categoryLabel;
      if (viewAllLink) {
        viewAllLink.textContent = `All Projects & Appeals in ${categoryLabel}`;
        viewAllLink.href = `/appeals?category=${categoryId}`;
      }

