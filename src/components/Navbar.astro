                </div>
                <span class="text-[16px] font-medium">{link.label}</span>
              </a>
            ))}
          </div>
          <div class="px-5 pb-5 pt-3" style="padding-bottom: calc(20px + env(safe-area-inset-bottom, 0px))">
            <div class="bg-gradient-to-br from-[#D97718] to-[#c46a14] rounded-xl p-4">
              <p class="text-white font-extrabold text-base mb-2 tracking-tight" style="font-family: 'Signika', sans-serif;">WHERE MOST NEEDED</p>
              <div class="grid grid-cols-4 gap-2 mb-2">
                <button type="button" class="mobile-donate-btn bg-white/20 hover:bg-white/30 text-white text-center py-2.5 rounded-lg text-sm font-bold transition cursor-pointer border-none" data-amount="25">$25</button>
                <button type="button" class="mobile-donate-btn bg-white/20 hover:bg-white/30 text-white text-center py-2.5 rounded-lg text-sm font-bold transition cursor-pointer border-none" data-amount="50">$50</button>
                <button type="button" class="mobile-donate-btn bg-white/20 hover:bg-white/30 text-white text-center py-2.5 rounded-lg text-sm font-bold transition cursor-pointer border-none" data-amount="100">$100</button>
                <button type="button" class="mobile-donate-btn bg-white/20 hover:bg-white/30 text-white text-center py-2.5 rounded-lg text-sm font-bold transition cursor-pointer border-none" data-amount="250">$250</button>
              </div>
              <div class="flex gap-2">
                <div class="relative flex-1">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-white font-bold text-sm">$</span>
                  <input type="number" placeholder="Other" class="mobile-sub-donate-amount w-full pl-7 pr-2 py-2.5 rounded-lg text-sm font-semibold text-white border-none focus:outline-none focus:ring-2 focus:ring-white/50 placeholder:text-white/70" style="background-color: rgba(255,255,255,0.2);" />
                </div>
                <button type="button" class="mobile-sub-donate-pay bg-white text-[#D97718] font-bold py-2.5 px-4 rounded-lg text-sm transition hover:bg-gray-100 cursor-pointer border-none whitespace-nowrap" style="font-family: 'Signika', sans-serif;">
                  Donate &rarr;
