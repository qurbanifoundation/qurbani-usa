    // Pay Zakat Now — add to cart and open checkout
    if (quickZakatPayBtn) {
      quickZakatPayBtn.addEventListener('click', () => {
        // Use custom input if filled, otherwise use selected preset
        const customVal = quickZakatInput ? parseFloat(quickZakatInput.value) : 0;
        const amount = (customVal > 0) ? customVal : quickZakatSelectedAmount;
        if (!amount || amount <= 0) return;

